<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Edge Nodes / Supernodes</data>
      <data key="d6">UserCompanyEdge</data>
      <data key="d7">WORKLOAD_PEEK: Devices running edge engine microservices (Android, iOS, IoT).</data>
    </node>
    <node id="1">
      <data key="d5">MDS (Microservice Discovery Service)</data>
      <data key="d6">EKS</data>
      <data key="d7">Handles node registry and manages the proximity service mesh.</data>
    </node>
    <node id="2">
      <data key="d5">MongoDB</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Tracks cluster associations and device proximity mesh mapping.</data>
    </node>
    <node id="3">
      <data key="d5">Profiles &amp; Associations Store</data>
      <data key="d6">DynamoDB</data>
      <data key="d7">Stores user profiles and hierarchical peer associations.</data>
    </node>
    <node id="4">
      <data key="d5">Kinesis Data Streams</data>
      <data key="d6">Kinesis</data>
      <data key="d7">DATA_PEEK: Ingests ~1,000 logs/events per second from supernodes.</data>
    </node>
    <node id="5">
      <data key="d5">Kinesis Data Firehose</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Batches and streams telemetry logs into S3 archive.</data>
    </node>
    <node id="6">
      <data key="d5">Telemetry Data Lake</data>
      <data key="d6">S3</data>
      <data key="d7">DATA_PEEK: Persistent archival storage for all edge API and telemetry logs.</data>
    </node>
    <node id="7">
      <data key="d5">Snowflake</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Runs SQL queries directly on top of data stored in S3.</data>
    </node>
    <node id="8">
      <data key="d5">Business Analyst</data>
      <data key="d6">UserCompanyAnalyst</data>
      <data key="d7">Queries Snowflake for long-term and real-time mesh analytics.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">New node registers metadata with MDS.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="0" target="4" id="0">
      <data key="d8">1</data>
      <data key="d9">Streams API and system telemetry logs.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">Defines and registers proximity clusters.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="3" id="0">
      <data key="d8">0</data>
      <data key="d9">Retrieves profiles and peer hierarchical configs.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="0" id="0">
      <data key="d8">0</data>
      <data key="d9">Confirms registration and proximity mesh joining.</data>
      <data key="d10">3</data>
      <data key="d11">meta</data>
    </edge>
    <edge source="4" target="5" id="0">
      <data key="d8">1</data>
      <data key="d9">Pushes telemetry down the pipeline.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="6" id="0">
      <data key="d8">1</data>
      <data key="d9">Saves archived telemetry to S3.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="6" target="7" id="0">
      <data key="d8">2</data>
      <data key="d9">Returns requested telemetry data.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="7" target="6" id="0">
      <data key="d8">2</data>
      <data key="d9">Fetches analytics data from S3 lake.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="7" target="8" id="0">
      <data key="d8">2</data>
      <data key="d9">Visualizes analytics dashboard data.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="8" target="7" id="0">
      <data key="d8">2</data>
      <data key="d9">Executes SQL query for edge metrics.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">Mimic Edge Engine</data>
    <data key="d1">https://www.youtube.com/watch?v=-S-R7MWRpaI</data>
    <data key="d2">Enables serverless-like edge microservices on devices like Android and iOS. Collects ~1000 messages/sec of log and event telemetry.</data>
    <data key="d3">data_ingestion, compute_intensive, other</data>
    <data key="d4">True</data>
  </graph>
</graphml>
