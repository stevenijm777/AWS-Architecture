<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Edge Node</data>
      <data key="d6">UserCompanyEdge</data>
      <data key="d7">Standard mobile/IoT edge device running Edge Engine.</data>
    </node>
    <node id="1">
      <data key="d5">Supernode</data>
      <data key="d6">UserCompanyEdge</data>
      <data key="d7">Coordinates local network node registrations and reports telemetry.</data>
    </node>
    <node id="2">
      <data key="d5">EKS (MDS)</data>
      <data key="d6">EKS</data>
      <data key="d7">Runs the Mobile Discovery Service.</data>
    </node>
    <node id="3">
      <data key="d5">MongoDB</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Document DB used to define clusters based on physical proximity.</data>
    </node>
    <node id="4">
      <data key="d5">DynamoDB</data>
      <data key="d6">DynamoDB</data>
      <data key="d7">Stores profile data and hierarchical peer associations.</data>
    </node>
    <node id="5">
      <data key="d5">Kinesis Data Streams</data>
      <data key="d6">KinesisDataStream</data>
      <data key="d7">Ingests real-time logs and business logic metrics. Handles ~1000 msg/sec.</data>
    </node>
    <node id="6">
      <data key="d5">Kinesis Firehose</data>
      <data key="d6">Firehose</data>
      <data key="d7">Buffers and formats stream data.</data>
    </node>
    <node id="7">
      <data key="d5">S3 Bucket</data>
      <data key="d6">S3</data>
      <data key="d7">Long-term data lake storage.</data>
    </node>
    <node id="8">
      <data key="d5">Snowflake</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Performs SQL queries over archived data for analytics.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">New node registers with Supernode.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">Supernode registers the new node in MDS.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="5" id="0">
      <data key="d8">1</data>
      <data key="d9">Sends API logs and business metrics.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="3" id="0">
      <data key="d8">0</data>
      <data key="d9">Saves proximity metadata.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="4" id="0">
      <data key="d8">0</data>
      <data key="d9">Fetches profile / association information.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="6" id="0">
      <data key="d8">1</data>
      <data key="d9">Streams telemetry.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="6" target="7" id="0">
      <data key="d8">1</data>
      <data key="d9">Archives raw metrics to S3.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="8" target="7" id="0">
      <data key="d8">1</data>
      <data key="d9">Queries telemetry archive data.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">Mimic Edge Engine Architecture</data>
    <data key="d1">https://www.youtube.com/watch?v=-S-R7MWRpaI</data>
    <data key="d2">Edge Engine allows microservices to run directly on Android/iOS devices. Supernodes coordinate discovery and local clustering while forwarding logs to AWS.</data>
    <data key="d3">data_ingestion, compute_intensive</data>
    <data key="d4">True</data>
  </graph>
</graphml>
