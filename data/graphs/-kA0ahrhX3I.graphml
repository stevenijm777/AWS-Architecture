<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Security Engineers</data>
      <data key="d6">UserCompanyAgent</data>
      <data key="d7">Internal security engineering team managing the posture and remediation process.</data>
    </node>
    <node id="1">
      <data key="d5">Amazon Athena</data>
      <data key="d6">Athena</data>
      <data key="d7">Queries S3 findings database using SQL for data discovery.</data>
    </node>
    <node id="2">
      <data key="d5">Amazon QuickSight</data>
      <data key="d6">QuickSight</data>
      <data key="d7">Used to create dashboards for telling a better story of risky buckets and PII types.</data>
    </node>
    <node id="3">
      <data key="d5">S3 Bucket (Findings)</data>
      <data key="d6">S3</data>
      <data key="d7">The centralized green bucket where Macie outputs discovery findings.</data>
    </node>
    <node id="4">
      <data key="d5">MySQL</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">A custom MySQL data lake used to house findings for analysis.</data>
    </node>
    <node id="5">
      <data key="d5">AWS Glue</data>
      <data key="d6">Glue</data>
      <data key="d7">Used to run automated ETL workflows for parsing and loading findings data.</data>
    </node>
    <node id="6">
      <data key="d5">Amazon Macie (Main)</data>
      <data key="d6">Macie</data>
      <data key="d7">The Macie instance running in the main/security account, collecting data.</data>
    </node>
    <node id="7">
      <data key="d5">Amazon Macie (Top Right)</data>
      <data key="d6">Macie</data>
      <data key="d7">Macie running in a connected member AWS account.</data>
    </node>
    <node id="8">
      <data key="d5">Amazon Simple Storage Service (Top Right)</data>
      <data key="d6">S3</data>
      <data key="d7">Production S3 bucket scanned by Macie in a connected AWS account.</data>
    </node>
    <node id="9">
      <data key="d5">Amazon Macie (Bottom Right)</data>
      <data key="d6">Macie</data>
      <data key="d7">Macie instance in another connected member AWS account.</data>
    </node>
    <node id="10">
      <data key="d5">Amazon Simple Storage Service (Bottom Right)</data>
      <data key="d6">S3</data>
      <data key="d7">Another production S3 bucket scanned by Macie.</data>
    </node>
    <edge source="1" target="3" id="0">
      <data key="d8">1</data>
      <data key="d9">Athena runs SQL queries against the findings stored in the S3 bucket.</data>
      <data key="d10">0</data>
      <data key="d11">control</data>
    </edge>
    <edge source="2" target="3" id="0">
      <data key="d8">1</data>
      <data key="d9">QuickSight accesses findings data from the bucket (via Athena) to generate dashboards.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="4" id="0">
      <data key="d8">2</data>
      <data key="d9">Data is extracted from the findings S3 bucket to be loaded into the MySQL data lake.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="6" target="3" id="0">
      <data key="d8">0</data>
      <data key="d9">Macie sends its metadata findings into the central findings S3 bucket.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">Opportune Data Security Posture Management with Amazon Macie</data>
    <data key="d1">https://www.youtube.com/watch?v=-kA0ahrhX3I</data>
    <data key="d2">Opportune uses Amazon Macie across multiple AWS accounts to perform automated sensitive data discovery (like SSNs and ITINs) on their S3 buckets. The findings (metadata) are aggregated into a central S3 bucket. They use Amazon Athena to query this data, Amazon QuickSight to visualize insights and share them with bucket owners, and AWS Glue to load the aggregated findings into a custom MySQL data lake for deeper reporting and remediation workflows.</data>
    <data key="d3">data_ingestion, interactive</data>
    <data key="d4">True</data>
  </graph>
</graphml>
