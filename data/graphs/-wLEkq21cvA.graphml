<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">ON-PREM</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">On-premises servers represented by the stacked server icon labeled ON-PREM, running Discovery and CloudEndure agents.</data>
    </node>
    <node id="1">
      <data key="d5">SLACK</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Slack chat tool used by the migration team to trigger operations.</data>
    </node>
    <node id="2">
      <data key="d5">MIGRATION TEAM</data>
      <data key="d6">UserCompanyAgent</data>
      <data key="d7">The migration team acting as the primary system operators.</data>
    </node>
    <node id="3">
      <data key="d5">APP DISCOVERY SERVICE</data>
      <data key="d6">AppDiscovery</data>
      <data key="d7">AWS Application Discovery Service collecting performance and connection metadata.</data>
    </node>
    <node id="4">
      <data key="d5">DYNAMODB</data>
      <data key="d6">DynamoDB</data>
      <data key="d7">Amazon DynamoDB storing target configuration metadata, RTOs, and RPOs.</data>
    </node>
    <node id="5">
      <data key="d5">EC2</data>
      <data key="d6">EC2</data>
      <data key="d7">The central EC2 instance acting as the Migration Factory orchestrator.</data>
    </node>
    <node id="6">
      <data key="d5">CLOUDENDURE</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">CloudEndure live migration tool managing volume replication.</data>
    </node>
    <node id="7">
      <data key="d5">EC2 HOT REPLICA</data>
      <data key="d6">EC2</data>
      <data key="d7">The replication destination EC2 instance receiving continuously replicated block data.</data>
    </node>
    <node id="8">
      <data key="d5">EC2 Target</data>
      <data key="d6">EC2</data>
      <data key="d7">The final launched EC2 instance on the target account side of the boundary.</data>
    </node>
    <edge source="0" target="3" id="0">
      <data key="d8">0</data>
      <data key="d9">Application Discovery Service agent collects TCP connections and performance metrics from the on-premises servers.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="0" target="7" id="0">
      <data key="d8">0</data>
      <data key="d9">Continuous block-level data replication from the on-premises source to the AWS EC2 replica instance.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="5" id="0">
      <data key="d8">1</data>
      <data key="d9">Slack integration triggers API calls on the EC2 Migration Factory orchestrator.</data>
      <data key="d10">1</data>
      <data key="d11">control</data>
    </edge>
    <edge source="2" target="4" id="0">
      <data key="d8">0</data>
      <data key="d9">The migration team populates DynamoDB with metadata, RTOs, RPOs, target account details, and subnet configurations.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="1" id="0">
      <data key="d8">1</data>
      <data key="d9">The migration team sends a command via Slack to trigger orchestration.</data>
      <data key="d10">0</data>
      <data key="d11">control</data>
    </edge>
    <edge source="3" target="7" id="0">
      <data key="d8">1</data>
      <data key="d9">App Discovery metadata influences configuration of the replica instance.</data>
      <data key="d10">3</data>
      <data key="d11">control</data>
    </edge>
    <edge source="5" target="3" id="0">
      <data key="d8">1</data>
      <data key="d9">Migration factory requests performance and connection metadata from AWS Discovery Service.</data>
      <data key="d10">2</data>
      <data key="d11">control</data>
    </edge>
    <edge source="5" target="6" id="0">
      <data key="d8">1</data>
      <data key="d9">Migration factory issues API calls to CloudEndure to manage replication.</data>
      <data key="d10">4</data>
      <data key="d11">control</data>
    </edge>
    <edge source="5" target="8" id="0">
      <data key="d8">1</data>
      <data key="d9">The migration factory launches and configures the target instance across the account boundary.</data>
      <data key="d10">6</data>
      <data key="d11">control</data>
    </edge>
    <edge source="6" target="7" id="0">
      <data key="d8">1</data>
      <data key="d9">CloudEndure manages the replication process and final cutover on the replica instance.</data>
      <data key="d10">5</data>
      <data key="d11">control</data>
    </edge>
    <data key="d0">Automated Migration Factory with CloudEndure</data>
    <data key="d1">https://www.youtube.com/watch?v=-wLEkq21cvA</data>
    <data key="d2">Versent's automated migration factory dramatically reduces migration time from 4 hours to 10 minutes. It automates the discovery of on-prem servers, configures replication targets via CloudEndure, and automates target instance launching inside of the target AWS accounts using metadata stored in DynamoDB, all driven via Slack commands.</data>
    <data key="d3">control, data_ingestion</data>
    <data key="d4">True</data>
  </graph>
</graphml>
