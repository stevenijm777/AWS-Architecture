<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="on_prem">
      <data key="d5">ON-PREM</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">The source on-premises servers containing the applications and databases to migrate.</data>
    </node>
    <node id="app_discovery">
      <data key="d5">APP DISCOVERY SERVICE</data>
      <data key="d6">AppDiscovery</data>
      <data key="d7">AWS Application Discovery Service, gathering server performance and network dependency metadata.</data>
    </node>
    <node id="dynamodb">
      <data key="d5">DYNAMODB</data>
      <data key="d6">DynamoDB</data>
      <data key="d7">Amazon DynamoDB, storing migration configuration parameters including target accounts, IPs, subnets, and tags.</data>
    </node>
    <node id="migration_team">
      <data key="d5">MIGRATION TEAM</data>
      <data key="d6">UserCompanyAgent</data>
      <data key="d7">The internal operations team managing and launching the migration workflow.</data>
    </node>
    <node id="slack">
      <data key="d5">SLACK</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">ChatOps platform used by the migration team to trigger automation.</data>
    </node>
    <node id="migration_factory">
      <data key="d5">EC2 (Migration Factory)</data>
      <data key="d6">EC2</data>
      <data key="d7">An EC2 orchestrator running the automation scripts to execute target launches and API interactions.</data>
    </node>
    <node id="cloudendure">
      <data key="d5">CLOUDENURE</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">CloudEndure agent-based tool replicating block-level data on-premises to AWS.</data>
    </node>
    <node id="hot_replica">
      <data key="d5">EC2 HOT REPLICA</data>
      <data key="d6">EC2</data>
      <data key="d7">The continuously replicating replica instance inside the destination AWS environment.</data>
    </node>
    <node id="target_ec2">
      <data key="d5">Target EC2</data>
      <data key="d6">EC2</data>
      <data key="d7">The final cutover EC2 instance launched inside the target account with proper configurations applied.</data>
    </node>
    <edge source="on_prem" target="app_discovery" id="0">
      <data key="d8">0</data>
      <data key="d9">AWS Application Discovery agent collects system performance and TCP connection metadata from on-premises servers.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="on_prem" target="hot_replica" id="0">
      <data key="d8">0</data>
      <data key="d9">CloudEndure agent conducts live, continuous block-level volume replication to the AWS replica.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="migration_team" target="dynamodb" id="0">
      <data key="d8">0</data>
      <data key="d9">The migration team populates target configurations, tags, subnet mappings, and IP allocations in DynamoDB.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="migration_team" target="slack" id="0">
      <data key="d8">1</data>
      <data key="d9">The migration team triggers automation commands via Slack ChatOps.</data>
      <data key="d10">0</data>
      <data key="d11">control</data>
    </edge>
    <edge source="slack" target="migration_factory" id="0">
      <data key="d8">1</data>
      <data key="d9">Slack integration triggers migration orchestrator scripts on the Migration Factory EC2 instance.</data>
      <data key="d10">1</data>
      <data key="d11">control</data>
    </edge>
    <edge source="migration_factory" target="app_discovery" id="0">
      <data key="d8">1</data>
      <data key="d9">Migration orchestrator queries ADS to retrieve server performance metrics and inbound/outbound connection data.</data>
      <data key="d10">2</data>
      <data key="d11">control</data>
    </edge>
    <edge source="migration_factory" target="cloudendure" id="0">
      <data key="d8">1</data>
      <data key="d9">Migration Factory issues API commands to CloudEndure to finalize and stop the replication process.</data>
      <data key="d10">3</data>
      <data key="d11">control</data>
    </edge>
    <edge source="migration_factory" target="target_ec2" id="0">
      <data key="d8">1</data>
      <data key="d9">The Migration Factory reads target details from DynamoDB, bakes and shares the AMI, and provisions the configured Target EC2 instance in the target account.</data>
      <data key="d10">5</data>
      <data key="d11">control</data>
    </edge>
    <edge source="cloudendure" target="hot_replica" id="0">
      <data key="d8">1</data>
      <data key="d9">CloudEndure manages the storage volumes and halts the replication state on the hot replica instance.</data>
      <data key="d10">4</data>
      <data key="d11">control</data>
    </edge>
    <data key="d0">Automated Cloud Migration Factory using CloudEndure and ChatOps</data>
    <data key="d1" />
    <data key="d2">This architecture automates on-premises migrations to AWS, dropping cutover time from hours to minutes. Using continuous replication from CloudEndure and metadata from AWS Application Discovery Service, a Slack command triggers a central Migration Factory instance on EC2 which coordinates volume status, AMI baking, and target-account EC2 provisioning using metadata stored in DynamoDB.</data>
    <data key="d3">control, other</data>
    <data key="d4">True</data>
  </graph>
</graphml>
