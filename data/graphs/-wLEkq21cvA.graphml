<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Migration Team</data>
      <data key="d6">UserCompanyAgent</data>
      <data key="d7">Triggers migration workflow and populates metadata.</data>
    </node>
    <node id="1">
      <data key="d5">Slack</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Chatops interface used to trigger the migration factory via API.</data>
    </node>
    <node id="2">
      <data key="d5">Migration Metadata</data>
      <data key="d6">DynamoDB</data>
      <data key="d7">Stores target account IDs, IPs, subnets, and instance tags.</data>
    </node>
    <node id="3">
      <data key="d5">Migration Factory Orchestrator</data>
      <data key="d6">EC2</data>
      <data key="d7">Orchestrates API calls, stops replication, and bakes/shares AMIs.</data>
    </node>
    <node id="4">
      <data key="d5">On-Premises Servers</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Source servers being migrated.</data>
    </node>
    <node id="5">
      <data key="d5">Application Discovery Service</data>
      <data key="d6">AppDiscovery</data>
      <data key="d7">Gathers on-prem TCP connections and performance metrics.</data>
    </node>
    <node id="6">
      <data key="d5">CloudEndure</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Manages continuous block-level replication.</data>
    </node>
    <node id="7">
      <data key="d5">EC2 Hot Replica</data>
      <data key="d6">EC2</data>
      <data key="d7">Replicated server volumes in the staging environment.</data>
    </node>
    <node id="8">
      <data key="d5">Target EC2 Instance</data>
      <data key="d6">EC2</data>
      <data key="d7">Final server instance launched in the target account.</data>
    </node>
    <edge source="0" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">Saves target migration metadata and server tags.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="0" target="1" id="0">
      <data key="d8">1</data>
      <data key="d9">Triggers migration command.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="3" id="0">
      <data key="d8">1</data>
      <data key="d9">API call to initiate orchestrator flow.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="2" id="0">
      <data key="d8">1</data>
      <data key="d9">Retrieves target migration specifications.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="5" id="0">
      <data key="d8">1</data>
      <data key="d9">Collects on-prem discovery metadata.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="6" id="0">
      <data key="d8">1</data>
      <data key="d9">Instructs CloudEndure to finalize replication.</data>
      <data key="d10">5</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="8" id="0">
      <data key="d8">1</data>
      <data key="d9">Bakes AMI from hot replica, shares to target account, and launches target EC2.</data>
      <data key="d10">6</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="5" id="0">
      <data key="d8">0</data>
      <data key="d9">Sends server performance and TCP dependency metadata.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="6" id="0">
      <data key="d8">0</data>
      <data key="d9">Performs block-by-block volume replication.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="6" target="7" id="0">
      <data key="d8">0</data>
      <data key="d9">Continuously replicates data to the staging target.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">Automated Cloud Migration Factory</data>
    <data key="d1">https://www.youtube.com/watch?v=0hK2C_64-Ww</data>
    <data key="d2">Automated migration pipeline reducing manual server migration time from 4 hours to 10 minutes.</data>
    <data key="d3">compute_intensive, control</data>
    <data key="d4">True</data>
  </graph>
</graphml>
