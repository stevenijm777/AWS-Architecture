<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Migration Team</data>
      <data key="d6">UserCompanyAgent</data>
      <data key="d7">Initiates migration commands and populates metadata.</data>
    </node>
    <node id="1">
      <data key="d5">Slack</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Chat platform used to trigger automation commands.</data>
    </node>
    <node id="2">
      <data key="d5">On-Premises Server</data>
      <data key="d6">OnPremDC</data>
      <data key="d7">The source server to be migrated.</data>
    </node>
    <node id="3">
      <data key="d5">Application Discovery Service</data>
      <data key="d6">AppDiscovery</data>
      <data key="d7">Collects on-premises metadata like TCP connections and utilization.</data>
    </node>
    <node id="4">
      <data key="d5">Migration Metadata Store</data>
      <data key="d6">DynamoDB</data>
      <data key="d7">Stores migration details, target IPs, and tags.</data>
    </node>
    <node id="5">
      <data key="d5">Migration Factory Controller</data>
      <data key="d6">EC2</data>
      <data key="d7">The orchestration controller that manages automation steps via APIs.</data>
    </node>
    <node id="6">
      <data key="d5">CloudEndure</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Continuous replication manager.</data>
    </node>
    <node id="7">
      <data key="d5">EC2 Hot Replica</data>
      <data key="d6">EC2</data>
      <data key="d7">Continuous block replication target in AWS.</data>
    </node>
    <node id="8">
      <data key="d5">Target EC2 Instance</data>
      <data key="d6">EC2</data>
      <data key="d7">The final launched instance in the target account.</data>
    </node>
    <edge source="0" target="4" id="0">
      <data key="d8">1</data>
      <data key="d9">Populates operational metadata including target account details, IPs, and tags</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="0" target="1" id="0">
      <data key="d8">2</data>
      <data key="d9">Triggers migration workflow via commands</data>
      <data key="d10">1</data>
      <data key="d11">control</data>
    </edge>
    <edge source="1" target="5" id="0">
      <data key="d8">2</data>
      <data key="d9">Calls API to initiate the automation process</data>
      <data key="d10">2</data>
      <data key="d11">control</data>
    </edge>
    <edge source="2" target="3" id="0">
      <data key="d8">0</data>
      <data key="d9">Provides TCP connection metadata and performance utilization details</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="7" id="0">
      <data key="d8">0</data>
      <data key="d9">Performs block-by-block volume replication managed by CloudEndure</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="3" id="0">
      <data key="d8">2</data>
      <data key="d9">Queries TCP connection metadata</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="4" id="0">
      <data key="d8">2</data>
      <data key="d9">Fetches target account specifications and network tagging details</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="6" id="0">
      <data key="d8">2</data>
      <data key="d9">Executes API calls to stop active block replication</data>
      <data key="d10">5</data>
      <data key="d11">control</data>
    </edge>
    <edge source="5" target="7" id="0">
      <data key="d8">2</data>
      <data key="d9">Triggers AMI baking process once replication is completed</data>
      <data key="d10">6</data>
      <data key="d11">control</data>
    </edge>
    <edge source="5" target="8" id="0">
      <data key="d8">2</data>
      <data key="d9">Launches instance in the target account using the shared AMI and applies metadata</data>
      <data key="d10">7</data>
      <data key="d11">control</data>
    </edge>
    <data key="d0">Automated Migration Factory with CloudEndure</data>
    <data key="d1" />
    <data key="d2">Automates migration from on-premises to AWS using CloudEndure and AWS Application Discovery Service, orchestrated by a Migration Factory Controller via Slack.</data>
    <data key="d3">control, other</data>
    <data key="d4">True</data>
  </graph>
</graphml>
