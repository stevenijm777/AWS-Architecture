<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Migration Team</data>
      <data key="d6">UserCompanyAnalyst</data>
      <data key="d7">WORKLOAD_PEEK: Operates and configures migration metadata and triggers cutover.</data>
    </node>
    <node id="1">
      <data key="d5">Slack Chatbot</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">WORKLOAD_PEEK: Chatops interface used to trigger orchestration commands.</data>
    </node>
    <node id="2">
      <data key="d5">Migration Factory Orchestrator</data>
      <data key="d6">EC2</data>
      <data key="d7">WORKLOAD_PEEK: Orchestration engine coordinating API calls across services to automate migration.</data>
    </node>
    <node id="3">
      <data key="d5">Migration Metadata Store</data>
      <data key="d6">DynamoDB</data>
      <data key="d7">DATA_PEEK: Stores target VPC, subnet, IP, tags, and RTO/RPO configs.</data>
    </node>
    <node id="4">
      <data key="d5">On-Premises Server</data>
      <data key="d6">UserCompanyEdge</data>
      <data key="d7">WORKLOAD_PEEK: Source server undergoing migration running agent software.</data>
    </node>
    <node id="5">
      <data key="d5">AWS Application Discovery Service</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">DATA_PEEK: Collects server network dependency and utilization metrics.</data>
    </node>
    <node id="6">
      <data key="d5">CloudEndure Replication</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">DATA_PEEK: Continually replicates block-level volume data to AWS.</data>
    </node>
    <node id="7">
      <data key="d5">Target EC2 Instance</data>
      <data key="d6">EC2</data>
      <data key="d7">WORKLOAD_PEEK: Migrated instance launched in target account with exact configurations.</data>
    </node>
    <edge source="0" target="3" id="0">
      <data key="d8">1</data>
      <data key="d9">Populates migration target configurations and metadata tags.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="0" target="1" id="0">
      <data key="d8">2</data>
      <data key="d9">Issues migration initiation command.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="2" id="0">
      <data key="d8">2</data>
      <data key="d9">Calls orchestration API on Migration Factory EC2.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="0" id="0">
      <data key="d8">2</data>
      <data key="d9">Notifies migration engineers of completion.</data>
      <data key="d10">8</data>
      <data key="d11">meta</data>
    </edge>
    <edge source="2" target="3" id="0">
      <data key="d8">2</data>
      <data key="d9">Fetches target subnet, IP, and tag requirements.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="5" id="0">
      <data key="d8">2</data>
      <data key="d9">Gathers port configurations and TCP connections.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="6" id="0">
      <data key="d8">2</data>
      <data key="d9">Halts replication and requests AMI generation from replicated volumes.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="7" id="0">
      <data key="d8">2</data>
      <data key="d9">Launches instance using metadata in target AWS account.</data>
      <data key="d10">5</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="1" id="0">
      <data key="d8">2</data>
      <data key="d9">Posts completion status to Slack interface.</data>
      <data key="d10">7</data>
      <data key="d11">meta</data>
    </edge>
    <edge source="4" target="5" id="0">
      <data key="d8">0</data>
      <data key="d9">Sends discovery TCP metadata and utilization statistics.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="6" id="0">
      <data key="d8">0</data>
      <data key="d9">Performs block-by-block live data replication.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="7" target="2" id="0">
      <data key="d8">2</data>
      <data key="d9">Acknowledges successful provisioning and startup.</data>
      <data key="d10">6</data>
      <data key="d11">meta</data>
    </edge>
    <data key="d0">Versent Automated AWS Migration Factory</data>
    <data key="d1">https://www.youtube.com/watch?v=-wLEkq21cvA</data>
    <data key="d2">Automated migration system that reduced migration time from 4 hours to 10 minutes per server by automating metadata collection, AMI baking, and target provisioning.</data>
    <data key="d3">compute_intensive, control</data>
    <data key="d4">True</data>
  </graph>
</graphml>
