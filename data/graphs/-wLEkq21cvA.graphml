<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Migration Team</data>
      <data key="d6">UserCompanyDeveloper</data>
      <data key="d7">Orchestrates migrations and manages metadata config.</data>
    </node>
    <node id="1">
      <data key="d5">On-Premises Server</data>
      <data key="d6">OnPremDC</data>
      <data key="d7">Source servers undergoing migration.</data>
    </node>
    <node id="2">
      <data key="d5">AWS Application Discovery Service</data>
      <data key="d6">AppDiscovery</data>
      <data key="d7">DATA_PEEK: Collects inbound/outbound TCP connections and utilization data.</data>
    </node>
    <node id="3">
      <data key="d5">CloudEndure Live Agent</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Performs continuous block-level data replication.</data>
    </node>
    <node id="4">
      <data key="d5">Metadata Store</data>
      <data key="d6">DynamoDB</data>
      <data key="d7">DATA_PEEK: Stores RPOs, RTOs, IPs, and tags for target environments.</data>
    </node>
    <node id="5">
      <data key="d5">Slack</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Chat interface used by migration team to trigger automation.</data>
    </node>
    <node id="6">
      <data key="d5">Migration Factory Controller</data>
      <data key="d6">EC2</data>
      <data key="d7">WORKLOAD_PEEK: Orchestrator EC2 instance driving APIs to coordinate migration phases.</data>
    </node>
    <node id="7">
      <data key="d5">Hot Replica Instance</data>
      <data key="d6">EC2</data>
      <data key="d7">Staging server in replication area receiving continuous blocks.</data>
    </node>
    <node id="8">
      <data key="d5">Target EC2 Instance</data>
      <data key="d6">EC2</data>
      <data key="d7">Final production server launched inside target account.</data>
    </node>
    <edge source="0" target="4" id="0">
      <data key="d8">0</data>
      <data key="d9">Migration metadata seeding.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="0" target="5" id="0">
      <data key="d8">1</data>
      <data key="d9">Command to initiate migration.</data>
      <data key="d10">0</data>
      <data key="d11">meta</data>
    </edge>
    <edge source="1" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">Sends TCP metadata and resource usage.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="3" id="0">
      <data key="d8">0</data>
      <data key="d9">Continuous block-level replication payload.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="7" id="0">
      <data key="d8">0</data>
      <data key="d9">Writes replicated blocks to replication EC2 storage.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="6" id="0">
      <data key="d8">1</data>
      <data key="d9">Triggers migration workflow script API.</data>
      <data key="d10">1</data>
      <data key="d11">meta</data>
    </edge>
    <edge source="6" target="4" id="0">
      <data key="d8">1</data>
      <data key="d9">Reads target specs (tags, IPs, target account).</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="6" target="2" id="0">
      <data key="d8">1</data>
      <data key="d9">Gathers port metadata for firewall configurations.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="6" target="3" id="0">
      <data key="d8">1</data>
      <data key="d9">API call to stop replication.</data>
      <data key="d10">4</data>
      <data key="d11">meta</data>
    </edge>
    <edge source="6" target="7" id="0">
      <data key="d8">1</data>
      <data key="d9">Commands to bake replication volume into AMI.</data>
      <data key="d10">5</data>
      <data key="d11">meta</data>
    </edge>
    <edge source="6" target="8" id="0">
      <data key="d8">1</data>
      <data key="d9">Shares encrypted AMI and provisions EC2 in target account with sizing and tags.</data>
      <data key="d10">6</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">Automated Migration Factory with CloudEndure and AWS ADS</data>
    <data key="d1">https://www.youtube.com/watch?v=-wLEkq21cvA</data>
    <data key="d2">Reduces server migration time from 4 hours to 10 minutes by automating metadata aggregation, live block replication, and final target-instance orchestration.</data>
    <data key="d3">control, data_ingestion</data>
    <data key="d4">True</data>
  </graph>
</graphml>
