<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Data Scientists</data>
      <data key="d6">UserCompanyDeveloper</data>
      <data key="d7">WORKLOAD_PEEK: Users of the system, building models using a model development toolkit. They upload model artifacts.</data>
    </node>
    <node id="1">
      <data key="d5">UI Portal</data>
      <data key="d6">UserCompanyWebsite</data>
      <data key="d7">WORKLOAD_PEEK: Provides a seamless experience for data scientists to upload model artifacts (Python pickle files, attributes.py, library dependencies).</data>
    </node>
    <node id="2">
      <data key="d5">Platform API</data>
      <data key="d6">Fargate</data>
      <data key="d7">WORKLOAD_PEEK: Backend API service that gets triggered after artifacts are uploaded through the UI. Manages initial model registration and artifact storage.</data>
    </node>
    <node id="3">
      <data key="d5">Model Registry</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">DATA_PEEK: Data store for creating entries in the model registry. Stores model metadata and updated endpoint information.</data>
    </node>
    <node id="4">
      <data key="d5">Model Artifacts Bucket</data>
      <data key="d6">S3</data>
      <data key="d7">DATA_PEEK: Stores model artifacts (e.g., Python pickle files, attributes.py) uploaded by data scientists.</data>
    </node>
    <node id="5">
      <data key="d5">Kafka Topic</data>
      <data key="d6">MSK</data>
      <data key="d7">WORKLOAD_PEEK: Serves as the central event bus for event-driven architecture. Initiates the model build process and triggers status updates.</data>
    </node>
    <node id="6">
      <data key="d5">Build Machine</data>
      <data key="d6">EC2</data>
      <data key="d7">WORKLOAD_PEEK: Runs a consumer app triggered by Kafka events. Copies artifacts from S3, pulls libraries from Artifactory, builds Docker images, and pushes them to ECR. Docker is installed here.</data>
    </node>
    <node id="7">
      <data key="d5">Artifactory</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">DATA_PEEK: External repository from which the build machine pulls additional libraries required for containerization.</data>
    </node>
    <node id="8">
      <data key="d5">Image Repository</data>
      <data key="d6">ECR</data>
      <data key="d7">DATA_PEEK: Stores the SageMaker-compatible Docker images built by the EC2 build machine.</data>
    </node>
    <node id="9">
      <data key="d5">Model Deployment &amp; Inferencing</data>
      <data key="d6">SageMaker</data>
      <data key="d7">WORKLOAD_PEEK: Managed service used to build, deploy, test, and train models at scale. Creates endpoint configurations (selecting instance types, scaling policies) and deploys endpoints for model inferencing.</data>
    </node>
    <node id="10">
      <data key="d5">SageMaker Events</data>
      <data key="d6">EventBridge</data>
      <data key="d7">WORKLOAD_PEEK: Receives events emitted by SageMaker (e.g., endpoint status changes) to facilitate asynchronous process updates.</data>
    </node>
    <node id="11">
      <data key="d5">Status Processor</data>
      <data key="d6">Lambda</data>
      <data key="d7">WORKLOAD_PEEK: Triggered by EventBridge events, watches for endpoint changes, and writes an event to the Kafka topic for further processing of status updates.</data>
    </node>
    <node id="12">
      <data key="d5">Status Consumer</data>
      <data key="d6">Fargate</data>
      <data key="d7">WORKLOAD_PEEK: Runs a consumer app triggered by Kafka events. Writes status messages back to the UI portal and updates the model registry with endpoint information.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">Data scientists upload model artifacts through the UI portal.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">UI portal initiates a request to the platform API.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="3" id="0">
      <data key="d8">0</data>
      <data key="d9">Platform API creates an entry in the model registry.</data>
      <data key="d10">2a</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="4" id="0">
      <data key="d8">0</data>
      <data key="d9">Platform API writes model artifacts to S3.</data>
      <data key="d10">2b</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="5" id="0">
      <data key="d8">0</data>
      <data key="d9">Platform API writes an event to Kafka to initiate the build process.</data>
      <data key="d10">2c</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="6" id="0">
      <data key="d8">1</data>
      <data key="d9">Kafka event triggers the build process consumer app on EC2.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="12" id="0">
      <data key="d8">3</data>
      <data key="d9">Kafka event triggers the Fargate status consumer app.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="6" target="4" id="0">
      <data key="d8">1</data>
      <data key="d9">EC2 build machine copies artifacts from S3 to its local drive.</data>
      <data key="d10">1a</data>
      <data key="d11">data</data>
    </edge>
    <edge source="6" target="7" id="0">
      <data key="d8">1</data>
      <data key="d9">EC2 build machine pulls other libraries from Artifactory.</data>
      <data key="d10">1b</data>
      <data key="d11">data</data>
    </edge>
    <edge source="6" target="8" id="0">
      <data key="d8">1</data>
      <data key="d9">EC2 builds and pushes the Docker image to ECR.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="8" target="9" id="0">
      <data key="d8">2</data>
      <data key="d9">SageMaker uses the ECR image for creating endpoint configurations and deploying the model.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="9" target="10" id="0">
      <data key="d8">3</data>
      <data key="d9">SageMaker emits events (e.g., endpoint change) to EventBridge.</data>
      <data key="d10">0</data>
      <data key="d11">meta</data>
    </edge>
    <edge source="10" target="11" id="0">
      <data key="d8">3</data>
      <data key="d9">EventBridge triggers a Lambda function to watch for SageMaker events.</data>
      <data key="d10">1</data>
      <data key="d11">meta</data>
    </edge>
    <edge source="11" target="5" id="0">
      <data key="d8">3</data>
      <data key="d9">Lambda writes an event to Kafka for status updates.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="12" target="1" id="0">
      <data key="d8">3</data>
      <data key="d9">Fargate status consumer writes status messages back to the UI portal.</data>
      <data key="d10">4a</data>
      <data key="d11">data</data>
    </edge>
    <edge source="12" target="3" id="0">
      <data key="d8">3</data>
      <data key="d9">Fargate status consumer updates endpoint information in the model registry if deployment succeeded.</data>
      <data key="d10">4b</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">Experian Model Onboarding &amp; Deployment</data>
    <data key="d1">https://www.youtube.com/watch?v=-yCol_7qH2U</data>
    <data key="d2">Experian developed an architecture to accelerate client model onboarding from months to days. Data scientists upload model artifacts via a UI portal. The system then containerizes the models, deploys them to SageMaker endpoints, and provides asynchronous status updates. Key design choices include leveraging event-driven architecture with Kafka (MSK), Fargate for APIs and consumers, EC2 for dedicated build machines, and SageMaker for managed ML deployment at scale. The solution provides rapid time-to-market and auto-scaling for model inferencing.</data>
    <data key="d3">data_ingestion, interactive, compute_intensive, control</data>
    <data key="d4">True</data>
  </graph>
</graphml>
