  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Data Scientists</data>
      <data key="d6">UserCompanyDeveloper</data>
      <data key="d7">DATA_PEEK: Uploads Python serialized (.pkl) files and attributes.py via UI Portal.</data>
    </node>
    <node id="1">
      <data key="d5">Platform API</data>
      <data key="d6">EC2</data>
      <data key="d7">Handles incoming model upload and registration requests.</data>
    </node>
    <node id="2">
      <data key="d5">Model Registry</data>
      <data key="d6">OpenSearch</data>
      <data key="d7">Metadata store tracking model status, versions, and endpoint URLs.</data>
    </node>
    <node id="3">
      <data key="d5">Artifact Store</data>
      <data key="d6">S3</data>
      <data key="d7">Stores uploaded raw model artifacts and attributes.</data>
    </node>
    <node id="4">
      <data key="d5">Kafka Event Bus</data>
      <data key="d6">MSK</data>
      <data key="d7">Asynchronous event broker managing pipeline stages.</data>
    </node>
    <node id="5">
      <data key="d5">Build Machine</data>
      <data key="d6">EC2</data>
      <data key="d7">WORKLOAD_PEEK: Runs Docker to containerize SageMaker-compatible images.</data>
    </node>
    <node id="6">
      <data key="d5">Artifactory</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Hosts required code and model library dependencies.</data>
    </node>
    <node id="7">
      <data key="d5">Container Registry</data>
      <data key="d6">ECR</data>
      <data key="d7">Stores built SageMaker-compatible Docker images.</data>
    </node>
    <node id="8">
      <data key="d5">Model Endpoint</data>
      <data key="d6">SageMaker</data>
      <data key="d7">Hosts model for scalable auto-scaling inference.</data>
    </node>
    <node id="9">
      <data key="d5">Event Router</data>
      <data key="d6">EventBridge</data>
      <data key="d7">Monitors SageMaker endpoint change events.</data>
    </node>
    <node id="10">
      <data key="d5">Status Handler</data>
      <data key="d6">Lambda</data>
      <data key="d7">Triggers on EventBridge signals to publish status changes back to MSK.</data>
    </node>
    <node id="11">
      <data key="d5">Status Consumer</data>
      <data key="d6">Fargate</data>
      <data key="d7">Consumes status updates, writes back to the UI portal and registry.</data>
    </node>
