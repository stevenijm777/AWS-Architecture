<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">User</data>
      <data key="d6">UserConsumerWebMobile</data>
      <data key="d7">Represents the user uploading media files to the ingest bucket.</data>
    </node>
    <node id="1">
      <data key="d5">S3</data>
      <data key="d6">S3</data>
      <data key="d7">S3 bucket where the raw media files are uploaded and proxy files are stored.</data>
    </node>
    <node id="2">
      <data key="d5">Step Functions</data>
      <data key="d6">StepFunctions</data>
      <data key="d7">Orchestrates the media processing workflows, triggering encoding and metadata extraction services.</data>
    </node>
    <node id="3">
      <data key="d5">Elemental MediaConvert</data>
      <data key="d6">MediaConvert</data>
      <data key="d7">Transcodes input videos into browser-compatible proxies.</data>
    </node>
    <node id="4">
      <data key="d5">Rekognition</data>
      <data key="d6">Rekognition</data>
      <data key="d7">Analyzes visual media for celebrity recognition, content moderation, and other visual tags.</data>
    </node>
    <node id="5">
      <data key="d5">Transcribe</data>
      <data key="d6">Transcribe</data>
      <data key="d7">Translates the audio from the video into text.</data>
    </node>
    <node id="6">
      <data key="d5">Comprehend</data>
      <data key="d6">Comprehend</data>
      <data key="d7">Performs natural language processing on transcribed text to extract insights and entities.</data>
    </node>
    <node id="7">
      <data key="d5">DynamoDB</data>
      <data key="d6">DynamoDB</data>
      <data key="d7">Serves as a temporary database storing the extracted metadata from multiple streams.</data>
    </node>
    <node id="8">
      <data key="d5">EC2 (Reach Engine)</data>
      <data key="d6">EC2</data>
      <data key="d7">Computes part of the Reach Engine system.</data>
    </node>
    <node id="9">
      <data key="d5">EKS (Reach Engine)</data>
      <data key="d6">EKS</data>
      <data key="d7">Runs the containerized Reach Engine orchestrator and platform.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">User uploads the raw video file into the S3 ingest bucket.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">Upload event triggers the AWS Step Functions workflow orchestration.</data>
      <data key="d10">1</data>
      <data key="d11">control</data>
    </edge>
    <edge source="2" target="3" id="0">
      <data key="d8">0</data>
      <data key="d9">Step Functions initiates the video transcoding job in Elemental MediaConvert.</data>
      <data key="d10">2</data>
      <data key="d11">control</data>
    </edge>
    <edge source="2" target="4" id="0">
      <data key="d8">0</data>
      <data key="d9">Step Functions triggers AWS Rekognition to extract visual and tag data from the video.</data>
      <data key="d10">4</data>
      <data key="d11">control</data>
    </edge>
    <edge source="2" target="5" id="0">
      <data key="d8">0</data>
      <data key="d9">Step Functions triggers Amazon Transcribe to convert audio to text.</data>
      <data key="d10">6</data>
      <data key="d11">control</data>
    </edge>
    <edge source="3" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">Elemental MediaConvert saves the generated proxy video back to the S3 bucket.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="7" id="0">
      <data key="d8">0</data>
      <data key="d9">Visual analysis results and tags are stored in DynamoDB.</data>
      <data key="d10">5</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="6" id="0">
      <data key="d8">0</data>
      <data key="d9">Transcribed text is sent to Amazon Comprehend for entity and sentiment analysis.</data>
      <data key="d10">7</data>
      <data key="d11">data</data>
    </edge>
    <edge source="6" target="7" id="0">
      <data key="d8">0</data>
      <data key="d9">Comprehend text analytics results are saved in DynamoDB.</data>
      <data key="d10">8</data>
      <data key="d11">data</data>
    </edge>
    <edge source="7" target="9" id="0">
      <data key="d8">0</data>
      <data key="d9">Extracted metadata in DynamoDB is imported into the Reach Engine platform running on EKS for user search and curation.</data>
      <data key="d10">9</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">Levels Beyond Media to Cloud Enrichment Workflow</data>
    <data key="d1">https://www.youtube.com/watch?v=07lfvavMdfU</data>
    <data key="d2">An AWS Step Functions orchestrated serverless workflow for ingesting media into Reach Engine. Videos are transcoded to browser-compatible proxies via AWS Elemental MediaConvert, while parallel metadata extraction is handled via Amazon Rekognition, Transcribe, and Comprehend before storing technical and enriched metadata in Amazon DynamoDB.</data>
    <data key="d3">data_ingestion, compute_intensive, control</data>
    <data key="d4">True</data>
  </graph>
</graphml>
