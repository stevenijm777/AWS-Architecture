    </node>
    <node id="2">
      <data key="d5">Orchestration</data>
      <data key="d6">StepFunctions</data>
      <data key="d7">Coordinates ingestion, transcoding, technical metadata extraction, and AI processing.</data>
    </node>
    <node id="3">
      <data key="d5">MediaConvert</data>
      <data key="d6">MediaConvert</data>
