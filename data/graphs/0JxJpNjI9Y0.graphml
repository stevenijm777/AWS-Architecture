  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Public Readers</data>
      <data key="d6">UserConsumerWebMobile</data>
      <data key="d7">Readers accessing WashingtonPost.com or client sites.</data>
    </node>
    <node id="1">
      <data key="d5">Web Developers</data>
      <data key="d6">UserCompanyDeveloper</data>
      <data key="d7">Deploys code updates to the Lambda rendering engine.</data>
    </node>
    <node id="2">
      <data key="d5">Newsroom Editors</data>
      <data key="d6">UserCompanyDomainExpert</data>
      <data key="d7">Creates page layouts via Page Builder Admin.</data>
    </node>
    <node id="3">
      <data key="d5">ECS Origin Proxy</data>
      <data key="d6">ECS</data>
      <data key="d7">WORKLOAD_PEEK: Handles traffic routing to static, cached, or dynamic targets.</data>
    </node>
    <node id="4">
      <data key="d5">S3 Static Resources</data>
      <data key="d6">S3</data>
      <data key="d7">Stores assets like JS and CSS files.</data>
    </node>
    <node id="5">
      <data key="d5">S3 Pre-Render Content</data>
      <data key="d6">S3</data>
      <data key="d7">Stores pre-rendered HTML files for fast load times.</data>
    </node>
    <node id="6">
      <data key="d5">Lambda Page Renderer</data>
      <data key="d6">Lambda</data>
      <data key="d7">WORKLOAD_PEEK: Dynamically constructs web pages on-demand using JavaScript engine.</data>
    </node>
    <node id="7">
      <data key="d5">DynamoDB Templates</data>
      <data key="d6">DynamoDB</data>
      <data key="d7">DATA_PEEK: Stores page builder web templates.</data>
    </node>
    <node id="8">
      <data key="d5">ECS Content Proxy</data>
      <data key="d6">ECS</data>
      <data key="d7">Bridges internal rendering with external or internal CMS APIs.</data>
    </node>
    <node id="9">
      <data key="d5">ElastiCache Redis</data>
      <data key="d6">ElastiCache</data>
      <data key="d7">DATA_PEEK: Caches raw JSON story/media payloads with active TTL.</data>
    </node>
    <node id="10">
      <data key="d5">CMS &amp; APIs</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">External content management APIs serving raw data (stories, videos).</data>
    </node>
    <edge source="0" target="3" id="0">
      <data key="d8">0</data>
      <data key="d9">User requests web page.</data>
