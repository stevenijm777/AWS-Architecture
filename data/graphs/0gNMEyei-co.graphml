  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Customer Applications</data>
      <data key="d6">UserCompanyAPI</data>
      <data key="d7">Generates security and transactional data.</data>
    </node>
    <node id="1">
      <data key="d5">Kinesis Stream</data>
      <data key="d6">Kinesis</data>
      <data key="d7">Ingests real-time security and transactional logs.</data>
    </node>
    <node id="2">
      <data key="d5">Ingestion Service</data>
      <data key="d6">Fargate</data>
      <data key="d7">Parses and routes incoming streams.</data>
    </node>
    <node id="3">
      <data key="d5">Aurora DB</data>
      <data key="d6">Aurora</data>
      <data key="d7">Stores transactional metadata.</data>
    </node>
    <node id="4">
      <data key="d5">S3 Bucket</data>
      <data key="d6">S3</data>
      <data key="d7">Stores raw and processed historical audit data.</data>
    </node>
    <node id="5">
      <data key="d5">Glue ETL Jobs</data>
      <data key="d6">Glue</data>
      <data key="d7">Scheduled ETL to transform raw S3 logs.</data>
    </node>
    <node id="6">
      <data key="d5">Scheduler</data>
      <data key="d6">EventBridge</data>
      <data key="d7">Manages schedule-based triggers for analysis.</data>
    </node>
    <node id="7">
      <data key="d5">Analysis Engine (Scoping)</data>
      <data key="d6">Fargate</data>
      <data key="d7">Determines scope and triggers EMR jobs.</data>
    </node>
    <node id="8">
      <data key="d5">EMR Spark Cluster</data>
      <data key="d6">EMR</data>
      <data key="d7">Runs auditing logic and identifies violations.</data>
    </node>
    <node id="9">
      <data key="d5">EventBridge</data>
      <data key="d6">EventBridge</data>
      <data key="d7">Routes violation events.</data>
    </node>
    <node id="10">
      <data key="d5">SQS Queue</data>
      <data key="d6">SQS</data>
      <data key="d7">Queues violations for email processing.</data>
    </node>
    <node id="11">
      <data key="d5">Violation Decorator Service</data>
      <data key="d6">Fargate</data>
      <data key="d7">Enriches violation data for notification.</data>
    </node>
    <node id="12">
      <data key="d5">SMTP Server</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Dispatches compliance alerts to clients.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">Streams security events.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">Consumes stream data.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="3" id="0">
      <data key="d8">0</data>
      <data key="d9">Saves structured records.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="4" id="0">
      <data key="d8">0</data>
      <data key="d9">Saves raw payload.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="8" id="0">
      <data key="d8">1</data>
      <data key="d9">EMR pulls transactional details.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="5" id="0">
      <data key="d8">0</data>
      <data key="d9">Reads raw data.</data>
      <data key="d10">5</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="8" id="0">
      <data key="d8">1</data>
      <data key="d9">EMR pulls audit logs.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="4" id="0">
      <data key="d8">0</data>
      <data key="d9">Writes back transformed data.</data>
      <data key="d10">6</data>
      <data key="d11">data</data>
    </edge>
    <edge source="6" target="7" id="0">
      <data key="d8">1</data>
      <data key="d9">Triggers schedule.</data>
      <data key="d10">1</data>
      <data key="d11">meta</data>
    </edge>
    <edge source="7" target="8" id="0">
      <data key="d8">1</data>
      <data key="d9">Spins up/triggers EMR Job.</data>
      <data key="d10">2</data>
      <data key="d11">meta</data>
    </edge>
    <edge source="8" target="9" id="0">
      <data key="d8">1</data>
      <data key="d9">Publishes violations.</data>
      <data key="d10">5</data>
      <data key="d11">data</data>
    </edge>
    <edge source="9" target="10" id="0">
      <data key="d8">1</data>
      <data key="d9">Queues violations.</data>
      <data key="d10">6</data>
      <data key="d11">data</data>
    </edge>
    <edge source="10" target="11" id="0">
      <data key="d8">1</data>
      <data key="d9">Pulls violations.</data>
      <data key="d10">7</data>
      <data key="d11">data</data>
    </edge>
    <edge source="11" target="12" id="0">
      <data key="d8">1</data>
      <data key="d9">Sends compliance emails.</data>
      <data key="d10">8</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">Infor Governance Risk and Compliance Architecture</data>
    <data key="d1">https://www.youtube.com/watch?v=0gNMEyei-co</data>
    <data key="d2">Handles risk and compliance auditing. Scales to millions of records per day per customer. Uses Spark on EMR for rule execution on big data stored in Aurora and S3.</data>
    <data key="d3">data_ingestion, compute_intensive</data>
    <data key="d4">True</data>
  </graph>
