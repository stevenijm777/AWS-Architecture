<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d12" for="edge" attr.name="id" attr.type="string" />
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Enterprise Users</data>
      <data key="d6">UserCompanyAPI</data>
      <data key="d7">80+ enterprises in retail, food, fashion, and automobile uploading images and downloading catalogs.</data>
    </node>
    <node id="1">
      <data key="d5">API Gateway</data>
      <data key="d6">ApiGateway</data>
      <data key="d7">Handles incoming image uploads from various sources (SDK, API, Web).</data>
    </node>
    <node id="2">
      <data key="d5">Application Load Balancer</data>
      <data key="d6">ELB</data>
      <data key="d7">Routes incoming traffic to the appropriate ECS services.</data>
    </node>
    <node id="3">
      <data key="d5">ECS Clusters</data>
      <data key="d6">ECS</data>
      <data key="d7">Categorizes images and handles parameters and metadata.</data>
    </node>
    <node id="4">
      <data key="d5">Amazon RDS</data>
      <data key="d6">RDS</data>
      <data key="d7">Stores metadata and powers the catalog dashboard.</data>
    </node>
    <node id="5">
      <data key="d5">Amazon SQS</data>
      <data key="d6">SQS</data>
      <data key="d7">Task queues mapping to appropriate CPU or GPU processing tasks.</data>
    </node>
    <node id="6">
      <data key="d5">CPU Instances (Pre/Post Processing)</data>
      <data key="d6">EC2</data>
      <data key="d7">Performs CPU-intensive tasks like resizing, color correction, and final image construction.</data>
    </node>
    <node id="7">
      <data key="d5">GPU Instances (Inference)</data>
      <data key="d6">EC2</data>
      <data key="d7">G5 instances (8x GPUs) running AI model inferences.</data>
    </node>
    <node id="8">
      <data key="d5">Amazon S3</data>
      <data key="d6">S3</data>
      <data key="d7">Stores training datasets, catalog assets, and trained model weights.</data>
    </node>
    <node id="9">
      <data key="d5">Amazon SageMaker</data>
      <data key="d6">SageMaker</data>
      <data key="d7">Runs model training using cost-effective Spot instances.</data>
    </node>
    <node id="10">
      <data key="d5">Weight Syncer Lambda</data>
      <data key="d6">Lambda</data>
      <data key="d7">Triggered post-benchmarking to synchronize trained model weights from S3 to EC2.</data>
    </node>
    <edge source="0" target="1">
      <data key="d8">0</data>
      <data key="d9">User uploads catalog images</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="1" target="2">
      <data key="d8">0</data>
      <data key="d9">Routes image requests</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="2" target="3">
      <data key="d8">0</data>
      <data key="d9">Forwards to appropriate ECS categorization task</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="3" target="4">
      <data key="d8">0</data>
      <data key="d9">Saves image metadata and parameters</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="3" target="5">
      <data key="d8">0</data>
      <data key="d9">Pushes tasks to categorized queues</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="4" target="0">
      <data key="d8">0</data>
      <data key="d9">Powers catalog dashboard for user views and downloads</data>
      <data key="d10">7</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="5" target="6">
      <data key="d8">0</data>
      <data key="d9">Triggers pre/post CPU processes</data>
      <data key="d10">5a</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="5" target="7">
      <data key="d8">0</data>
      <data key="d9">Triggers GPU model inference</data>
      <data key="d10">5b</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="6" target="8">
      <data key="d8">0</data>
      <data key="d9">Uploads finished catalog images</data>
      <data key="d10">6a</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="7" target="8">
      <data key="d8">0</data>
      <data key="d9">Retrieves image payload for model consumption</data>
      <data key="d10">6b</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="8" target="9">
      <data key="d8">1</data>
      <data key="d9">Loads training datasets</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="9" target="8">
      <data key="d8">1</data>
      <data key="d9">Uploads trained model weights</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="9" target="10">
      <data key="d8">1</data>
      <data key="d9">Triggers weight sync lambda post-benchmarking</data>
      <data key="d10">2</data>
      <data key="d11">meta</data>
      <data key="d12">0</data>
    </edge>
    <edge source="10" target="8">
      <data key="d8">1</data>
      <data key="d9">Reads weight files</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="10" target="7">
      <data key="d8">1</data>
      <data key="d9">Pushes new weight models to inference engines</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <data key="d0">Spyne.AI: High-Quality Product Visuals at Scale with AI on AWS</data>
    <data key="d1">https://www.youtube.com/watch?v=0wnNlOg42dc</data>
    <data key="d2">Processes ~100k images daily using segregated CPU/GPU pipelines and spot instances on SageMaker for cost reduction.</data>
    <data key="d3">compute_intensive, data_ingestion</data>
    <data key="d4">True</data>
  </graph>
</graphml>
