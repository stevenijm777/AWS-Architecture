  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Salesforce CRM</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">CRM containing product and creative ad requirements.</data>
    </node>
    <node id="1">
      <data key="d5">API Gateway</data>
      <data key="d6">ApiGateway</data>
      <data key="d7">Entry point for CRM triggers and front-end requests.</data>
    </node>
    <node id="2">
      <data key="d5">Parsing Lambda</data>
      <data key="d6">Lambda</data>
      <data key="d7">Parses and standardizes payload from Salesforce.</data>
    </node>
    <node id="3">
      <data key="d5">Ad Data Table</data>
      <data key="d6">DynamoDB</data>
      <data key="d7">Stores parsed ad details and operational status.</data>
    </node>
    <node id="4">
      <data key="d5">Routing Lambda</data>
      <data key="d6">Lambda</data>
      <data key="d7">Coordinates downstream delivery and manages routing paths.</data>
    </node>
    <node id="5">
      <data key="d5">Config Table</data>
      <data key="d6">DynamoDB</data>
      <data key="d7">Stores environment routing configurations and system credentials.</data>
    </node>
    <node id="6">
      <data key="d5">Workflow Lambda</data>
      <data key="d6">Lambda</data>
      <data key="d7">Executes core business logic for ad creation, proofing, and fulfillment.</data>
    </node>
    <node id="7">
      <data key="d5">Front-end Hosting S3 Bucket</data>
      <data key="d6">S3</data>
      <data key="d7">Hosts static web UI assets.</data>
    </node>
    <node id="8">
      <data key="d5">Cognito User Pools</data>
      <data key="d6">Cognito</data>
      <data key="d7">Provides user auth and single sign-on capabilities.</data>
    </node>
    <node id="9">
      <data key="d5">Admins</data>
      <data key="d6">UserCompanyInternalPlatform</data>
      <data key="d7">Admins managing system routing configurations.</data>
    </node>
    <node id="10">
      <data key="d5">Creative Users</data>
      <data key="d6">UserCompanyAgent</data>
      <data key="d7">Designers and proofing agents executing creative tasks.</data>
    </node>
