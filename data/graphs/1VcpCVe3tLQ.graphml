  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Athlete and Race Data Sources</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">DATA_PEEK: Race results and athlete information from multiple external sources.</data>
    </node>
    <node id="1">
      <data key="d5">Data Processing &amp; ETL</data>
      <data key="d6">Glue</data>
      <data key="d7">WORKLOAD_PEEK: Loads data from sources into S3 landing. Converts and transforms data (XML/JSON to optimized structure), and creates curated views. Orchestrated by Step Functions.</data>
    </node>
    <node id="2">
      <data key="d5">Landing Bucket</data>
      <data key="d6">S3</data>
      <data key="d7">DATA_PEEK: Stores raw data from sources in XML and JSON format. WORKLOAD_PEEK: Not optimal for querying, acts as an initial ingestion point.</data>
    </node>
    <node id="3">
      <data key="d5">Data Lake Bucket</data>
      <data key="d6">S3</data>
      <data key="d7">DATA_PEEK: Stores data in an optimized structure after initial conversion and transformation.</data>
    </node>
    <node id="4">
      <data key="d5">Curated Bucket</data>
      <data key="d6">S3</data>
      <data key="d7">DATA_PEEK: Stores curated views of the data in the right structure. WORKLOAD_PEEK: Consumed by Aurora (for the web application) and Athena (for machine learning model training).</data>
    </node>
    <node id="5">
      <data key="d5">Orchestration Workflows</data>
      <data key="d6">StepFunctions</data>
      <data key="d7">WORKLOAD_PEEK: Orchestrates the entire data pipeline (Glue jobs) and the machine learning model training/deployment pipeline (Athena, SageMaker training, verification, deployment). Provides a single place to monitor pipelines and handles failure/retry logic. Coaches can trigger model retraining.</data>
    </node>
    <node id="6">
      <data key="d5">Web Application Database</data>
      <data key="d6">Aurora</data>
      <data key="d7">WORKLOAD_PEEK: Backs the web application, providing data for the user interface.</data>
    </node>
    <node id="7">
      <data key="d5">Data Query Service</data>
      <data key="d6">Athena</data>
      <data key="d7">WORKLOAD_PEEK: Used by data scientists (via SageMaker Notebook) and SageMaker training jobs to query curated data directly from S3 using a SQL interface.</data>
    </node>
    <node id="8">
      <data key="d5">Coaches' Web Application</data>
      <data key="d6">UserConsumerWeb</data>
      <data key="d7">WORKLOAD_PEEK: Coaches interact with this user interface to select teams, request relay orders, view results, rankings, historical data, and comparisons. Displays best swimmers and optimal swim order. Data refresh rate is 15 minutes during competition, weekly outside. Allows manipulation of swimmer choices and viewing skill parameters.</data>
    </node>
    <node id="9">
      <data key="d5">Inference API Gateway</data>
      <data key="d6">ApiGateway</data>
      <data key="d7">WORKLOAD_PEEK: Provides an API endpoint for the web application to request relay order predictions, triggering a Lambda function.</data>
    </node>
    <node id="10">
      <data key="d5">Inference Function</data>
      <data key="d6">Lambda</data>
      <data key="d7">WORKLOAD_PEEK: Invoked by API Gateway, calls the SageMaker model for inference to get the best relay order.</data>
    </node>
    <node id="11">
      <data key="d5">ML Inference Endpoint</data>
      <data key="d6">SageMaker</data>
      <data key="d7">WORKLOAD_PEEK: Deploys the trained ML model, providing an API endpoint for real-time inference (predicting best relay order, individual swim times, team standings).</data>
    </node>
    <node id="12">
      <data key="d5">ML Notebook (Experimentation)</data>
      <data key="d6">SageMaker</data>
      <data key="d7">WORKLOAD_PEEK: Used by data scientists for development and experimentation. Makes SQL queries via Athena to get data for model building. Supports iterative algorithm testing (LightGBM, XGBoost).</data>
    </node>
    <node id="13">
      <data key="d5">ML Training Job</data>
      <data key="d6">SageMaker</data>
      <data key="d7">WORKLOAD_PEEK: Trains the machine learning algorithm using data queried from Athena. Produces the final model artifact. Algorithms like XGBoost are used to predict individual swim times, team standings, and optimal relay lineups.</data>
    </node>
    <node id="14">
      <data key="d5">ML Model Verification</data>
      <data key="d6">SageMaker</data>
      <data key="d7">WORKLOAD_PEEK: A step in the ML pipeline that verifies model results (e.g., checks if predictions are within reasonable bounds) before deployment to the endpoint. Part of the automated pipeline orchestrated by Step Functions.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">Glue loads race results and athlete information from various sources.</data>
      <data key="d10">0.1</data>
      <data key="d11">data</data>
    </edge>
