    </edge>
    <edge source="2" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">Glue reads raw XML/JSON data from the landing bucket for conversion and transformation.</data>
      <data key="d10">0.3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">Glue reads optimized data from the data lake for further transformation and curation.</data>
      <data key="d10">0.5</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="7" id="0">
      <data key="d8">1</data>
      <data key="d9">Athena queries curated data directly from the S3 Curated Bucket for ML model training and experimentation.</data>
      <data key="d10">1.1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">Step Functions orchestrates the Glue data pipeline, managing its execution, monitoring, and error handling.</data>
      <data key="d10">0.0</data>
      <data key="d11">meta</data>
    </edge>
    <edge source="5" target="7" id="0">
      <data key="d8">1</data>
      <data key="d9">Step Functions orchestrates the ML pipeline, including triggering Athena queries for training data.</data>
      <data key="d10">1.0</data>
      <data key="d11">meta</data>
    </edge>
    <edge source="5" target="13" id="0">
      <data key="d8">1</data>
      <data key="d9">Step Functions triggers and orchestrates the SageMaker training job.</data>
      <data key="d10">1.3</data>
      <data key="d11">meta</data>
    </edge>
    <edge source="5" target="14" id="0">
      <data key="d8">1</data>
      <data key="d9">Step Functions orchestrates the model verification step.</data>
      <data key="d10">1.5</data>
      <data key="d11">meta</data>
    </edge>
    <edge source="5" target="11" id="0">
      <data key="d8">1</data>
      <data key="d9">Step Functions orchestrates the deployment of the verified model to the SageMaker endpoint.</data>
      <data key="d10">1.7</data>
      <data key="d11">meta</data>
    </edge>
    <edge source="6" target="8" id="0">
      <data key="d8">2</data>
      <data key="d9">Aurora provides data to the web application for display.</data>
      <data key="d10">2.8</data>
      <data key="d11">data</data>
    </edge>
    <edge source="7" target="13" id="0">
      <data key="d8">1</data>
      <data key="d9">Athena provides queried data to the SageMaker training job for model training.</data>
      <data key="d10">1.2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="7" target="12" id="0">
      <data key="d8">1</data>
      <data key="d9">Athena returns query results to the SageMaker Notebook for analysis and model building.</data>
      <data key="d10">1.9</data>
      <data key="d11">data</data>
    </edge>
