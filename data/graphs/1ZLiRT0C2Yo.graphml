  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">End User</data>
      <data key="d6">UserConsumerWebMobile</data>
      <data key="d7">Customers accessing mobile and web applications like the store locator.</data>
    </node>
    <node id="1">
      <data key="d5">Platform Developers</data>
      <data key="d6">UserCompanyDeveloper</data>
      <data key="d7">T-Mobile platform engineers managing cloud infrastructure configurations.</data>
    </node>
    <node id="2">
      <data key="d5">GitOps Pipeline</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Terraform and Ansible automated deployment engine.</data>
    </node>
    <node id="3">
      <data key="d5">Elastic Load Balancer</data>
      <data key="d6">ELB</data>
      <data key="d7">Distributes incoming traffic to application containers.</data>
    </node>
    <node id="4">
      <data key="d5">Region K8s Clusters</data>
      <data key="d6">EC2</data>
      <data key="d7">WORKLOAD_PEEK: Hosts 40 clusters and 30,000 containers across East/West regions.</data>
    </node>
    <node id="5">
      <data key="d5">LAX Local Zone Clusters</data>
      <data key="d6">EC2</data>
      <data key="d7">Provides ultra-low latency (~5ms) container hosting close to users in LA.</data>
    </node>
    <node id="6">
      <data key="d5">Relational Database</data>
      <data key="d6">RDS</data>
      <data key="d7">Relational backend storage utilized by application teams.</data>
    </node>
    <node id="7">
      <data key="d5">Transit Gateway</data>
      <data key="d6">TransitGateway</data>
      <data key="d7">Interconnects VPCs and connects back to on-premises environments.</data>
    </node>
    <node id="8">
      <data key="d5">On-Premises Data Centers</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Data centers in Texas and Washington State.</data>
    </node>
    <node id="9">
      <data key="d5">S3</data>
      <data key="d6">S3</data>
      <data key="d7">Stores configuration files, states, and GitOps artifacts.</data>
    </node>
    <node id="10">
      <data key="d5">CloudWatch &amp; Prometheus</data>
      <data key="d6">CloudWatch</data>
      <data key="d7">Observability solution collecting cluster metrics.</data>
    </node>
    <edge source="0" target="3" id="0">
      <data key="d8">1</data>
      <data key="d9">User requests standard application.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
