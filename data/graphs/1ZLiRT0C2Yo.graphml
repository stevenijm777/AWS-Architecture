  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">T-Mobile Developers</data>
      <data key="d6">UserCompanyDeveloper</data>
      <data key="d7">Manage cluster configurations using GitOps, Terraform, and Ansible.</data>
    </node>
    <node id="1">
      <data key="d5">Mobile Users</data>
      <data key="d6">UserConsumerMobile</data>
      <data key="d7">Access low-latency applications like store locators.</data>
    </node>
    <node id="2">
      <data key="d5">Elastic Load Balancer</data>
      <data key="d6">ELB</data>
      <data key="d7">Distributes incoming application traffic to Kubernetes nodes.</data>
    </node>
    <node id="3">
      <data key="d5">Kubernetes Clusters (EC2)</data>
      <data key="d6">EC2</data>
      <data key="d7">WORKLOAD_PEEK: Runs 30,000 containers across 40 clusters spanning multiple AZs and local zones.</data>
    </node>
    <node id="4">
      <data key="d5">Amazon RDS</data>
      <data key="d6">RDS</data>
      <data key="d7">Database storage for applications.</data>
    </node>
    <node id="5">
      <data key="d5">Amazon S3</data>
      <data key="d6">S3</data>
      <data key="d7">Stores configuration states and deployment templates.</data>
    </node>
    <node id="6">
      <data key="d5">Transit Gateway</data>
      <data key="d6">TransitGateway</data>
      <data key="d7">Interconnects VPCs, accounts, and on-premises infrastructure.</data>
    </node>
    <node id="7">
      <data key="d5">On-Premises Data Centers</data>
      <data key="d6">OnPremDC</data>
      <data key="d7">Located in Texas and Washington State.</data>
    </node>
    <node id="8">
      <data key="d5">Amazon CloudWatch</data>
      <data key="d6">CloudWatch</data>
      <data key="d7">Centralized observability integrated with Prometheus.</data>
    </node>
    <edge source="0" target="5" id="0">
      <data key="d8">0</data>
      <data key="d9">Developers push infrastructure config to S3.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="2" id="0">
      <data key="d8">1</data>
      <data key="d9">User requests route to the load balancer.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="3" id="0">
      <data key="d8">1</data>
      <data key="d9">Traffic forwarded to Kubernetes pods.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="4" id="0">
      <data key="d8">1</data>
      <data key="d9">Application data queries to RDS database.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
