<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">USER</data>
      <data key="d6">UserCompanyDeveloper</data>
      <data key="d7">Represents the developer or end-user of the platform requesting environment creation through the Orion portal.</data>
    </node>
    <node id="1">
      <data key="d5">ROUTE 53</data>
      <data key="d6">Route53</data>
      <data key="d7">Used for DNS resolution of the request to the Orion portal.</data>
    </node>
    <node id="2">
      <data key="d5">ALB</data>
      <data key="d6">ALB</data>
      <data key="d7">Application Load Balancer distributing incoming traffic to EKS resources.</data>
    </node>
    <node id="3">
      <data key="d5">EKS</data>
      <data key="d6">EKS</data>
      <data key="d7">Amazon Elastic Kubernetes Service managing and orchestrating containerized microservices.</data>
    </node>
    <node id="4">
      <data key="d5">SPOT</data>
      <data key="d6">AutoScaling</data>
      <data key="d7">100% Spot Instances running the actual workloads, with node termination handlers deployed.</data>
    </node>
    <node id="5">
      <data key="d5">SNS</data>
      <data key="d6">SNS</data>
      <data key="d7">Simple Notification Service to publish state events when microservice provisioning jobs are triggered.</data>
    </node>
    <node id="6">
      <data key="d5">SQS</data>
      <data key="d6">SQS</data>
      <data key="d7">Simple Queue Service queue to hold state messages for newly spun up jobs to recover state.</data>
    </node>
    <node id="7">
      <data key="d5">Microservices Jobs (m.s. 1, m.s. 2, m.s. 3)</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Kubernetes jobs representing individual microservice deployments.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">1</data>
      <data key="d9">User makes a request to the Orion portal resolved by Route 53</data>
      <data key="d10">0</data>
      <data key="d11">control</data>
    </edge>
    <edge source="1" target="2" id="0">
      <data key="d8">1</data>
      <data key="d9">DNS resolves and sends traffic to the ALB</data>
      <data key="d10">1</data>
      <data key="d11">control</data>
    </edge>
    <edge source="2" target="3" id="0">
      <data key="d8">1</data>
      <data key="d9">ALB routes requests to the Kubernetes pod orchestrator</data>
      <data key="d10">2</data>
      <data key="d11">control</data>
    </edge>
    <edge source="2" target="4" id="0">
      <data key="d8">1</data>
      <data key="d9">ALB directs traffic to pods hosted on spot instances</data>
      <data key="d10">3</data>
      <data key="d11">control</data>
    </edge>
    <edge source="3" target="7" id="0">
      <data key="d8">2</data>
      <data key="d9">EKS triggers Kubernetes jobs to deploy specific microservices</data>
      <data key="d10">0</data>
      <data key="d11">control</data>
    </edge>
    <edge source="3" target="5" id="0">
      <data key="d8">2</data>
      <data key="d9">The EKS control plane / jobs send execution state notifications to SNS</data>
      <data key="d10">2</data>
      <data key="d11">control</data>
    </edge>
    <edge source="5" target="6" id="0">
      <data key="d8">2</data>
      <data key="d9">SNS fans out state messages to SQS</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="6" target="7" id="0">
      <data key="d8">2</data>
      <data key="d9">Replaced jobs read unfinished job states from SQS to resume execution gracefully</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <edge source="7" target="4" id="0">
      <data key="d8">2</data>
      <data key="d9">Kubernetes jobs execute and deploy on top of Spot instances</data>
      <data key="d10">1</data>
      <data key="d11">control</data>
    </edge>
    <data key="d0">OLX Autos Internal Developer Platform with EKS and Spot Instances</data>
    <data key="d1">https://www.youtube.com/watch?v=1aYoIZvabbk</data>
    <data key="d2">OLX Autos uses an internal developer platform on Amazon EKS running 100% on Spot Instances to create replica environments. They utilize AWS Node Termination Handler, SNS, and SQS to track microservice deployment job states and gracefully recover from spot interruptions.</data>
    <data key="d3">compute_intensive, interactive, other</data>
    <data key="d4">True</data>
  </graph>
</graphml>
