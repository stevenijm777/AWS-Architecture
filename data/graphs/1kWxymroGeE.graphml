<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Application Component A</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Represents a microservice or application component for a specific tenant. It interacts with the various data services to store and retrieve different types of data.</data>
    </node>
    <node id="1">
      <data key="d5">Application Component B</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Represents another microservice or application component for a different tenant, demonstrating the multi-tenancy aspect of the data architecture.</data>
    </node>
    <node id="2">
      <data key="d5">S3 Buckets</data>
      <data key="d6">S3</data>
      <data key="d7">DATA_PEEK: Stores binary data, unstructured blob data, and structured data accessed by key (effectively a key-value store). WORKLOAD_PEEK: Utilized for its natural scalability and resilience for unstructured and key-value data. Supports multi-tenancy, with isolation through dedicated buckets or prefixes per tenant.</data>
    </node>
    <node id="3">
      <data key="d5">Aurora Serverless Instances</data>
      <data key="d6">Aurora</data>
      <data key="d7">DATA_PEEK: Stores core relational items critical for defining customer applications. WORKLOAD_PEEK: Chosen for relational data where each tenant gets its own dedicated Aurora Serverless instance, enabling high performance, independent scaling, and strong data isolation in a multi-tenant environment.</data>
    </node>
    <node id="4">
      <data key="d5">DynamoDB Tables</data>
      <data key="d6">DynamoDB</data>
      <data key="d7">DATA_PEEK: Stores configuration data and other key-value pairs, strategically offloaded from the relational database. WORKLOAD_PEEK: Provides better scalability and cost-efficiency for key-value data compared to relational databases. Used in a multi-tenant context.</data>
    </node>
    <node id="5">
      <data key="d5">Secrets Manager</data>
      <data key="d6">SecretsManager</data>
      <data key="d7">DATA_PEEK: Securely stores sensitive encrypted information and application secrets. WORKLOAD_PEEK: Offloads the burden of secure secret management from the application, leveraging AWS's capabilities for high security and integration with IAM for tenancy boundaries. Used for multi-tenancy.</data>
    </node>
    <node id="6">
      <data key="d5">Key Management Service (KMS)</data>
      <data key="d6">KMS</data>
      <data key="d7">WORKLOAD_PEEK: Central service for managing encryption keys. Critical for multi-tenancy, as it generates and manages per-tenant keys (or multiple keys per tenant) used to encrypt data across S3, Aurora, DynamoDB, and Secrets Manager. Facilitates Bring Your Own Key (BYOK) strategies.</data>
    </node>
    <edge source="0" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">Application Component A stores and retrieves binary/key-value data from S3.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="0" target="3" id="0">
      <data key="d8">0</data>
      <data key="d9">Application Component A reads and writes core relational data in its Aurora Serverless instance.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="0" target="4" id="0">
      <data key="d8">0</data>
      <data key="d9">Application Component A accesses configuration and key-value data in DynamoDB.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="0" target="5" id="0">
      <data key="d8">0</data>
      <data key="d9">Application Component A retrieves sensitive encrypted data/secrets from Secrets Manager.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="2" id="0">
      <data key="d8">1</data>
      <data key="d9">Application Component B stores and retrieves binary/key-value data from its S3 resources.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="3" id="0">
      <data key="d8">1</data>
      <data key="d9">Application Component B reads and writes core relational data in its Aurora Serverless instance.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="4" id="0">
      <data key="d8">1</data>
      <data key="d9">Application Component B accesses configuration and key-value data in DynamoDB.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="5" id="0">
      <data key="d8">1</data>
      <data key="d9">Application Component B retrieves sensitive encrypted data/secrets from Secrets Manager.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="6" target="2" id="0">
      <data key="d8">2</data>
      <data key="d9">KMS provides per-tenant encryption keys for S3 objects/buckets, ensuring data at rest is encrypted.</data>
      <data key="d10">0</data>
      <data key="d11">meta</data>
    </edge>
    <edge source="6" target="3" id="0">
      <data key="d8">2</data>
      <data key="d9">KMS provides per-tenant encryption keys for Aurora Serverless instances/data volumes, safeguarding relational data.</data>
      <data key="d10">1</data>
      <data key="d11">meta</data>
    </edge>
    <edge source="6" target="4" id="0">
      <data key="d8">2</data>
      <data key="d9">KMS provides per-tenant encryption keys for DynamoDB tables/items, protecting key-value data.</data>
      <data key="d10">2</data>
      <data key="d11">meta</data>
    </edge>
    <edge source="6" target="5" id="0">
      <data key="d8">2</data>
      <data key="d9">KMS integrates with Secrets Manager for managing the encryption of stored secrets, often using customer-managed keys (CMKs) for additional control.</data>
      <data key="d10">3</data>
      <data key="d11">meta</data>
    </edge>
    <data key="d0">Out Systems Data Decomposition for Multi-Tenancy</data>
    <data key="d1">https://www.youtube.com/watch?v=1kWxymroGeE</data>
    <data key="d2">This architecture illustrates Out Systems' approach to decomposing a monolithic application by focusing on data. The key design principle is to separate different data types into purpose-built AWS storage and database services: S3 for binary/unstructured data, Aurora Serverless for core relational data, DynamoDB for configuration/key-value data, and Secrets Manager for sensitive encrypted data. A strong multi-tenancy model is supported, where each tenant operates with isolated data instances or logical partitions. IAM roles enforce tenancy boundaries, and KMS provides per-tenant encryption keys, including support for Bring Your Own Key (BYOK) across all data services. This design empowers independent development teams and ensures scalability, security, and cost-effectiveness.</data>
    <data key="d3">data_ingestion, interactive, control</data>
    <data key="d4">True</data>
  </graph>
</graphml>
