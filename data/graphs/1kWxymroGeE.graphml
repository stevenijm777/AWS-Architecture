<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">OutSystems Platform</data>
      <data key="d6">EC2</data>
      <data key="d7">Decomposed application platform routing data based on type.</data>
    </node>
    <node id="1">
      <data key="d5">Amazon S3</data>
      <data key="d6">S3</data>
      <data key="d7">DATA_PEEK: Stores binary and unstructured blob data.</data>
    </node>
    <node id="2">
      <data key="d5">Aurora Serverless</data>
      <data key="d6">Aurora</data>
      <data key="d7">Stores core relational definitions with tenant-specific instances.</data>
    </node>
    <node id="3">
      <data key="d5">Amazon DynamoDB</data>
      <data key="d6">DynamoDB</data>
      <data key="d7">Stores configuration and key-value pair data.</data>
    </node>
    <node id="4">
      <data key="d5">Secrets Manager</data>
      <data key="d6">SecretsManager</data>
      <data key="d7">Stores encrypted sensitive configuration and secrets directly.</data>
    </node>
    <node id="5">
      <data key="d5">AWS KMS</data>
      <data key="d6">KMS</data>
      <data key="d7">Manages tenant-specific keys for encryption and BYOK support.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">Routes unstructured binary data to S3.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="0" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">Routes relational configuration to Aurora Serverless.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="0" target="3" id="0">
      <data key="d8">0</data>
      <data key="d9">Offloads key-value configuration data to DynamoDB.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="0" target="4" id="0">
      <data key="d8">0</data>
      <data key="d9">Saves sensitive encrypted data directly into Secrets Manager.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="1" id="0">
      <data key="d8">1</data>
      <data key="d9">Encrypts S3 storage with tenant-specific keys.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="2" id="0">
      <data key="d8">1</data>
      <data key="d9">Encrypts Aurora databases with tenant-specific keys.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="3" id="0">
      <data key="d8">1</data>
      <data key="d9">Encrypts DynamoDB tables with tenant-specific keys.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="4" id="0">
      <data key="d8">1</data>
      <data key="d9">Encrypts Secrets Manager parameters with tenant-specific keys.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">OutSystems Monolith Data Decomposition</data>
    <data key="d1">https://www.youtube.com/watch?v=1kWxymroGeE</data>
    <data key="d2">Architectural shift from a single relational database catch-all to purpose-built data stores (S3, Aurora Serverless, DynamoDB, Secrets Manager) with KMS-driven multi-tenant isolation.</data>
    <data key="d3">data_ingestion</data>
    <data key="d4">True</data>
  </graph>
</graphml>
