  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Platform Application</data>
      <data key="d6">UserCompanyInternalPlatform</data>
      <data key="d7">Represents the OutSystems platform applications that generate, consume, and manage various data types for its tenants/customers. WORKLOAD_PEEK: Developers empower to work detached and independently. DATA_PEEK: Handles binary, relational, key-value, and encrypted sensitive data.</data>
    </node>
    <node id="1">
      <data key="d5">S3 Bucket</data>
      <data key="d6">S3</data>
      <data key="d7">Used for storing 'binary data' and 'structured data that is just accessed by key'. Effectively acts as a key-value store. DATA_PEEK: Stores unstructured blob data and document data. WORKLOAD_PEEK: Chosen for its scalability and resilience for blob/document storage.</data>
    </node>
    <node id="2">
      <data key="d5">Aurora Serverless</data>
      <data key="d6">Aurora</data>
      <data key="d7">Stores 'core relational items' for the applications. WORKLOAD_PEEK: Crucially, 'each of our customers, each of our tenants, will have their own instances' of Aurora Serverless, enabling multi-tenancy and independent management by teams. Leverages Serverless model for request-based scaling.</data>
    </node>
    <node id="3">
      <data key="d5">DynamoDB Table</data>
      <data key="d6">DynamoDB</data>
      <data key="d7">Used for 'configuration or key value pair data'. WORKLOAD_PEEK: Selected to offload data from relational databases, providing a 'less expensive' and 'better scale' alternative for specific data types. DATA_PEEK: Tiered data, specifically key-value pairs, to provide more agility than a relational singleton.</data>
    </node>
    <node id="4">
      <data key="d5">Secrets Manager</data>
      <data key="d6">SecretsManager</data>
      <data key="d7">Stores 'encrypted data for sensitive information' directly. WORKLOAD_PEEK: Offloads the management of sensitive data; instead of pre-encrypting and storing in RDS, data is stored securely here. Enables use of IAM roles for 'tendency boundary'.</data>
    </node>
    <node id="5">
      <data key="d5">Key Management Service</data>
      <data key="d6">KMS</data>
      <data key="d7">Manages encryption keys for data protection. WORKLOAD_PEEK: Enables generation of 'per-tenant key or multiple keys for that tenant' and application of these to different services. Supports a 'bring-your-own-key (BYOK) strategy'. Integrates with S3, Aurora, DynamoDB, and Secrets Manager for built-in encryption mechanisms. Used with IAM roles for segregation of permissions in a multi-tenant world.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">Platform Application stores binary data and structured key-value data in S3.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="0" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">Platform Application stores core relational data in Aurora Serverless.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="0" target="3" id="0">
      <data key="d8">0</data>
      <data key="d9">Platform Application stores configuration and key-value pair data in DynamoDB.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <edge source="0" target="4" id="0">
      <data key="d8">0</data>
      <data key="d9">Platform Application stores encrypted sensitive information directly in Secrets Manager.</data>
      <data key="d10">6</data>
      <data key="d11">data</data>
    </edge>
    <edge source="0" target="5" id="0">
      <data key="d8">1</data>
      <data key="d9">Platform Application (or underlying AWS services on its behalf) requests encryption keys or operations from KMS for tenant data.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="0" id="0">
      <data key="d8">0</data>
      <data key="d9">Platform Application retrieves binary data and structured key-value data from S3.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="0" id="0">
      <data key="d8">0</data>
      <data key="d9">Platform Application retrieves core relational data from Aurora Serverless.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="0" id="0">
      <data key="d8">0</data>
      <data key="d9">Platform Application retrieves configuration and key-value pair data from DynamoDB.</data>
      <data key="d10">5</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="0" id="0">
      <data key="d8">0</data>
      <data key="d9">Platform Application retrieves encrypted sensitive information from Secrets Manager.</data>
      <data key="d10">7</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="1" id="0">
      <data key="d8">1</data>
      <data key="d9">KMS provides encryption keys/integrates with S3 for server-side encryption.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="2" id="0">
      <data key="d8">1</data>
      <data key="d9">KMS provides encryption keys/integrates with Aurora Serverless for database encryption.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="3" id="0">
      <data key="d8">1</data>
      <data key="d9">KMS provides encryption keys/integrates with DynamoDB for table encryption.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="4" id="0">
      <data key="d8">1</data>
      <data key="d9">KMS provides encryption keys/integrates with Secrets Manager for secret encryption.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">OutSystems Multi-Tenant Data Platform on AWS</data>
    <data key="d1">https://www.youtube.com/watch?v=1kWxymroGeE</data>
    <data key="d2">OutSystems re-architects its low-code application development platform by decomposing its monolith, primarily focusing on data. The architecture leverages purpose-built AWS data services for different data types (binary, relational, key-value, encrypted sensitive information) to achieve multi-tenancy, cost optimization, and scalability. Key design principles include offloading data from traditional relational databases to specialized services and employing per-tenant encryption via KMS for data isolation and security.</data>
    <data key="d3">data_ingestion, interactive, control</data>
    <data key="d4">True</data>
  </graph>
</graphml>
