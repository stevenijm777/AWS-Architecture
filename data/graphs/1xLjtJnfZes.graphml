<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Users</data>
      <data key="d6">UserConsumerMobile</data>
      <data key="d7">DATA_PEEK: Submits vaccine credentials as photos, screenshots, or PDFs.</data>
    </node>
    <node id="1">
      <data key="d5">ELB</data>
      <data key="d6">ELB</data>
      <data key="d7">Receives verification requests and routes them to WAF, Shield, and EKS.</data>
    </node>
    <node id="2">
      <data key="d5">WAF</data>
      <data key="d6">WAF</data>
      <data key="d7">Performs sanity checks, inspects content length, and drops specific headers.</data>
    </node>
    <node id="3">
      <data key="d5">Shield Advanced</data>
      <data key="d6">ShieldAdvanced</data>
      <data key="d7">Protects against DDoS attacks during peak credential validation events.</data>
    </node>
    <node id="4">
      <data key="d5">EKS</data>
      <data key="d6">EKS</data>
      <data key="d7">WORKLOAD_PEEK: Hosts microservices processing and verifying user credentials.</data>
    </node>
    <node id="5">
      <data key="d5">Auto Scaling Group</data>
      <data key="d6">AutoScaling</data>
      <data key="d7">Primes and scales infrastructure out and in based on peak loads.</data>
    </node>
    <node id="6">
      <data key="d5">Terraform</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Infrastructure as code used to provision and reproduce environments.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">Sends credential verification request</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">Inspects and filters web traffic</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="3" id="0">
      <data key="d8">0</data>
      <data key="d9">Evaluates traffic for DDoS protection</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="4" id="0">
      <data key="d8">0</data>
      <data key="d9">Routes checked requests to microservices</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="4" id="0">
      <data key="d8">0</data>
      <data key="d9">Scales EKS nodes up and down</data>
      <data key="d10">4</data>
      <data key="d11">meta</data>
    </edge>
    <data key="d0">Matter Verifier API for My Vaccine Pass</data>
    <data key="d1">https://www.youtube.com/watch?v=1xLjtJnfZes</data>
    <data key="d2">Handles high peak traffic scaling for pre-verification of vaccine credentials using infrastructure as code and automatic scaling on EKS.</data>
    <data key="d3">data_ingestion, compute_intensive</data>
    <data key="d4">True</data>
  </graph>
