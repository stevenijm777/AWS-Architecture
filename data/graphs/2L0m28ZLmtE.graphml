  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Users</data>
      <data key="d6">UserCompanyAnalyst</data>
      <data key="d7">Sanofi data scientists and analysts accessing the data analytics portal.</data>
    </node>
    <node id="1">
      <data key="d5">SANOFI SSO</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Sanofi corporate Single Sign-On Identity Provider federated with Cognito.</data>
    </node>
    <node id="2">
      <data key="d5">CLOUDFRONT</data>
      <data key="d6">CloudFront</data>
      <data key="d7">CloudFront CDN serving the portal static website with SSL/TLS certificate offloading.</data>
    </node>
    <node id="3">
      <data key="d5">COGNITO</data>
      <data key="d6">Cognito</data>
      <data key="d7">AWS Cognito managing authentication and federation with Sanofi's identity provider.</data>
    </node>
    <node id="4">
      <data key="d5">S3</data>
      <data key="d6">S3</data>
      <data key="d7">S3 bucket hosting the static website assets of the portal.</data>
    </node>
    <node id="5">
      <data key="d5">API GATEWAY</data>
      <data key="d6">ApiGateway</data>
      <data key="d7">Amazon API Gateway managing dynamic REST API endpoints for user and audit metadata.</data>
    </node>
    <node id="6">
      <data key="d5">DYNAMO DB</data>
      <data key="d6">DynamoDB</data>
      <data key="d7">Amazon DynamoDB storing user metadata and comprehensive platform audit logs.</data>
    </node>
    <node id="7">
      <data key="d5">SERVICE CATALOG</data>
      <data key="d6">ServiceCatalog</data>
      <data key="d7">AWS Service Catalog managing standardized analytical environment provisioning via CloudFormation.</data>
    </node>
    <node id="8">
      <data key="d5">LAMBDA</data>
      <data key="d6">Lambda</data>
      <data key="d7">AWS Lambda executing provisioning lifecycle scripts and analytical backend tasks.</data>
    </node>
    <node id="9">
      <data key="d5">R STUDIO</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Standardized RStudio analytical workspace provisioned per-user.</data>
    </node>
    <node id="10">
      <data key="d5">SAGEMAKER</data>
      <data key="d6">SageMaker</data>
      <data key="d7">Amazon SageMaker notebook instances provisioned for individual ML development.</data>
    </node>
    <node id="11">
      <data key="d5">TRANSLATE</data>
      <data key="d6">Translate</data>
      <data key="d7">Amazon Translate used for bulk document translation of clinical and medical text files.</data>
    </node>
    <node id="12">
      <data key="d5">COMPREHEND MEDICAL</data>
      <data key="d6">Comprehend</data>
      <data key="d7">Amazon Comprehend Medical used to recognize medical entities and de-identify sensitive data.</data>
    </node>
    <node id="13">
      <data key="d5">DATA LAKE</data>
      <data key="d6">S3</data>
      <data key="d7">Secure landing zone and analytical data lake with strong access boundaries to prevent extraction.</data>
    </node>
    <edge source="0" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">Users access the web portal interface via CloudFront CDN.</data>
      <data key="d10">0</data>
      <data key="d11">control</data>
    </edge>
    <edge source="1" target="3" id="0">
      <data key="d8">0</data>
      <data key="d9">Sanofi SSO federates user authentication with Amazon Cognito.</data>
      <data key="d10">2</data>
      <data key="d11">control</data>
    </edge>
    <edge source="2" target="4" id="0">
      <data key="d8">0</data>
      <data key="d9">CloudFront serves the static portal assets stored securely in S3.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="4" id="0">
      <data key="d8">0</data>
      <data key="d9">Cognito session token authorizes access to protected portal assets in S3.</data>
      <data key="d10">3</data>
      <data key="d11">control</data>
    </edge>
    <edge source="4" target="5" id="0">
      <data key="d8">1</data>
      <data key="d9">Static portal frontend triggers dynamic API operations using API Gateway.</data>
      <data key="d10">0</data>
      <data key="d11">control</data>
    </edge>
    <edge source="4" target="7" id="0">
      <data key="d8">2</data>
      <data key="d9">User interacts with the frontend to trigger deployment of workspace sandboxes via Service Catalog.</data>
      <data key="d10">0</data>
      <data key="d11">control</data>
    </edge>
    <edge source="5" target="6" id="0">
      <data key="d8">1</data>
      <data key="d9">API Gateway records user actions and stores/reads metadata in DynamoDB for traceability.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="7" target="9" id="0">
      <data key="d8">2</data>
      <data key="d9">Service Catalog provisions isolated RStudio server environments for statistics workloads.</data>
      <data key="d10">1</data>
      <data key="d11">control</data>
    </edge>
    <edge source="7" target="10" id="0">
      <data key="d8">2</data>
      <data key="d9">Service Catalog spins up custom encrypted SageMaker Notebooks for users.</data>
      <data key="d10">2</data>
      <data key="d11">control</data>
    </edge>
    <edge source="7" target="8" id="0">
      <data key="d8">2</data>
      <data key="d9">Service Catalog orchestrates lifecycle hooks using AWS Lambda functions.</data>
      <data key="d10">3</data>
      <data key="d11">control</data>
    </edge>
    <edge source="8" target="11" id="0">
      <data key="d8">3</data>
      <data key="d9">Lambda triggers translation of bulk clinical documentation using Amazon Translate SDK.</data>
      <data key="d10">0</data>
      <data key="d11">control</data>
    </edge>
    <edge source="8" target="12" id="0">
      <data key="d8">3</data>
      <data key="d9">Lambda invokes Comprehend Medical to detect PHI and de-identify raw files.</data>
      <data key="d10">1</data>
      <data key="d11">control</data>
    </edge>
    <data key="d0">Sanofi Darwin - Real World Evidence (RWE) Data Analytics Platform</data>
    <data key="d1">https://www.youtube.com/watch?v=2L0m28ZLmtE</data>
    <data key="d2">An enterprise analytical workspace platform built for Sanofi data scientists to securely analyze medical and Real World Evidence (RWE) data. It hosts static assets on S3 distributed via CloudFront, secures user authentication via AWS Cognito federated with Sanofi SSO, provisions reproducible analytical sandboxes (RStudio, SageMaker) via Service Catalog, and runs de-identification and translation pipelines using Lambda with Amazon Comprehend Medical and Amazon Translate.</data>
    <data key="d3">interactive, compute_intensive, other</data>
    <data key="d4">True</data>
  </graph>
</graphml>
