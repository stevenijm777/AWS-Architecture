  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Hospital / Clinicians</data>
      <data key="d6">UserConsumerHospital</data>
      <data key="d7">Upload raw medical images and request inference.</data>
    </node>
    <node id="1">
      <data key="d5">Pathologists</data>
      <data key="d6">UserCompanyDomainExpert</data>
      <data key="d7">Perform data labeling, annotations, and final model validation.</data>
    </node>
    <node id="2">
      <data key="d5">Raw Medical Images</data>
      <data key="d6">S3</data>
      <data key="d7">DATA_PEEK: Stores around 5TB of raw medical images per project.</data>
    </node>
    <node id="3">
      <data key="d5">Kubernetes labeling &amp; inference platform</data>
      <data key="d6">EKS</data>
      <data key="d7">Hosts labeling UI for pathologists and performs final model inference.</data>
    </node>
    <node id="4">
      <data key="d5">SageMaker Training</data>
      <data key="d6">SageMaker</data>
      <data key="d7">Orchestrates parallel training pipelines containerized in Docker.</data>
    </node>
    <node id="5">
      <data key="d5">FSx for Lustre</data>
      <data key="d6">FSX</data>
      <data key="d7">WORKLOAD_PEEK: High performance storage layer for accelerated training.</data>
    </node>
    <node id="6">
      <data key="d5">AWS IAM</data>
      <data key="d6">IAM</data>
      <data key="d7">Ensures data access control to comply with HDS certification.</data>
    </node>
    <node id="7">
      <data key="d5">Model &amp; Results Storage</data>
      <data key="d6">S3</data>
      <data key="d7">Stores exported models and pipeline execution results.</data>
    </node>
    <edge source="0" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">Hospitals upload raw medical images to S3.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="0" target="3" id="0">
      <data key="d8">1</data>
      <data key="d9">Hospitals query EKS for inferences using the validated model.</data>
      <data key="d10">9</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="3" id="0">
      <data key="d8">0</data>
      <data key="d9">Pathologists access the labeling application.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="3" id="1">
      <data key="d8">1</data>
      <data key="d9">Pathologist views results to validate or reject the model.</data>
      <data key="d10">7</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="3" id="0">
      <data key="d8">0</data>
      <data key="d9">Images are fetched from S3 for labeling.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="4" id="0">
      <data key="d8">1</data>
      <data key="d9">SageMaker streams training dataset from raw S3.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">Interactive labeling session returns results to pathologists.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="1" id="1">
      <data key="d8">1</data>
      <data key="d9">Sends model validation approval back to platform.</data>
      <data key="d10">8</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="4" id="0">
      <data key="d8">1</data>
      <data key="d9">Labeling platform triggers a new SageMaker training pipeline.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="0" id="0">
      <data key="d8">1</data>
      <data key="d9">Returns clinical analytics and prediction data back to the hospital.</data>
      <data key="d10">10</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="5" id="0">
      <data key="d8">1</data>
      <data key="d9">Uses FSx for fast I/O caching.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="6" id="0">
      <data key="d8">1</data>
      <data key="d9">Verifies data access and compliance policies.</data>
      <data key="d10">4</data>
      <data key="d11">meta</data>
    </edge>
    <edge source="4" target="7" id="0">
      <data key="d8">1</data>
      <data key="d9">Saves trained model and output metrics.</data>
      <data key="d10">5</data>
      <data key="d11">data</data>
    </edge>
    <edge source="7" target="3" id="0">
      <data key="d8">1</data>
      <data key="d9">Model results are loaded back to Kubernetes.</data>
      <data key="d10">6</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">Kinaï Medical Image Analysis and Annotation Pipeline</data>
    <data key="d1">https://www.youtube.com/watch?v=2XVgpMwY5iE</data>
    <data key="d2">Transitioned to SageMaker with FSx for Lustre, accelerating training by 30x and saving 30% on infrastructure costs. Compliant with HDS certification for sensitive health data.</data>
    <data key="d3">compute_intensive, interactive</data>
    <data key="d4">True</data>
