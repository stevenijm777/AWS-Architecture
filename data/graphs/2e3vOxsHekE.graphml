<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Fire Hydrant</data>
      <data key="d6">UserConsumerIOT</data>
      <data key="d7">Smart fire hydrant IoT devices that collect acoustic signals daily to detect pipe leaks.</data>
    </node>
    <node id="1">
      <data key="d5">API GATEWAY</data>
      <data key="d6">ApiGateway</data>
      <data key="d7">Handles secure ingestion and authentication of the acoustic signal data files.</data>
    </node>
    <node id="2">
      <data key="d5">S3</data>
      <data key="d6">S3</data>
      <data key="d7">Acts as the data lake, persisting the daily uploaded acoustic signal files.</data>
    </node>
    <node id="3">
      <data key="d5">ECS</data>
      <data key="d6">ECS</data>
      <data key="d7">Runs containerized, processor-intensive batch processes on a daily basis to analyze node-pair correlations.</data>
    </node>
    <node id="4">
      <data key="d5">SAGEMAKER</data>
      <data key="d6">SageMaker</data>
      <data key="d7">Classifies persistent correlations to assign a leak probability score using ML models.</data>
    </node>
    <node id="5">
      <data key="d5">ANALYST</data>
      <data key="d6">UserCompanyAnalyst</data>
      <data key="d7">Human analyst team who reviews and qualifies the leak predictions.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">Sensors send daily acoustic signal files to the ingestion endpoint.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">Ingested files are persisted securely in S3 storage.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="3" id="0">
      <data key="d8">0</data>
      <data key="d9">A daily batch process in ECS reads the acoustic data files from S3.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="4" id="0">
      <data key="d8">0</data>
      <data key="d9">ECS sends the correlated acoustic signal data to SageMaker for ML classification.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">Muller Water Products - Intelligent Water Platform</data>
    <data key="d1">https://www.youtube.com/watch?v=2e3vOxsHekE</data>
    <data key="d2">An intelligent water network monitoring system that ingests acoustic data from smart fire hydrants via API Gateway to S3. A batch processing architecture in ECS runs intensive acoustic algorithms, sending results to SageMaker to calculate leak probability scores.</data>
    <data key="d3">data_ingestion, compute_intensive, other</data>
    <data key="d4">True</data>
  </graph>
</graphml>
