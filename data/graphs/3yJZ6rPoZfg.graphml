<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">End User / Device</data>
      <data key="d6">UserConsumerWebMobile</data>
      <data key="d7">Uploads raw geospatial data from handheld devices or vehicle scanners.</data>
    </node>
    <node id="1">
      <data key="d5">S3 (Data Account)</data>
      <data key="d6">S3</data>
      <data key="d7">DATA_PEEK: Main store for licensed geospatial data.</data>
    </node>
    <node id="2">
      <data key="d5">EKS (Data Account)</data>
      <data key="d6">EKS</data>
      <data key="d7">WORKLOAD_PEEK: Exposes and serves the central geospatial data sets.</data>
    </node>
    <node id="3">
      <data key="d5">VPC Peering</data>
      <data key="d6">VPCPeering</data>
      <data key="d7">Connects the central data account to development, QA, and production accounts using AWS backbone.</data>
    </node>
    <node id="4">
      <data key="d5">EKS (User Pro Account)</data>
      <data key="d6">EKS</data>
      <data key="d7">WORKLOAD_PEEK: Handles user experience, metadata logic, and coordinates job processing.</data>
    </node>
    <node id="5">
      <data key="d5">S3 (User/Upload Bucket)</data>
      <data key="d6">S3</data>
      <data key="d7">DATA_PEEK: Multi-tenant bucket for raw user uploads and final processed outputs.</data>
    </node>
    <node id="6">
      <data key="d5">SQS Queue</data>
      <data key="d6">SQS</data>
      <data key="d7">Buffers upload notifications and processing job items.</data>
    </node>
    <node id="7">
      <data key="d5">ASG (EC2 Workers)</data>
      <data key="d6">AutoScaling</data>
      <data key="d7">WORKLOAD_PEEK: Dynamic pool of customized EC2 instances pulling container templates from ECR.</data>
    </node>
    <edge source="0" target="5" id="0">
      <data key="d8">1</data>
      <data key="d9">Direct file uploads via S3 pre-signed URLs.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">EKS queries the core geospatial S3 database.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="3" id="0">
      <data key="d8">0</data>
      <data key="d9">Transfers data securely over AWS backbone.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="4" id="0">
      <data key="d8">0</data>
      <data key="d9">Reaches the User/Processing account.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="6" id="0">
      <data key="d8">1</data>
      <data key="d9">EKS submits job back to queue for worker instances.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="6" id="0">
      <data key="d8">1</data>
      <data key="d9">S3 event notification triggers on successful upload.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="6" target="4" id="0">
      <data key="d8">1</data>
      <data key="d9">EKS microservice consumes S3 upload notification.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="6" target="7" id="0">
      <data key="d8">1</data>
      <data key="d9">EC2 processing instances poll jobs from SQS.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <edge source="7" target="5" id="0">
      <data key="d8">1</data>
      <data key="d9">Uploads the final processed output back to S3.</data>
      <data key="d10">5</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">Hexagon Digital Reality Processing Pipeline</data>
    <data key="d1">https://www.youtube.com/watch?v=3yJZ6rPoZfg</data>
    <data key="d2">Handles high-precision geospatial data securely and privately across multiple AWS environments via VPC Peering. Uses Auto Scaling Groups on EC2 to process compute-heavy, variable-workload geospatial datasets.</data>
    <data key="d3">data_ingestion, compute_intensive</data>
    <data key="d4">True</data>
  </graph>
</graphml>
