<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Geospatial Handheld/Car/Plane Devices &amp; Users</data>
      <data key="d6">UserConsumerWebMobile</data>
      <data key="d7">Professionals uploading and consuming geospatial map datasets.</data>
    </node>
    <node id="1">
      <data key="d5">EKS Web Platform UI</data>
      <data key="d6">EKS</data>
      <data key="d7">Serves frontend, maps, and generates pre-signed S3 upload URLs.</data>
    </node>
    <node id="2">
      <data key="d5">Central S3 Data Store</data>
      <data key="d6">S3</data>
      <data key="d7">DATA_PEEK: Central data account S3 bucket accessed via VPC Peering.</data>
    </node>
    <node id="3">
      <data key="d5">Upload Notifications Queue</data>
      <data key="d6">SQS</data>
      <data key="d7">Triggers upon successful S3 file uploads.</data>
    </node>
    <node id="4">
      <data key="d5">EKS Queue Listener Service</data>
      <data key="d6">EKS</data>
      <data key="d7">Listens to SQS and coordinates jobs across processing instances.</data>
    </node>
    <node id="5">
      <data key="d5">EC2 Processing Engine</data>
      <data key="d6">EC2</data>
      <data key="d7">WORKLOAD_PEEK: Auto-scaling group of EC2 instances optimized for custom CPU/memory pipelines.</data>
    </node>
    <node id="6">
      <data key="d5">Elastic Container Registry</data>
      <data key="d6">ECR</data>
      <data key="d7">Stores custom processing container images utilized by EC2.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">Requests pre-signed upload URL</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="0" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">Direct file upload to S3</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="0" id="0">
      <data key="d8">0</data>
      <data key="d9">Returns pre-signed URL</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="0" id="1">
      <data key="d8">1</data>
      <data key="d9">Displays rendering on map or triggers download</data>
      <data key="d10">6</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="3" id="0">
      <data key="d8">1</data>
      <data key="d9">S3 ObjectCreated event notification</data>
      <data key="d10">0</data>
      <data key="d11">meta</data>
    </edge>
    <edge source="2" target="1" id="0">
      <data key="d8">1</data>
      <data key="d9">Queries processed assets</data>
      <data key="d10">5</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="4" id="0">
      <data key="d8">1</data>
      <data key="d9">Pulls message from SQS queue</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="5" id="0">
      <data key="d8">1</data>
      <data key="d9">Dispatches job details to specialized EC2 task runner</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="2" id="0">
      <data key="d8">1</data>
      <data key="d9">Writes finalized processed spatial assets back</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <edge source="6" target="5" id="0">
      <data key="d8">1</data>
      <data key="d9">Pulls processing task container image</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">Hexagon Digital Reality Processing Pipeline</data>
    <data key="d1">https://www.youtube.com/watch?v=3yJZ6rPoZfg</data>
    <data key="d2">Handles high-precision geospatial data ingestion and auto-scaling processing pipelines. Leverages VPC peering with a single data account for security and minimal duplication.</data>
    <data key="d3">data_ingestion, compute_intensive, interactive</data>
    <data key="d4">True</data>
  </graph>
</graphml>
