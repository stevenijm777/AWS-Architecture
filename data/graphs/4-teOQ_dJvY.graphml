<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Locomotive Sensors</data>
      <data key="d6">UserConsumerIOT</data>
      <data key="d7">Generates 3 million samples per day of raw locomotive telemetry data.</data>
    </node>
    <node id="1">
      <data key="d5">Locomotive Ingest Lambda</data>
      <data key="d6">Lambda</data>
      <data key="d7">Receives raw locomotive telemetry in various formats and forwards it to Kinesis.</data>
    </node>
    <node id="2">
      <data key="d5">Locomotive Kinesis Stream</data>
      <data key="d6">Kinesis</data>
      <data key="d7">Ingests raw telemetry stream.</data>
    </node>
    <node id="3">
      <data key="d5">Kinesis Analytics</data>
      <data key="d6">Kinesis</data>
      <data key="d7">Filters and reduces incoming data to only retain critical records.</data>
    </node>
    <node id="4">
      <data key="d5">Normalized Kinesis Stream</data>
      <data key="d6">Kinesis</data>
      <data key="d7">Central hub containing harmonized, standardized train sensor data.</data>
    </node>
    <node id="5">
      <data key="d5">Track Sensors</data>
      <data key="d6">UserConsumerIOT</data>
      <data key="d7">Sensors positioned along the railway tracks generating physical measurement data.</data>
    </node>
    <node id="6">
      <data key="d5">Track Ingest Lambda</data>
      <data key="d6">Lambda</data>
      <data key="d7">Processes raw track sensor metrics and forwards them downstream.</data>
    </node>
    <node id="7">
      <data key="d5">Track Kinesis Stream</data>
      <data key="d6">Kinesis</data>
      <data key="d7">Ingests track-based sensor data stream.</data>
    </node>
    <node id="8">
      <data key="d5">Kinesis Analytics 2</data>
      <data key="d6">Kinesis</data>
      <data key="d7">Filters and drops non-critical track sensor records.</data>
    </node>
    <node id="9">
      <data key="d5">Database Manager Lambda</data>
      <data key="d6">Lambda</data>
      <data key="d7">Manages writes from the normalized stream into DynamoDB, as well as reads triggered from the API Gateway.</data>
    </node>
    <node id="10">
      <data key="d5">Train Digital Twin Database</data>
      <data key="d6">DynamoDB</data>
      <data key="d7">Stores structural and telemetry status for trains.</data>
    </node>
    <node id="11">
      <data key="d5">Digital Twin API</data>
      <data key="d6">ApiGateway</data>
      <data key="d7">Exposes endpoints for consumer algorithms to query train health status.</data>
    </node>
    <node id="12">
      <data key="d5">Inspection Algorithm</data>
      <data key="d6">UserCompanyInternalPlatform</data>
      <data key="d7">Decides if a train is in good health or requires manual inspection.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">Telemetry sent from locomotive.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">Ingested to raw stream.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="3" id="0">
      <data key="d8">0</data>
      <data key="d9">Data processed by analytics stream.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="4" id="0">
      <data key="d8">0</data>
      <data key="d9">Filtered telemetry merged to main stream.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="9" id="0">
      <data key="d8">2</data>
      <data key="d9">Pulls unified events from main stream.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="6" id="0">
      <data key="d8">1</data>
      <data key="d9">Track telemetry sent.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="6" target="7" id="0">
      <data key="d8">1</data>
      <data key="d9">Ingested to track raw stream.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="7" target="8" id="0">
      <data key="d8">1</data>
      <data key="d9">Filtered by track analytics.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="8" target="4" id="0">
      <data key="d8">1</data>
      <data key="d9">Track analytics output merged to main stream.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="9" target="10" id="0">
      <data key="d8">2</data>
      <data key="d9">Writes formatted status data to DynamoDB.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="9" target="10" id="1">
      <data key="d8">3</data>
      <data key="d9">Queries train record from DynamoDB.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="9" target="11" id="0">
      <data key="d8">3</data>
      <data key="d9">Forwards payload to API gateway.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <edge source="10" target="9" id="0">
      <data key="d8">3</data>
      <data key="d9">Returns DB record.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="11" target="9" id="0">
      <data key="d8">3</data>
      <data key="d9">Invokes DB manager Lambda to read status.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="11" target="12" id="0">
      <data key="d8">3</data>
      <data key="d9">Returns digital twin output back to inspection algorithm.</data>
      <data key="d10">5</data>
      <data key="d11">data</data>
    </edge>
    <edge source="12" target="11" id="0">
      <data key="d8">3</data>
      <data key="d9">Requests train status report.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">SBB Cargo Train Inspection Digital Twin</data>
    <data key="d1">https://www.youtube.com/watch?v=4-teOQ_dJvY</data>
    <data key="d2">Automates train inspections using AWS-native serverless components to ingest, process, and query sensor data, reducing manual inspection time from 30 minutes to a few minutes.</data>
    <data key="d3">data_ingestion, compute_intensive</data>
    <data key="d4">True</data>
  </graph>
</graphml>
