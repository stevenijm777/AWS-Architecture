  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Data Engineers &amp; Scientists</data>
      <data key="d6">UserCompanyDeveloper</data>
      <data key="d7">Ingest ad-hoc genomic sequences containing hundreds of billions of ATCs and Gs.</data>
    </node>
    <node id="1">
      <data key="d5">Ad-hoc VMs</data>
      <data key="d6">EC2</data>
      <data key="d7">WORKLOAD_PEEK: Spin up sporadically to handle initial data ingestion.</data>
    </node>
    <node id="2">
      <data key="d5">Amazon FSx</data>
      <data key="d6">FSX</data>
      <data key="d7">DATA_PEEK: Stores raw genomic samples, mounted directly onto EKS nodes.</data>
    </node>
    <node id="3">
      <data key="d5">Amazon ECR</data>
      <data key="d6">ECR</data>
      <data key="d7">Stores frozen, version-controlled pipeline containers for reproducible science.</data>
    </node>
    <node id="4">
      <data key="d5">Amazon EKS</data>
      <data key="d6">EKS</data>
      <data key="d7">WORKLOAD_PEEK: Scales dynamically from 0 to 100+ instances using Auto Scaling to curate genomic data into matrices.</data>
    </node>
    <node id="5">
      <data key="d5">S3 Data Lake</data>
      <data key="d6">S3</data>
      <data key="d7">DATA_PEEK: Persists curated gene matrices for downstream target discovery.</data>
    </node>
    <node id="6">
      <data key="d5">Downstream Biologists &amp; Analysts</data>
      <data key="d6">UserCompanyAnalyst</data>
      <data key="d7">Perform statistical analysis on gene targets of interest.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">Upload genomic datasets</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="2" id="0">
      <data key="d8">0</data>
