<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Data Engineers &amp; Scientists</data>
      <data key="d6">UserCompanyDeveloper</data>
      <data key="d7">Ingest hundreds to thousands of genomic samples.</data>
    </node>
    <node id="1">
      <data key="d5">Ad-hoc VMs</data>
      <data key="d6">EC2</data>
      <data key="d7">WORKLOAD_PEEK: Ad-hoc instances used to ingest raw genomics data.</data>
    </node>
    <node id="2">
      <data key="d5">FSx Storage</data>
      <data key="d6">FSX</data>
      <data key="d7">DATA_PEEK: Stores raw ATCG genomics sequence data, mounted to processing nodes.</data>
    </node>
    <node id="3">
      <data key="d5">Elastic Container Registry</data>
      <data key="d6">ECR</data>
      <data key="d7">Stores frozen, versioned container images for pipeline reproducibility.</data>
    </node>
    <node id="4">
      <data key="d5">Elastic Kubernetes Service</data>
      <data key="d6">EKS</data>
      <data key="d7">WORKLOAD_PEEK: Auto-scales from 0 to hundreds of nodes to process and curate data.</data>
    </node>
    <node id="5">
      <data key="d5">Data Lake</data>
      <data key="d6">S3</data>
      <data key="d7">DATA_PEEK: Stores processed and curated genomic matrices.</data>
    </node>
    <node id="6">
      <data key="d5">Biologists &amp; Data Scientists</data>
      <data key="d6">UserCompanyAnalyst</data>
      <data key="d7">Perform statistical analyses and target gene discovery.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">Ingest raw genomics data.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">Write raw data to FSx.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="4" id="0">
      <data key="d8">1</data>
      <data key="d9">Mount FSx storage to access raw data.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="4" id="0">
      <data key="d8">1</data>
      <data key="d9">Pull versioned container images.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="5" id="0">
      <data key="d8">1</data>
      <data key="d9">Persist curated matrices to Data Lake.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="6" id="0">
      <data key="d8">2</data>
      <data key="d9">Query curated data for analysis.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">Reproducible Genomics Data Curation Pipeline</data>
    <data key="d1">https://www.youtube.com/watch?v=53sUjFv9ByI</data>
    <data key="d2">Uses EKS and ECR to achieve reproducible science by versioning analytical pipelines. Leverages FSx for high-throughput genomic data curation, scaling from 0 to hundreds of nodes dynamically.</data>
    <data key="d3">data_ingestion, compute_intensive</data>
    <data key="d4">True</data>
  </graph>
</graphml>
