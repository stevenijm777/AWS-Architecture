<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Content Originator</data>
      <data key="d6">UserCompanyAPI</data>
      <data key="d7">Advertisers, brands, and publishing houses uploading ad content via UI, API, or Java agent.</data>
    </node>
    <node id="1">
      <data key="d5">Web Application Firewall</data>
      <data key="d6">WAF</data>
      <data key="d7">Monitors and filters promiscuous traffic entering the ELB.</data>
    </node>
    <node id="2">
      <data key="d5">Elastic Load Balancer</data>
      <data key="d6">ELB</data>
      <data key="d7">Fronts the application tier.</data>
    </node>
    <node id="3">
      <data key="d5">App Tier</data>
      <data key="d6">EC2</data>
      <data key="d7">Primary user interface, APIs, and upload handlers.</data>
    </node>
    <node id="4">
      <data key="d5">Ad Cloud S3 Storage</data>
      <data key="d6">S3</data>
      <data key="d7">DATA_PEEK: Stores master video files and multi-format transcoded versions.</data>
    </node>
    <node id="5">
      <data key="d5">Asynchronous Priority Queues</data>
      <data key="d6">SQS</data>
      <data key="d7">Hundreds of prioritized queues managing asynchronous processing tasks.</data>
    </node>
    <node id="6">
      <data key="d5">Batch &amp; Transcoding Fleet</data>
      <data key="d6">EC2</data>
      <data key="d7">WORKLOAD_PEEK: Custom transcoding and quality control (QC) applications running on EC2.</data>
    </node>
    <node id="7">
      <data key="d5">CloudFront CDN</data>
      <data key="d6">CloudFront</data>
      <data key="d7">Delivers digital video advertising.</data>
    </node>
    <node id="8">
      <data key="d5">Media Outlet</data>
      <data key="d6">UserCompanyAgent</data>
      <data key="d7">Destinations pulling broadcast-ready ad versions.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">Content originator initiates request.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="0" target="4" id="0">
      <data key="d8">0</data>
      <data key="d9">Direct master file upload to S3.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">Inspected traffic reaches ELB.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="3" id="0">
      <data key="d8">0</data>
      <data key="d9">ELB distributes traffic to App Tier.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="0" id="0">
      <data key="d8">0</data>
      <data key="d9">App Tier provides direct upload authorization.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="5" id="0">
      <data key="d8">0</data>
      <data key="d9">App Tier triggers transcode job in SQS priority queue.</data>
      <data key="d10">5</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="8" id="0">
      <data key="d8">1</data>
      <data key="d9">Returns file locations.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="8" id="0">
      <data key="d8">1</data>
      <data key="d9">Media outlet downloads TV commercial directly from S3.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="7" id="0">
      <data key="d8">1</data>
      <data key="d9">CloudFront caches assets from S3 origin.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <edge source="6" target="5" id="0">
      <data key="d8">0</data>
      <data key="d9">Batch/transcoding fleet polls queues.</data>
      <data key="d10">6</data>
      <data key="d11">meta</data>
    </edge>
    <edge source="6" target="4" id="0">
      <data key="d8">0</data>
      <data key="d9">Fleet downloads master, performs transcoding/QC, and uploads new versions.</data>
      <data key="d10">7</data>
      <data key="d11">data</data>
    </edge>
    <edge source="7" target="8" id="0">
      <data key="d8">1</data>
      <data key="d9">Media outlet pulls digital video ads through CloudFront.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="8" target="3" id="0">
      <data key="d8">1</data>
      <data key="d9">Media outlet checks manifest via API/UI.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">Extreme Reach Adbridge Platform</data>
    <data key="d1">https://www.youtube.com/watch?v=5EmA67lSJEs</data>
    <data key="d2">Adbridge platform distributes 80% of US ad traffic. Utilizes prioritized SQS queues to orchestrate asynchronous transcoding and quality control on customized EC2 instances before delivering via S3 and CloudFront.</data>
    <data key="d3">data_ingestion, compute_intensive</data>
    <data key="d4">True</data>
  </graph>
</graphml>
