<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Milling Machines</data>
      <data key="d6">UserConsumerIOT</data>
      <data key="d7">DATA_PEEK: Approximately 40 milling machines producing unique dental restorations. WORKLOAD_PEEK: Generates telemetry data such as OEE and operational states.</data>
    </node>
    <node id="1">
      <data key="d5">App Machines</data>
      <data key="d6">UserCompanyInternalPlatform</data>
      <data key="d7">DATA_PEEK: Approximately 20 machines running local applications generating job data.</data>
    </node>
    <node id="2">
      <data key="d5">IoT Core Gateway</data>
      <data key="d6">IoTCore</data>
      <data key="d7">WORKLOAD_PEEK: Handles real-time messaging of around 1 million messages per day from machines and apps.</data>
    </node>
    <node id="3">
      <data key="d5">Job Queue</data>
      <data key="d6">SQS</data>
      <data key="d7">Buffers job-specific data from apps and IoT Core.</data>
    </node>
    <node id="4">
      <data key="d5">OEE Queue</data>
      <data key="d6">SQS</data>
      <data key="d7">Buffers machine telemetry and overall equipment effectiveness data.</data>
    </node>
    <node id="5">
      <data key="d5">Job Database</data>
      <data key="d6">RDS</data>
      <data key="d7">Stores transactional information about active dental restoration jobs.</data>
    </node>
    <node id="6">
      <data key="d5">OEE Database</data>
      <data key="d6">RDS</data>
      <data key="d7">Stores raw telemetry and metrics of milling machine operations.</data>
    </node>
    <node id="7">
      <data key="d5">Dentists</data>
      <data key="d6">UserCompanyDomainExpert</data>
      <data key="d7">Dentists providing restoration evaluations.</data>
    </node>
    <node id="8">
      <data key="d5">Evals S3 Bucket</data>
      <data key="d6">S3</data>
      <data key="d7">Stores evaluation documents and feedback from dentists.</data>
    </node>
    <node id="9">
      <data key="d5">Statistical Service</data>
      <data key="d6">ECS</data>
      <data key="d7">WORKLOAD_PEEK: The brain of the architecture. Calculates aggregate statistics about machines, apps, and personnel against predefined thresholds.</data>
    </node>
    <node id="10">
      <data key="d5">Statistics Database</data>
      <data key="d6">RDS</data>
      <data key="d7">Aggregated stats for trends, thresholds, and dashboard querying.</data>
    </node>
    <node id="11">
      <data key="d5">Ticketing Service</data>
      <data key="d6">ECS</data>
      <data key="d7">Interacts with the Statistical Service to manage machine recalibration commands and external support escalations.</data>
    </node>
    <node id="12">
      <data key="d5">Ticketing System</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">External third-party software used to create operator action tickets.</data>
    </node>
    <node id="13">
      <data key="d5">Email Notification Service</data>
      <data key="d6">SES</data>
      <data key="d7">Generates threshold-breach alert emails to managers.</data>
    </node>
    <node id="14">
      <data key="d5">Supervisors &amp; Managers</data>
      <data key="d6">UserCompanyAgent</data>
      <data key="d7">Receives email alerts regarding poorly performing machines.</data>
    </node>
    <node id="15">
      <data key="d5">Microsoft Teams Webhook</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Sends real-time alerts directly into support channels.</data>
    </node>
    <node id="16">
      <data key="d5">Operators &amp; Support</data>
      <data key="d6">UserCompanyAgent</data>
      <data key="d7">Monitors the MS Teams support channel to troubleshoot offline machines.</data>
    </node>
    <node id="17">
      <data key="d5">Proprietary Dashboard</data>
      <data key="d6">ECS</data>
      <data key="d7">Custom-built business intelligence dashboard for non-technical executives.</data>
    </node>
    <node id="18">
      <data key="d5">Executives</data>
      <data key="d6">UserCompanyAnalyst</data>
      <data key="d7">Interrogates manufacturing line performance and analytics.</data>
    </node>
    <edge source="0" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">Sends telemetry and job data.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">Sends job transactional data.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="3" id="0">
      <data key="d8">0</data>
      <data key="d9">Routes job-specific messages to Job Queue.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="4" id="0">
      <data key="d8">0</data>
      <data key="d9">Routes machine OEE data to OEE Queue.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="0" id="0">
      <data key="d8">2</data>
      <data key="d9">Commands machine to run self-calibration block.</data>
      <data key="d10">6</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="5" id="0">
      <data key="d8">0</data>
      <data key="d9">Persists job records.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="6" id="0">
      <data key="d8">0</data>
      <data key="d9">Persists OEE metrics.</data>
      <data key="d10">5</data>
      <data key="d11">data</data>
    </edge>
    <edge source="7" target="8" id="0">
      <data key="d8">1</data>
      <data key="d9">Dentists upload evaluations.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="9" target="8" id="0">
      <data key="d8">2</data>
      <data key="d9">Reads evaluation data.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="9" target="5" id="0">
      <data key="d8">2</data>
      <data key="d9">Fetches job stats.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="9" target="6" id="0">
      <data key="d8">2</data>
      <data key="d9">Fetches machine stats.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="9" target="10" id="0">
      <data key="d8">2</data>
      <data key="d9">Saves aggregated statistical data.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="9" target="11" id="0">
      <data key="d8">2</data>
      <data key="d9">Triggers ticket/calibration workflow.</data>
      <data key="d10">4</data>
      <data key="d11">meta</data>
    </edge>
    <edge source="9" target="13" id="0">
      <data key="d8">3</data>
      <data key="d9">Triggers manager alerts.</data>
      <data key="d10">0</data>
      <data key="d11">meta</data>
    </edge>
    <edge source="9" target="15" id="0">
      <data key="d8">3</data>
      <data key="d9">Posts notification hook to MS Teams.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="10" target="17" id="0">
      <data key="d8">4</data>
      <data key="d9">Returns statistics payload.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="11" target="2" id="0">
      <data key="d8">2</data>
      <data key="d9">Sends calibration request message.</data>
      <data key="d10">5</data>
      <data key="d11">data</data>
    </edge>
    <edge source="11" target="12" id="0">
      <data key="d8">2</data>
      <data key="d9">Fails over to manual support ticketing if calibration fails.</data>
      <data key="d10">7</data>
      <data key="d11">data</data>
    </edge>
    <edge source="13" target="14" id="0">
      <data key="d8">3</data>
      <data key="d9">Sends notification email.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="15" target="16" id="0">
      <data key="d8">3</data>
      <data key="d9">Alerts operators to machine downtime.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="17" target="10" id="0">
      <data key="d8">4</data>
      <data key="d9">Queries historical statistics.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="17" target="18" id="0">
      <data key="d8">4</data>
      <data key="d9">Renders dashboard panels.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
