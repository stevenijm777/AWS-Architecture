<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d12" for="edge" attr.name="id" attr.type="string" />
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">IBM Netezza</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">On-premises source database.</data>
    </node>
    <node id="1">
      <data key="d5">AWS Snowball</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Used for initial 20 TB database seeding.</data>
    </node>
    <node id="2">
      <data key="d5">AWS Storage Gateway</data>
      <data key="d6">StorageGateway</data>
      <data key="d7">NFS volumes for daily 100 GB delta increments.</data>
    </node>
    <node id="3">
      <data key="d5">AWS Direct Connect</data>
      <data key="d6">DirectConnect</data>
      <data key="d7">2x 10G link with SSL encryption.</data>
    </node>
    <node id="4">
      <data key="d5">S3 Landing Zone</data>
      <data key="d6">S3</data>
      <data key="d7">Landing zone bucket with 2-day retention.</data>
    </node>
    <node id="5">
      <data key="d5">Amazon RDS PostgreSQL</data>
      <data key="d6">RDS</data>
      <data key="d7">Stores ELT metadata and transformation scripts.</data>
    </node>
    <node id="6">
      <data key="d5">EC2 Processing Nodes</data>
      <data key="d6">EC2</data>
      <data key="d7">Executes quality cleansing and ELT transformations.</data>
    </node>
    <node id="7">
      <data key="d5">S3 Transformation Zone</data>
      <data key="d6">S3</data>
      <data key="d7">Stores processed data. 1-day retention.</data>
    </node>
    <node id="8">
      <data key="d5">Amazon Redshift</data>
      <data key="d6">RedShift</data>
      <data key="d7">Core data warehouse supporting Redshift Spectrum.</data>
    </node>
    <node id="9">
      <data key="d5">S3 Publish Zone</data>
      <data key="d6">S3</data>
      <data key="d7">Stores finalized dashboard data. Retention: 1 year, 1 month.</data>
    </node>
    <node id="10">
      <data key="d5">S3 Glacier</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Long-term archive for compliance.</data>
    </node>
    <node id="11">
      <data key="d5">Business Analysts</data>
      <data key="d6">UserCompanyAnalyst</data>
      <data key="d7">Accesses reports and dashboards.</data>
    </node>
    <edge source="0" target="1">
      <data key="d8">0</data>
      <data key="d9">Initial seeding extract.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="0" target="2">
      <data key="d8">1</data>
      <data key="d9">Daily delta extracted.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="1" target="4">
      <data key="d8">0</data>
      <data key="d9">Seeded data loaded into landing bucket.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="2" target="3">
      <data key="d8">1</data>
