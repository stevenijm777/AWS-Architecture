    <edge source="6" target="5">
      <data key="d8">1</data>
      <data key="d9">EC2 pulls transformation scripts.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="6" target="4">
      <data key="d8">1</data>
      <data key="d9">EC2 reads raw landing data.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="6" target="7">
      <data key="d8">1</data>
      <data key="d9">EC2 writes cleansed data to transformation zone.</data>
      <data key="d10">5</data>
