<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Car</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Vehicles collecting sensor and visual inspection data as they drive.</data>
    </node>
    <node id="1">
      <data key="d5">REST API</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Ingestion REST API hosted in a separate AWS account to receive vehicle payloads.</data>
    </node>
    <node id="2">
      <data key="d5">S3 (Ingest)</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">S3 bucket storing raw vehicle ingestion data.</data>
    </node>
    <node id="3">
      <data key="d5">SQS</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Queue used to trigger processing workers based on incoming raw S3 files.</data>
    </node>
    <node id="4">
      <data key="d5">EKS (Process)</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Auto-scaling EKS cluster executing workers that preprocess and format incoming telemetry data.</data>
    </node>
    <node id="5">
      <data key="d5">Step Functions</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Orchestrates AWS Lambda functions running algorithms like potential construction zone extraction.</data>
    </node>
    <node id="6">
      <data key="d5">S3 (Store)</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Stores preprocessed and formatted intermediate datasets.</data>
    </node>
    <node id="7">
      <data key="d5">Elasticsearch</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Document database providing self-indexing for cost-effective event query capabilities.</data>
    </node>
    <node id="8">
      <data key="d5">Cockroach DB</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Relational database used for frequent and high-volume data updates, deployed inside EKS.</data>
    </node>
    <node id="9">
      <data key="d5">API Gateway</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Exposes secure REST API endpoints to city planners and operators.</data>
    </node>
    <node id="10">
      <data key="d5">EKS (Consume)</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">EKS cluster hosting application servers to serve processed insights to the web application and APIs.</data>
    </node>
    <node id="11">
      <data key="d5">Webapp</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Front-end web dashboard visualizing live event maps.</data>
    </node>
    <node id="12">
      <data key="d5">Planners &amp; Operators</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Enterprise customers such as city and road planners who consume analytical reports.</data>
    </node>
    <node id="13">
      <data key="d5">Users</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">End-users utilizing the web application to visualize mapped events.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">Vehicles upload collected sensor and visual inspection data to the ingestion REST API.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">Ingestion REST API stores data payloads to S3.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="3" id="0">
      <data key="d8">0</data>
      <data key="d9">Triggers message creation in SQS to notify processors of new items.</data>
      <data key="d10">2</data>
      <data key="d11">control</data>
    </edge>
    <edge source="3" target="4" id="0">
      <data key="d8">0</data>
      <data key="d9">EKS workers pull jobs/tasks from the SQS queue.</data>
      <data key="d10">3</data>
      <data key="d11">control</data>
    </edge>
    <edge source="4" target="5" id="0">
      <data key="d8">0</data>
      <data key="d9">EKS workers invoke Step Functions to execute parallel algorithm execution and workflow orchestration.</data>
      <data key="d10">4</data>
      <data key="d11">control</data>
    </edge>
    <edge source="4" target="6" id="0">
      <data key="d8">0</data>
      <data key="d9">EKS workers write formatted data to the S3 store.</data>
      <data key="d10">5</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="7" id="0">
      <data key="d8">0</data>
      <data key="d9">EKS workers write insights and event documents into Elasticsearch.</data>
      <data key="d10">7</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="8" id="0">
      <data key="d8">0</data>
      <data key="d9">EKS workers execute frequent table updates in CockroachDB.</data>
      <data key="d10">8</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="6" id="0">
      <data key="d8">0</data>
      <data key="d9">Algorithms run via Step Functions write their output results to S3.</data>
      <data key="d10">6</data>
      <data key="d11">data</data>
    </edge>
    <edge source="6" target="9" id="0">
      <data key="d8">1</data>
      <data key="d9">S3 datasets are mapped or made accessible to the API Gateway.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="7" target="10" id="0">
      <data key="d8">1</data>
      <data key="d9">EKS cluster reads indexed event details from Elasticsearch.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="8" target="10" id="0">
      <data key="d8">1</data>
      <data key="d9">EKS cluster reads operational data updates from CockroachDB.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="9" target="12" id="0">
      <data key="d8">1</data>
      <data key="d9">City planners consume structured analytics and reports directly via the API.</data>
      <data key="d10">4</data>
      <data key="d11">control</data>
    </edge>
    <edge source="10" target="9" id="0">
      <data key="d8">1</data>
      <data key="d9">EKS acts as the upstream backend serving requests for API Gateway.</data>
      <data key="d10">3</data>
      <data key="d11">control</data>
    </edge>
    <edge source="10" target="11" id="0">
      <data key="d8">1</data>
      <data key="d9">EKS cluster hosts and serves API payloads rendering on the web app.</data>
      <data key="d10">5</data>
      <data key="d11">control</data>
    </edge>
    <edge source="11" target="13" id="0">
      <data key="d8">1</data>
      <data key="d9">End-users access the front-end dashboard to visualize live event maps.</data>
      <data key="d10">6</data>
      <data key="d11">control</data>
    </edge>
    <data key="d0">Mobileye Dynamic RAM Cloud Architecture</data>
    <data key="d1">https://www.youtube.com/watch?v=5hjkSczrke4</data>
    <data key="d2">Dynamic RAM is an evolutionary platform at Mobileye that processes vehicle sensor and visual inspection data to provide city planners and operators with mobility intelligence and live event data. It leverages an auto-scaling EKS processing layer, Step Functions for serverless algorithmic workflows, and a multi-tiered storage layer consisting of Amazon S3, Elasticsearch, and CockroachDB.</data>
    <data key="d3">data_ingestion, interactive, compute_intensive</data>
    <data key="d4">True</data>
  </graph>
</graphml>
