<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Customer Apps &amp; Data Sources</data>
      <data key="d6">UserCompanyAPI</data>
      <data key="d7">Generates structured or unstructured logs and metrics.</data>
    </node>
    <node id="1">
      <data key="d5">Ingest Lambda</data>
      <data key="d6">Lambda</data>
      <data key="d7">Processes and forwards events directly into Splunk.</data>
    </node>
    <node id="2">
      <data key="d5">Kinesis Data Firehose</data>
      <data key="d6">Firehose</data>
      <data key="d7">Streams data directly into Splunk indexers.</data>
    </node>
    <node id="3">
      <data key="d5">Standard HEC ELB</data>
      <data key="d6">ELB</data>
      <data key="d7">Balances incoming HEC data stream traffic.</data>
    </node>
    <node id="4">
      <data key="d5">Sticky ELB for Firehose</data>
      <data key="d6">ELB</data>
      <data key="d7">Handles sticky session routing required by Firehose.</data>
    </node>
    <node id="5">
      <data key="d5">Splunk Indexers (ASG)</data>
      <data key="d6">EC2</data>
      <data key="d7">Runs Splunk cache tier. Evicts cold data dynamically.</data>
    </node>
    <node id="6">
      <data key="d5">Splunk Smart Store</data>
      <data key="d6">S3</data>
      <data key="d7">Maintains data replica storage for durability.</data>
    </node>
    <node id="7">
      <data key="d5">Customer S3 Bucket</data>
      <data key="d6">S3</data>
      <data key="d7">Enables dynamic data self-storage export.</data>
    </node>
    <node id="8">
      <data key="d5">Glacier Archive</data>
      <data key="d6">S3</data>
      <data key="d7">Retains long-term archival data.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">Sends data serverlessly.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="0" target="2" id="0">
      <data key="d8">1</data>
      <data key="d9">Streams data via Firehose.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="3" id="0">
      <data key="d8">0</data>
      <data key="d9">Forwards to standard HEC load balancer.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="0" id="0">
      <data key="d8">0</data>
      <data key="d9">Acknowledge receipt to source.</data>
      <data key="d10">6</data>
      <data key="d11">meta</data>
    </edge>
    <edge source="2" target="4" id="0">
      <data key="d8">1</data>
      <data key="d9">Connects to sticky load balancer.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="0" id="0">
      <data key="d8">1</data>
      <data key="d9">Confirms ingestion batch.</data>
      <data key="d10">5</data>
      <data key="d11">meta</data>
    </edge>
    <edge source="3" target="5" id="0">
      <data key="d8">0</data>
      <data key="d9">Routes to Splunk Indexers.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">Acks transaction.</data>
      <data key="d10">5</data>
      <data key="d11">meta</data>
    </edge>
    <edge source="4" target="5" id="0">
      <data key="d8">1</data>
      <data key="d9">Distributes stream safely to EC2 indexers.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="2" id="0">
      <data key="d8">1</data>
      <data key="d9">Acknowledge response.</data>
      <data key="d10">4</data>
      <data key="d11">meta</data>
    </edge>
    <edge source="5" target="6" id="0">
      <data key="d8">0</data>
      <data key="d9">Offloads cold data to Smart Store S3.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="3" id="0">
      <data key="d8">0</data>
      <data key="d9">Acks data write.</data>
      <data key="d10">4</data>
      <data key="d11">meta</data>
    </edge>
    <edge source="5" target="4" id="0">
      <data key="d8">1</data>
      <data key="d9">Acks data write.</data>
      <data key="d10">3</data>
      <data key="d11">meta</data>
    </edge>
    <edge source="5" target="7" id="0">
      <data key="d8">2</data>
      <data key="d9">Exports data to customer S3 bucket.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="8" id="0">
      <data key="d8">2</data>
      <data key="d9">Archives old logs.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="8" target="5" id="0">
      <data key="d8">2</data>
      <data key="d9">Rehydrates data back to indexer cache tier via UI.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">Splunk Cloud SmartStore Architecture</data>
    <data key="d1">https://www.youtube.com/watch?v=5vR5aN_xdI0</data>
    <data key="d2">Decouples compute from storage for cost savings and high resilience. Features dynamic data self-storage and Glacier rehydration.</data>
    <data key="d3">data_ingestion, interactive</data>
    <data key="d4">True</data>
  </graph>
</graphml>
