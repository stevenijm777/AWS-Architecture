<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d12" for="edge" attr.name="id" attr.type="string" />
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Customer Data</data>
      <data key="d6">UserCompanyDataStream</data>
      <data key="d7">Source data from customer applications and services.</data>
    </node>
    <node id="1">
      <data key="d5">Ingestion Lambda</data>
      <data key="d6">Lambda</data>
      <data key="d7">Serverless ingestion mechanism sending data directly to Splunk.</data>
    </node>
    <node id="2">
      <data key="d5">Kinesis Data Firehose</data>
      <data key="d6">Firehose</data>
      <data key="d7">Streams data from AWS sources to Splunk with sticky load balancing requirements.</data>
    </node>
    <node id="3">
      <data key="d5">HEC Load Balancer</data>
      <data key="d6">ELB</data>
      <data key="d7">Handles standard HTTP Event Collector (HEC) traffic and Lambda ingestion.</data>
    </node>
    <node id="4">
      <data key="d5">Sticky Load Balancer</data>
      <data key="d6">ELB</data>
      <data key="d7">Handles Firehose traffic which requires sticky sessions.</data>
    </node>
    <node id="5">
      <data key="d5">Splunk Indexers (ASG)</data>
      <data key="d6">EC2</data>
      <data key="d7">Compute layer with fast caching tiers for quick dashboard and search performance.</data>
    </node>
    <node id="6">
      <data key="d5">Splunk S3 Bucket</data>
      <data key="d6">S3</data>
      <data key="d7">SmartStore cold storage tier for data replication and durability.</data>
    </node>
    <node id="7">
      <data key="d5">Splunk Glacier Bucket</data>
      <data key="d6">S3</data>
      <data key="d7">Archival storage tier, allows self-service rehydration via UI.</data>
    </node>
    <node id="8">
      <data key="d5">Customer S3 Bucket</data>
      <data key="d6">S3</data>
      <data key="d7">Destination for dynamic data self-storage exports.</data>
    </node>
    <edge source="0" target="3">
      <data key="d8">0</data>
      <data key="d9">Direct HEC data path.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="0" target="1">
      <data key="d8">1</data>
      <data key="d9">Serverless ingestion trigger.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="0" target="2">
      <data key="d8">2</data>
      <data key="d9">Streaming data ingestion.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="1" target="3">
      <data key="d8">1</data>
      <data key="d9">Lambda forwards data to HEC load balancer.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="2" target="4">
      <data key="d8">2</data>
      <data key="d9">Firehose routes through dedicated sticky load balancer.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="3" target="5">
      <data key="d8">0</data>
      <data key="d9">Routes standard traffic to indexers.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="4" target="5">
      <data key="d8">2</data>
      <data key="d9">Routes sticky stream traffic to indexers.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="5" target="6">
      <data key="d8">3</data>
      <data key="d9">Evicts cold data from EC2 cache to S3.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="5" target="7">
      <data key="d8">3</data>
      <data key="d9">Archives compliance and long-term data to Glacier.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="6" target="8">
      <data key="d8">4</data>
      <data key="d9">Dynamic data self-storage export to customer's account.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <data key="d0">Splunk: Data at Scale by Decoupling Compute and Storage LIVE</data>
    <data key="d1">https://www.youtube.com/watch?v=5vR5aN_xdI0</data>
    <data key="d2">Separates compute and storage to optimize performance and cost using EC2 caching, S3, and Glacier, while enabling direct data export to customer-owned S3 buckets.</data>
    <data key="d3">data_ingestion, compute_intensive</data>
    <data key="d4">True</data>
  </graph>
</graphml>
