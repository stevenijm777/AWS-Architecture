  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Internal Stakeholders</data>
      <data key="d6">UserCompanyDeveloper</data>
      <data key="d7">Developers and internal teams requiring AWS accounts and infrastructure.</data>
    </node>
    <node id="1">
      <data key="d5">ITSM Tool</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">WORKLOAD_PEEK: Self-service portal where users trigger automated account generation workflow.</data>
    </node>
    <node id="2">
      <data key="d5">AWS Control Tower</data>
      <data key="d6">ControlTower</data>
      <data key="d7">Runs in the root account; provisions baseline-compliant AWS accounts via Account Factory.</data>
    </node>
    <node id="3">
      <data key="d5">AWS Service Catalog</data>
      <data key="d6">ServiceCatalog</data>
      <data key="d7">Used within vended accounts to deploy standardized VPC architectures and workloads.</data>
    </node>
    <node id="4">
      <data key="d5">STNO Orchestrator</data>
      <data key="d6">Lambda</data>
      <data key="d7">AWS Serverless Transit Network Orchestrator. Triggered on VPC creation to parse tags and configure networking.</data>
    </node>
    <node id="5">
      <data key="d5">AWS Transit Gateway</data>
      <data key="d6">TransitGateway</data>
      <data key="d7">Central transit hub in core services account facilitating network interconnectivity.</data>
    </node>
    <node id="6">
      <data key="d5">EC2 Web Apps</data>
      <data key="d6">EC2</data>
      <data key="d7">Worker instances provisioned via Service Catalog.</data>
    </node>
    <node id="7">
      <data key="d5">EKS Web Apps</data>
      <data key="d6">EKS</data>
      <data key="d7">Containerized web applications running on Kubernetes.</data>
    </node>
    <node id="8">
      <data key="d5">RDS Database</data>
      <data key="d6">RDS</data>
      <data key="d7">Database infrastructure for deployed applications.</data>
    </node>
