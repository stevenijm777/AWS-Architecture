<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Devices</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Client devices (mobile and PC) requesting and viewing personalized video content.</data>
    </node>
    <node id="1">
      <data key="d5">API Gateway</data>
      <data key="d6">ApiGateway</data>
      <data key="d7">Entry point for incoming rendering requests; controls load using API keys and usage plans.</data>
    </node>
    <node id="2">
      <data key="d5">Lambda (Frontend)</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Performs validations on rendering requests, pushes jobs to SQS, and returns playlist file links back to client devices.</data>
    </node>
    <node id="3">
      <data key="d5">SQS (Request)</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Queue storing rendering instructions that rendering engines pull from when they have capacity.</data>
    </node>
    <node id="4">
      <data key="d5">SQS (Response)</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Queue where rendering engines immediately publish task receipts to satisfy frontend polling.</data>
    </node>
    <node id="5">
      <data key="d5">EC2 Auto Scaling</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Diversified EC2 Spot Instances acting as rendering engines spread across multiple Availability Zones.</data>
    </node>
    <node id="6">
      <data key="d5">S3</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Object storage where rendered video segments are uploaded by the EC2 engines.</data>
    </node>
    <node id="7">
      <data key="d5">CloudFront</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Content Delivery Network (CDN) caching and serving video segments to the client devices.</data>
    </node>
    <node id="8">
      <data key="d5">Step Functions</data>
      <data key="d6">StepFunctions</data>
      <data key="d7">Orchestrator that triggers the scaling Lambda function every 15 seconds.</data>
    </node>
    <node id="9">
      <data key="d5">Lambda (Scaler)</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Custom scaling logic function calculating required capacity based on performance metrics and modifying the Auto Scaling group limits.</data>
    </node>
    <node id="10">
      <data key="d5">CloudWatch</data>
      <data key="d6">CloudWatch</data>
      <data key="d7">Monitors the system, gathers metrics, and dispatches spot instance interruption events.</data>
    </node>
    <node id="11">
      <data key="d5">Lambda (Spot Handler)</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Processes spot interruption notices to safely stop engine tasks, drain active jobs, and detach EC2 instances.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">Client requests a personalized video link via the API Gateway.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="0" target="7" id="0">
      <data key="d8">1</data>
      <data key="d9">Device players request video segments from CloudFront CDN using the playlist links.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">API Gateway routes the request to the Frontend Lambda function.</data>
      <data key="d10">1</data>
      <data key="d11">control</data>
    </edge>
    <edge source="2" target="3" id="0">
      <data key="d8">0</data>
      <data key="d9">Frontend Lambda pushes rendering instructions to the SQS Request queue.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="0" id="0">
      <data key="d8">0</data>
      <data key="d9">Frontend Lambda returns a playlist file link containing references to video segments back to the device.</data>
      <data key="d10">6</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="5" id="0">
      <data key="d8">0</data>
      <data key="d9">Rendering engines in the EC2 Auto Scaling group poll and pull jobs from SQS.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">Frontend Lambda polls SQS Response queue to confirm the job was successfully scheduled.</data>
      <data key="d10">5</data>
      <data key="d11">control</data>
    </edge>
    <edge source="5" target="4" id="0">
      <data key="d8">0</data>
      <data key="d9">Rendering engines immediately push acknowledgement back to the SQS Response queue.</data>
      <data key="d10">4</data>
      <data key="d11">control</data>
    </edge>
    <edge source="5" target="6" id="0">
      <data key="d8">1</data>
      <data key="d9">Rendering engines upload processed video segments to S3.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="9" id="0">
      <data key="d8">2</data>
      <data key="d9">Rendering engine performance and capacity metrics are pushed/made available to Scaler Lambda.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="10" id="0">
      <data key="d8">3</data>
      <data key="d9">CloudWatch monitors the Auto Scaling Group and captures spot interruption events.</data>
      <data key="d10">0</data>
      <data key="d11">control</data>
    </edge>
    <edge source="6" target="7" id="0">
      <data key="d8">1</data>
      <data key="d9">CloudFront pulls video segments from the S3 origin bucket.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="8" target="9" id="0">
      <data key="d8">2</data>
      <data key="d9">Step Functions triggers the Scaler Lambda every 15 seconds.</data>
      <data key="d10">0</data>
      <data key="d11">control</data>
    </edge>
    <edge source="9" target="8" id="0">
      <data key="d8">2</data>
      <data key="d9">Scaler Lambda completes its evaluation and reports status back to Step Functions.</data>
      <data key="d10">1</data>
      <data key="d11">control</data>
    </edge>
    <edge source="9" target="5" id="0">
      <data key="d8">2</data>
      <data key="d9">Scaler Lambda updates the capacity targets on the Auto Scaling Group based on calculated requirements.</data>
      <data key="d10">3</data>
      <data key="d11">control</data>
    </edge>
    <edge source="10" target="11" id="0">
      <data key="d8">3</data>
      <data key="d9">CloudWatch sends the 2-minute spot interruption notice to the Spot Handler Lambda.</data>
      <data key="d10">1</data>
      <data key="d11">control</data>
    </edge>
    <edge source="11" target="5" id="0">
      <data key="d8">3</data>
      <data key="d9">Spot Handler Lambda triggers API calls to the targeted EC2 instance to drain rendering tasks and detach it from the ASG.</data>
      <data key="d10">2</data>
      <data key="d11">control</data>
    </edge>
    <data key="d0">Sunday Sky Rendering as a Service (RaaS) Architecture</data>
    <data key="d1">https://www.youtube.com/watch?v=6CgqEzyWpeA</data>
    <data key="d2">Sunday Sky's rendering as a service (RaaS) architecture processes and generates personalized, dynamic video experiences (such as monthly video bills). The pipeline is fully scalable, cost-optimized using EC2 Spot Instances, and orchestrates scaling and spot interruption handling using Step Functions and Lambda handlers.</data>
    <data key="d3">interactive, compute_intensive, control</data>
    <data key="d4">True</data>
  </graph>
</graphml>
