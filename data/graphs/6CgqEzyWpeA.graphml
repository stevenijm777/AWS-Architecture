<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">User Consumer Web/Mobile</data>
      <data key="d6">UserConsumerWebMobile</data>
      <data key="d7">Client player platform where users request personalized video bills and play back processed video streams.</data>
    </node>
    <node id="1">
      <data key="d5">API Gateway</data>
      <data key="d6">ApiGateway</data>
      <data key="d7">Acts as the frontend link, managing client requests with usage plans and API keys to throttle and secure requests.</data>
    </node>
    <node id="2">
      <data key="d5">Frontend Lambda</data>
      <data key="d6">Lambda</data>
      <data key="d7">Validates incoming rendering requests, pushes instructions to the SQS queue, and polls the response queue for playlist metadata.</data>
    </node>
    <node id="3">
      <data key="d5">Rendering SQS Queue</data>
      <data key="d6">SQS</data>
      <data key="d7">Decouples the frontend validation service from the backend rendering farm, holding scheduled rendering jobs.</data>
    </node>
    <node id="4">
      <data key="d5">Response SQS Queue</data>
      <data key="d6">SQS</data>
      <data key="d7">Receives immediate rendering engine status/metadata updates to allow fast delivery of playlist URLs to clients.</data>
    </node>
    <node id="5">
      <data key="d5">EC2 Auto Scaling Rendering Instances</data>
      <data key="d6">EC2</data>
      <data key="d7">Diversified Spot Instances distributed across multiple AZs. Pulls tasks from the rendering queue and uploads segments to S3.</data>
    </node>
    <node id="6">
      <data key="d5">S3 Bucket</data>
      <data key="d6">S3</data>
      <data key="d7">Stores the individual processed video segments uploaded by the EC2 rendering engines.</data>
    </node>
    <node id="7">
      <data key="d5">CloudFront CDN</data>
      <data key="d6">CloudFront</data>
      <data key="d7">Caches and serves the generated video segments from S3 with low latency to players globally.</data>
    </node>
    <node id="8">
      <data key="d5">Step Functions Scaling Orchestrator</data>
      <data key="d6">StepFunctions</data>
      <data key="d7">Runs continuously, triggering the Scaling Lambda every 15 seconds to ensure highly responsive auto scaling.</data>
    </node>
    <node id="9">
      <data key="d5">Scaling Lambda</data>
      <data key="d6">Lambda</data>
      <data key="d7">Calculates required rendering capacity based on CloudWatch metrics and dynamically updates the Auto Scaling Group size.</data>
    </node>
    <node id="10">
      <data key="d5">CloudWatch Events</data>
      <data key="d6">CloudWatch</data>
      <data key="d7">Monitors instance state changes, including the crucial 2-minute AWS Spot Instance interruption warnings.</data>
    </node>
    <node id="11">
      <data key="d5">Interruption Lambda</data>
      <data key="d6">Lambda</data>
      <data key="d7">Triggered by Spot interruption warnings; calls an API on the specific EC2 instance to drain active jobs and detaches it gracefully.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">User initiates request for personalized video content.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="0" target="7" id="0">
      <data key="d8">0</data>
      <data key="d9">User consumer player fetches cached video segments from CloudFront CDN.</data>
      <data key="d10">9</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">API Gateway routes request to Frontend Lambda.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="3" id="0">
      <data key="d8">0</data>
      <data key="d9">Frontend Lambda pushes rendering instructions to queue.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="0" id="0">
      <data key="d8">0</data>
      <data key="d9">Returns compiled playlist file URL back to client player.</data>
      <data key="d10">6</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="5" id="0">
      <data key="d8">0</data>
      <data key="d9">EC2 rendering instances poll tasks from the queue.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">Frontend Lambda polls metadata/playlist link from response queue.</data>
      <data key="d10">5</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="4" id="0">
      <data key="d8">0</data>
      <data key="d9">EC2 instances post early response details to the response queue.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="6" id="0">
      <data key="d8">0</data>
      <data key="d9">EC2 rendering engines upload generated video segments directly to S3.</data>
      <data key="d10">7</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="10" id="0">
      <data key="d8">1</data>
      <data key="d9">EC2 instances push capacity metrics to CloudWatch.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="6" target="7" id="0">
      <data key="d8">0</data>
      <data key="d9">CloudFront fetches original video segments from S3 bucket on demand.</data>
      <data key="d10">8</data>
      <data key="d11">data</data>
    </edge>
    <edge source="8" target="9" id="0">
      <data key="d8">1</data>
      <data key="d9">Triggers capacity evaluation function every 15 seconds.</data>
      <data key="d10">1</data>
      <data key="d11">control</data>
    </edge>
    <edge source="9" target="5" id="0">
      <data key="d8">1</data>
      <data key="d9">Instructs the Auto Scaling Group to scale out/in based on metrics.</data>
      <data key="d10">2</data>
      <data key="d11">control</data>
    </edge>
    <edge source="10" target="11" id="0">
      <data key="d8">2</data>
      <data key="d9">Notifies Lambda of an impending EC2 Spot Instance termination warning.</data>
      <data key="d10">0</data>
      <data key="d11">control</data>
    </edge>
    <edge source="11" target="5" id="0">
      <data key="d8">2</data>
      <data key="d9">Triggers API call on targeted EC2 instance to stop fetching jobs and gracefully drain.</data>
      <data key="d10">1</data>
      <data key="d11">control</data>
    </edge>
    <data key="d0">Sunday Sky Rendering as a Service RAS Architecture</data>
    <data key="d1" />
    <data key="d2">Sunday Sky's Rendering as a Service (RAS) ecosystem dynamically processes and delivers billions of personalized video experiences yearly, optimizing costs with diversified Spot Instances across multiple Availability Zones, and coordinating rapid automated scaling and graceful termination handling.</data>
    <data key="d3">Media Processing, Scalable Systems, Spot Fleet Management</data>
    <data key="d4">True</data>
  </graph>
</graphml>

