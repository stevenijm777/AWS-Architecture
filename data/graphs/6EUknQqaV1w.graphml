<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Cloud Providers Event Streams</data>
      <data key="d6">UserCompanyDataStream</data>
      <data key="d7">DATA_PEEK: Real-time event streams (e.g. AWS CloudWatch Events, Azure Activity Log) generating billions of events daily.</data>
    </node>
    <node id="1">
      <data key="d5">Collection Framework</data>
      <data key="d6">EKS</data>
      <data key="d7">Evaluates the native cloud provider events to capture current resource state configurations.</data>
    </node>
    <node id="2">
      <data key="d5">Ingestion Kinesis Data Stream</data>
      <data key="d6">Kinesis</data>
      <data key="d7">Buffers the processed cloud resource configuration events for ingestion consumption.</data>
    </node>
    <node id="3">
      <data key="d5">Sharder Service</data>
      <data key="d6">EKS</data>
      <data key="d7">Intelligent load balancing microservice that shards writes across target database clusters based on real-time performance metrics.</data>
    </node>
    <node id="4">
      <data key="d5">Amazon Neptune Graph DB</data>
      <data key="d6">Neptune</data>
      <data key="d7">Primary schema-less persistence database storing highly interconnected cloud resource configurations for graph-based queries.</data>
    </node>
    <node id="5">
      <data key="d5">Elasticsearch Backing Store</data>
      <data key="d6">OpenSearch</data>
      <data key="d7">Used as a backing search engine to enable flexible search, filtering, and analytical aggregations.</data>
    </node>
    <node id="6">
      <data key="d5">Resource Configurations DB</data>
      <data key="d6">DynamoDB</data>
      <data key="d7">Stores historical resource configuration details to track state changes over time.</data>
    </node>
    <node id="7">
      <data key="d5">CloudWatch Metrics</data>
      <data key="d6">CloudWatch</data>
      <data key="d7">Captures CPU, memory, and database metrics from Neptune and Elasticsearch to inform the Sharder Service.</data>
    </node>
    <node id="8">
      <data key="d5">Rule Engine Kinesis Stream</data>
      <data key="d6">Kinesis</data>
      <data key="d7">Buffers events and resource updates destined for the rule evaluation pipeline.</data>
    </node>
    <node id="9">
      <data key="d5">Rule Execution Engine</data>
      <data key="d6">EKS</data>
      <data key="d7">Executes thousands of security rules against the Neptune graph model to discover infrastructure compliance issues.</data>
    </node>
    <node id="10">
      <data key="d5">Security Violations DB</data>
      <data key="d6">DynamoDB</data>
      <data key="d7">Persistent database for logging detected compliance and security violations.</data>
    </node>
    <node id="11">
      <data key="d5">Notification Channels</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">External alerting platforms including Slack, Splunk, and email gateways.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">1</data>
      <data key="d9">Ingests native cloud security event streams.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="2" id="0">
      <data key="d8">1</data>
      <data key="d9">Publishes evaluated events into Kinesis.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="3" id="0">
      <data key="d8">1</data>
      <data key="d9">Consumes stream events for sharded persistence routing.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="8" id="0">
      <data key="d8">2</data>
      <data key="d9">Forwards incoming event streams to the rule execution pipeline.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="4" id="0">
      <data key="d8">1</data>
      <data key="d9">Persists graph relationship data to Neptune.</data>
      <data key="d10">4a</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="5" id="0">
      <data key="d8">1</data>
      <data key="d9">Replicates event properties to Elasticsearch.</data>
      <data key="d10">4b</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="6" id="0">
      <data key="d8">1</data>
      <data key="d9">Saves state history changes to DynamoDB.</data>
      <data key="d10">4c</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="7" id="0">
      <data key="d8">1</data>
      <data key="d9">Sends performance metrics to CloudWatch.</data>
      <data key="d10">5a</data>
      <data key="d11">meta</data>
    </edge>
    <edge source="4" target="9" id="0">
      <data key="d8">2</data>
      <data key="d9">Returns graph relationships to rule evaluations.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="7" id="0">
      <data key="d8">1</data>
      <data key="d9">Sends performance metrics to CloudWatch.</data>
      <data key="d10">5b</data>
      <data key="d11">meta</data>
    </edge>
    <edge source="7" target="3" id="0">
      <data key="d8">1</data>
      <data key="d9">Queries resource usage metrics to dynamically determine shards.</data>
      <data key="d10">6</data>
      <data key="d11">meta</data>
    </edge>
    <edge source="8" target="9" id="0">
      <data key="d8">2</data>
      <data key="d9">Feeds resource configuration changes into the Rule Engine.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="9" target="4" id="0">
      <data key="d8">2</data>
      <data key="d9">Executes relational graph lookups to check security properties.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="9" target="10" id="0">
      <data key="d8">2</data>
      <data key="d9">Records positive findings/violations.</data>
      <data key="d10">5</data>
      <data key="d11">data</data>
    </edge>
    <edge source="9" target="11" id="0">
      <data key="d8">2</data>
      <data key="d9">Dispatches security alerts to integrated systems (Slack, Splunk, email).</data>
      <data key="d10">6</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">CloudHealth SecureState Real-Time Security Monitoring Architecture</data>
    <data key="d1">https://www.youtube.com/watch?v=6EUknQqaV1w</data>
    <data key="d2">Handles billions of daily cloud events and monitors over 50 million resources across multiple cloud providers. Employs a sharder service with feedback loops from CloudWatch metrics to dynamically balance write traffic across Amazon Neptune clusters.</data>
    <data key="d3">data_ingestion, compute_intensive, control</data>
    <data key="d4">True</data>
  </graph>
</graphml>
