<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Dev</data>
      <data key="d6">UserCompanyDeveloper</data>
      <data key="d7">The developer actor who writes and commits the application and infrastructure code.</data>
    </node>
    <node id="1">
      <data key="d5">CODEPIPELINE</data>
      <data key="d6">CodePipeline</data>
      <data key="d7">Orchestrates the continuous integration and deployment stages.</data>
    </node>
    <node id="2">
      <data key="d5">CODECOMMIT</data>
      <data key="d6">CodeCommit</data>
      <data key="d7">Source control repository where developers push code changes.</data>
    </node>
    <node id="3">
      <data key="d5">CODEBUILD</data>
      <data key="d6">CodeBuild</data>
      <data key="d7">Builds the application code into a container image.</data>
    </node>
    <node id="4">
      <data key="d5">REGISTRY</data>
      <data key="d6">ECR</data>
      <data key="d7">Stores the built Docker container images ready for deployment.</data>
    </node>
    <node id="5">
      <data key="d5">CLOUDFORMATION</data>
      <data key="d6">CloudFormation</data>
      <data key="d7">Provisions and configures AWS infrastructure using templates.</data>
    </node>
    <node id="6">
      <data key="d5">VPC</data>
      <data key="d6">VPC</data>
      <data key="d7">Isolated virtual network environment containing the deployed workloads.</data>
    </node>
    <node id="7">
      <data key="d5">ECS</data>
      <data key="d6">ECS</data>
      <data key="d7">Runs the containerized applications inside the VPC.</data>
    </node>
    <node id="8">
      <data key="d5">IAM</data>
      <data key="d6">IAM</data>
      <data key="d7">Defines access control and execution roles for deployed application resources.</data>
    </node>
    <node id="9">
      <data key="d5">ALB</data>
      <data key="d6">ALB</data>
      <data key="d7">Application Load Balancer directing traffic to ECS tasks.</data>
    </node>
    <edge source="0" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">Developer commits code changes directly into CodeCommit.</data>
      <data key="d10">0</data>
      <data key="d11">control</data>
    </edge>
    <edge source="2" target="3" id="0">
      <data key="d8">0</data>
      <data key="d9">Changes in CodeCommit trigger the build phase in CodeBuild.</data>
      <data key="d10">1</data>
      <data key="d11">control</data>
    </edge>
    <edge source="3" target="4" id="0">
      <data key="d8">0</data>
      <data key="d9">CodeBuild uploads the completed container image to Amazon ECR (labeled REGISTRY).</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="6" id="0">
      <data key="d8">0</data>
      <data key="d9">CloudFormation template execution provisions and updates resources inside the target VPC.</data>
      <data key="d10">3</data>
      <data key="d11">control</data>
    </edge>
    <data key="d0">Etion Automated Infrastructure and Application Deployment Pipeline</data>
    <data key="d1">https://www.youtube.com/watch?v=6YkguepAQuQ</data>
    <data key="d2">This architecture automates infrastructure provisioning and application deployment for Etion's multi-customer environment. A developer pushes code changes to CodeCommit, triggering CodeBuild to compile and upload the Docker image to Amazon ECR. CloudFormation templates are then executed to configure and spin up application instances consistently across multiple isolated customer VPCs with embedded approval workflows using Change Sets.</data>
    <data key="d3">control, other</data>
    <data key="d4">True</data>
  </graph>
</graphml>
