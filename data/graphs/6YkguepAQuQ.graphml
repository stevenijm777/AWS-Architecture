  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Developer</data>
      <data key="d6">UserCompanyDeveloper</data>
      <data key="d7">Initiates pipeline with commits.</data>
    </node>
    <node id="1">
      <data key="d5">AWS CodeCommit</data>
      <data key="d6">CodeCommit</data>
      <data key="d7">Stores application code and templates.</data>
