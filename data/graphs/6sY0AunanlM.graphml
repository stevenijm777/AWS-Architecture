<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Users</data>
      <data key="d6">UserConsumerWebMobile</data>
      <data key="d7">Represents the end-users accessing the modern applications.</data>
    </node>
    <node id="1">
      <data key="d5">Amazon Load Balancer</data>
      <data key="d6">ELB</data>
      <data key="d7">WORKLOAD_PEEK: Provides basic infrastructure load balancing, high availability, and acts as the edge entry point for user traffic. The transcript specifically mentions 'classic load balancer, maybe an ELB'.</data>
    </node>
    <node id="2">
      <data key="d5">Nginx Kubernetes Ingress Controller</data>
      <data key="d6">EKS</data>
      <data key="d7">WORKLOAD_PEEK: Runs within the EKS cluster. Provides advanced Layer 7 traffic management including routing based on URL, arguments, and host headers. Incorporates Nginx App Protect for WAF capabilities, DDoS protection, and integrates with identity providers for authentication and authorization. Described as the 'swiss army knife of the web' for application control and security.</data>
    </node>
    <node id="3">
      <data key="d5">Application Service A</data>
      <data key="d6">EKS</data>
      <data key="d7">One of the backend containerized application services running within the EKS cluster, receiving traffic distributed by the Nginx KIC.</data>
    </node>
    <node id="4">
      <data key="d5">Application Service B</data>
      <data key="d6">EKS</data>
      <data key="d7">One of the backend containerized application services running within the EKS cluster, receiving traffic distributed by the Nginx KIC.</data>
    </node>
    <node id="5">
      <data key="d5">Application Service C</data>
      <data key="d6">EKS</data>
      <data key="d7">One of the backend containerized application services running within the EKS cluster, receiving traffic distributed by the Nginx KIC.</data>
    </node>
    <node id="6">
      <data key="d5">Administrator</data>
      <data key="d6">UserCompanyDeveloper</data>
      <data key="d7">Responsible for building infrastructure as code, creating Docker containers, pushing them to ECR, and using `kubectl` commands to administer and manage the Kubernetes (EKS) environment, including deploying and scaling services via a CI/CD pipeline.</data>
    </node>
    <node id="7">
      <data key="d5">Elastic Container Registry</data>
      <data key="d6">ECR</data>
      <data key="d7">Stores Docker container images built by the administrator, which are then pulled by the EKS cluster for deployment.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">Users send application traffic to the load balancer.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">The ELB distributes application traffic to the Nginx Ingress Controller within the EKS containerized environment.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="3" id="0">
      <data key="d8">0</data>
      <data key="d9">The Nginx KIC routes traffic to Application Service A based on Layer 7 rules (e.g., URL, host header).</data>
      <data key="d10">2a</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="4" id="0">
      <data key="d8">0</data>
      <data key="d9">The Nginx KIC routes traffic to Application Service B based on Layer 7 rules.</data>
      <data key="d10">2b</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="5" id="0">
      <data key="d8">0</data>
      <data key="d9">The Nginx KIC routes traffic to Application Service C based on Layer 7 rules.</data>
      <data key="d10">2c</data>
      <data key="d11">data</data>
    </edge>
    <edge source="6" target="7" id="0">
      <data key="d8">1</data>
      <data key="d9">Administrator pushes Docker container images (built as infrastructure as code) to the Elastic Container Registry.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="6" target="2" id="0">
      <data key="d8">1</data>
      <data key="d9">Administrator uses `kubectl` commands to administer and manage Kubernetes, deploying and configuring the Nginx KIC and backend services within EKS, and automating changes through CI/CD.</data>
      <data key="d10">1</data>
      <data key="d11">meta</data>
    </edge>
    <edge source="7" target="2" id="0">
      <data key="d8">1</data>
      <data key="d9">The EKS cluster (represented by the KIC as the ingress point for deployments) pulls container images from ECR for deployment of the KIC itself and backend services.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">Nginx Modern Application Architecture on AWS EKS</data>
    <data key="d1">https://www.youtube.com/watch?v=6sY0AunanlM</data>
    <data key="d2">This architecture describes a modern application deployment on AWS using Nginx as a Kubernetes Ingress Controller (KIC). The solution emphasizes advanced Layer 7 traffic management, security (WAF, DDoS protection), and authentication/authorization within a containerized EKS environment. It highlights an administrator's workflow using CI/CD pipelines for deploying and managing applications, focusing on rapid feature development and simplified infrastructure management.</data>
    <data key="d3">data_ingestion, interactive, compute_intensive, control</data>
    <data key="d4">True</data>
  </graph>
</graphml>
