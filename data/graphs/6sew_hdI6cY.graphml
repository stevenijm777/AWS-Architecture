  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Customer</data>
      <data key="d6">UserConsumerWebMobile</data>
      <data key="d7">Shoppers visiting the online stores managed by Triboo.</data>
    </node>
    <node id="1">
      <data key="d5">Route 53</data>
      <data key="d6">Route53</data>
      <data key="d7">Handles external domains and internal FQDNs for service-to-service calls.</data>
    </node>
    <node id="2">
      <data key="d5">AWS WAF</data>
      <data key="d6">WAF</data>
      <data key="d7">Protects against DDoS and bot attacks.</data>
    </node>
    <node id="3">
      <data key="d5">CloudFront CDN</data>
      <data key="d6">CloudFront</data>
      <data key="d7">Caches static assets at the edge and handles request routing behaviors.</data>
    </node>
    <node id="4">
      <data key="d5">Static S3 Bucket</data>
      <data key="d6">S3</data>
      <data key="d7">Stores images and other static assets.</data>
    </node>
    <node id="5">
      <data key="d5">Custom Load Balancer</data>
      <data key="d6">EC2</data>
      <data key="d7">Runs 'pass secure' proprietary load balancing software on EC2 instances.</data>
    </node>
    <node id="6">
      <data key="d5">Magento EKS Cluster</data>
      <data key="d6">EKS</data>
      <data key="d7">Runs containerized Magento storefronts, segregating search traffic and purchase traffic.</data>
    </node>
    <node id="7">
      <data key="d5">Amazon Aurora</data>
      <data key="d6">Aurora</data>
      <data key="d7">MySQL-compatible database for Magento relational data.</data>
    </node>
    <node id="8">
      <data key="d5">ElastiCache Redis</data>
      <data key="d6">ElastiCache</data>
      <data key="d7">Used for session storage and application caching.</data>
    </node>
    <node id="9">
      <data key="d5">Elasticsearch</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Used for product catalog indexing and search features.</data>
    </node>
    <node id="10">
      <data key="d5">EFS / Custom NFS</data>
      <data key="d6">EFS</data>
      <data key="d7">Shared file system for media and assets (combination of EFS and custom EC2-based NFS).</data>
    </node>
    <node id="11">
      <data key="d5">Log S3 Bucket</data>
      <data key="d6">S3</data>
      <data key="d7">Saves system and application logs.</data>
    </node>
    <node id="12">
      <data key="d5">Triboo Ops/Dev Team</data>
      <data key="d6">UserCompanyDeveloper</data>
      <data key="d7">Internal users managing the platform services.</data>
    </node>
    <node id="13">
      <data key="d5">AWS VPN</data>
      <data key="d6">VPN</data>
      <data key="d7">IPsec VPN used as the secure entry point for managing all internal platform services.</data>
    </node>
    <node id="14">
      <data key="d5">Mail Server</data>
      <data key="d6">EC2</data>
      <data key="d7">Self-managed EC2 instance running email dispatching services.</data>
    </node>
    <node id="15">
      <data key="d5">Amazon Redshift</data>
      <data key="d6">RedShift</data>
      <data key="d7">Data warehouse for BI analytics.</data>
    </node>
    <node id="16">
      <data key="d5">Monitoring &amp; Config Lambda</data>
      <data key="d6">Lambda</data>
      <data key="d7">Triggers monitoring, configuration tasks, and alerts.</data>
