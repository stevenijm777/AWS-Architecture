  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Practitioner Client</data>
      <data key="d6">UserConsumerWeb</data>
      <data key="d7">Doctors and nurses searching for job opportunities.</data>
    </node>
    <node id="1">
      <data key="d5">.NET App Controller</data>
      <data key="d6">ECS</data>
      <data key="d7">WORKLOAD_PEEK: Handles orchestration of the chat and search experience.</data>
    </node>
    <node id="2">
      <data key="d5">Claude 2 (Sanitization)</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Checks prompt injection, sanitizes inputs, and converts locations to lat/lon.</data>
    </node>
    <node id="3">
      <data key="d5">Titan (Query Vectorizer)</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Used for quick and cost-effective text embeddings.</data>
    </node>
    <node id="4">
      <data key="d5">SQL Database</data>
      <data key="d6">EC2</data>
      <data key="d7">Stores user search and interaction history.</data>
    </node>
    <node id="5">
      <data key="d5">Elasticsearch Knowledge Base</data>
      <data key="d6">EC2</data>
      <data key="d7">Self-hosted Elasticsearch indexing job descriptions.</data>
    </node>
    <node id="6">
      <data key="d5">Claude 2 (Response Generation)</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Generates and streams final tailored job responses.</data>
    </node>
    <node id="7">
      <data key="d5">Job Feeds &amp; APIs</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">External partner feeds, RSS, and APIs.</data>
    </node>
    <node id="8">
      <data key="d5">Document Store</data>
      <data key="d6">S3</data>
      <data key="d7">Stores raw ingested job posting documents.</data>
    </node>
    <node id="9">
      <data key="d5">Titan (Job Embedding)</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Vectorizes job descriptions during ingestion.</data>
    </node>
    <edge source="0" target="1">
      <data key="d8">0</data>
