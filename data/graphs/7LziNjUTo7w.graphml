<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Instructor</data>
      <data key="d6">UserCompanyDeveloper</data>
      <data key="d7">Triggers class environment creation via CloudFormation templates.</data>
    </node>
    <node id="1">
      <data key="d5">CloudFormation</data>
      <data key="d6">CloudFormation</data>
      <data key="d7">Orchestrates provisioning of all training class infrastructure and AppStream custom images.</data>
    </node>
    <node id="2">
      <data key="d5">Custom Resource Lambda</data>
      <data key="d6">Lambda</data>
      <data key="d7">Triggered by CloudFormation to initiate AppStream image customization within the 15-minute execution limit.</data>
    </node>
    <node id="3">
      <data key="d5">Systems Manager</data>
      <data key="d6">SystemsManager</data>
      <data key="d7">Executes remote configuration commands on the EC2 instance.</data>
    </node>
    <node id="4">
      <data key="d5">EC2 License &amp; Helper Server</data>
      <data key="d6">EC2</data>
      <data key="d7">WORKLOAD_PEEK: Acts as the License Server for Kingdom, and executes the SSM scripts to remote-configure AppStream's session script.</data>
    </node>
    <node id="5">
      <data key="d5">AppStream 2.0</data>
      <data key="d6">AppStream</data>
      <data key="d7">WORKLOAD_PEEK: Delivers high-end GPU-backed desktop applications directly to lightweight browser devices.</data>
    </node>
    <node id="6">
      <data key="d5">FSx for Windows File Server</data>
      <data key="d6">FSX</data>
      <data key="d7">DATA_PEEK: High-performance shared storage used to hold student projects.</data>
    </node>
    <node id="7">
      <data key="d5">RDS SQL Express</data>
      <data key="d6">RDS</data>
      <data key="d7">DATA_PEEK: Cost-optimized SQL Express instance containing database files for Kingdom projects, saving 80% compared to Enterprise SQL.</data>
    </node>
    <node id="8">
      <data key="d5">Student</data>
      <data key="d6">UserConsumerWeb</data>
      <data key="d7">Accesses the petrotechnical training environment via a single-click streaming URL.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">Instructor deploys CloudFormation template to create class resources.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="7" id="0">
      <data key="d8">0</data>
      <data key="d9">Provisions RDS SQL Express Instance.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="6" id="0">
      <data key="d8">0</data>
      <data key="d9">Provisions FSx shared file system.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">Triggers custom resource Lambda function.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="5" id="0">
      <data key="d8">0</data>
      <data key="d9">Provisions the custom AppStream image and fleet once image building is complete.</data>
      <data key="d10">8</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="0" id="0">
      <data key="d8">0</data>
      <data key="d9">Returns completed environment status to Instructor.</data>
      <data key="d10">9</data>
      <data key="d11">meta</data>
    </edge>
    <edge source="2" target="3" id="0">
      <data key="d8">0</data>
      <data key="d9">Lambda invokes Systems Manager to run configuration commands.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="4" id="0">
      <data key="d8">0</data>
      <data key="d9">Executes script on EC2 instance.</data>
      <data key="d10">5</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="5" id="0">
      <data key="d8">0</data>
      <data key="d9">EC2 script remotes into AppStream's image builder to configure session script (mounting FSx).</data>
      <data key="d10">6</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">Sends success signal to CloudFormation Wait Condition.</data>
      <data key="d10">7</data>
      <data key="d11">meta</data>
    </edge>
    <edge source="5" target="6" id="0">
      <data key="d8">1</data>
      <data key="d9">AppStream session automatically mounts the custom FSx directory.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="7" id="0">
      <data key="d8">1</data>
      <data key="d9">Kingdom app connects to SQL Express database.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="4" id="0">
      <data key="d8">1</data>
      <data key="d9">Appstream checks out license key from License Server on EC2.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="8" id="0">
      <data key="d8">1</data>
      <data key="d9">Streams full GPU Kingdom interactive application GUI back to Student's browser.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <edge source="8" target="5" id="0">
      <data key="d8">1</data>
      <data key="d9">Student launches browser session via single-click streaming URL.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">IHS Markit Virtual Software Training Architecture</data>
    <data key="d1">https://www.youtube.com/watch?v=7LziNjUTo7w</data>
    <data key="d2">Delivers petrotechnical training application (Kingdom) using AppStream with cost-optimized SQL Express RDS and dynamically provisioned FSx storage. Custom EC2 script orchestration integrates AppStream image building with CloudFormation.</data>
    <data key="d3">compute_intensive, interactive</data>
    <data key="d4">True</data>
  </graph>
</graphml>
