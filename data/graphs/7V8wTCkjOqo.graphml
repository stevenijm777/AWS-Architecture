<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Service Teams</data>
      <data key="d6">UserCompanyDeveloper</data>
      <data key="d7">NAB developers running pipelines in non-production environments.</data>
    </node>
    <node id="1">
      <data key="d5">Kong API Gateway</data>
      <data key="d6">ECS</data>
      <data key="d7">WORKLOAD_PEEK: Publishes endpoints and routes incoming pipeline events.</data>
    </node>
    <node id="2">
      <data key="d5">Ingestion Lambda</data>
      <data key="d6">Lambda</data>
      <data key="d7">Captures and processes build events.</data>
    </node>
    <node id="3">
      <data key="d5">Build Events DB</data>
      <data key="d6">DynamoDB</data>
      <data key="d7">DATA_PEEK: Key-value store capturing build events and code scan evidence.</data>
    </node>
    <node id="4">
      <data key="d5">Assessment Lambda</data>
      <data key="d6">Lambda</data>
      <data key="d7">Executes compliance evaluation, matching build events against standards.</data>
    </node>
    <node id="5">
      <data key="d5">Compliance DB</data>
      <data key="d6">RDS</data>
      <data key="d7">PostgreSQL instance containing standards, compliance rules, and team mappings.</data>
    </node>
    <node id="6">
      <data key="d5">Promotion Topic</data>
      <data key="d6">SNS</data>
      <data key="d7">Fans out secure notifications across accounts to trigger artifact promotion.</data>
    </node>
    <node id="7">
      <data key="d5">Production Copy Lambda</data>
      <data key="d6">Lambda</data>
      <data key="d7">Runs in production account to copy validated artifacts.</data>
    </node>
    <node id="8">
      <data key="d5">Deployment Queue</data>
      <data key="d6">SQS</data>
      <data key="d7">Receives notification messages to trigger automated deployment tools.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">Sends build events from pipeline.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="0" target="1" id="1">
      <data key="d8">1</data>
      <data key="d9">Sends Promote API call.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">Routes request.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="0" id="0">
      <data key="d8">0</data>
      <data key="d9">Ack response.</data>
      <data key="d10">5</data>
      <data key="d11">meta</data>
    </edge>
    <edge source="1" target="0" id="1">
      <data key="d8">1</data>
      <data key="d9">Success promotion ack.</data>
      <data key="d10">10</data>
      <data key="d11">meta</data>
    </edge>
    <edge source="1" target="4" id="0">
      <data key="d8">1</data>
      <data key="d9">Routes promotion request.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="3" id="0">
      <data key="d8">0</data>
      <data key="d9">Saves evidence to DynamoDB.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">Ack.</data>
      <data key="d10">4</data>
      <data key="d11">meta</data>
    </edge>
    <edge source="3" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">Ack.</data>
      <data key="d10">3</data>
      <data key="d11">meta</data>
    </edge>
    <edge source="3" target="4" id="0">
      <data key="d8">1</data>
      <data key="d9">Returns evidence data.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="3" id="0">
      <data key="d8">1</data>
      <data key="d9">Queries build evidence.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="5" id="0">
      <data key="d8">1</data>
      <data key="d9">Queries compliance standards.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="6" id="0">
      <data key="d8">1</data>
      <data key="d9">Triggers promotion upon success.</data>
      <data key="d10">6</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="8" id="0">
      <data key="d8">1</data>
      <data key="d9">Sends deployment notification.</data>
      <data key="d10">8</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="1" id="0">
      <data key="d8">1</data>
      <data key="d9">Acceptance response.</data>
      <data key="d10">9</data>
      <data key="d11">meta</data>
    </edge>
    <edge source="5" target="4" id="0">
      <data key="d8">1</data>
      <data key="d9">Returns compliance rules.</data>
      <data key="d10">5</data>
      <data key="d11">data</data>
    </edge>
    <edge source="6" target="7" id="0">
      <data key="d8">1</data>
      <data key="d9">Triggers prod artifact copy.</data>
      <data key="d10">7</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">National Australia Bank Automated Compliance Framework</data>
    <data key="d1">https://www.youtube.com/watch?v=7V8wTCkjOqo</data>
    <data key="d2">Automates compliance checks for 1000+ workloads moving to AWS. Evaluates pipeline build metadata against relational compliance frameworks.</data>
    <data key="d3">control, data_ingestion</data>
    <data key="d4">True</data>
  </graph>
</graphml>
