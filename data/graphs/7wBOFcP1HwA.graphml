  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Almosafer Users</data>
      <data key="d6">UserConsumerWebMobile</data>
      <data key="d7">DATA_PEEK: Handles ~300k requests per minute at peak.</data>
    </node>
    <node id="1">
      <data key="d5">CloudFront CDN</data>
      <data key="d6">CloudFront</data>
      <data key="d7">Serves static content and acts as the entry point for API traffic.</data>
    </node>
    <node id="2">
      <data key="d5">Static Assets S3 Bucket</data>
      <data key="d6">S3</data>
      <data key="d7">Stores images, 3D images, and videos.</data>
    </node>
    <node id="3">
      <data key="d5">Edge Routing Lambda</data>
      <data key="d6">Lambda</data>
      <data key="d7">Determines user region and injects geolocation headers for backend APIs.</data>
    </node>
    <node id="4">
      <data key="d5">Application Load Balancer</data>
      <data key="d6">ELB</data>
      <data key="d7">WORKLOAD_PEEK: Over 60 LBs deployed to separate backend API and web traffic.</data>
    </node>
    <node id="5">
      <data key="d5">Legacy Monolith</data>
      <data key="d6">EC2</data>
      <data key="d7">Receives remaining 20% of legacy application traffic.</data>
    </node>
    <node id="6">
      <data key="d5">Microservices EKS Cluster</data>
      <data key="d6">EKS</data>
      <data key="d7">WORKLOAD_PEEK: Runs 250+ microservices across 1400+ pods in production.</data>
    </node>
    <node id="7">
      <data key="d5">Relational Databases</data>
      <data key="d6">RDS</data>
      <data key="d7">Managed SQL databases for relational application storage.</data>
    </node>
    <node id="8">
      <data key="d5">MongoDB &amp; Kafka Cluster</data>
      <data key="d6">EC2</data>
      <data key="d7">Self-managed NoSQL data store and stream broker for microservices messaging.</data>
    </node>
    <node id="9">
      <data key="d5">Monitoring Agent</data>
      <data key="d6">EC2</data>
      <data key="d7">Collects logs and operational metrics from the compute fleets.</data>
    </node>
    <node id="10">
      <data key="d5">CloudWatch</data>
      <data key="d6">CloudWatch</data>
      <data key="d7">Centralized dashboard for tracking performance and operational metrics.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">User requests static assets.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="0" target="1" id="1">
      <data key="d8">1</data>
      <data key="d9">User sends dynamic API / web request.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">Fetch images and videos.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="0" id="0">
      <data key="d8">0</data>
      <data key="d9">Serve assets to user.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="0" id="1">
      <data key="d8">1</data>
      <data key="d9">Render content to user.</data>
      <data key="d10">9</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="3" id="0">
      <data key="d8">1</data>
      <data key="d9">Trigger edge validation / header injection.</data>
      <data key="d10">1</data>
      <data key="d11">meta</data>
    </edge>
    <edge source="1" target="4" id="0">
      <data key="d8">1</data>
      <data key="d9">Route request to Load Balancing tier.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">Return cached static assets.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="1" id="0">
      <data key="d8">1</data>
      <data key="d9">Return modified request metadata.</data>
      <data key="d10">2</data>
      <data key="d11">meta</data>
    </edge>
    <edge source="4" target="5" id="0">
      <data key="d8">1</data>
      <data key="d9">Route 20% of traffic to legacy monolith.</data>
      <data key="d10">4a</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="6" id="0">
      <data key="d8">1</data>
      <data key="d9">Route 80% of traffic to microservices.</data>
      <data key="d10">4b</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="1" id="0">
      <data key="d8">1</data>
      <data key="d9">Forward response.</data>
      <data key="d10">8</data>
      <data key="d11">data</data>
    </edge>
    <edge source="6" target="8" id="0">
      <data key="d8">1</data>
      <data key="d9">Fetch/Publish data to MongoDB or Kafka.</data>
      <data key="d10">5</data>
      <data key="d11">data</data>
    </edge>
    <edge source="6" target="7" id="0">
      <data key="d8">1</data>
      <data key="d9">Relational queries.</data>
      <data key="d10">6</data>
      <data key="d11">data</data>
    </edge>
    <edge source="6" target="4" id="0">
      <data key="d8">1</data>
      <data key="d9">Return response payload.</data>
      <data key="d10">7</data>
      <data key="d11">data</data>
    </edge>
    <edge source="6" target="9" id="0">
      <data key="d8">2</data>
      <data key="d9">Export operational metrics.</data>
      <data key="d10">0</data>
      <data key="d11">meta</data>
    </edge>
    <edge source="9" target="10" id="0">
      <data key="d8">2</data>
      <data key="d9">Aggregate and monitor via CloudWatch dashboards.</data>
      <data key="d10">1</data>
      <data key="d11">meta</data>
    </edge>
    <data key="d0">Seera Group: Scaling Almosafer to 300k Requests Per Minute with EKS</data>
    <data key="d1">https://www.youtube.com/watch?v=7wBOFcP1HwA</data>
    <data key="d2">Seera Group migrated 80% of their legacy travel booking monolith to over 250 microservices (1400 pods) on Amazon EKS, handling peak traffic of 300,000 requests per minute during major travel events.</data>
    <data key="d3">interactive, compute_intensive</data>
    <data key="d4">True</data>
