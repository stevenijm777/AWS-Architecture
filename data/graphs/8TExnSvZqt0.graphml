  <graph edgedefault="directed">
    <node id="ecs">
      <data key="d5">ECS Orchestration</data>
      <data key="d6">ECS</data>
      <data key="d7">WORKLOAD_PEEK: Manages the containerized application stack for each tenant environment.</data>
    </node>
    <node id="ami">
      <data key="d5">CIS Hardened AMIs</data>
      <data key="d6">AMI</data>
      <data key="d7">CIS-hardened images built for every environment and client.</data>
    </node>
    <node id="rds">
      <data key="d5">RDS (OLTP)</data>
      <data key="d6">RDS</data>
      <data key="d7">Handles transactional database workloads (OLTP) for the risk platform.</data>
    </node>
    <node id="redshift">
      <data key="d5">Redshift (OLAP)</data>
      <data key="d6">RedShift</data>
      <data key="d7">DATA_PEEK: Processes large volumes of analytical risk data using RA3 nodes for independent scaling of compute and storage.</data>
    </node>
    <node id="s3">
      <data key="d5">Amazon S3</data>
      <data key="d6">S3</data>
      <data key="d7">DATA_PEEK: Stores historical and warm data, fully encrypted at rest.</data>
    </node>
    <node id="kms">
      <data key="d5">KMS Key Management</data>
      <data key="d6">KMS</data>
      <data key="d7">Provides end-to-end data encryption keys for transit and rest.</data>
    </node>
    <node id="security_hub">
      <data key="d5">AWS Security Hub</data>
      <data key="d6">SecurityHub</data>
      <data key="d7">Centralized security posture management.</data>
    </node>
    <node id="guardduty">
      <data key="d5">Amazon GuardDuty</data>
      <data key="d6">GuardDuty</data>
      <data key="d7">Continuous threat detection monitoring.</data>
    </node>
    <node id="config">
      <data key="d5">AWS Config</data>
      <data key="d6">AWSConfig</data>
      <data key="d7">Tracks resource configurations and automates incident response.</data>
    </node>
    <node id="cloudwatch">
      <data key="d5">Amazon CloudWatch</data>
      <data key="d6">CloudWatch</data>
      <data key="d7">Monitors application events and triggers security alerts.</data>
    </node>
    <node id="cloudtrail">
      <data key="d5">AWS CloudTrail</data>
      <data key="d6">CloudTrail</data>
      <data key="d7">Records user activity and API usage.</data>
    </node>
    <edge source="ecs" target="ami" id="0">
      <data key="d8">0</data>
      <data key="d9">Orchestrates build and packaging of hardened virtual images.</data>
      <data key="d10">0</data>
