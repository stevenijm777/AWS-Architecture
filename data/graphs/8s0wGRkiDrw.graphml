<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Enterprise Clients</data>
      <data key="d6">UserCompanyAPI</data>
      <data key="d7">Retrieve shared data from Mobilewala via dedicated S3 buckets.</data>
    </node>
    <node id="1">
      <data key="d5">Client S3 Buckets</data>
      <data key="d6">S3</data>
      <data key="d7">Dedicated buckets containing shared client data.</data>
    </node>
    <node id="2">
      <data key="d5">Dedicated Access Log Bucket</data>
      <data key="d6">S3</data>
      <data key="d7">S3 bucket configured to receive access logs generated by client actions on the data buckets.</data>
    </node>
    <node id="3">
      <data key="d5">Log Parser &amp; Geolocation Mapper</data>
      <data key="d6">Lambda</data>
      <data key="d7">Triggered by S3 log uploads. Parses access logs, converts source IP addresses to numeric country IDs via a geolocation database, adds metadata, and pushes to Elasticsearch.</data>
    </node>
    <node id="4">
      <data key="d5">Elasticsearch Service</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">DATA_PEEK: Processes 18-20 million log records monthly. Configured with anomaly detectors using client filters and numeric country IDs to identify suspicious access pattern changes.</data>
    </node>
    <node id="5">
      <data key="d5">Alerting SNS</data>
      <data key="d6">SNS</data>
      <data key="d7">Sends real-time email alerts when Elasticsearch flags anomalous access behavior.</data>
    </node>
    <node id="6">
      <data key="d5">Service Team</data>
      <data key="d6">UserCompanyAgent</data>
      <data key="d7">Receives email notifications and performs investigation to validate access patterns.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">Client requests data from S3 bucket</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="0" id="0">
      <data key="d8">0</data>
      <data key="d9">S3 returns data payload to Client</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">S3 automatically writes access logs to the dedicated log bucket</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="3" id="0">
      <data key="d8">1</data>
      <data key="d9">New log entry triggers Lambda processing</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="4" id="0">
      <data key="d8">1</data>
      <data key="d9">Enriched log data (with numeric country IDs) is loaded into Elasticsearch</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="5" id="0">
      <data key="d8">1</data>
      <data key="d9">Triggers alert upon anomaly detection</data>
      <data key="d10">2</data>
      <data key="d11">meta</data>
    </edge>
    <edge source="5" target="6" id="0">
      <data key="d8">1</data>
      <data key="d9">Dispatches email alert to service team for further investigation</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">Mobilewala Real-time S3 Access Log Anomaly Detection</data>
    <data key="d1">https://www.youtube.com/watch?v=8s0wGRkiDrw</data>
    <data key="d2">Mobilewala tracks and analyzes S3 access patterns for security monitoring. The system handles 18 to 20 million access log records monthly and detects behavioral anomalies like unusual access times or country changes using Elasticsearch's anomaly detection capabilities.</data>
    <data key="d3">data_ingestion, compute_intensive</data>
    <data key="d4">True</data>
  </graph>
</graphml>
