  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Developer</data>
      <data key="d6">UserCompanyDeveloper</data>
      <data key="d7">Developers create code and push it to Git repositories.</data>
    </node>
    <node id="1">
      <data key="d5">Git Repository</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Stores developer code. Has Webhooks connected to Lagoon to trigger deployments. WORKLOAD_PEEK: Defines deployments as infrastructure as code.</data>
    </node>
    <node id="2">
      <data key="d5">Lagoon EKS (Core Platform)</data>
      <data key="d6">EKS</data>
      <data key="d7">The core of the Amazie.io application delivery platform. Listens to Git repository webhooks and decides deployment actions based on infrastructure as code definitions.</data>
    </node>
    <node id="3">
      <data key="d5">Developer Environment EKS</data>
      <data key="d6">EKS</data>
      <data key="d7">Provides Kubernetes environments for developers. Contains an operator that provisions and manages underlying AWS services like storage and compute as requested by the deployed application.</data>
    </node>
    <node id="4">
      <data key="d5">EC2 (Base Infrastructure)</data>
      <data key="d6">EC2</data>
      <data key="d7">Runs the whole base workload for developer environments. Uses normal EC2 instances.</data>
    </node>
    <node id="5">
      <data key="d5">EC2 (Spot Instances)</data>
      <data key="d6">EC2</data>
      <data key="d7">Used for development or non-productive infrastructure where failure/termination of pods can be tolerated. DATA_PEEK: Achieves 70-90% cost benefit compared to on-demand EC2.</data>
    </node>
    <node id="6">
      <data key="d5">Aurora (Developer Database)</data>
      <data key="d6">Aurora</data>
      <data key="d7">Provisioned by the EKS operator when a developer requests a database. Uses Graviton 2 instances (R6J) for improved performance and cost-efficiency. WORKLOAD_PEEK: Aurora exposes connection secrets back to the project.</data>
    </node>
    <node id="7">
      <data key="d5">EBS (Developer Specialized Storage)</data>
      <data key="d6">EBS</data>
      <data key="d7">Provisioned by the EKS operator for specialized workloads like databases (e.g., OpenSearch or Solr). Uses GP3 volumes for lower storage costs and better IOPS performance.</data>
    </node>
    <node id="8">
      <data key="d5">EFS (Developer File Storage)</data>
      <data key="d6">EFS</data>
      <data key="d7">Provisioned by the EKS operator for storing normal application assets and files.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">Developers create and push code to their Git repositories.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">Git repository webhooks notify Lagoon about code changes (e.g., feature branch, pull request).</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="3" id="0">
      <data key="d8">0</data>
      <data key="d9">Lagoon orchestrates deployment to the developer's hosting zones (environments) based on infrastructure as code.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="4" id="0">
      <data key="d8">0</data>
      <data key="d9">The EKS operator deploys base infrastructure workloads onto normal EC2 instances.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="5" id="0">
      <data key="d8">0</data>
      <data key="d9">The EKS operator deploys development and non-production infrastructure workloads onto EC2 Spot instances.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="6" id="0">
      <data key="d8">0</data>
      <data key="d9">The EKS operator provisions an Aurora database as requested by the developer's application.</data>
      <data key="d10">5</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="7" id="0">
      <data key="d8">0</data>
      <data key="d9">The EKS operator provisions EBS volumes for specialized application storage.</data>
      <data key="d10">7</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="8" id="0">
      <data key="d8">0</data>
      <data key="d9">The EKS operator provisions EFS file systems for general application assets.</data>
      <data key="d10">9</data>
      <data key="d11">data</data>
    </edge>
    <edge source="6" target="3" id="0">
      <data key="d8">0</data>
      <data key="d9">Aurora exposes database connection secrets back to the project within the EKS cluster.</data>
      <data key="d10">6</data>
      <data key="d11">meta</data>
    </edge>
    <edge source="7" target="3" id="0">
      <data key="d8">0</data>
      <data key="d9">EBS volume configuration and mount point secrets are exposed to the project within the EKS cluster.</data>
      <data key="d10">8</data>
      <data key="d11">meta</data>
    </edge>
    <edge source="8" target="3" id="0">
      <data key="d8">0</data>
      <data key="d9">EFS mount point secrets are exposed to the project within the EKS cluster.</data>
      <data key="d10">10</data>
      <data key="d11">meta</data>
    </edge>
    <data key="d0">Amazie.io's Lagoon Application Delivery Platform</data>
    <data key="d1">https://www.youtube.com/watch?v=90rWUjKjnAE</data>
    <data key="d2">Amazie.io's Lagoon is an open-source application delivery platform that helps developers deploy applications into Kubernetes (EKS) without deep Kubernetes knowledge. It uses an infrastructure-as-code paradigm, leveraging Git webhooks to trigger deployments. The platform uses separate EKS clusters for its core (Lagoon) and for the developer-provisioned environments. Developer environments utilize a mix of EC2 and cost-optimized EC2 Spot instances, along with managed storage services like Aurora (with Graviton2), EBS (with GP3), and EFS, provisioned via an EKS operator to abstract storage complexities from developers. Key design goals include cost optimization and flexibility.</data>
    <data key="d3">data_ingestion, interactive, compute_intensive, control</data>
    <data key="d4">True</data>
  </graph>
</graphml>
