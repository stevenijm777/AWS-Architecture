<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Skyscanner Users</data>
      <data key="d6">UserConsumerWebMobile</data>
      <data key="d7">DATA_PEEK: 80 million unique users. WORKLOAD_PEEK: Generates 60,000 to 70,000 queries per second at peak per cluster.</data>
    </node>
    <node id="1">
      <data key="d5">Load Balancer</data>
      <data key="d6">ELB</data>
      <data key="d7">Receives inbound traffic from users. EC2 instances deregister from this LB upon receiving a Spot termination notice to prevent new traffic.</data>
    </node>
    <node id="2">
      <data key="d5">Kubernetes Worker Nodes</data>
      <data key="d6">EC2</data>
      <data key="d7">DATA_PEEK: Multiple clusters across multiple regions. An individual cluster has 120-130 nodes at peak, using C8X, C9X, C5, C4, M5 instance types, totaling 3500-4000 cores. WORKLOAD_PEEK: Runs HG proxy ingress controllers across all nodes. Scripts on these nodes check the Instance Metadata Service every 5 seconds for Spot termination notices and execute shutdown procedures (cordon, deregister from LB, drain).</data>
    </node>
    <node id="3">
      <data key="d5">ASG Diversified Spot Pool 1</data>
      <data key="d6">AutoScaling</data>
      <data key="d7">One of typically five Auto Scaling Groups used for diversification of instance types (C3s, C4s, C5s, M4s, R3s) across multiple Availability Zones. Utilizes 100% Spot Instances.</data>
    </node>
    <node id="4">
      <data key="d5">ASG Diversified Spot Pool 2</data>
      <data key="d6">AutoScaling</data>
      <data key="d7">One of typically five Auto Scaling Groups used for diversification of instance types (C3s, C4s, C5s, M4s, R3s) across multiple Availability Zones. Utilizes 100% Spot Instances.</data>
    </node>
    <node id="5">
      <data key="d5">Kubernetes Cluster Autoscaler</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">This Kubernetes component manipulates the desired count on multiple Auto Scaling Groups (ASGs) to scale the cluster. It required a patch (from Zalando) to fix an issue where it wouldn't autoscale if an ASG reached zero nodes.</data>
    </node>
    <node id="6">
      <data key="d5">Instance Metadata Service</data>
      <data key="d6">EC2</data>
      <data key="d7">Provides information to EC2 instances, including the two-minute Spot termination notification. Checked by scripts running on Kubernetes worker nodes.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">User queries for travel search</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">Forwards inbound traffic to Kubernetes worker nodes (HG proxy ingress controllers)</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="1" id="0">
      <data key="d8">2</data>
      <data key="d9">Node's shutdown script sends command to deregister instance from Load Balancer</data>
      <data key="d10">1</data>
      <data key="d11">meta</data>
    </edge>
    <edge source="2" target="2" id="0">
      <data key="d8">2</data>
      <data key="d9">Node's shutdown script cordons the node and gracefully drains running pods within Kubernetes (internal cluster communication)</data>
      <data key="d10">2</data>
      <data key="d11">meta</data>
    </edge>
    <edge source="3" target="2" id="0">
      <data key="d8">1</data>
      <data key="d9">Provisions and terminates EC2 instances for the Kubernetes cluster</data>
      <data key="d10">2</data>
      <data key="d11">meta</data>
    </edge>
    <edge source="4" target="2" id="0">
      <data key="d8">1</data>
      <data key="d9">Provisions and terminates EC2 instances for the Kubernetes cluster</data>
      <data key="d10">3</data>
      <data key="d11">meta</data>
    </edge>
    <edge source="5" target="3" id="0">
      <data key="d8">1</data>
      <data key="d9">Manipulates desired count of ASG to scale worker nodes</data>
      <data key="d10">0</data>
      <data key="d11">meta</data>
    </edge>
    <edge source="5" target="4" id="0">
      <data key="d8">1</data>
      <data key="d9">Manipulates desired count of ASG to scale worker nodes</data>
      <data key="d10">1</data>
      <data key="d11">meta</data>
    </edge>
    <edge source="6" target="2" id="0">
      <data key="d8">2</data>
      <data key="d9">Delivers 2-minute Spot instance termination notice</data>
      <data key="d10">0</data>
      <data key="d11">meta</data>
    </edge>
    <data key="d0">Skyscanner 100% Spot Kubernetes Cluster</data>
    <data key="d1">https://www.youtube.com/watch?v=99nNHsbwBpg</data>
    <data key="d2">Skyscanner manages a self-hosted Kubernetes cluster on AWS EC2 instances, leveraging 100% Spot Instances for cost savings. The architecture handles 80 million unique users and 60-70k queries/second per cluster. Diversification across multiple Availability Zones, instance types, and Auto Scaling Groups is key to mitigating Spot termination risk. Custom scripts interact with the Instance Metadata Service and Load Balancer to gracefully handle Spot instance terminations.</data>
    <data key="d3">compute_intensive, data_ingestion, control</data>
    <data key="d4">True</data>
  </graph>
</graphml>
