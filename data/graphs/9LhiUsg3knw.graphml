  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Mobile App Users</data>
      <data key="d6">UserConsumerMobile</data>
      <data key="d7">Provide direct and indirect feedback on lyrics sync quality.</data>
    </node>
    <node id="1">
      <data key="d5">Legacy Backend</data>
      <data key="d6">EC2</data>
      <data key="d7">Docker-based API servers managing application logic and publishing lyrics.</data>
    </node>
    <node id="2">
      <data key="d5">Editorial Database</data>
      <data key="d6">Aurora</data>
      <data key="d7">Stores official editorial lyrics data.</data>
    </node>
    <node id="3">
      <data key="d5">Couchbase DB</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Self-hosted NoSQL cluster holding user-generated data.</data>
    </node>
    <node id="4">
      <data key="d5">Tasks DynamoDB</data>
      <data key="d6">DynamoDB</data>
      <data key="d7">Central registry holding tasks needing curation or validation.</data>
    </node>
    <node id="5">
      <data key="d5">AWS AppSync</data>
      <data key="d6">AppSync</data>
      <data key="d7">Distributes task status and synchronization data to curators in real-time.</data>
    </node>
    <node id="6">
      <data key="d5">Curators and Experts</data>
      <data key="d6">UserCompanyInternalPlatform</data>
      <data key="d7">Review, edit, and sync lyrics based on received tasks.</data>
    </node>
    <node id="7">
      <data key="d5">Fargate Prioritization Jobs</data>
      <data key="d6">Fargate</data>
      <data key="d7">Runs batch jobs pulling music streaming charts to prioritize tasks.</data>
    </node>
    <node id="8">
      <data key="d5">AWS Redshift Analytics</data>
      <data key="d6">RedShift</data>
      <data key="d7">Calculates content ranks per country to help prioritize tasks.</data>
    </node>
    <node id="9">
      <data key="d5">Submission Orchestrator</data>
      <data key="d6">Lambda</data>
      <data key="d7">Handles complex multi-write transactions and publishes completed content.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">Sends feedback from mobile app.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">Queries editorial metadata.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="3" id="0">
      <data key="d8">0</data>
      <data key="d9">Saves user feedback details.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="4" id="0">
      <data key="d8">0</data>
      <data key="d9">Creates curation tasks in DynamoDB.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="0" id="0">
      <data key="d8">0</data>
      <data key="d9">Returns confirmation back to mobile user.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="4" id="0">
      <data key="d8">2</data>
      <data key="d9">Queries active curation tasks.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="6" id="0">
      <data key="d8">2</data>
      <data key="d9">Distributes synchronization and draft tasks.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="6" id="1">
      <data key="d8">2</data>
      <data key="d9">Confirm task is successfully published.</data>
      <data key="d10">7</data>
      <data key="d11">meta</data>
    </edge>
    <edge source="5" target="9" id="0">
      <data key="d8">2</data>
      <data key="d9">Triggers complex orchestration for task completion.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="6" target="5" id="0">
      <data key="d8">2</data>
      <data key="d9">Submits corrected drafts and tasks.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="7" target="4" id="0">
      <data key="d8">1</data>
      <data key="d9">Updates task priority based on external streaming charts.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="8" target="4" id="0">
      <data key="d8">1</data>
      <data key="d9">Injects priority ranks derived from country-specific analysis.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="9" target="4" id="0">
      <data key="d8">2</data>
      <data key="d9">Writes final task state.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <edge source="9" target="1" id="0">
      <data key="d8">2</data>
      <data key="d9">Publishes updated lyrics into production database.</data>
      <data key="d10">5</data>
      <data key="d11">data</data>
    </edge>
    <edge source="9" target="5" id="0">
      <data key="d8">2</data>
      <data key="d9">Acknowledges success to AppSync.</data>
      <data key="d10">6</data>
      <data key="d11">meta</data>
    </edge>
    <data key="d0">Musixmatch Lyrics Crowd-Sourcing and Synchronization Platform</data>
    <data key="d1">https://www.youtube.com/watch?v=9LhiUsg3knw</data>
    <data key="d2">Architected to ingest continuous lyrics synchronization feedback from mobile apps and orchestrate curation tasks among curators, experts, and internal operators using AWS AppSync and DynamoDB.</data>
    <data key="d3">data_ingestion, compute_intensive, interactive</data>
    <data key="d4">True</data>
