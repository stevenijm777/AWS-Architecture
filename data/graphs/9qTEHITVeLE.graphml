<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d12" for="edge" attr.name="id" attr.type="string" />
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Frontend</data>
      <data key="d6">UserConsumerWebMobile</data>
      <data key="d7">Represents end-user interactions via web and mobile applications (e.g., loyalty app, mall Wi-Fi), connecting to the MetaManager.</data>
    </node>
    <node id="1">
      <data key="d5">Multiple Data Sources</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Various data sources (e.g., different networks, countries, technologies) providing raw data for collection into the data grid.</data>
    </node>
    <node id="2">
      <data key="d5">Applications</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Other internal company applications that consume from APIs, contribute data, and receive feedback/campaigns from the data grid.</data>
    </node>
    <node id="3">
      <data key="d5">MetaManager</data>
      <data key="d6">EKS</data>
      <data key="d7">The 'brains of the grid' running a microservice architecture on EKS. Its main goal is to abstract the complexity of data movement and apply data protection policies. It also orchestrates customer engagement.</data>
    </node>
    <node id="4">
      <data key="d5">Elasticsearch NEO4J</data>
      <data key="d6">OpenSearch</data>
      <data key="d7">Used by MetaManager to discover and store meta-information (tables, schemas, APIs) about the data. Described as a 'MetaStore' which is a combination of document and graph database.</data>
    </node>
    <node id="5">
      <data key="d5">Kafka</data>
      <data key="d6">MSK</data>
      <data key="d7">An enterprise streaming platform used to bring data from various sources into the data lake. Handles approximately 600 topics, 250 gigabytes of data with an average retention period of seven days.</data>
    </node>
    <node id="6">
      <data key="d5">EMR</data>
      <data key="d6">EMR</data>
      <data key="d7">Used in combination with Kafka to process and bring data into the centralized data lake.</data>
    </node>
    <node id="7">
      <data key="d5">Data Lake</data>
      <data key="d6">S3</data>
      <data key="d7">Centralized data lake storing all collected data, around 60 terabytes today. All data in and out of the data lake needs protection.</data>
    </node>
    <node id="8">
      <data key="d5">RDS</data>
      <data key="d6">RDS</data>
      <data key="d7">A data store for consuming data from the data lake, used by data analysts and data scientists for traditional analytics.</data>
    </node>
    <node id="9">
      <data key="d5">Vertica</data>
      <data key="d6">EC2</data>
      <data key="d7">A data store (Vertica, a columnar database) running on EC2 instances for consuming data from the data lake, used by data analysts and data scientists for traditional analytics.</data>
    </node>
    <node id="10">
      <data key="d5">DA/DS</data>
      <data key="d6">UserCompanyAnalyst</data>
      <data key="d7">Data Analysts and Data Scientists who consume data from RDS and Vertica, run models, and create dashboards.</data>
    </node>
    <edge source="0" target="3">
      <data key="d8">0</data>
      <data key="d9">Frontend connection to MetaManager as the initial point of contact for the grid.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="1" target="3">
      <data key="d8">0</data>
      <data key="d9">MetaManager discovers tables, schemas, and APIs from various data sources.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="1" target="5">
      <data key="d8">0</data>
      <data key="d9">Data from multiple sources is brought into the data lake via Kafka (MSK).</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="2" target="5">
      <data key="d8">0</data>
      <data key="d9">Applications consume APIs and send data to the enterprise streaming platform (Kafka/MSK).</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="2" target="6">
      <data key="d8">0</data>
      <data key="d9">Applications directly interact with EMR for data processing (from diagram).</data>
      <data key="d10">5</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="2" target="3">
      <data key="d8">1</data>
      <data key="d9">Other applications consume APIs from the MetaManager and feed data back into the system.</data>
      <data key="d10">10</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="3" target="4">
      <data key="d8">0</data>
      <data key="d9">MetaManager stores discovered meta information in the MetaStore (Elasticsearch NEO4J).</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="3" target="5">
      <data key="d8">1</data>
      <data key="d9">MetaManager orchestrates and interacts with Kafka (MSK) as part of the enterprise streaming platform for connecting back to business.</data>
      <data key="d10">1</data>
      <data key="d11">meta</data>
      <data key="d12">0</data>
    </edge>
    <edge source="3" target="6">
      <data key="d8">1</data>
      <data key="d9">MetaManager orchestrates and controls EMR jobs related to data processing and flow.</data>
      <data key="d10">2</data>
      <data key="d11">meta</data>
      <data key="d12">0</data>
    </edge>
    <edge source="3" target="7">
      <data key="d8">1</data>
      <data key="d9">MetaManager orchestrates and controls aspects of the S3 data lake.</data>
      <data key="d10">3</data>
      <data key="d11">meta</data>
      <data key="d12">0</data>
    </edge>
    <edge source="3" target="0">
      <data key="d8">1</data>
      <data key="d9">MetaManager provides push notifications to end-users (e.g., free popcorn vouchers, loyalty services).</data>
      <data key="d10">8</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="3" target="2">
      <data key="d8">1</data>
      <data key="d9">MetaManager connects back to business applications for cross-campaigns and feedback.</data>
      <data key="d10">9</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="5" target="6">
      <data key="d8">0</data>
      <data key="d9">Kafka (MSK) streams data to EMR for processing as part of ingestion.</data>
      <data key="d10">6</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="5" target="7">
      <data key="d8">0</data>
      <data key="d9">Kafka (MSK) streams data directly into the S3 data lake.</data>
      <data key="d10">7</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="6" target="7">
      <data key="d8">0</data>
      <data key="d9">Processed data from EMR is stored in the S3 data lake.</data>
      <data key="d10">8</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="7" target="3">
      <data key="d8">1</data>
      <data key="d9">MetaManager applies data protection policies on data from the S3 data lake.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="7" target="8">
      <data key="d8">1</data>
      <data key="d9">Data from the S3 data lake is sent to RDS for consumption.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="7" target="9">
      <data key="d8">1</data>
      <data key="d9">Data from the S3 data lake is sent to Vertica (on EC2) for consumption.</data>
      <data key="d10">5</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="8" target="10">
      <data key="d8">1</data>
      <data key="d9">Data analysts and data scientists consume data from RDS.</data>
      <data key="d10">6</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="9" target="10">
      <data key="d8">1</data>
      <data key="d9">Data analysts and data scientists consume data from Vertica (on EC2).</data>
      <data key="d10">7</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <data key="d0">Majid Al Futtaim: Building a Custom Data Management Solution on AWS</data>
    <data key="d1">https://www.youtube.com/watch?v=9qTEHITVeLE</data>
    <data key="d2">Majid Al Futtaim's data grid architecture addresses three pillars: collecting, protecting, and connecting data. It provides a 360-degree view of customers by consolidating data from various sources (e.g., mall parking, Wi-Fi, loyalty apps) and enabling cross-campaigns like personalized push notifications. The architecture is built with a DevOps approach, allowing infrastructure to be spun up and down as code, and an MVP was delivered in six months.</data>
    <data key="d3">data_ingestion, interactive, compute_intensive, control</data>
    <data key="d4">True</data>
  </graph>
</graphml>
