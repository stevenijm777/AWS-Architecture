<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Students</data>
      <data key="d6">UserConsumerWebMobile</data>
      <data key="d7">Students access the application via mobile devices and web browsers.</data>
    </node>
    <node id="1">
      <data key="d5">DNS</data>
      <data key="d6">Route53</data>
      <data key="d7">Used as the DNS service for the application.</data>
    </node>
    <node id="2">
      <data key="d5">CDN</data>
      <data key="d6">CloudFront</data>
      <data key="d7">Used to reduce latency by preloading static/cached content, as the main architecture is in Virginia.</data>
    </node>
    <node id="3">
      <data key="d5">Static Content &amp; Data Lake Storage</data>
      <data key="d6">S3</data>
      <data key="d7">Stores static content, cached content, images, videos, logs for CloudFront. Also serves as an intermediate storage layer for the data lake.</data>
    </node>
    <node id="4">
      <data key="d5">Elastic Load Balancing</data>
      <data key="d6">ELB</data>
      <data key="d7">Handles incoming requests to the EKS cluster.</data>
    </node>
    <node id="5">
      <data key="d5">Microservices Cluster</data>
      <data key="d6">EKS</data>
      <data key="d7">WORKLOAD_PEEK: Runs approximately 60 microservices, splitting from a monolithic application. Handles application logic, such as enrollment renewal.</data>
    </node>
    <node id="6">
      <data key="d5">Caching Layer</data>
      <data key="d6">ElastiCache</data>
      <data key="d7">Used by microservices to load data, acting as a cache.</data>
    </node>
    <node id="7">
      <data key="d5">Evaluation Databases</data>
      <data key="d6">RDS</data>
      <data key="d7">DATA_PEEK: Primary evaluation database. There are around 20 different databases, with 3 specifically for the enrollment renewal microservice.</data>
    </node>
    <node id="8">
      <data key="d5">ETL Service</data>
      <data key="d6">Glue</data>
      <data key="d7">Used for ETL operations to load data from RDS into the data lake.</data>
    </node>
    <node id="9">
      <data key="d5">Data Warehouse</data>
      <data key="d6">RedShift</data>
      <data key="d7">Receives structured and non-structured data for analytics and running AI algorithms.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">Students log into the application, initiating a DNS lookup.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">Route 53 directs requests for cached/static content to CloudFront.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="4" id="0">
      <data key="d8">0</data>
      <data key="d9">Route 53 directs requests for dynamic application content to ELB.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="3" id="0">
      <data key="d8">0</data>
      <data key="d9">CloudFront fetches static content, cached data, and images from S3.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="9" id="0">
      <data key="d8">2</data>
      <data key="d9">Data is then loaded from S3 into Redshift for data warehousing.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="5" id="0">
      <data key="d8">0</data>
      <data key="d9">ELB forwards dynamic requests to the EKS cluster running microservices.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="6" id="0">
      <data key="d8">1</data>
      <data key="d9">EKS microservices attempt to load data from ElastiCache first.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="7" id="0">
      <data key="d8">1</data>
      <data key="d9">If data is not in ElastiCache, EKS microservices connect to RDS to load the data.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="7" target="8" id="0">
      <data key="d8">2</data>
      <data key="d9">Glue loads data from RDS as part of the data lake ingestion process.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="8" target="3" id="0">
      <data key="d8">2</data>
      <data key="d9">Glue sends processed data to S3 as an intermediate staging area for the data lake.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">Anima Educação - EKS Microservices and Data Lake Architecture</data>
    <data key="d1">https://www.youtube.com/watch?v=9yziTe6lBwk</data>
    <data key="d2">Anima Educação transitioned from an on-premises monolithic application to AWS, leveraging EKS for microservices and building a data lake for analytics. The main application is hosted in Virginia, using CloudFront to reduce latency for users in Brazil. The EKS cluster hosts approximately 60 microservices. Data from operational databases (RDS) is ingested into a data lake for analytics and AI algorithms.</data>
    <data key="d3">data_ingestion, interactive, compute_intensive</data>
    <data key="d4">True</data>
  </graph>
</graphml>
