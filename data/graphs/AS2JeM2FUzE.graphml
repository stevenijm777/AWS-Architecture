<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">External Data Sources</data>
      <data key="d6">UserCompanyDataStream</data>
      <data key="d7">Three types: crawled data (social media, wellness, regulatory, company data), premium connectors (processed data), and customized connectors for specific carriers.</data>
    </node>
    <node id="1">
      <data key="d5">Elastic Load Balancer</data>
      <data key="d6">ELB</data>
      <data key="d7">Ingestion point for all incoming data from various sources. Fans out requests based on the number of data sources being crawled or connected.</data>
    </node>
    <node id="2">
      <data key="d5">Kubernetes Cluster</data>
      <data key="d6">EC2</data>
      <data key="d7">Self-managed Kubernetes cluster running on EC2 instances. Hosts multiple microservices including: crawler service, JSON mapper, Ddupe service, Keycloak (for authentication), Kong API Gateway (for consumer access), and Jupyter notebooks (for ML algorithms). WORKLOAD_PEEK: Processes 1 to 2 million messages at any point in time. Provides pod-level auto-scaling.</data>
    </node>
    <node id="3">
      <data key="d5">Amazon MQ</data>
      <data key="d6">AmazonMQ</data>
      <data key="d7">Used to loosely couple microservices within the Kubernetes cluster. Data is pushed here due to different latency factors, facilitating a processing pipeline.</data>
    </node>
    <node id="4">
      <data key="d5">MongoDB Atlas</data>
      <data key="d6">MongoDBAtlas</data>
      <data key="d7">Stores the processed and analyzed data. This is a third-party managed MongoDB solution hosted on AWS, connected to the Kubernetes cluster via VPC peering. Previously, MongoDB was self-managed on EC2 instances.</data>
    </node>
    <node id="5">
      <data key="d5">Insurance Carriers/Underwriters</data>
      <data key="d6">UserCompanyAnalyst</data>
      <data key="d7">The primary clients of Intellect Design. Includes underwriters, agents, policy agents, and various insurance carriers who consume data and insights.</data>
    </node>
    <node id="6">
      <data key="d5">Postgres RDS</data>
      <data key="d6">RDS</data>
      <data key="d7">Managed Postgres database. Used by the Keycloak microservice (running in Kubernetes) for authentication purposes. Provides auto-scaling capabilities.</data>
    </node>
    <node id="7">
      <data key="d5">Redis Cache</data>
      <data key="d6">ElastiCache</data>
      <data key="d7">Used for cache management and user session management. Supports the 200+ microservices within the Kubernetes cluster for scalable session handling.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">Various external data sources are crawled and connected to the platform's entry point.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">The ELB fans out the ingested data to multiple microservices running within the Kubernetes cluster.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="3" id="0">
      <data key="d8">0</data>
      <data key="d9">Kubernetes microservices (e.g., crawler, JSON mapper, Ddupe) push raw or partially processed data to Amazon MQ for queueing and loose coupling.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="4" id="0">
      <data key="d8">0</data>
      <data key="d9">Processed and analyzed data from the Kubernetes ML pipeline is pushed to MongoDB Atlas for persistent storage, leveraging VPC peering for secure connectivity.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="4" id="1">
      <data key="d8">1</data>
      <data key="d9">Kubernetes microservices query and retrieve processed entity data from MongoDB Atlas (via VPC peering) to serve consumer requests.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="6" id="0">
      <data key="d8">1</data>
      <data key="d9">The Keycloak microservice (within K8s) uses Postgres RDS for authentication of consumer requests.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="6" id="1">
      <data key="d8">1</data>
      <data key="d9">Kubernetes microservices retrieve authentication or configuration data from Postgres RDS.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="7" id="0">
      <data key="d8">1</data>
      <data key="d9">Various microservices within the Kubernetes cluster interact with ElastiCache (Redis) for cache management and user session management.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="7" id="1">
      <data key="d8">1</data>
      <data key="d9">Kubernetes microservices retrieve cached data from ElastiCache (Redis) for faster response times.</data>
      <data key="d10">5</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">The Kubernetes cluster's ML pipeline (using Jupyter notebooks) consumes messages from Amazon MQ for data cleansing, triangulation, contextual, and sentiment analysis.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="2" id="0">
      <data key="d8">1</data>
      <data key="d9">Consumers (underwriters, agents) connect to the Kubernetes cluster via the Kong API Gateway microservice.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">Intellect Fabric Data Service Architecture</data>
    <data key="d1">https://www.youtube.com/watch?v=AS2JeM2FUzE</data>
    <data key="d2">Intellect Design's FinTech and Insutech platform processes and analyzes diverse data sources (2000+) for insurance carriers, providing entity scores for risk analysis. The architecture leverages a self-managed Kubernetes cluster on EC2 for microservices and ML, with Amazon MQ for loose coupling and MongoDB Atlas for data persistence. Future plans include migration to EKS, SageMaker, and DocumentDB, focusing on managed and serverless solutions to reduce operational overhead.</data>
    <data key="d3">data_ingestion, interactive, compute_intensive</data>
    <data key="d4">True</data>
  </graph>
</graphml>
