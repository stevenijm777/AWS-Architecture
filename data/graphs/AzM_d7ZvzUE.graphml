  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Client Lambda</data>
      <data key="d6">Lambda</data>
      <data key="d7">WORKLOAD_PEEK: Monitored function in customer account running billions of times monthly.</data>
    </node>
    <node id="1">
      <data key="d5">Ingestion Kinesis</data>
      <data key="d6">Kinesis</data>
      <data key="d7">DATA_PEEK: Streams filtered CloudWatch logs from customer account.</data>
    </node>
    <node id="2">
      <data key="d5">Transform Lambda</data>
      <data key="d6">Lambda</data>
      <data key="d7">Extracts log records into structured invocation records.</data>
    </node>
    <node id="3">
      <data key="d5">Customer Metadata DB</data>
      <data key="d6">DynamoDB</data>
      <data key="d7">Stores metadata about customer functions and partial invocation details.</data>
    </node>
    <node id="4">
      <data key="d5">Invocation Records Kinesis</data>
      <data key="d6">Kinesis</data>
      <data key="d7">Streams uniform parsed invocation records.</data>
    </node>
    <node id="5">
      <data key="d5">Aurora Writer Lambda</data>
      <data key="d6">Lambda</data>
      <data key="d7">Writes records to Aurora. Managed concurrency prevents database connection exhaustion.</data>
    </node>
    <node id="6">
      <data key="d5">Serverless Aurora</data>
      <data key="d6">Aurora</data>
      <data key="d7">Optimized database for fast single-item invocation queries.</data>
    </node>
    <node id="7">
      <data key="d5">Firehose Parquet Converter</data>
      <data key="d6">Firehose</data>
      <data key="d7">Batches incoming records and converts them to Parquet.</data>
    </node>
    <node id="8">
      <data key="d5">Glue Data Catalog</data>
      <data key="d6">Glue</data>
      <data key="d7">Provides structural schema definition for Firehose Parquet conversion.</data>
    </node>
    <node id="9">
      <data key="d5">S3 Data Lake</data>
      <data key="d6">S3</data>
      <data key="d7">Optimized storage bucket for long-term telemetry analysis.</data>
    </node>
    <node id="10">
      <data key="d5">Athena Query Engine</data>
      <data key="d6">Athena</data>
      <data key="d7">Performs fast aggregated queries over S3 telemetry.</data>
    </node>
    <node id="11">
      <data key="d5">Epsagon UI Developer</data>
      <data key="d6">UserCompanyDeveloper</data>
      <data key="d7">Represents the user or internal developer querying monitoring metrics.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">Sends log data via CloudWatch integration.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">Triggers transform function.</data>
