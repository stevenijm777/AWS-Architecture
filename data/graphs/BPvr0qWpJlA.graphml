  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Caller Carrie</data>
      <data key="d6">UserConsumerWebMobile</data>
      <data key="d7">End customer initiating voice call, chat, or email.</data>
    </node>
    <node id="1">
      <data key="d5">Agent Andy</data>
      <data key="d6">UserCompanyAgent</data>
      <data key="d7">Contact center agent accessing platform via browser.</data>
    </node>
    <node id="2">
      <data key="d5">Amazon Connect</data>
      <data key="d6">Connect</data>
      <data key="d7">Manages voice and chat customer flows.</data>
    </node>
    <node id="3">
      <data key="d5">Connect Contact Flows</data>
      <data key="d6">Lambda</data>
      <data key="d7">Determines call routing logic and self-service automation.</data>
    </node>
    <node id="4">
      <data key="d5">ContactSuite &amp; KB SenseIQ</data>
      <data key="d6">EC2</data>
      <data key="d7">Runs on EC2 ASG; provides the agent desktop and knowledge base.</data>
    </node>
    <node id="5">
      <data key="d5">ECS Microservices</data>
      <data key="d6">ECS</data>
      <data key="d7">Microservices platform executing business logic and integrations.</data>
    </node>
    <node id="6">
      <data key="d5">External CRMs</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">CRMs like Salesforce or Siebel.</data>
    </node>
    <node id="7">
      <data key="d5">DynamoDB</data>
      <data key="d6">DynamoDB</data>
      <data key="d7">Stores Connect/Lambda IVR states and dynamic configurations.</data>
    </node>
    <node id="8">
      <data key="d5">RDS Database</data>
      <data key="d6">RDS</data>
      <data key="d7">Relational datastore for ContactSuite backend services.</data>
    </node>
    <node id="9">
      <data key="d5">Amazon SES</data>
      <data key="d6">SES</data>
      <data key="d7">Ingests customer emails for routing.</data>
    </node>
    <edge source="0" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">Voice call or chat interaction.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="0" target="9" id="0">
      <data key="d8">2</data>
      <data key="d9">Sends email.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="4" id="0">
      <data key="d8">0</data>
      <data key="d9">Agent logs in and establishes session.</data>
      <data key="d10">6</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="0" id="0">
      <data key="d8">0</data>
      <data key="d9">Agent talks to caller.</data>
      <data key="d10">8</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="3" id="0">
      <data key="d8">0</data>
      <data key="d9">Triggers Lambda for routing logic.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="4" id="0">
      <data key="d8">0</data>
      <data key="d9">Delivers call context directly to ContactSuite.</data>
      <data key="d10">5</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="7" id="0">
      <data key="d8">0</data>
      <data key="d9">Queries database for customer history.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="2" id="0">
      <data key="d8">0</data>
