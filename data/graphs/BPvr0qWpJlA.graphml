  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Caller Carrie</data>
      <data key="d6">UserConsumerMobile</data>
      <data key="d7">Initiates voice calls, chats, or emails.</data>
    </node>
    <node id="1">
      <data key="d5">Amazon Connect</data>
      <data key="d6">Connect</data>
      <data key="d7">Handles contact flows, IVR, and chat/voice channels.</data>
    </node>
    <node id="2">
      <data key="d5">Contact Flow Lambda</data>
      <data key="d6">Lambda</data>
      <data key="d7">Determines call routing logic and automation triggers.</data>
    </node>
    <node id="3">
      <data key="d5">CRM Integration Microservices</data>
      <data key="d6">ECS</data>
      <data key="d7">WORKLOAD_PEEK: Handles CRM backend queries during active sessions.</data>
    </node>
    <node id="4">
      <data key="d5">External CRMs</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">CRM platforms such as Salesforce or Siebel.</data>
    </node>
    <node id="5">
      <data key="d5">ContactSuite Engine</data>
      <data key="d6">EC2</data>
      <data key="d7">Hosted on ELB, EC2, and ASG. Embeds SenseIQ KB and serves agent screens.</data>
    </node>
    <node id="6">
      <data key="d5">Agent Andy</data>
      <data key="d6">UserCompanyAgent</data>
      <data key="d7">Receives real-time browser screen pops and calls.</data>
    </node>
    <node id="7">
      <data key="d5">Amazon SES</data>
      <data key="d6">SES</data>
      <data key="d7">Receives customer inbound support emails.</data>
    </node>
    <node id="8">
      <data key="d5">Email Handler Lambda</data>
      <data key="d6">Lambda</data>
      <data key="d7">Processes and normalizes incoming emails for queue injection.</data>
    </node>
    <node id="9">
      <data key="d5">DynamoDB</data>
      <data key="d6">DynamoDB</data>
      <data key="d7">DATA_PEEK: Stores fast transactional, session, and state records.</data>
    </node>
    <node id="10">
      <data key="d5">RDS Database</data>
      <data key="d6">RDS</data>
      <data key="d7">DATA_PEEK: Relational store used for reporting and analytics.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">Caller initiates voice or chat session</data>
