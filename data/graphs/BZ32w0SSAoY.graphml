<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Web Browser</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Allows the user to log in, configure S3 settings, select workflows, and monitor jobs.</data>
    </node>
    <node id="1">
      <data key="d5">WEB SERVER / JOB MANAGER</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Hosts the web portal front-end and coordinates parallel video processing jobs.</data>
    </node>
    <node id="2">
      <data key="d5">DATABASE</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Caches the extracted video metadata and job configurations for the web UI.</data>
    </node>
    <node id="3">
      <data key="d5">S3</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">User-managed storage bucket containing input video files and receiving the processed outputs.</data>
    </node>
    <node id="4">
      <data key="d5">LAMBDA</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">An AWS Lambda function that retrieves technical metadata from video clips in the S3 bucket.</data>
    </node>
    <node id="5">
      <data key="d5">G3</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">GPU-accelerated EC2 instances handling video processing (wormhole, spacetime, dark energy) and encoding.</data>
    </node>
    <node id="6">
      <data key="d5">IMF</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">An EC2 compute node that wraps processed outputs into Interoperable Master Format for delivery.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">User connects via Web Browser to manage jobs and configure storage credentials.</data>
      <data key="d10">0</data>
      <data key="d11">control</data>
    </edge>
    <edge source="1" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">Job Manager stores and caches metadata in the database, allowing the Web Server to read and present it to the browser.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="4" id="0">
      <data key="d8">0</data>
      <data key="d9">AWS Lambda retrieves video clip metadata directly from the user's S3 bucket.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">Lambda forwards the retrieved clip metadata back to the Job Manager.</data>
      <data key="d10">2</data>
      <data key="d11">control</data>
    </edge>
    <edge source="5" target="3" id="0">
      <data key="d8">1</data>
      <data key="d9">The GPU-enabled G3 instances write the processed output video clips back to the user's S3 bucket.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">Cinefilm PixelStrings GPU-Accelerated Video Processing Architecture</data>
    <data key="d1">https://www.youtube.com/watch?v=BZ32w0SSAoY</data>
    <data key="d2">PixelStrings by Cinefilm uses a web-based portal to allow users to process video clips (retiming, de-interlacing, and noise reduction) using GPU-powered EC2 G3 instances, with automated metadata extraction powered by AWS Lambda and Amazon S3.</data>
    <data key="d3">compute_intensive, interactive, data_ingestion</data>
    <data key="d4">True</data>
  </graph>
</graphml>
