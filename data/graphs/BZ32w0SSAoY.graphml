<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Web Browser</data>
      <data key="d6">UserConsumerWeb</data>
      <data key="d7">User accesses the PixelStrings platform via Chrome.</data>
    </node>
    <node id="1">
      <data key="d5">Web Server &amp; Job Manager</data>
      <data key="d6">EC2</data>
      <data key="d7">Handles user login, database queries, and parallel job orchestration.</data>
    </node>
    <node id="2">
      <data key="d5">Database</data>
      <data key="d6">RDS</data>
      <data key="d7">Caches metadata. The web server reads from it to update the client UI.</data>
    </node>
    <node id="3">
      <data key="d5">S3 Bucket</data>
      <data key="d6">S3</data>
      <data key="d7">User-managed bucket storing input and output video clips.</data>
    </node>
    <node id="4">
      <data key="d5">Metadata Lambda</data>
      <data key="d6">Lambda</data>
      <data key="d7">Runs MediaInfo to fetch metadata from video clips in S3.</data>
    </node>
    <node id="5">
      <data key="d5">G3 GPU Instance (Asset Manager)</data>
      <data key="d6">EC2</data>
      <data key="d7">Runs GPU-accelerated workloads (Wormhole, Spacetime, Dark Energy).</data>
    </node>
    <node id="6">
      <data key="d5">IMF Wrapping Server</data>
      <data key="d6">EC2</data>
      <data key="d7">Formats finished video clips into Netflix-compatible Interoperable Master Format.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">User logs in and inputs S3 credentials.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="0" target="1" id="1">
      <data key="d8">1</data>
      <data key="d9">User submits processing job.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="0" target="1" id="2">
      <data key="d8">2</data>
      <data key="d9">User submits IMF wrapping workflow.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="4" id="0">
      <data key="d8">0</data>
      <data key="d9">Job Manager invokes Lambda to get video metadata.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">Job Manager caches metadata in the database.</data>
      <data key="d10">6</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="0" id="0">
      <data key="d8">0</data>
      <data key="d9">Web server retrieves cached metadata to show in browser.</data>
      <data key="d10">7</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="0" id="1">
      <data key="d8">1</data>
      <data key="d9">Job completed status updated on UI.</data>
      <data key="d10">5</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="0" id="2">
      <data key="d8">2</data>
      <data key="d9">Web UI displays job complete status.</data>
      <data key="d10">5</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="5" id="0">
      <data key="d8">1</data>
      <data key="d9">Job Manager tells Asset Manager on G3 to fetch the input clip.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="4" id="0">
      <data key="d8">0</data>
      <data key="d9">Returns file metadata to Lambda.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="5" id="0">
      <data key="d8">1</data>
      <data key="d9">Asset Manager copies clip from S3 to local G3 storage.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="5" id="1">
      <data key="d8">2</data>
      <data key="d9">Asset Manager fetches clip from S3.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="3" id="0">
      <data key="d8">0</data>
      <data key="d9">Lambda queries video files in S3.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">Lambda returns extracted metadata.</data>
      <data key="d10">5</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="3" id="0">
      <data key="d8">1</data>
      <data key="d9">Asset Manager copies processed output clip back to S3.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="6" id="0">
      <data key="d8">2</data>
      <data key="d9">Job Manager routes completed GPU output directly to IMF server.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="6" target="3" id="0">
      <data key="d8">2</data>
      <data key="d9">IMF wrap output copied back to customer S3 bucket.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">PixelStrings by Cinnafilm: A Flexible &amp; Scalable Platform for Video Audio Optimization &amp; Conversion</data>
    <data key="d1">https://youtu.be/BZ32w0SSAoY</data>
    <data key="d2">PixelStrings runs video processing (retiming, deinterlacing, noise removal) on GPU-enabled G3 EC2 instances, leveraging AWS Lambda to extract metadata and write to S3.</data>
    <data key="d3">compute_intensive, interactive</data>
    <data key="d4">True</data>
  </graph>
</graphml>
