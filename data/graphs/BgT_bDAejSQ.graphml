<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d12" for="edge" attr.name="id" attr.type="string" />
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">GoDaddy Developer</data>
      <data key="d6">UserCompanyDeveloper</data>
      <data key="d7">GoDaddy internal developers who initiate the application readiness process.</data>
    </node>
    <node id="1">
      <data key="d5">Public Cloud Portal</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Custom portal used by developers for AWS account provisioning and readiness reviews.</data>
    </node>
    <node id="2">
      <data key="d5">EKS Cluster (Env 1)</data>
      <data key="d6">EKS</data>
      <data key="d7">EKS cluster running within Account A (isolated dev environment 1). Rebuilds nodes every 24 hours.</data>
    </node>
    <node id="3">
      <data key="d5">NAT Gateway (Env 1)</data>
      <data key="d6">NAT</data>
      <data key="d7">Provides secure outbound-only internet access for EKS cluster in Env 1.</data>
    </node>
    <node id="4">
      <data key="d5">EKS Cluster (Env 2)</data>
      <data key="d6">EKS</data>
      <data key="d7">EKS cluster running within Account A (isolated dev environment 2). Rebuilds nodes every 24 hours.</data>
    </node>
    <node id="5">
      <data key="d5">NAT Gateway (Env 2)</data>
      <data key="d6">NAT</data>
      <data key="d7">Provides secure outbound-only internet access for EKS cluster in Env 2.</data>
    </node>
    <node id="6">
      <data key="d5">AWS Direct Connect</data>
      <data key="d6">DirectConnect</data>
      <data key="d7">Establishes a dedicated connection between AWS and GoDaddy's on-premises environment.</data>
    </node>
    <node id="7">
      <data key="d5">On-Premises Data Center</data>
      <data key="d6">OnPremDC</data>
      <data key="d7">GoDaddy internal data centers hosting on-premise services.</data>
    </node>
    <node id="8">
      <data key="d5">End User</data>
      <data key="d6">UserConsumerWeb</data>
      <data key="d7">Customers/end-users accessing the live GoDaddy application.</data>
    </node>
    <node id="9">
      <data key="d5">AWS WAF</data>
      <data key="d6">WAF</data>
      <data key="d7">Web Application Firewall protecting production workloads from web exploits.</data>
    </node>
    <node id="10">
      <data key="d5">Application Load Balancer</data>
      <data key="d6">ALB</data>
      <data key="d7">Distributes incoming traffic to the production EKS cluster.</data>
    </node>
    <node id="11">
      <data key="d5">EKS Cluster (Production)</data>
      <data key="d6">EKS</data>
      <data key="d7">Production EKS cluster hosting the application in Account B.</data>
    </node>
    <edge source="0" target="1">
      <data key="d8">0</data>
      <data key="d9">Developer triggers cloud review and account provisioning workflows.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="2" target="3">
      <data key="d8">1</data>
      <data key="d9">EKS Env 1 traffic routed to external resources via NAT Gateway.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="2" target="6">
      <data key="d8">3</data>
      <data key="d9">EKS Env 1 routes traffic through Direct Connect to access on-prem databases/services.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="4" target="5">
      <data key="d8">2</data>
      <data key="d9">EKS Env 2 traffic routed to external resources via NAT Gateway.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="4" target="6">
      <data key="d8">3</data>
      <data key="d9">EKS Env 2 routes traffic through Direct Connect to access on-prem databases/services.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="6" target="7">
      <data key="d8">3</data>
      <data key="d9">Traffic arrives at GoDaddy On-Premises Data Center.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="8" target="9">
      <data key="d8">4</data>
      <data key="d9">End-user requests pass through AWS WAF.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="9" target="10">
      <data key="d8">4</data>
      <data key="d9">WAF-approved traffic is forwarded to the Application Load Balancer.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="10" target="11">
      <data key="d8">4</data>
      <data key="d9">ALB routes the production traffic to the Production EKS Cluster.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <data key="d0">GoDaddy: Empowering Agility with ZeroTrust Environment Best Practices</data>
    <data key="d1">https://www.youtube.com/watch?v=BgT_bDAejSQ</data>
    <data key="d2">GoDaddy's multi-account architecture isolates environments into distinct AWS accounts to minimize the blast radius. It restricts lateral movement by disabling VPC peering, forcing communication to flow either through NAT Gateways or secure AWS Direct Connect to the on-premises DC. EKS nodes are automatically rotated every 24 hours using golden AMIs for strong security posture.</data>
    <data key="d3">control, interactive</data>
    <data key="d4">True</data>
  </graph>
</graphml>
