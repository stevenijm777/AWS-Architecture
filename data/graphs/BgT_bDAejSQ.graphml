<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">GoDaddy Developer</data>
      <data key="d6">UserCompanyDeveloper</data>
      <data key="d7">Uses the cloud readiness portal to provision and manage applications.</data>
    </node>
    <node id="1">
      <data key="d5">Public Cloud Portal</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Self-service developer portal implementing AWS Well-Architected readiness reviews.</data>
    </node>
    <node id="2">
      <data key="d5">NAT Gateway (Dev VPC)</data>
      <data key="d6">VPC</data>
      <data key="d7">Handles outbound-only traffic for private resources in the Dev VPC.</data>
    </node>
    <node id="3">
      <data key="d5">EKS Cluster (Dev)</data>
      <data key="d6">EKS</data>
      <data key="d7">WORKLOAD_PEEK: Runs development containers with nodes rotated every 24 hours.</data>
    </node>
    <node id="4">
      <data key="d5">NAT Gateway (CI/CD VPC)</data>
      <data key="d6">VPC</data>
      <data key="d7">Handles outbound-only traffic for private resources in the CI/CD VPC.</data>
    </node>
    <node id="5">
      <data key="d5">EKS Cluster (CI/CD)</data>
      <data key="d6">EKS</data>
      <data key="d7">The only authorized workspace allowed to execute deployments into other accounts.</data>
    </node>
    <node id="6">
      <data key="d5">Direct Connect</data>
      <data key="d6">DirectConnect</data>
      <data key="d7">Provides secure, private hybrid connectivity to GoDaddy's on-premises systems.</data>
    </node>
    <node id="7">
      <data key="d5">AWS WAF</data>
      <data key="d6">WAF</data>
      <data key="d7">Protects production workloads from web exploits.</data>
    </node>
    <node id="8">
      <data key="d5">Application Load Balancer</data>
      <data key="d6">ELB</data>
      <data key="d7">Distributes incoming production traffic to EKS services.</data>
    </node>
    <node id="9">
      <data key="d5">EKS Cluster (Prod)</data>
      <data key="d6">EKS</data>
      <data key="d7">WORKLOAD_PEEK: Production workloads running under isolated, zero-trust rules.</data>
    </node>
    <node id="10">
      <data key="d5">End User</data>
      <data key="d6">UserConsumerWebMobile</data>
      <data key="d7">Accesses production applications hosted on GoDaddy.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">Developer logs in to portal to trigger cloud environment provisioning.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="0" id="0">
      <data key="d8">0</data>
      <data key="d9">Portal provides visibility into the setup phase and workspace details.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="6" id="0">
      <data key="d8">1</data>
      <data key="d9">Forwards traffic to on-premises resources via Direct Connect.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="3" id="0">
      <data key="d8">1</data>
      <data key="d9">Delivers secure response back to EKS private pods.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="2" id="0">
      <data key="d8">1</data>
      <data key="d9">Private development EKS pods initiate outbound calls.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="3" id="0">
      <data key="d8">2</data>
      <data key="d9">CI/CD pipeline securely performs deployments into isolated Dev environments.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="6" target="2" id="0">
      <data key="d8">1</data>
      <data key="d9">On-premise response payload sent back.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="7" target="8" id="0">
      <data key="d8">3</data>
      <data key="d9">WAF forwards inspected, clean traffic to ALB.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="8" target="9" id="0">
      <data key="d8">3</data>
      <data key="d9">ALB routes request to production EKS container target groups.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="8" target="10" id="0">
      <data key="d8">3</data>
      <data key="d9">Sends application response back to customer.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <edge source="9" target="8" id="0">
      <data key="d8">3</data>
      <data key="d9">EKS processes requests and returns data response.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="10" target="7" id="0">
      <data key="d8">3</data>
      <data key="d9">End-user traffic targeted at production web services.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">GoDaddy Multi-Account EKS Security Architecture</data>
    <data key="d1">https://www.youtube.com/watch?v=BgT_bDAejSQ</data>
    <data key="d2">Ensures zero-trust and containment by avoiding VPC peering, using account isolation, and rebuilding EKS nodes every 24 hours via a golden AMI.</data>
    <data key="d3">compute_intensive, interactive</data>
    <data key="d4">True</data>
  </graph>
</graphml>
