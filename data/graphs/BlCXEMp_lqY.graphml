    <edge source="2" target="4" id="0">
      <data key="d8">0</data>
      <data key="d9">Loads subset of columns</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="5" id="0">
      <data key="d8">1</data>
      <data key="d9">Returns requested aggregated datasets</data>
