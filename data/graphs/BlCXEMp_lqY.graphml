<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Smart TVs</data>
      <data key="d6">UserConsumerTV</data>
      <data key="d7">WORKLOAD_PEEK: Millions of connected devices generating billions of events per month (logs, performance telemetry, and user data).</data>
    </node>
    <node id="1">
      <data key="d5">Kinesis Data Stream</data>
      <data key="d6">Kinesis</data>
      <data key="d7">Runs an 8-shard stream acting as the front door for all TV telemetry data.</data>
    </node>
    <node id="2">
      <data key="d5">Kinesis Firehose</data>
      <data key="d6">Firehose</data>
      <data key="d7">Handles ingestion as-is without sticking to a rigid schema, distributing data to both S3 and Redshift.</data>
    </node>
    <node id="3">
      <data key="d5">S3 Raw Store</data>
      <data key="d6">S3</data>
      <data key="d7">DATA_PEEK: Serves as a cheap, long-term raw data store for future use and potential database reloads.</data>
    </node>
    <node id="4">
      <data key="d5">Amazon Redshift</data>
      <data key="d6">RedShift</data>
      <data key="d7">Columnar data warehouse optimized for running aggregations over billions of rows.</data>
    </node>
    <node id="5">
      <data key="d5">Amazon QuickSight</data>
      <data key="d6">QuickSight</data>
      <data key="d7">Visualizes data using its in-memory SPICE database with custom SQL queries for snappy dashboard performance.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">TVs post logs, performance data, and app utilization.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">Pipes stream events to Firehose.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="3" id="0">
      <data key="d8">0</data>
      <data key="d9">Archives raw, unfiltered data to S3.</data>
      <data key="d10">2a</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="4" id="0">
      <data key="d8">0</data>
      <data key="d9">Dumps a subset of formatted columns into Redshift for analytics.</data>
      <data key="d10">2b</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="5" id="0">
      <data key="d8">0</data>
      <data key="d9">Fetches analytical datasets into SPICE database for visualization.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">Vizio Telemetry Analytics Architecture</data>
    <data key="d1">https://www.youtube.com/watch?v=BlCXEMp_lqY</data>
    <data key="d2">Ingests billions of telemetry events per month from millions of connected smart TVs. Uses a simple, schema-less raw ingestion flow backed by Redshift and QuickSight Spice for rapid reporting.</data>
    <data key="d3">data_ingestion, interactive</data>
    <data key="d4">True</data>
  </graph>
</graphml>
