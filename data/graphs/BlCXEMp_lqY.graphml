  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Smart TVs</data>
      <data key="d6">UserConsumerTV</data>
      <data key="d7">Generates logs, performance telemetry, and user app-usage data.</data>
    </node>
    <node id="1">
      <data key="d5">Kinesis Data Streams</data>
      <data key="d6">Kinesis</data>
      <data key="d7">WORKLOAD_PEEK: Configured with 8 shards to ingest billions of events.</data>
    </node>
    <node id="2">
      <data key="d5">Kinesis Firehose</data>
      <data key="d6">Firehose</data>
      <data key="d7">Handles ingestion delivery to both S3 and Redshift.</data>
    </node>
    <node id="3">
      <data key="d5">S3 Data Store</data>
      <data key="d6">S3</data>
      <data key="d7">DATA_PEEK: Stores raw telemetry indefinitely as an affordable archive.</data>
    </node>
    <node id="4">
      <data key="d5">Amazon Redshift</data>
      <data key="d6">RedShift</data>
      <data key="d7">Columnar data warehouse optimized for large aggregates on subset columns.</data>
    </node>
    <node id="5">
      <data key="d5">Amazon QuickSight</data>
      <data key="d6">QuickSight</data>
      <data key="d7">Uses in-memory SPICE database to provide fast dashboards.</data>
    </node>
    <node id="6">
      <data key="d5">Vizio Analysts</data>
      <data key="d6">UserCompanyAnalyst</data>
      <data key="d7">Consumes telemetry insights and generates business reports.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">Streams raw telemetry logs</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="0" id="0">
      <data key="d8">0</data>
      <data key="d9">Ingest acknowledgment</data>
