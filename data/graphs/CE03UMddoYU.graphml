<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Water Sensors</data>
      <data key="d6">UserConsumerIOT</data>
      <data key="d7">WORKLOAD_PEEK: 100k IoT water meters emitting three generations of protocol variants.</data>
    </node>
    <node id="1">
      <data key="d5">Ingestion API Gateway</data>
      <data key="d6">ApiGateway</data>
      <data key="d7">First point of contact for utility telemetry data ingestion.</data>
    </node>
    <node id="2">
      <data key="d5">Transformer Lambda</data>
      <data key="d6">Lambda</data>
      <data key="d7">DATA_PEEK: Streamlines multiple sensor protocols into a standard format, splitting into flow and alarm segments.</data>
    </node>
    <node id="3">
      <data key="d5">FIFO Queues</data>
      <data key="d6">SQS</data>
      <data key="d7">Buffers decoupled telemetry data segments to preserve strict chronological ordering.</data>
    </node>
    <node id="4">
      <data key="d5">Pre-processor Lambda</data>
      <data key="d6">Lambda</data>
      <data key="d7">DATA_PEEK: Determines in real-time which data points are useful. Drops ~60% of unnecessary idle utility records.</data>
    </node>
    <node id="5">
      <data key="d5">In-Memory Redis Cache</data>
      <data key="d6">ElastiCache</data>
      <data key="d7">Stores active state of sensors to support instant deduplication and filtering decisions in the pre-processor.</data>
    </node>
    <node id="6">
      <data key="d5">Post-processor Engine</data>
      <data key="d6">EC2</data>
      <data key="d7">Runs a suite of continuous processing jobs to summarize the allowed 40% of telemetry events.</data>
    </node>
    <node id="7">
      <data key="d5">Aurora Serverless MySQL</data>
      <data key="d6">Aurora</data>
      <data key="d7">DATA_PEEK: Stores summarized daily utility statistics, aggregates, and critical alerts.</data>
    </node>
    <node id="8">
      <data key="d5">Event Log Store</data>
      <data key="d6">DynamoDB</data>
      <data key="d7">DATA_PEEK: Stores discrete source/inlet event timestamps, such as water lorry deliveries and borewell triggers.</data>
    </node>
    <node id="9">
      <data key="d5">Web API Portal Gateway</data>
      <data key="d6">ApiGateway</data>
      <data key="d7">Serves end-user consumption metrics and optimization alerts to web and mobile apps.</data>
    </node>
    <node id="10">
      <data key="d5">Web and Mobile Users</data>
      <data key="d6">UserConsumerWebMobile</data>
      <data key="d7">Property managers and residents viewing water consumption dashboards and sustainability reports.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">Sensors push telemetry payloads.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">Triggers transformer to normalize protocols.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="0" id="0">
      <data key="d8">0</data>
      <data key="d9">Closes HTTP connection back to sensor.</data>
      <data key="d10">4</data>
      <data key="d11">meta</data>
    </edge>
    <edge source="2" target="3" id="0">
      <data key="d8">0</data>
      <data key="d9">Pushes normalized segment payloads into SQS FIFO queues.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">Ingestion request synchronous response acknowledgment.</data>
      <data key="d10">3</data>
      <data key="d11">meta</data>
    </edge>
    <edge source="3" target="4" id="0">
      <data key="d8">0</data>
      <data key="d9">Pre-processor polls messages sequentially.</data>
      <data key="d10">5</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="5" id="0">
      <data key="d8">0</data>
      <data key="d9">Queries sensor states to evaluate data relevance.</data>
      <data key="d10">6</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="6" id="0">
      <data key="d8">0</data>
      <data key="d9">Forwards 40% of relevant utility events.</data>
      <data key="d10">8</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="4" id="0">
      <data key="d8">0</data>
      <data key="d9">Returns current sensor threshold/state metadata.</data>
      <data key="d10">7</data>
      <data key="d11">data</data>
    </edge>
    <edge source="6" target="7" id="0">
      <data key="d8">0</data>
      <data key="d9">Writes daily summarized statistics.</data>
      <data key="d10">9</data>
      <data key="d11">data</data>
    </edge>
    <edge source="6" target="8" id="0">
      <data key="d8">0</data>
      <data key="d9">Writes discrete transactional events.</data>
      <data key="d10">10</data>
      <data key="d11">data</data>
    </edge>
    <edge source="7" target="9" id="0">
      <data key="d8">1</data>
      <data key="d9">Returns requested daily stats.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="8" target="9" id="0">
      <data key="d8">1</data>
      <data key="d9">Returns requested event entries.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <edge source="9" target="7" id="0">
      <data key="d8">1</data>
      <data key="d9">Fetches daily utility summaries.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="9" target="8" id="0">
      <data key="d8">1</data>
      <data key="d9">Fetches discrete sensor/source event records.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="9" target="10" id="0">
      <data key="d8">1</data>
      <data key="d9">Aggregates and delivers the formatted dashboard data to the user.</data>
      <data key="d10">5</data>
      <data key="d11">data</data>
    </edge>
    <edge source="10" target="9" id="0">
      <data key="d8">1</data>
      <data key="d9">Requests metrics dashboards or reports.</data>
      <data key="d10">0</data>
