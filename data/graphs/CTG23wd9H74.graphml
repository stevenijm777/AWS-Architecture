  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">3M Scientists &amp; Engineers</data>
      <data key="d6">UserCompanyDomainExpert</data>
      <data key="d7">End users running simulations and developers publishing models.</data>
    </node>
    <node id="1">
      <data key="d5">CDN &amp; Entry Point</data>
      <data key="d6">CloudFront</data>
      <data key="d7">Delivers the SPA and handles ingress routing.</data>
    </node>
    <node id="2">
      <data key="d5">Lambda@Edge Auth</data>
      <data key="d6">Lambda</data>
      <data key="d7">Authenticates requests with external identity provider.</data>
    </node>
    <node id="3">
      <data key="d5">App &amp; Data Storage</data>
      <data key="d6">S3</data>
      <data key="d7">Hosts static SPA assets and receives simulation results.</data>
    </node>
    <node id="4">
      <data key="d5">API Gateway</data>
      <data key="d6">ApiGateway</data>
      <data key="d7">Secures and routes frontend API requests.</data>
    </node>
    <node id="5">
      <data key="d5">API Layer (Fargate)</data>
      <data key="d6">ECS</data>
      <data key="d7">WORKLOAD_PEEK: Handles user requests, configurations, and job triggers.</data>
    </node>
    <node id="6">
      <data key="d5">Metadata Store</data>
      <data key="d6">DynamoDB</data>
      <data key="d7">DATA_PEEK: Holds frontend configurations and access management rules.</data>
    </node>
    <node id="7">
      <data key="d5">Git Repository</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Triggers publishing pipeline upon code commits.</data>
    </node>
    <node id="8">
      <data key="d5">CICD Orchestrator</data>
      <data key="d6">StepFunctions</data>
      <data key="d7">Coordinates model publishing workflow.</data>
    </node>
    <node id="9">
      <data key="d5">Publishing Workers</data>
      <data key="d6">Lambda</data>
      <data key="d7">Processes files and pushes definitions to HPC.</data>
    </node>
    <node id="10">
      <data key="d5">HPC Cluster</data>
      <data key="d6">EC2</data>
      <data key="d7">WORKLOAD_PEEK: Runs physics-based and ML model simulations.</data>
    </node>
