<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Snapchat Client (iOS/Android)</data>
      <data key="d6">UserConsumerWebMobile</data>
      <data key="d7">WORKLOAD_PEEK: Over 300 million daily active users interact with the app on iOS and Android devices.</data>
    </node>
    <node id="1">
      <data key="d5">Gateway</data>
      <data key="d6">EKS</data>
      <data key="d7">Acts as the primary API gateway for client applications. Described as an EKS service, handling incoming requests from mobile clients.</data>
    </node>
    <node id="2">
      <data key="d5">Media Delivery Service</data>
      <data key="d6">EKS</data>
      <data key="d7">Handles the processing, storage coordination, and delivery of snap content. Responsible for sending snap data to CloudFront and metadata to SnapDB. Runs on EKS clusters.</data>
    </node>
    <node id="3">
      <data key="d5">CloudFront CDN</data>
      <data key="d6">CloudFront</data>
      <data key="d7">Global Content Delivery Network (CDN) used for edge caching and fast delivery of snap media content closer to recipients. Uses S3 as its origin.</data>
    </node>
    <node id="4">
      <data key="d5">Snap Media Storage</data>
      <data key="d6">S3</data>
      <data key="d7">DATA_PEEK: Stores the actual ephemeral snap media (images, videos). Serves as the origin for CloudFront.</data>
    </node>
    <node id="5">
      <data key="d5">SnapDB</data>
      <data key="d6">EKS</data>
      <data key="d7">Custom database layer built on EKS, operating 'under the covers' of DynamoDB. Provides higher-level features like transactions, TTL (Time-to-Live), and efficient management of ephemeral data. Manages incremental state synchronization to reduce the burden on DynamoDB. WORKLOAD_PEEK: Involved in nightly scans on DynamoDB for tasks like deleting ephemeral data.</data>
    </node>
    <node id="6">
      <data key="d5">Snap Metadata Database</data>
      <data key="d6">DynamoDB</data>
      <data key="d7">DATA_PEEK: Stores approximately 400 terabytes of snap metadata. WORKLOAD_PEEK: Subject to very heavy usage, including nightly scans processing 2 billion rows per minute for various operations (e.g., friend suggestions, ephemeral data deletion).</data>
    </node>
    <node id="7">
      <data key="d5">Connection/Media ID Cache</data>
      <data key="d6">ElastiCache</data>
      <data key="d7">Stores connection IDs, server IDs, and media IDs for rapid lookup by the Messaging Service. Critical for low-latency delivery of snap messages.</data>
    </node>
    <node id="8">
      <data key="d5">Messaging Service</data>
      <data key="d6">EKS</data>
      <data key="d7">A highly latency-sensitive EKS service responsible for pushing snap notifications and messages to clients. Queries ElastiCache for client connection information to establish persistent connections. Achieved a 24% reduction in P50 (median) latency for sending snaps after moving to this architecture.</data>
    </node>
    <node id="9">
      <data key="d5">Friend Graph</data>
      <data key="d6">EKS</data>
      <data key="d7">An EKS service that manages user friendship relationships. WORKLOAD_PEEK: Participates in nightly scans of DynamoDB to look for and suggest new friends.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">Client sends a snap request to the Gateway.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="0" target="3" id="0">
      <data key="d8">1</data>
      <data key="d9">Recipient client uses the media ID from the notification to request the actual snap content from CloudFront.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">Gateway forwards the snap request/payload to the Media Delivery Service.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="0" id="0">
      <data key="d8">1</data>
      <data key="d9">Gateway pushes the snap notification to the recipient's mobile client.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="3" id="0">
      <data key="d8">0</data>
      <data key="d9">Media Delivery Service pushes the snap content to CloudFront for distribution and caching.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="5" id="0">
      <data key="d8">0</data>
      <data key="d9">Media Delivery Service sends snap metadata (e.g., media ID) to the SnapDB layer.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="4" id="0">
      <data key="d8">0</data>
      <data key="d9">CloudFront persists the snap media content into S3.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="4" id="1">
      <data key="d8">1</data>
      <data key="d9">CloudFront retrieves the snap media content from S3 (its origin).</data>
      <data key="d10">5</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="0" id="0">
      <data key="d8">1</data>
      <data key="d9">CloudFront delivers the snap media content to the recipient's mobile client.</data>
      <data key="d10">7</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="3" id="0">
      <data key="d8">1</data>
      <data key="d9">S3 delivers the snap media content back to CloudFront.</data>
      <data key="d10">6</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="6" id="0">
      <data key="d8">0</data>
      <data key="d9">SnapDB stores the snap metadata in DynamoDB.</data>
      <data key="d10">5</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="6" id="1">
      <data key="d8">2</data>
      <data key="d9">SnapDB service performs nightly scans on DynamoDB to delete ephemeral data.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="7" id="0">
      <data key="d8">0</data>
      <data key="d9">SnapDB also persists the media ID into ElastiCache for quick lookups during snap retrieval.</data>
      <data key="d10">6</data>
      <data key="d11">data</data>
    </edge>
    <edge source="7" target="8" id="0">
      <data key="d8">1</data>
      <data key="d9">ElastiCache returns the lookup results (connection/server ID) to the Messaging Service.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="8" target="7" id="0">
      <data key="d8">1</data>
      <data key="d9">Messaging Service looks up the recipient's connection ID and server ID from ElastiCache to deliver the snap message.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="8" target="1" id="0">
      <data key="d8">1</data>
      <data key="d9">Messaging Service sends the snap message/notification (containing media ID) through the Gateway for delivery.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="9" target="6" id="0">
      <data key="d8">2</data>
      <data key="d9">Friend Graph service performs nightly scans on DynamoDB for friend suggestions.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">Snapchat Snap Sending and Receiving Architecture</data>
    <data key="d1">https://www.youtube.com/watch?v=Cgv0kfp_6xQ</data>
    <data key="d2">Snapchat's core architecture for sending and receiving snaps, supporting over 300 million daily active users. Leverages a microservices approach built on AWS EKS, with over 900 clusters and 1000+ instances per cluster. Key design decisions include building a custom 'SnapDB' layer over DynamoDB for advanced features and optimizing for low latency (24% P50 reduction in snap sending) and cost efficiency using auto-scaling and Graviton instances. Handles massive data scale with 400TB in DynamoDB and nightly scans processing 2 billion rows per minute.</data>
    <data key="d3">interactive, data_ingestion, compute_intensive</data>
    <data key="d4">True</data>
  </graph>
</graphml>
