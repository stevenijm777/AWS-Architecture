<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">EC2 App Server</data>
      <data key="d6">EC2</data>
      <data key="d7">EC2 instances hosting the SAP application cluster and DB nodes inside the regional boundary.</data>
    </node>
    <node id="1">
      <data key="d5">SAP Application &amp; Database</data>
      <data key="d6">SAP</data>
      <data key="d7">The primary SAP workload running active-passive, monitored for application availability and process states.</data>
    </node>
    <node id="2">
      <data key="d5">Amazon CloudWatch</data>
      <data key="d6">CloudWatch</data>
      <data key="d7">Merged infrastructure metric collection and CloudWatch event routing mechanisms that detect application/server-level anomalies.</data>
    </node>
    <node id="3">
      <data key="d5">Amazon SNS</data>
      <data key="d6">SNS</data>
      <data key="d7">Simple Notification Service that distributes alerts to external communication channels (Email/ITSM integration) and invokes target recovery functions simultaneously.</data>
    </node>
    <node id="4">
      <data key="d5">Healing Lambda</data>
      <data key="d6">Lambda</data>
      <data key="d7">Serverless orchestrator triggered by SNS to execute targeted operational commands based on the detected alert type.</data>
    </node>
    <node id="5">
      <data key="d5">AWS Systems Manager</data>
      <data key="d6">SystemsManager</data>
      <data key="d7">Performs remediation on the operating system layer of the SAP EC2 instances via secure SSM Run Command executions.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">Underlying compute resource provisioning and hosting of SAP application processes.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="0" id="0">
      <data key="d8">0</data>
      <data key="d9">SAP applications utilizing local storage, networking, and CPU capacity of the EC2 instances.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="2" id="0">
      <data key="d8">1</data>
      <data key="d9">Application metrics and execution status monitored continuously by CloudWatch.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="3" id="0">
      <data key="d8">1</data>
      <data key="d9">CloudWatch detects an application failure and triggers an alert event to the dedicated SNS topic.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="4" id="0">
      <data key="d8">2</data>
      <data key="d9">SNS forwards the alert payload to initiate the self-healing Lambda routine.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="5" id="0">
      <data key="d8">2</data>
      <data key="d9">Lambda invokes Systems Manager APIs to target the impacted instances for OS-level repair operations.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="1" id="0">
      <data key="d8">2</data>
      <data key="d9">SSM Run Command executes script actions on SAP to restore application services automatically.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">Self-Healing Architecture for SAP Applications on AWS</data>
    <data key="d1" />
    <data key="d2">Automated recovery framework designed to monitor active SAP applications on EC2. Real-time application detection triggers AWS-native serverless healing workflows, executing system-level actions via Systems Manager to minimize down-time.</data>
    <data key="d3">control</data>
    <data key="d4">True</data>
  </graph>
</graphml>