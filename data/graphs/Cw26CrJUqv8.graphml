<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Salesforce Admin UI</data>
      <data key="d6">UserCompanyDeveloper</data>
      <data key="d7">Initiates connection setup or teardown.</data>
    </node>
    <node id="1">
      <data key="d5">Control Plane API Gateway</data>
      <data key="d6">ApiGateway</data>
      <data key="d7">Exposes setup and teardown endpoints.</data>
    </node>
    <node id="2">
      <data key="d5">Provisioning Lambda</data>
      <data key="d6">Lambda</data>
      <data key="d7">WORKLOAD_PEEK: Orchestrates PrivateLink endpoint setup and metadata management.</data>
    </node>
    <node id="3">
      <data key="d5">Metadata Store</data>
      <data key="d6">DynamoDB</data>
      <data key="d7">DATA_PEEK: Stores customer metadata and connection routing tables.</data>
    </node>
    <node id="4">
      <data key="d5">State Notifications</data>
      <data key="d6">SNS</data>
      <data key="d7">Receives PrivateLink state changes.</data>
    </node>
    <node id="5">
      <data key="d5">Salesforce Data Center</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Origin of the customer data.</data>
    </node>
    <node id="6">
      <data key="d5">Transit Gateway</data>
      <data key="d6">TransitGateway</data>
      <data key="d7">Routes encrypted VPN traffic from Salesforce DC to the forwarding layer.</data>
    </node>
    <node id="7">
      <data key="d5">Connection Forwarders</data>
      <data key="d6">EKS</data>
      <data key="d7">WORKLOAD_PEEK: Runs containerized multi-tenant connection forwarders.</data>
    </node>
    <node id="8">
      <data key="d5">Customer VPC</data>
      <data key="d6">VPC</data>
      <data key="d7">Destination AWS environment.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">Triggers connection provisioning.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">Invokes provisioning logic.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="0" id="0">
      <data key="d8">0</data>
      <data key="d9">Confirms connection establishment to user.</data>
      <data key="d10">7</data>
      <data key="d11">meta</data>
    </edge>
    <edge source="2" target="3" id="0">
      <data key="d8">0</data>
      <data key="d9">Saves customer connection metadata.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="8" id="0">
      <data key="d8">0</data>
      <data key="d9">Establishes PrivateLink to Customer VPC.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">Returns provisioning status.</data>
      <data key="d10">6</data>
      <data key="d11">meta</data>
    </edge>
    <edge source="3" target="7" id="0">
      <data key="d8">1</data>
      <data key="d9">Returns customer endpoint details.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">Triggers lambda on connection state change.</data>
      <data key="d10">5</data>
      <data key="d11">meta</data>
    </edge>
    <edge source="5" target="6" id="0">
      <data key="d8">1</data>
      <data key="d9">Sends data via encrypted VPN tunnel.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="6" target="7" id="0">
      <data key="d8">1</data>
      <data key="d9">Forwards incoming traffic to EKS.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="7" target="3" id="0">
      <data key="d8">1</data>
      <data key="d9">Looks up tenant routing metadata.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="7" target="8" id="0">
      <data key="d8">1</data>
      <data key="d9">Routes payload to Customer VPC via PrivateLink.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <edge source="8" target="4" id="0">
      <data key="d8">0</data>
      <data key="d9">Sends PrivateLink state change notification.</data>
      <data key="d10">4</data>
      <data key="d11">meta</data>
    </edge>
    <data key="d0">Salesforce Private Connect</data>
    <data key="d1">https://www.youtube.com/watch?v=Cw26CrJUqv8</data>
    <data key="d2">Salesforce Private Connect simplifies and automates secure, compliant, private connections between Salesforce and AWS customer VPCs using PrivateLink, Transit Gateway, and EKS.</data>
    <data key="d3">control, data_ingestion</data>
    <data key="d4">True</data>
  </graph>
</graphml>
