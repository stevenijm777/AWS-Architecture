<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d12" for="edge" attr.name="id" attr.type="string" />
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Salesforce Administrator</data>
      <data key="d6">UserCompanyDeveloper</data>
      <data key="d7">Logs into Salesforce UI to initiate Private Connect setup.</data>
    </node>
    <node id="1">
      <data key="d5">Salesforce Platform</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">DATA_PEEK: Hosts the customer UI and initiates API requests/VPN tunnels.</data>
    </node>
    <node id="2">
      <data key="d5">API Gateway</data>
      <data key="d6">ApiGateway</data>
      <data key="d7">Receives setup and teardown requests in the Control Plane VPC.</data>
    </node>
    <node id="3">
      <data key="d5">Connection Provisioner</data>
      <data key="d6">Lambda</data>
      <data key="d7">WORKLOAD_PEEK: Handles connection logic and orchestrates AWS resource creation.</data>
    </node>
    <node id="4">
      <data key="d5">Metadata Store</data>
      <data key="d6">DynamoDB</data>
      <data key="d7">DATA_PEEK: Stores customer connection configurations and state metadata.</data>
    </node>
    <node id="5">
      <data key="d5">State Change Notifications</data>
      <data key="d6">SNS</data>
      <data key="d7">Receives alerts on status changes of the PrivateLink connections.</data>
    </node>
    <node id="6">
      <data key="d5">Transit Gateway</data>
      <data key="d6">TransitGateway</data>
      <data key="d7">Terminates the IPSec VPN tunnel from Salesforce and routes internal traffic.</data>
    </node>
    <node id="7">
      <data key="d5">Connection Forwarders</data>
      <data key="d6">EKS</data>
      <data key="d7">WORKLOAD_PEEK: Containerized multi-tenant routing service to map traffic to correct endpoints.</data>
    </node>
    <node id="8">
      <data key="d5">Transit VPC Endpoint</data>
      <data key="d6">PrivateLink</data>
      <data key="d7">AWS PrivateLink interface representing the SaaS endpoint side.</data>
    </node>
    <node id="9">
      <data key="d5">Customer VPC Endpoint</data>
      <data key="d6">PrivateLink</data>
      <data key="d7">AWS PrivateLink endpoint running in the customer-owned VPC.</data>
    </node>
    <edge source="0" target="1">
      <data key="d8">0</data>
      <data key="d9">Developer configures connection details in Salesforce UI.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="1" target="2">
      <data key="d8">0</data>
      <data key="d9">Salesforce calls API Gateway to trigger setup.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="1" target="6">
      <data key="d8">1</data>
      <data key="d9">Salesforce routes payload data via VPN tunnel to Transit Gateway.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="2" target="3">
      <data key="d8">0</data>
      <data key="d9">API Gateway forwards setup request to Lambda.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="3" target="4">
      <data key="d8">0</data>
      <data key="d9">Lambda registers setup state and metadata in DynamoDB.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="3" target="8">
      <data key="d8">0</data>
      <data key="d9">Lambda provisions PrivateLink connection.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="6" target="7">
      <data key="d8">1</data>
      <data key="d9">Transit Gateway routes traffic to connection forwarders.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="7" target="8">
      <data key="d8">1</data>
      <data key="d9">Forwarders direct the traffic to the corresponding customer PrivateLink.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="8" target="5">
      <data key="d8">0</data>
      <data key="d9">State changes of PrivateLink emit notifications to SNS.</data>
      <data key="d10">5</data>
      <data key="d11">meta</data>
      <data key="d12">0</data>
    </edge>
    <edge source="8" target="9">
      <data key="d8">1</data>
      <data key="d9">PrivateLink establishes secure cross-account connection to Customer VPC.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <data key="d0">Salesforce: Automating SaaS Application Connectivity</data>
    <data key="d1">https://www.youtube.com/watch?v=Cw26CrJUqv8</data>
    <data key="d2">Enables secure, private connections between Salesforce and customer AWS VPCs using VPC Endpoints, eliminating internet exposure and simplifying network configuration.</data>
    <data key="d3">control, data_ingestion</data>
    <data key="d4">True</data>
  </graph>
</graphml>
