<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">GE Avio Employee</data>
      <data key="d6">UserCompanyInternalPlatform</data>
      <data key="d7">Accesses system at quarter end to manage special expenses.</data>
    </node>
    <node id="1">
      <data key="d5">Corporate OpenID</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Handles identity management and corporate authentication.</data>
    </node>
    <node id="2">
      <data key="d5">Application Load Balancer</data>
      <data key="d6">ELB</data>
      <data key="d7">Ingress point for application and API traffic.</data>
    </node>
    <node id="3">
      <data key="d5">SPA Web Server</data>
      <data key="d6">ECS</data>
      <data key="d7">Hosts and serves Dockerized Single Page Application.</data>
    </node>
    <node id="4">
      <data key="d5">Authorizer Lambda</data>
      <data key="d6">Lambda</data>
      <data key="d7">Executes logic to authorize and authenticate users.</data>
    </node>
    <node id="5">
      <data key="d5">API Gateway Proxy</data>
      <data key="d6">ECS</data>
      <data key="d7">Containerized proxy acting as API Gateway for the application.</data>
    </node>
    <node id="6">
      <data key="d5">Business Logic Lambdas</data>
      <data key="d6">Lambda</data>
      <data key="d7">DATA_PEEK: ~20 Lambdas doing ticket creation, state transitions, and file uploads.</data>
    </node>
    <node id="7">
      <data key="d5">Metadata Store</data>
      <data key="d6">DynamoDB</data>
      <data key="d7">DATA_PEEK: Stores metadata of expense tickets.</data>
    </node>
    <node id="8">
      <data key="d5">Attachment Bucket</data>
      <data key="d6">S3</data>
      <data key="d7">DATA_PEEK: Stores financial documents and attachments.</data>
    </node>
    <node id="9">
      <data key="d5">KMS Keys</data>
      <data key="d6">KMS</data>
      <data key="d7">Used for encrypting attachments in S3 at rest.</data>
    </node>
    <edge source="0" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">User initiates authentication flow.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="0" target="2" id="1">
      <data key="d8">1</data>
      <data key="d9">User makes API calls via SPA application.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">Returns auth response token.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">Forward to OpenID for corporate login.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="4" id="0">
      <data key="d8">0</data>
      <data key="d9">Invokes authorizer Lambda to validate user.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="3" id="0">
      <data key="d8">0</data>
      <data key="d9">Access request for SPA asset.</data>
      <data key="d10">5</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="5" id="0">
      <data key="d8">1</data>
      <data key="d9">Forward request to API Gateway ECS container.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="0" id="0">
      <data key="d8">0</data>
      <data key="d9">Download SPA static bundle to client browser.</data>
      <data key="d10">6</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">Authorization status returned.</data>
      <data key="d10">4</data>
      <data key="d11">meta</data>
    </edge>
    <edge source="5" target="6" id="0">
      <data key="d8">1</data>
      <data key="d9">Routes request to specific business logic Lambda.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="6" target="7" id="0">
      <data key="d8">1</data>
      <data key="d9">Saves or queries ticket metadata.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="6" target="8" id="0">
      <data key="d8">1</data>
      <data key="d9">Saves financial attachments.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <edge source="6" target="0" id="0">
      <data key="d8">1</data>
      <data key="d9">Returns business response back to user SPA.</data>
      <data key="d10">6</data>
      <data key="d11">data</data>
    </edge>
    <edge source="8" target="9" id="0">
      <data key="d8">1</data>
      <data key="d9">Encrypts documents at rest using KMS key.</data>
      <data key="d10">5</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">Avio Aero, a GE Aviation Business: Serverless Application to Manage Expense Purchase Approvals</data>
    <data key="d1">https://www.youtube.com/watch?v=D77FSUkPJ3o</data>
    <data key="d2">Serverless application built to replace a legacy app, dealing with end-of-quarter spikes. Scalable, cost-efficient, and highly reliable.</data>
    <data key="d3">interactive</data>
    <data key="d4">True</data>
  </graph>
</graphml>
