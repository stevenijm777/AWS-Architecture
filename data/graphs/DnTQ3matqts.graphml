  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Fitness Equipment Sensors</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">DATA_PEEK: Generates utilization data from gym equipment across multiple facilities.</data>
    </node>
    <node id="1">
      <data key="d5">IoT Gateway</data>
      <data key="d6">Greengrass</data>
      <data key="d7">WORKLOAD_PEEK: On-premises device running AWS IoT Greengrass for local deployments and maintenance. Buffers data when offline and syncs when back online. Contains edge Lambdas for local processing.</data>
    </node>
    <node id="2">
      <data key="d5">IoT Core</data>
      <data key="d6">IoTCore</data>
      <data key="d7">WORKLOAD_PEEK: Handles real-time sensor information from Greengrass gateways. Provides authentication, certificate, and security management. DATA_PEEK: Real-time driving sensor information primarily for sensor health monitoring.</data>
    </node>
    <node id="3">
      <data key="d5">Data Ingestion &amp; App API</data>
      <data key="d6">ApiGateway</data>
      <data key="d7">WORKLOAD_PEEK: Exposes a RESTful interface for raw sensor data ingestion from Greengrass gateways and for the installation app's backend services.</data>
    </node>
    <node id="4">
      <data key="d5">Utilization Data Processor</data>
      <data key="d6">Lambda</data>
      <data key="d7">WORKLOAD_PEEK: Crunches raw sensor data ingested via API Gateway to create processed utilization data. Stores this processed data in the data lake and the time series database.</data>
    </node>
    <node id="5">
      <data key="d5">Data Lake</data>
      <data key="d6">S3</data>
      <data key="d7">DATA_PEEK: Stores processed utilization data as a data lake, serving as a repository for further analytics or historical archiving.</data>
    </node>
    <node id="6">
      <data key="d5">Time Series Database</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">DATA_PEEK: Central source of truth for all processed time-series data related to equipment utilization. WORKLOAD_PEEK: Used for generating customer reports and accessed directly by BI tools for ad-hoc queries.</data>
    </node>
    <node id="7">
      <data key="d5">Installer Mobile/Web App</data>
      <data key="d6">UserConsumerWebMobile</data>
      <data key="d7">WORKLOAD_PEEK: An internal application used by installers to deploy and configure EcoFit systems (sensors and gateways) in gyms. Consumes data via API Gateway for backend services and gets real-time information directly from gateways via a third-party server.</data>
    </node>
    <node id="8">
      <data key="d5">Real-time Gateway Interface Server</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">WORKLOAD_PEEK: An external server that acts as a proxy or intermediary, providing a RESTful interface for the Installation App to retrieve real-time information directly from the Greengrass Gateway.</data>
    </node>
    <node id="9">
      <data key="d5">Sensor Health Monitor</data>
      <data key="d6">Lambda</data>
      <data key="d7">WORKLOAD_PEEK: Processes real-time sensor data and messages from IoT Core. Detects offline sensors or gateways by monitoring data flow patterns and updates an SQS queue with status information. Triggers alerts via SNS.</data>
    </node>
    <node id="10">
      <data key="d5">Sensor Health Queue</data>
      <data key="d6">SQS</data>
      <data key="d7">WORKLOAD_PEEK: Used as a queue for sensor health information. The Sensor Health Monitor Lambda utilizes this queue to identify prolonged periods of inactivity from specific gateways or sensors, indicating a potential outage.</data>
    </node>
    <node id="11">
      <data key="d5">Alert Notification Service</data>
      <data key="d6">SNS</data>
      <data key="d7">WORKLOAD_PEEK: Publishes alerts regarding critical system health issues, such as offline gateways or sensors, notifying the EcoFit operations team.</data>
    </node>
    <node id="12">
      <data key="d5">Automated Reporting Lambda</data>
      <data key="d6">Lambda</data>
      <data key="d7">WORKLOAD_PEEK: Periodically queries the Time Series Database to extract and process data, generating automated reports for EcoFit's end customers.</data>
    </node>
    <node id="13">
      <data key="d5">Customer Reports Portal</data>
      <data key="d6">UserConsumerWeb</data>
      <data key="d7">WORKLOAD_PEEK: A web-based portal where EcoFit's end customers (gym chains) can access their generated automated utilization reports.</data>
    </node>
    <node id="14">
      <data key="d5">Business Intelligence Tools</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">WORKLOAD_PEEK: External Business Intelligence tools used by customers or internal analysts to connect directly to the Time Series Database for ad-hoc querying, custom analysis, and generating offline reports.</data>
    </node>
    <node id="15">
      <data key="d5">EcoFit Operations Team</data>
      <data key="d6">UserConsumerWebMobile</data>
      <data key="d7">WORKLOAD_PEEK: Internal team responsible for monitoring the EcoFit system. Receives critical system alerts and notifications via SNS regarding sensor/gateway health.</data>
    </node>
    <node id="16">
      <data key="d5">Installation Backend Lambdas</data>
      <data key="d6">Lambda</data>
      <data key="d7">WORKLOAD_PEEK: A set of backend Lambdas serving the Installation App, likely handling deployment configurations, status updates, and management logic for gym equipment systems.</data>
    </node>
