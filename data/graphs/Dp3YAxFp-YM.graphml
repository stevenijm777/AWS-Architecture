  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Students</data>
      <data key="d6">UserConsumerMobile</data>
      <data key="d7">DATA_PEEK: ~120k students. WORKLOAD_PEEK: Generating learning events and performance data, scoring assessments. Generating ~100 million data points for learning experience.</data>
    </node>
    <node id="1">
      <data key="d5">S3 Bucket</data>
      <data key="d6">S3</data>
      <data key="d7">DATA_PEEK: Stores unstructured student learning event data. WORKLOAD_PEEK: Target for 100 million data points generated by students.</data>
    </node>
    <node id="2">
      <data key="d5">Authors</data>
      <data key="d6">UserCompanyDeveloper</data>
      <data key="d7">DATA_PEEK: Generating authoring events. WORKLOAD_PEEK: Inserting ~65k data points related to content publishing.</data>
    </node>
    <node id="3">
      <data key="d5">Redshift Cluster</data>
      <data key="d6">RedShift</data>
      <data key="d7">DATA_PEEK: Stores authoring events directly. Receives transformed unstructured data from S3. Contains over 3 terabytes of merged structured and unstructured data for K-12 students. WORKLOAD_PEEK: Scalable data warehouse, ready for ML processing.</data>
    </node>
    <node id="4">
      <data key="d5">EKS Training Cluster</data>
      <data key="d6">EKS</data>
      <data key="d7">WORKLOAD_PEEK: Runs Kubeflow for training machine learning models. Receives consolidated data from Redshift for training.</data>
    </node>
    <node id="5">
      <data key="d5">SageMaker Hyperparameter Tuning</data>
      <data key="d6">SageMaker</data>
      <data key="d7">WORKLOAD_PEEK: Optimizes ML models by fine-tuning parameters. Uses F1 score as primary and Recall as secondary objective metric.</data>
    </node>
    <node id="6">
      <data key="d5">ECR Repository</data>
      <data key="d6">ECR</data>
      <data key="d7">DATA_PEEK: Stores the best trained ML model, bundled as a Docker image.</data>
    </node>
    <node id="7">
      <data key="d5">Application Load Balancer</data>
      <data key="d6">ELB</data>
      <data key="d7">WORKLOAD_PEEK: Fronts the EKS inference cluster, handling requests for personalized recommendations from students.</data>
    </node>
    <node id="8">
      <data key="d5">EKS Inference Cluster</data>
      <data key="d6">EKS</data>
      <data key="d7">WORKLOAD_PEEK: Hosts the deployed machine learning model for personalized recommendations. Processes ~65k recommendation events per day. Auto-scales up and down based on student usage.</data>
    </node>
    <node id="9">
      <data key="d5">CloudWatch Monitoring</data>
      <data key="d6">CloudWatch</data>
      <data key="d7">WORKLOAD_PEEK: Monitors both training and inference processes. Collects logs/metrics from EKS clusters. Triggers alerts for model accuracy, enabling early stopping and model lineage techniques.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">Students' learning events (100M data points) are collected into S3.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="0" target="7" id="0">
      <data key="d8">2</data>
      <data key="d9">Students request personalized recommendations from the platform.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="3" id="0">
      <data key="d8">0</data>
      <data key="d9">Unstructured data from S3 is transformed and loaded into Redshift via a Spark streaming job.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="3" id="0">
      <data key="d8">0</data>
      <data key="d9">Authors' publishing events (~65k data points) are inserted into Redshift.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="4" id="0">
      <data key="d8">1</data>
      <data key="d9">Consolidated data from Redshift is used for training the machine learning model on the EKS cluster.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="5" id="0">
      <data key="d8">1</data>
      <data key="d9">Fine-tuned models from EKS are passed to SageMaker for hyperparameter tuning.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="9" id="0">
      <data key="d8">3</data>
      <data key="d9">Logs and metrics from the EKS training cluster are sent to CloudWatch for monitoring and early stopping.</data>
      <data key="d10">0</data>
      <data key="d11">meta</data>
    </edge>
    <edge source="5" target="6" id="0">
      <data key="d8">1</data>
      <data key="d9">The best optimized model is bundled as a Docker image and published to ECR.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="6" target="8" id="0">
      <data key="d8">2</data>
      <data key="d9">The best model from ECR is deployed to the EKS inference cluster.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="7" target="8" id="0">
      <data key="d8">2</data>
      <data key="d9">ELB routes student recommendation requests to the EKS inference cluster.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="8" target="9" id="0">
      <data key="d8">3</data>
      <data key="d9">Inference data and accuracy metrics from the EKS inference cluster are sent to CloudWatch for monitoring and alerting.</data>
      <data key="d10">1</data>
      <data key="d11">meta</data>
    </edge>
    <data key="d0">Alph Education Personalized Recommendation System</data>
    <data key="d1">https://www.youtube.com/watch?v=Dp3YAxFp-YM</data>
    <data key="d2">Alph Education is an e-learning platform for K-12 students. The architecture supports collecting student learning events (100M data points) and authoring content events (65k data points). A Spark streaming job transforms S3 data into Redshift, resulting in 3TB of merged data. This data feeds an ML pipeline for personalized recommendations. Training occurs on EKS with Kubeflow, with hyperparameter tuning via SageMaker. The best model is containerized in ECR. For inference, an auto-scaling EKS cluster serves 65k recommendations/day, fronted by an ELB. CloudWatch provides comprehensive monitoring for both training and inference, enabling early stopping and accuracy alerts.</data>
    <data key="d3">data_ingestion, interactive, compute_intensive, control</data>
    <data key="d4">True</data>
  </graph>
</graphml>
