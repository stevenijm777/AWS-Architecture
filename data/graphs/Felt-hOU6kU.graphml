<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Developers</data>
      <data key="d6">UserCompanyDeveloper</data>
      <data key="d7">WORKLOAD_PEEK: Over 1600 developers are users of this self-service portal.</data>
    </node>
    <node id="1">
      <data key="d5">Developer Portal ALB</data>
      <data key="d6">ALB</data>
      <data key="d7">Provides secure access to the developer portal, eliminating the need for VPN access.</data>
    </node>
    <node id="2">
      <data key="d5">Developer Portal</data>
      <data key="d6">EKS</data>
      <data key="d7">Hosts the self-service developer portal on Kubernetes clusters.</data>
    </node>
    <node id="3">
      <data key="d5">Self-Service Job Queue</data>
      <data key="d6">SQS</data>
      <data key="d7">Queues jobs initiated by developers through self-service forms for infrastructure provisioning. DATA_PEEK: Handles 'queuing jobs'.</data>
    </node>
    <node id="4">
      <data key="d5">Terraform Runner</data>
      <data key="d6">EKS</data>
      <data key="d7">Runs Terraform configurations on Kubernetes clusters to provision and configure AWS resources in various accounts. WORKLOAD_PEEK: Processes self-service infrastructure jobs.</data>
    </node>
    <node id="5">
      <data key="d5">Resource Access Manager</data>
      <data key="d6">RAM</data>
      <data key="d7">Facilitates sharing and managing resources, specifically network configurations (subnets), across 150+ AWS accounts, ensuring consistency and best practices.</data>
    </node>
    <node id="6">
      <data key="d5">Provisioned Subnets</data>
      <data key="d6">VPC</data>
      <data key="d7">Represents the network configurations and subnets across the 150+ AWS accounts where resources are provisioned and managed. The 'SUBNET' icon on the whiteboard maps to this.</data>
    </node>
    <node id="7">
      <data key="d5">Provisioned Database</data>
      <data key="d6">RDS</data>
      <data key="d7">An example of a database resource type (like RDS) that can be provisioned by developers through the self-service portal.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">Developers access the self-service portal.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">ALB routes traffic to the EKS-hosted developer portal.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="3" id="0">
      <data key="d8">1</data>
      <data key="d9">The developer portal submits infrastructure provisioning jobs to SQS.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="4" id="0">
      <data key="d8">1</data>
      <data key="d9">The EKS Terraform Runner consumes and processes jobs from the SQS queue.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="5" id="0">
      <data key="d8">1</data>
      <data key="d9">Terraform running on EKS interacts with RAM to configure shared resource access and policies across accounts.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="6" id="0">
      <data key="d8">1</data>
      <data key="d9">Terraform running on EKS provisions and configures network resources (subnets) in various AWS accounts.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="7" id="0">
      <data key="d8">1</data>
      <data key="d9">Terraform running on EKS provisions database instances (e.g., RDS) as requested by developers.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="6" id="0">
      <data key="d8">1</data>
      <data key="d9">RAM applies shared configurations and access policies to the provisioned subnets across accounts.</data>
      <data key="d10">5</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">Xero Developer Self-Service Portal</data>
    <data key="d1">https://www.youtube.com/watch?v=Felt-hOU6kU</data>
    <data key="d2">Xero's architecture provides a self-service portal for over 1600 developers to securely provision infrastructure across 150+ AWS accounts without VPN. The system leverages EKS for both hosting the portal and running Terraform jobs, enabling compliant infrastructure provisioning in minutes instead of days. AWS SQS decouples job submission from execution, and Resource Access Manager (RAM) facilitates consistent management of shared network configurations (subnets) across numerous accounts.</data>
    <data key="d3">control, interactive, compute_intensive</data>
    <data key="d4">True</data>
  </graph>
</graphml>
