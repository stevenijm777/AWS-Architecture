<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Developers</data>
      <data key="d6">UserConsumerWeb</data>
      <data key="d7">WORKLOAD_PEEK: Push merge requests to GitLab.</data>
    </node>
    <node id="1">
      <data key="d5">GitLab (On-Prem)</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">WORKLOAD_PEEK: On-premise source code management and CI orchestrator. Runs parallel pipelines. Plugin calls EC2 API to launch spot instances.</data>
    </node>
    <node id="2">
      <data key="d5">Jenkins (On-Prem)</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">WORKLOAD_PEEK: On-premise CI/CD orchestrator. Pulls repository from GitLab twice a day. Runs build, full test, security scan. Executes regression and performance tests. Plugin calls EC2 API to launch spot instances.</data>
    </node>
    <node id="3">
      <data key="d5">On-Prem Self-Farm Compute</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">WORKLOAD_PEEK: On-premise compute cluster for running CI/CD jobs, including Windows, Linux, and macOS environments. Faced capacity issues leading to job queues as the company grew.</data>
    </node>
    <node id="4">
      <data key="d5">Site-to-Site VPN Connection</data>
      <data key="d6">VPN</data>
      <data key="d7">WORKLOAD_PEEK: Establishes a secure tunnel between the on-premise data center and Amazon VPC. Guarantees security and isolates traffic (in/out from VPC only from on-prem infrastructure).</data>
    </node>
    <node id="5">
      <data key="d5">Amazon VPC</data>
      <data key="d6">VPC</data>
      <data key="d7">WORKLOAD_PEEK: Serves as the extension of the on-premise infrastructure in the cloud. Connections are isolated to only come from the on-prem infrastructure.</data>
    </node>
    <node id="6">
      <data key="d5">EC2 API</data>
      <data key="d6">EC2</data>
      <data key="d7">WORKLOAD_PEEK: Interface that receives API calls from GitLab and Jenkins plugins to programmatically launch and manage EC2 Spot Instances.</data>
    </node>
    <node id="7">
      <data key="d5">EC2 Spot Instances for Test Workload</data>
      <data key="d6">EC2</data>
      <data key="d7">WORKLOAD_PEEK: Launched via EC2 API to provide scalable and cost-effective compute capacity for CI/CD tests. DATA_PEEK: Test workloads do not require data retention, so instances are destroyed after tests. Achieves up to 62% cost savings compared to an on-premise solution.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">Developers push merge requests to GitLab.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="3" id="0">
      <data key="d8">0</data>
      <data key="d9">GitLab runs parallel pipelines, executing jobs on the on-premise self-farm. WORKLOAD_PEEK: Typically runs up to 5 minutes.</data>
      <data key="d10">1</data>
      <data key="d11">meta</data>
    </edge>
    <edge source="1" target="6" id="0">
      <data key="d8">1</data>
      <data key="d9">GitLab plugin makes API calls to EC2 (via VPN) to launch instances.</data>
      <data key="d10">2</data>
      <data key="d11">meta</data>
    </edge>
    <edge source="2" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">Jenkins pulls the repository from GitLab twice a day.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="3" id="0">
      <data key="d8">0</data>
      <data key="d9">Jenkins performs build, full test, and security scanning on the on-premise self-farm. WORKLOAD_PEEK: Takes up to 1 hour.</data>
      <data key="d10">3</data>
      <data key="d11">meta</data>
    </edge>
    <edge source="2" target="3" id="1">
      <data key="d8">0</data>
      <data key="d9">Jenkins executes jobs for regression and performance tests on the on-premise self-farm. WORKLOAD_PEEK: Takes up to 7 hours.</data>
      <data key="d10">4</data>
      <data key="d11">meta</data>
    </edge>
    <edge source="2" target="6" id="0">
      <data key="d8">1</data>
      <data key="d9">Jenkins plugin makes API calls to EC2 (via VPN) to launch instances.</data>
      <data key="d10">3</data>
      <data key="d11">meta</data>
    </edge>
    <edge source="3" target="4" id="0">
      <data key="d8">1</data>
      <data key="d9">On-premise infrastructure establishes a secure site-to-site VPN connection with AWS.</data>
      <data key="d10">0</data>
      <data key="d11">meta</data>
    </edge>
    <edge source="4" target="5" id="0">
      <data key="d8">1</data>
      <data key="d9">VPN connection extends into the Amazon VPC.</data>
      <data key="d10">1</data>
      <data key="d11">meta</data>
    </edge>
    <edge source="6" target="7" id="0">
      <data key="d8">1</data>
      <data key="d9">EC2 API launches EC2 Spot Instances in the VPC as many as needed. WORKLOAD_PEEK: Instances are launched for running test workloads.</data>
      <data key="d10">4</data>
      <data key="d11">meta</data>
    </edge>
    <edge source="7" target="2" id="0">
      <data key="d8">1</data>
      <data key="d9">Implied: Test results or status reported back to Jenkins from Spot Instances, enabling transparent extension of CI/CD.</data>
      <data key="d10">5</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">Accellion kiteworks: Cost-Effective CI/CD Platform Using Amazon EC2 Spot</data>
    <data key="d1">https://www.youtube.com/watch?v=FqCs3BD6qvo</data>
    <data key="d2">Axilion developed a hybrid CI/CD platform to address on-premise capacity constraints for their growing developer team. They extended their existing GitLab and Jenkins-based CI/CD pipeline to AWS using a secure site-to-site VPN connection. The architecture leverages EC2 Spot Instances, provisioned on-demand via EC2 API calls from GitLab and Jenkins plugins, to run ephemeral test workloads that do not require data retention. This approach provides significant cost savings (up to 62%) and dynamic scalability, ensuring that CI/CD pipelines no longer face queuing issues. Future plans include expanding to Mac OS instances on AWS.</data>
    <data key="d3">compute_intensive, control</data>
    <data key="d4">True</data>
  </graph>
</graphml>
