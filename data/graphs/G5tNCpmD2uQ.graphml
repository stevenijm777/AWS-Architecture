<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">ALB</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Application Load Balancer distributing incoming ad request traffic to the compute tier.</data>
    </node>
    <node id="1">
      <data key="d5">EC2</data>
      <data key="d6">EC2</data>
      <data key="d7">EC2 instances acting as the host infrastructure for ECS containers in an Auto Scaling Group.</data>
    </node>
    <node id="2">
      <data key="d5">ECS</data>
      <data key="d6">ECS</data>
      <data key="d7">ECS cluster executing business logic filters, querying user features, and calling SageMaker Model Endpoint.</data>
    </node>
    <node id="3">
      <data key="d5">SAGEMAKER</data>
      <data key="d6">SageMaker</data>
      <data key="d7">Fully managed machine learning platform used to train and host models autonomously.</data>
    </node>
    <node id="4">
      <data key="d5">NOTEBOOK</data>
      <data key="d6">SageMaker</data>
      <data key="d7">Jupyter Notebook instance for Data Scientists to explore data, test offline predictions, and build models.</data>
    </node>
    <node id="5">
      <data key="d5">MODEL ENDPOINT</data>
      <data key="d6">SageMaker</data>
      <data key="d7">Real-time SageMaker hosted model endpoint processing millions of predictions daily for ad recommendations.</data>
    </node>
    <node id="6">
      <data key="d5">MODEL TRAINING</data>
      <data key="d6">SageMaker</data>
      <data key="d7">SageMaker model training jobs for automated training processes.</data>
    </node>
    <node id="7">
      <data key="d5">DYNAMODB</data>
      <data key="d6">DynamoDB</data>
      <data key="d7">NoSQL database containing necessary features used by the ML model to perform real-time user-targeted recommendations.</data>
    </node>
    <node id="8">
      <data key="d5">S3 (Data Lake)</data>
      <data key="d6">S3</data>
      <data key="d7">Data lake S3 bucket holding raw logs and mobile interaction datasets.</data>
    </node>
    <node id="9">
      <data key="d5">EMR</data>
      <data key="d6">EMR</data>
      <data key="d7">EMR clusters executing scheduled batch jobs to aggregate, join, and clean data lake inputs.</data>
    </node>
    <node id="10">
      <data key="d5">S3 (Prepared Dataset)</data>
      <data key="d6">S3</data>
      <data key="d7">Target S3 bucket storing prepared, aggregated datasets used for offline research and model training.</data>
    </node>
    <edge source="2" target="7" id="0">
      <data key="d8">0</data>
      <data key="d9">ECS queries DynamoDB to retrieve real-time user features required for machine learning model invocation.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="5" id="0">
      <data key="d8">0</data>
      <data key="d9">ECS invokes the SageMaker Model Endpoint to obtain ad installation probability predictions.</data>
      <data key="d10">1</data>
      <data key="d11">control</data>
    </edge>
    <edge source="9" target="8" id="0">
      <data key="d8">1</data>
      <data key="d9">EMR batch jobs read raw data from the S3 Data Lake.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="9" target="10" id="0">
      <data key="d8">1</data>
      <data key="d9">EMR aggregates and writes the cleaned, processed training dataset back into S3.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="10" target="4" id="0">
      <data key="d8">1</data>
      <data key="d9">Data scientists read the prepared datasets into SageMaker Notebooks for offline model training and validation.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">Voodoo Mobile Game Ad Cross-Promotion ML Architecture</data>
    <data key="d1">https://www.youtube.com/watch?v=G5tNCpmD2uQ</data>
    <data key="d2">An AWS architecture optimized for cross-promoting and monentizing mobile applications using SageMaker. It includes an online serving stack built with ECS on EC2 backed by DynamoDB and SageMaker Model Endpoints, alongside an offline batch pipeline leveraging EMR for data preparation and SageMaker Notebooks for model evaluation.</data>
    <data key="d3">data_ingestion, compute_intensive</data>
    <data key="d4">True</data>
  </graph>
</graphml>
