    </edge>
    <edge source="6" target="8" id="0">
      <data key="d8">1</data>
      <data key="d9">Lambda triggers SageMaker to start prediction job</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <edge source="7" target="5" id="0">
      <data key="d8">1</data>
      <data key="d9">Clustered data results inserted back into S3</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="8" target="5" id="0">
      <data key="d8">1</data>
      <data key="d9">Prediction results ('Next Best Offer') inserted back into S3</data>
      <data key="d10">5</data>
