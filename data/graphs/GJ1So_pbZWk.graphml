  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Customer Data (EFS)</data>
      <data key="d6">EFS</data>
      <data key="d7">DATA_PEEK: Source for customer data, often flat files or similar.</data>
    </node>
    <node id="1">
      <data key="d5">Customer Data (DynamoDB)</data>
      <data key="d6">DynamoDB</data>
      <data key="d7">DATA_PEEK: Source for structured customer data from traditional databases.</data>
    </node>
    <node id="2">
      <data key="d5">Customer Data (Redshift)</data>
      <data key="d6">RedShift</data>
      <data key="d7">DATA_PEEK: Source for structured, columnar customer data.</data>
    </node>
    <node id="3">
      <data key="d5">Customer Data (Flat Files/CSVs)</data>
      <data key="d6">S3</data>
      <data key="d7">DATA_PEEK: Source for customer data, such as CSV files.</data>
    </node>
    <node id="4">
      <data key="d5">Data Transformation</data>
      <data key="d6">Glue</data>
      <data key="d7">WORKLOAD_PEEK: Performs ETL (Extract, Transform, Load) to prepare data from various sources for machine learning models.</data>
    </node>
    <node id="5">
      <data key="d5">ML Data Store</data>
      <data key="d6">S3</data>
      <data key="d7">DATA_PEEK: Stores raw, transformed, clustered, and final prediction results ('Next Best Offer'). WORKLOAD_PEEK: Triggers Lambda functions on new data load events and when intermediate ML results are written.</data>
    </node>
    <node id="6">
      <data key="d5">ML Workflow Orchestrator</data>
      <data key="d6">Lambda</data>
      <data key="d7">WORKLOAD_PEEK: Triggered by S3 data load events. Orchestrates the chaining of SageMaker jobs for clustering and prediction. Described as the 'heart of the solution' for this serverless, event-driven architecture.</data>
    </node>
    <node id="7">
      <data key="d5">K-Means Clustering Model</data>
      <data key="d6">SageMaker</data>
      <data key="d7">WORKLOAD_PEEK: The first run-through of the ML pipeline. Performs K-means clustering to group customers into different segments based on their features.</data>
    </node>
    <node id="8">
      <data key="d5">Random Forest Prediction Model</data>
      <data key="d6">SageMaker</data>
      <data key="d7">WORKLOAD_PEEK: The second run-through of the ML pipeline. Performs prediction using Random Forest or Linear Regression models to determine the 'next best offer' for customer groups. Also used for training non-parametric business data.</data>
    </node>
    <node id="9">
      <data key="d5">ML Results API</data>
      <data key="d6">ApiGateway</data>
      <data key="d7">WORKLOAD_PEEK: Exposes a real-time API endpoint for consuming ML prediction results (e.g., 'next best offer') for applications like call centers or websites.</data>
    </node>
    <node id="10">
      <data key="d5">API Query Processor</data>
      <data key="d6">Lambda</data>
      <data key="d7">WORKLOAD_PEEK: Processes real-time API requests from API Gateway, querying the 'Next Best Offer' results stored in S3 for immediate consumption.</data>
    </node>
    <node id="11">
      <data key="d5">API Consumer</data>
      <data key="d6">UserConsumerWebMobile</data>
      <data key="d7">Represents end-users or applications (e.g., call center agents, websites) making API calls for real-time ML insights.</data>
    </node>
    <node id="12">
      <data key="d5">BI User</data>
      <data key="d6">UserCompanyAnalyst</data>
      <data key="d7">Represents business users or management consuming historical and aggregated views of the ML insights via BI dashboards.</data>
    </node>
    <edge source="0" target="4" id="0">
      <data key="d8">0</data>
      <data key="d9">EFS data input for ETL</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
