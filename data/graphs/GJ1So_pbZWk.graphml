      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="10" target="5" id="0">
      <data key="d8">2</data>
      <data key="d9">Lambda queries S3 for 'Next Best Offer' results</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="11" target="9" id="0">
      <data key="d8">2</data>
      <data key="d9">API request for ML results</data>
