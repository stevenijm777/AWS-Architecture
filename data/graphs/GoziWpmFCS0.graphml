<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">iRobot Data Pipeline</data>
      <data key="d6">UserCompanyDataStream</data>
      <data key="d7">Source of IoT robot data in JSON format.</data>
    </node>
    <node id="1">
      <data key="d5">S3 JSON Data Lake</data>
      <data key="d6">S3</data>
      <data key="d7">DATA_PEEK: Stores incoming JSON records from the data pipeline. WORKLOAD_PEEK: Receives about three terabytes of data per day.</data>
    </node>
    <node id="2">
      <data key="d5">Glue Crawler (JSON)</data>
      <data key="d6">Glue</data>
      <data key="d7">Catalogs the schema of the recently arrived JSON data in the S3 JSON Data Lake.</data>
    </node>
    <node id="3">
      <data key="d5">Glue Data Catalog</data>
      <data key="d6">Glue</data>
      <data key="d7">Stores schema information (column type, column name, table name) for both JSON and Parquet datasets, allowing inspection of data schemas.</data>
    </node>
    <node id="4">
      <data key="d5">Athena</data>
      <data key="d6">Athena</data>
      <data key="d7">Used by research scientists to query data for immediate search on JSON records and full history querying on Parquet data.</data>
    </node>
    <node id="5">
      <data key="d5">Glue Job (JSON to Parquet)</data>
      <data key="d6">Glue</data>
      <data key="d7">Converts recently arrived data from JSON records into Parquet format to enable full history querying and optimize query performance.</data>
    </node>
    <node id="6">
      <data key="d5">S3 Parquet Data Lake</data>
      <data key="d6">S3</data>
      <data key="d7">DATA_PEEK: Stores data converted from JSON to Parquet format. Parquet is a columnar data format that allows query engines to selectively scan information, saving money and time on queries and supporting full history analysis.</data>
    </node>
    <node id="7">
      <data key="d5">Glue Crawler (Parquet)</data>
      <data key="d6">Glue</data>
      <data key="d7">Catalogs the schema of the Parquet files stored in the S3 Parquet Data Lake.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">JSON records ingested from the data pipeline.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">Reads JSON data from S3 to infer schema.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="3" id="0">
      <data key="d8">0</data>
      <data key="d9">Stores inferred JSON schema information in the Data Catalog.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="3" id="0">
      <data key="d8">1</data>
      <data key="d9">Retrieves schema definitions for query execution from the Data Catalog.</data>
      <data key="d10">0</data>
      <data key="d11">meta</data>
    </edge>
    <edge source="4" target="1" id="0">
      <data key="d8">1</data>
      <data key="d9">Queries recent JSON data directly from S3 for immediate search. WORKLOAD_PEEK: Typically queries a couple of hours or one day of data.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="6" id="0">
      <data key="d8">1</data>
      <data key="d9">Queries Parquet data directly from S3 for full history querying.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="1" id="0">
      <data key="d8">2</data>
      <data key="d9">Reads recently arrived JSON data from S3 for conversion.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="6" id="0">
      <data key="d8">2</data>
      <data key="d9">Writes converted data in Parquet format to S3.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="7" target="6" id="0">
      <data key="d8">2</data>
      <data key="d9">Reads Parquet data from S3 to infer schema.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="7" target="3" id="0">
      <data key="d8">2</data>
      <data key="d9">Stores inferred Parquet schema information in the Data Catalog.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">iRobot Data Lake Architecture</data>
    <data key="d1">https://www.youtube.com/watch?v=GoziWpmFCS0</data>
    <data key="d2">This completely serverless architecture processes IoT robot data for research scientists. It supports quick queries on recent JSON data and full-history queries on optimized Parquet data, enabling bug detection and new feature development. Data volume: ~3 TB/day.</data>
    <data key="d3">data_ingestion, compute_intensive, interactive</data>
    <data key="d4">True</data>
  </graph>
</graphml>
