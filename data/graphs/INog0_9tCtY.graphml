<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">ThreatStack Agent</data>
      <data key="d6">UserCompanyAgent</data>
      <data key="d7">Proprietary software installed by customers via Chef, Ansible, Terraform etc. on their EC2 instances.</data>
    </node>
    <node id="1">
      <data key="d5">Customer instances with Agent</data>
      <data key="d6">EC2</data>
      <data key="d7">WORKLOAD_PEEK: EC2 instances within customer VPCs running the ThreatStack agent.</data>
    </node>
    <node id="2">
      <data key="d5">Customer's VPC</data>
      <data key="d6">VPC</data>
      <data key="d7">The customer's Virtual Private Cloud environment where their EC2 instances reside.</data>
    </node>
    <node id="3">
      <data key="d5">Customer's CloudTrail</data>
      <data key="d6">CloudTrail</data>
      <data key="d7">Customer's AWS CloudTrail environments, hooked up to ThreatStack for data ingestion.</data>
    </node>
    <node id="4">
      <data key="d5">Kafka Ingestion Bus</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">DATA_PEEK: Receives data initially in JSON, then serialized internally to Avro for high performance. WORKLOAD_PEEK: Ingests approximately 60 billion events per day.</data>
    </node>
    <node id="5">
      <data key="d5">Apache Flink Cluster</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">WORKLOAD_PEEK: Processes data from Kafka for near real-time insights and routing to short-term storage.</data>
    </node>
    <node id="6">
      <data key="d5">Near Real-time S3 (GZIP)</data>
      <data key="d6">S3</data>
      <data key="d7">DATA_PEEK: Stores a smaller subset of important fields, GZIP compressed in JSON format (exported from Avro). WORKLOAD_PEEK: Provides data for quick understanding and can be forwarded to customer S3 buckets.</data>
    </node>
    <node id="7">
      <data key="d5">Elasticsearch</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">WORKLOAD_PEEK: Stores a subset of data for very quick understanding and rapid search capability.</data>
    </node>
    <node id="8">
      <data key="d5">ThreatStack Customers (Platform/API)</data>
      <data key="d6">UserConsumerWebMobile</data>
      <data key="d7">End users or APIs interacting with the ThreatStack platform to understand security events quickly.</data>
    </node>
    <node id="9">
      <data key="d5">EMR (Long-term Processing)</data>
      <data key="d6">EMR</data>
      <data key="d7">WORKLOAD_PEEK: EMR cluster that processes data directly from Kafka for long-term storage (approx. 30 days) in S3 Parquet format.</data>
    </node>
    <node id="10">
      <data key="d5">EMR Orchestration Service</data>
      <data key="d6">EC2</data>
      <data key="d7">WORKLOAD_PEEK: A custom-built service running on EC2 instances that orchestrates and spins up EMR clusters in well-known, security-approved configurations. It also submits Spark jobs (jars) to the EMR clusters, e.g., to process Kafka data to S3 Parquet.</data>
    </node>
    <node id="11">
      <data key="d5">Long-term S3 (Parquet)</data>
      <data key="d6">S3</data>
      <data key="d7">DATA_PEEK: Data warehouse storing data for approximately 30 days, formatted with Apache Parquet. WORKLOAD_PEEK: Designed for advanced and quick map-reduce type searches.</data>
    </node>
    <node id="12">
      <data key="d5">Athena</data>
      <data key="d6">Athena</data>
      <data key="d7">WORKLOAD_PEEK: Used by security and services teams familiar with SQL to query the Parquet data for longer-term analysis and behavioral insights.</data>
    </node>
    <node id="13">
      <data key="d5">SageMaker</data>
      <data key="d6">SageMaker</data>
      <data key="d7">WORKLOAD_PEEK: Utilized by ThreatStack for machine learning, trend analysis, and anomaly detection on the long-lived Parquet data.</data>
    </node>
    <node id="14">
      <data key="d5">EMR (Consumption &amp; Analytics)</data>
      <data key="d6">EMR</data>
      <data key="d7">WORKLOAD_PEEK: EMR clusters used for running nightly reports or by developers to understand and process data from the long-term S3 bucket.</data>
    </node>
    <node id="15">
      <data key="d5">Customer's S3 Bucket</data>
      <data key="d6">S3</data>
      <data key="d7">DATA_PEEK: S3 bucket owned by the customer, where they can choose to sync data forwarded from ThreatStack's near real-time S3 bucket. WORKLOAD_PEEK: Used by customers for integration with their own security information and event management (SIEM) or analytics tooling.</data>
    </node>
    <node id="16">
      <data key="d5">Customer Developers/Analysts</data>
      <data key="d6">UserCompanyDeveloper</data>
      <data key="d7">Customers who prefer to use their own EMR, SageMaker, Athena services, or other tools to analyze the ThreatStack telemetry synced to their own S3 bucket.</data>
    </node>
    <node id="17">
      <data key="d5">CloudWatch (ThreatStack Internal Monitoring)</data>
      <data key="d6">CloudWatch</data>
      <data key="d7">WORKLOAD_PEEK: EMR clusters are configured to publish monitoring and logging data into ThreatStack's infrastructure for immediate visibility and operational insight.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">ThreatStack agent collects data from customer EC2 instances.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">Agent data transits through the customer's VPC.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="4" id="0">
      <data key="d8">0</data>
      <data key="d9">Customer data crosses the internet to ThreatStack's Kafka for ingestion.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="4" id="0">
      <data key="d8">0</data>
      <data key="d9">CloudTrail data is sent to ThreatStack's Kafka.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="5" id="0">
      <data key="d8">1</data>
      <data key="d9">Data flows from Kafka to Apache Flink for real-time processing.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="9" id="0">
      <data key="d8">2</data>
      <data key="d9">Kafka data is processed by an EMR cluster for long-term warehousing.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="6" id="0">
      <data key="d8">1</data>
      <data key="d9">Flink routes processed data to a GZIP S3 bucket for near real-time storage.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="7" id="0">
      <data key="d8">1</data>
      <data key="d9">Flink routes processed data to Elasticsearch for quick lookups.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="6" target="15" id="0">
      <data key="d8">4</data>
      <data key="d9">Customers can configure ThreatStack to sync processed GZIP data from ThreatStack's S3 to their own S3 bucket via STS role.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="8" target="6" id="0">
      <data key="d8">1</data>
      <data key="d9">Customers access near real-time data in S3 via ThreatStack's platform/APIs for quick understanding.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="8" target="7" id="0">
      <data key="d8">1</data>
      <data key="d9">Customers access data in Elasticsearch via ThreatStack's platform/APIs for quick understanding.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <edge source="9" target="11" id="0">
      <data key="d8">2</data>
      <data key="d9">Processed data is stored in the long-term S3 bucket in Parquet format.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="9" target="17" id="0">
      <data key="d8">2</data>
      <data key="d9">EMR clusters publish monitoring and logging data to ThreatStack's internal logging infrastructure.</data>
      <data key="d10">2</data>
      <data key="d11">meta</data>
    </edge>
    <edge source="10" target="9" id="0">
      <data key="d8">2</data>
      <data key="d9">Orchestration service running on EC2 spins up and submits jobs (e.g., Spark jobs) to the EMR cluster.</data>
      <data key="d10">0.5</data>
      <data key="d11">meta</data>
    </edge>
    <edge source="12" target="11" id="0">
      <data key="d8">3</data>
      <data key="d9">Athena queries the Parquet data in S3 for long-term analysis.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="13" target="11" id="0">
      <data key="d8">3</data>
      <data key="d9">SageMaker accesses the Parquet data in S3 for machine learning and anomaly detection.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="14" target="11" id="0">
      <data key="d8">3</data>
      <data key="d9">EMR (consumption) processes Parquet data from S3 for reports and developer insights.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="14" target="17" id="0">
      <data key="d8">3</data>
      <data key="d9">EMR clusters publish monitoring and logging data to ThreatStack's internal logging infrastructure.</data>
      <data key="d10">3</data>
      <data key="d11">meta</data>
    </edge>
    <edge source="16" target="15" id="0">
      <data key="d8">4</data>
      <data key="d9">Customer developers use their own analytics tools (EMR, SageMaker, Athena) to analyze synced data in their S3 bucket.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">ThreatStack Data Ingestion and Analytics Architecture</data>
    <data key="d1">https://www.youtube.com/watch?v=INog0_9tCtY</data>
    <data key="d2">ThreatStack ingests about 60 billion events daily from customer VPCs (EC2 agents) and CloudTrail. The architecture supports both near real-time insights and long-term data warehousing for analytics and compliance. Data is processed through Kafka, Flink, and EMR, stored in S3 (GZIP for real-time, Parquet for long-term), and made available via Elasticsearch, Athena, SageMaker, and EMR. A custom EC2 service orchestrates EMR cluster deployments for security and performance. Customers can also export processed data to their own S3 buckets for independent analysis.</data>
    <data key="d3">data_ingestion, interactive, compute_intensive</data>
    <data key="d4">True</data>
  </graph>
</graphml>
