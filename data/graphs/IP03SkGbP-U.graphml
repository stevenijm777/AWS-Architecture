<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">End User</data>
      <data key="d6">UserConsumerWebMobile</data>
      <data key="d7">Users interacting with the stock exchange applications.</data>
    </node>
    <node id="1">
      <data key="d5">Route 53</data>
      <data key="d6">Route53</data>
      <data key="d7">WORKLOAD_PEEK: High-level traffic management using weighted policies (100% active, 0% DR initially). Used for failover orchestration.</data>
    </node>
    <node id="2">
      <data key="d5">ALB (Active Region)</data>
      <data key="d6">ALB</data>
      <data key="d7">Load Balancer for public and private web applications in the active region.</data>
    </node>
    <node id="3">
      <data key="d5">EC2 (NASDAQ Engine - Active Region)</data>
      <data key="d6">EC2</data>
      <data key="d7">WORKLOAD_PEEK: Hosts the core NASDAQ machine engine in the active region.</data>
    </node>
    <node id="4">
      <data key="d5">RDS (NASDAQ Database - Active Region)</data>
      <data key="d6">RDS</data>
      <data key="d7">DATA_PEEK: Core database for the NASDAQ machine engine in the active region. Transcript mentions 'Rift Deplica' (Read Replica).</data>
    </node>
    <node id="5">
      <data key="d5">ECS (Auxiliary Systems - Active Region)</data>
      <data key="d6">ECS</data>
      <data key="d7">WORKLOAD_PEEK: Runs auxiliary systems as container services in the active region. Transcript mentions 'ACS' and 'EC2 container services'.</data>
    </node>
    <node id="6">
      <data key="d5">ECR (Active Region)</data>
      <data key="d6">ECR</data>
      <data key="d7">DATA_PEEK: Container registry for ECS images in the active region. Transcript mentions 'ACR'. Used to keep actual versions of images.</data>
    </node>
    <node id="7">
      <data key="d5">DynamoDB (Auxiliary Systems - Active Region)</data>
      <data key="d6">DynamoDB</data>
      <data key="d7">DATA_PEEK: Stores data for auxiliary systems in the active region. Part of a global table.</data>
    </node>
    <node id="8">
      <data key="d5">ALB (DR Region)</data>
      <data key="d6">ALB</data>
      <data key="d7">Load Balancer for applications in the disaster recovery region, initially receiving 0% traffic.</data>
    </node>
    <node id="9">
      <data key="d5">EC2 (NASDAQ Engine - DR Region)</data>
      <data key="d6">EC2</data>
      <data key="d7">WORKLOAD_PEEK: Standby EC2 instances for the NASDAQ machine engine in the disaster recovery region.</data>
    </node>
    <node id="10">
      <data key="d5">RDS (NASDAQ Database - DR Region)</data>
      <data key="d6">RDS</data>
      <data key="d7">DATA_PEEK: Read Replica of the NASDAQ machine engine database in the disaster recovery region.</data>
    </node>
    <node id="11">
      <data key="d5">ECS (Auxiliary Systems - DR Region)</data>
      <data key="d6">ECS</data>
      <data key="d7">WORKLOAD_PEEK: Standby ECS clusters/services for auxiliary systems in the disaster recovery region.</data>
    </node>
    <node id="12">
      <data key="d5">ECR (DR Region)</data>
      <data key="d6">ECR</data>
      <data key="d7">DATA_PEEK: Container registry for ECS images in the disaster recovery region.</data>
    </node>
    <node id="13">
      <data key="d5">DynamoDB (Auxiliary Systems - DR Region)</data>
      <data key="d6">DynamoDB</data>
      <data key="d7">DATA_PEEK: Stores data for auxiliary systems in the disaster recovery region. Part of a global table.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">End users access the stock exchange, DNS queries hit Route 53.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">Route 53 routes 100% of traffic to the active region's ALB under normal operation.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="1" id="0">
      <data key="d8">2</data>
      <data key="d9">Failover script updates Route 53 weighted policy, setting active region traffic to 0% (deactivates).</data>
      <data key="d10">0</data>
      <data key="d11">meta</data>
    </edge>
    <edge source="1" target="1" id="1">
      <data key="d8">2</data>
      <data key="d9">Failover script updates Route 53 weighted policy, setting DR region traffic to 100% (activates).</data>
      <data key="d10">1</data>
      <data key="d11">meta</data>
    </edge>
    <edge source="2" target="3" id="0">
      <data key="d8">0</data>
      <data key="d9">ALB distributes traffic to EC2 instances running the NASDAQ machine engine.</data>
      <data key="d10">2a</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="5" id="0">
      <data key="d8">0</data>
      <data key="d9">ALB distributes traffic to ECS services running auxiliary applications.</data>
      <data key="d10">2b</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="4" id="0">
      <data key="d8">0</data>
      <data key="d9">NASDAQ machine engine on EC2 interacts with its RDS database.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="9" id="0">
      <data key="d8">1</data>
      <data key="d9">EC2 instance data (e.g., EBS snapshots) are replicated to the DR region using a lifecycle manager to keep an actual version.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="10" id="0">
      <data key="d8">1</data>
      <data key="d9">RDS database is replicated to the DR region using RDS Read Replicas (transcript: 'Rift Deplica service').</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="7" id="0">
      <data key="d8">0</data>
      <data key="d9">Auxiliary systems on ECS interact with DynamoDB for data storage.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="6" id="0">
      <data key="d8">0</data>
      <data key="d9">ECS services pull container images from ECR as needed.</data>
      <data key="d10">5</data>
      <data key="d11">data</data>
    </edge>
    <edge source="6" target="12" id="0">
      <data key="d8">1</data>
      <data key="d9">ECR images are copied/synced to the DR region to ensure actual versions are available.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="7" target="13" id="0">
      <data key="d8">1</data>
      <data key="d9">DynamoDB data is automatically replicated to the DR region via Global Tables.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="10" target="10" id="0">
      <data key="d8">2</data>
      <data key="d9">Failover script promotes the RDS Read Replica in the DR region to a primary instance.</data>
      <data key="d10">2</data>
      <data key="d11">meta</data>
    </edge>
    <edge source="12" target="12" id="0">
      <data key="d8">2</data>
      <data key="d9">Failover script starts/ensures the copy of images in the DR region's ECR if not fully synced or activated ('starts the copy of images and different regions also').</data>
      <data key="d10">3</data>
      <data key="d11">meta</data>
    </edge>
    <data key="d0">Astana International Exchange Cloud Architecture</data>
    <data key="d1">https://www.youtube.com/watch?v=IP03SkGbP-U</data>
    <data key="d2">Astana International Exchange runs its entire stock exchange in the AWS cloud across two regions for high availability (active/passive disaster recovery). The core system uses NASDAQ machine engine on EC2 and RDS, while auxiliary systems use ECS, ECR, and DynamoDB. Route 53 is used for traffic management and failover orchestration via weighted routing policies. Data replication across regions employs EC2 snapshots (via Lifecycle Manager), RDS Read Replicas, ECR image copies, and DynamoDB Global Tables. Failover is managed by a shell script that updates Route 53 policies, promotes RDS instances, and ensures ECR image availability in the DR region, aiming for a 30-second technical recovery time.</data>
    <data key="d3">interactive, compute_intensive, control</data>
    <data key="d4">True</data>
  </graph>
</graphml>
