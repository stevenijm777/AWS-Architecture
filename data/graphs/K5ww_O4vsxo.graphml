    <node id="13">
      <data key="d5">Site-to-Site VPN</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Planned for connecting other services or users securely to the AWS Transit Gateway network.</data>
    </node>
    <node id="14">
