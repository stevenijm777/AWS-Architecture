    <node id="0">
      <data key="d5">Galaxy Smartphone Users</data>
      <data key="d6">UserConsumerMobile</data>
      <data key="d7">DATA_PEEK: User data includes photos and videos for backup and restore. WORKLOAD_PEEK: Represents hundreds of millions of users globally.</data>
    </node>
    <node id="1">
      <data key="d5">Samsung Cloud VPC (Korea)</data>
      <data key="d6">VPC</data>
      <data key="d7">One of the Virtual Private Clouds hosting the Samsung Cloud service in the Korea (KR) region.</data>
    </node>
    <node id="2">
      <data key="d5">Samsung Cloud VPC (US)</data>
      <data key="d6">VPC</data>
      <data key="d7">One of the Virtual Private Clouds hosting the Samsung Cloud service in the US region.</data>
    </node>
    <node id="3">
      <data key="d5">Samsung Cloud VPC (Europe)</data>
      <data key="d6">VPC</data>
      <data key="d7">One of the Virtual Private Clouds hosting the Samsung Cloud service in the Europe (EU) region.</data>
    </node>
    <node id="4">
      <data key="d5">Samsung Cloud VPC (Singapore)</data>
      <data key="d6">VPC</data>
      <data key="d7">One of the Virtual Private Clouds hosting the Samsung Cloud service in the Singapore (SG) region.</data>
    </node>
    <node id="5">
      <data key="d5">Samsung Cloud VPC (China)</data>
      <data key="d6">VPC</data>
      <data key="d7">One of the Virtual Private Clouds hosting the Samsung Cloud service in the China (CN) region, explicitly mentioned in the transcript.</data>
    </node>
    <node id="6">
      <data key="d5">Transit Gateway (Korea)</data>
      <data key="d6">TransitGateway</data>
      <data key="d7">Connects VPCs within the Korea region and facilitates inter-region communication to other Transit Gateways.</data>
    </node>
    <node id="7">
      <data key="d5">Transit Gateway (US)</data>
      <data key="d6">TransitGateway</data>
      <data key="d7">Connects VPCs within the US region and facilitates inter-region communication to other Transit Gateways.</data>
    </node>
    <node id="8">
      <data key="d5">Transit Gateway (Europe)</data>
      <data key="d6">TransitGateway</data>
      <data key="d7">Connects VPCs within the Europe region and facilitates inter-region communication to other Transit Gateways.</data>
    </node>
    <node id="9">
      <data key="d5">Transit Gateway (Singapore)</data>
      <data key="d6">TransitGateway</data>
      <data key="d7">Connects VPCs within the Singapore region and facilitates inter-region communication to other Transit Gateways.</data>
    </node>
    <node id="10">
