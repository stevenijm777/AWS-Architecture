<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Customer</data>
      <data key="d6">UserConsumerWebMobile</data>
      <data key="d7">The end user attempting to book a ticket from the Vietjet system.</data>
    </node>
    <node id="1">
      <data key="d5">CloudFront CDN</data>
      <data key="d6">CloudFront</data>
      <data key="d7">DATA_PEEK: Serves as the initial entry point for customer requests to the booking system. WORKLOAD_PEEK: Triggers a Lambda function at the Edge for validation.</data>
    </node>
    <node id="2">
      <data key="d5">Pattern Match (Lambda@Edge)</data>
      <data key="d6">LambdaAtEdge</data>
      <data key="d7">WORKLOAD_PEEK: Triggered by CloudFront. Contains business logic validator to identify legitimate customer requests versus bots. If a bot is detected, the request is dropped. Patterns are manually updated based on analysis results.</data>
    </node>
    <node id="3">
      <data key="d5">WAF</data>
      <data key="d6">WAF</data>
      <data key="d7">WORKLOAD_PEEK: Protects against common OWASP top 10 vulnerabilities. Logs all requests to Kinesis Firehose for further analysis.</data>
    </node>
    <node id="4">
      <data key="d5">Internet Booking System</data>
      <data key="d6">EC2</data>
      <data key="d7">WORKLOAD_PEEK: The core backend system for ticket booking. Protected by CloudFront, Lambda@Edge, and WAF. Experiences 90% traffic reduction due to bot filtering.</data>
    </node>
    <node id="5">
      <data key="d5">Kinesis Firehose</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">DATA_PEEK: Ingests logs from WAF for persistent storage and further analysis. Delivers logs to S3.</data>
    </node>
    <node id="6">
      <data key="d5">S3 Data Lake</data>
      <data key="d6">S3</data>
      <data key="d7">DATA_PEEK: Stores all raw logs delivered by Kinesis Firehose. Also stores transformed log data in Parquet format. Serves as the single data lake for all information related to traffic and booking patterns.</data>
    </node>
    <node id="7">
      <data key="d5">Transform Lambda</data>
      <data key="d6">Lambda</data>
      <data key="d7">WORKLOAD_PEEK: Triggered by S3 events when new logs are delivered. DATA_PEEK: Transforms raw log data from its original format into Parquet, suitable for Athena queries.</data>
    </node>
    <node id="8">
      <data key="d5">Athena</data>
      <data key="d6">Athena</data>
      <data key="d7">WORKLOAD_PEEK: Used to query log information stored in S3 (especially Parquet files). Helps analyze backlog data to figure out new attack patterns.</data>
    </node>
    <node id="9">
      <data key="d5">QuickSight</data>
      <data key="d6">QuickSight</data>
      <data key="d7">WORKLOAD_PEEK: Builds dashboards to visualize system performance and identify potential attacks (e.g., number of bookings mapped by IP or country). DATA_PEEK: Gets data from Athena.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">Customer initiates a request to book a ticket</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">CloudFront triggers Lambda@Edge for request validation</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="3" id="0">
      <data key="d8">0</data>
      <data key="d9">Valid requests are forwarded from CloudFront to WAF</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">Lambda@Edge returns validation result to CloudFront</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="4" id="0">
      <data key="d8">0</data>
      <data key="d9">Legitimate requests (not blocked by WAF) proceed to the Internet Booking System</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="5" id="0">
      <data key="d8">1</data>
      <data key="d9">WAF sends all logs (including bot/attack attempts) to Kinesis Firehose</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="6" id="0">
      <data key="d8">1</data>
      <data key="d9">Kinesis Firehose delivers logs to S3 for storage and further analysis</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="6" target="7" id="0">
      <data key="d8">1</data>
      <data key="d9">S3 event triggers Lambda for log transformation</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="7" target="6" id="0">
      <data key="d8">1</data>
      <data key="d9">Transformed log data (Parquet format) is stored back into S3</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="8" target="6" id="0">
      <data key="d8">1</data>
      <data key="d9">Athena queries the transformed log data in S3</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <edge source="9" target="8" id="0">
      <data key="d8">1</data>
      <data key="d9">QuickSight retrieves data from Athena to build dashboards</data>
      <data key="d10">5</data>
      <data key="d11">data</data>
    </edge>
    <edge source="9" target="2" id="0">
      <data key="d8">1</data>
      <data key="d9">Based on insights from QuickSight dashboards and Athena analysis, new patterns are manually updated in the Lambda@Edge function.</data>
      <data key="d10">6</data>
      <data key="d11">meta</data>
    </edge>
    <data key="d0">Vietjet Bot Protection and Log Analysis Architecture</data>
    <data key="d1">https://www.youtube.com/watch?v=KQ6Fg206O9U</data>
    <data key="d2">Vietjet developed this architecture to protect their internet booking system from bot attacks and fraudulent bookings, which were affecting customer experience and revenue. The solution leverages AWS serverless technologies and data analytics to identify and block bots, and analyze traffic patterns. It has reduced traffic to the backend by 90% and protected revenue. Future plans include automating the pattern update process using machine learning with SageMaker.</data>
    <data key="d3">data_ingestion, interactive, compute_intensive, control</data>
    <data key="d4">True</data>
  </graph>
</graphml>
