    </edge>
    <edge source="5" target="4" id="0">
      <data key="d8">0</data>
      <data key="d9">CodeBuild pulls the artifact from ECR for deployment to QA.</data>
      <data key="d10">6</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">CodeBuild sends a notification to Slack upon successful deployment to QA.</data>
      <data key="d10">7</data>
      <data key="d11">data</data>
    </edge>
    <edge source="6" target="7" id="0">
      <data key="d8">1</data>
      <data key="d9">SNS publishes the approval payload to the Lambda function.</data>
      <data key="d10">1</data>
      <data key="d11">meta</data>
    </edge>
    <edge source="7" target="2" id="0">
      <data key="d8">1</data>
      <data key="d9">Lambda uses a webhook to send an interactive 'yes-no' message box to Slack.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="8" target="9" id="0">
      <data key="d8">1</data>
      <data key="d9">API Gateway invokes the Lambda function to trigger CodePipeline continuation.</data>
      <data key="d10">5</data>
