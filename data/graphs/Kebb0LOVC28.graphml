  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Developer</data>
      <data key="d6">UserCompanyDeveloper</data>
      <data key="d7">WORKLOAD_PEEK: Initiates the continuous deployment pipeline by submitting a pull request (PR).</data>
    </node>
    <node id="1">
      <data key="d5">CD Pipeline Orchestrator</data>
      <data key="d6">CodePipeline</data>
      <data key="d7">WORKLOAD_PEEK: Orchestrates the build, test, deploy, and approve stages of the continuous deployment process. Triggered by PRs.</data>
    </node>
    <node id="2">
      <data key="d5">Slack Channel</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">DATA_PEEK: Receives PR reports and deployment notifications. WORKLOAD_PEEK: Hosts interactive 'yes-no' messages for approval, used by the QA and DevOps teams.</data>
    </node>
    <node id="3">
      <data key="d5">Build Artifact Project</data>
      <data key="d6">CodeBuild</data>
      <data key="d7">WORKLOAD_PEEK: Builds the immutable artifact from source code. DATA_PEEK: Outputs the built artifact.</data>
    </node>
    <node id="4">
      <data key="d5">Artifact Repository</data>
      <data key="d6">ECR</data>
      <data key="d7">DATA_PEEK: Stores the immutable build artifacts (Docker images) produced by CodeBuild.</data>
    </node>
    <node id="5">
      <data key="d5">Deploy to QA Project</data>
      <data key="d6">CodeBuild</data>
      <data key="d7">WORKLOAD_PEEK: Pulls the immutable artifact from ECR and deploys it to the QA testing environment.</data>
    </node>
    <node id="6">
      <data key="d5">Approval Notification Topic</data>
      <data key="d6">SNS</data>
      <data key="d7">WORKLOAD_PEEK: Receives approval requests from CodePipeline and publishes them to subscribers for processing the interactive Slack message.</data>
    </node>
    <node id="7">
      <data key="d5">Slack Interactive Message Sender</data>
      <data key="d6">Lambda</data>
      <data key="d7">WORKLOAD_PEEK: Subscribes to SNS, receives approval payload, and uses a webhook to deliver an interactive 'yes-no' message box to Slack.</data>
    </node>
    <node id="8">
      <data key="d5">Approval Callback API</data>
      <data key="d6">ApiGateway</data>
      <data key="d7">WORKLOAD_PEEK: Exposes a REST API endpoint that is triggered by the interactive 'yes-no' button click in Slack.</data>
    </node>
    <node id="9">
      <data key="d5">CodePipeline Continue Trigger</data>
      <data key="d6">Lambda</data>
      <data key="d7">WORKLOAD_PEEK: Invoked by API Gateway after a Slack approval. Tells CodePipeline to continue with its flow (e.g., deploy to production).</data>
    </node>
    <node id="10">
      <data key="d5">Deploy to Production Project</data>
      <data key="d6">CodeBuild</data>
      <data key="d7">WORKLOAD_PEEK: Pulls the approved immutable artifact from ECR and deploys it to the production environment.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">Developer submits a pull request to initiate the CodePipeline.</data>
      <data key="d10">0</data>
      <data key="d11">meta</data>
    </edge>
    <edge source="0" target="2" id="0">
      <data key="d8">1</data>
      <data key="d9">DevOps team (User) clicks the 'yes' or 'no' button in Slack for approval.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">CodePipeline sends a report about the PR to the relevant Slack channel.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="3" id="0">
      <data key="d8">0</data>
      <data key="d9">CodePipeline triggers the CodeBuild project for building the artifact.</data>
      <data key="d10">2</data>
      <data key="d11">meta</data>
    </edge>
    <edge source="1" target="5" id="0">
      <data key="d8">0</data>
      <data key="d9">CodePipeline triggers the CodeBuild project to deploy the artifact to QA.</data>
      <data key="d10">5</data>
      <data key="d11">meta</data>
    </edge>
    <edge source="1" target="6" id="0">
      <data key="d8">1</data>
      <data key="d9">CodePipeline triggers an SNS message for the approval step after QA deployment.</data>
      <data key="d10">0</data>
      <data key="d11">meta</data>
    </edge>
    <edge source="1" target="10" id="0">
      <data key="d8">2</data>
      <data key="d9">CodePipeline triggers the CodeBuild project to deploy the artifact to production after approval.</data>
      <data key="d10">0</data>
      <data key="d11">meta</data>
    </edge>
    <edge source="2" target="8" id="0">
      <data key="d8">1</data>
      <data key="d9">Slack sends a callback to the API Gateway endpoint when the interactive button is clicked.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="4" id="0">
      <data key="d8">0</data>
      <data key="d9">CodeBuild saves the immutable artifact (e.g., Docker image) to ECR.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">CodeBuild sends a notification to Slack upon successful artifact build.</data>
      <data key="d10">4</data>
