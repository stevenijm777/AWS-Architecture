<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d12" for="edge" attr.name="id" attr.type="string" />
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">On-Premises Systems</data>
      <data key="d6">OnPremDC</data>
      <data key="d7">Source of data from existing data warehouses and data marts.</data>
    </node>
    <node id="1">
      <data key="d5">Direct Connect</data>
      <data key="d6">DirectConnect</data>
      <data key="d7">Securely brings data from on-premises systems into AWS.</data>
    </node>
    <node id="2">
      <data key="d5">Ingestion Compute</data>
      <data key="d6">EC2</data>
      <data key="d7">WORKLOAD_PEEK: Hosts various ingestion technologies like Kafka, Talend, and Databricks. Acts as the initial landing and processing environment for on-prem data.</data>
    </node>
    <node id="3">
      <data key="d5">Kafka on EC2</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">WORKLOAD_PEEK: Ingestion technology running on EC2 instances, used to pump data into S3.</data>
    </node>
    <node id="4">
      <data key="d5">Talend on EC2</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">WORKLOAD_PEEK: ETL technology running on EC2 instances, used to pump data into S3.</data>
    </node>
    <node id="5">
      <data key="d5">Databricks on EC2</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">WORKLOAD_PEEK: Data processing technology running on EC2 instances, used to pump data into S3.</data>
    </node>
    <node id="6">
      <data key="d5">Data Lake</data>
      <data key="d6">S3</data>
      <data key="d7">DATA_PEEK: Stores raw source data (origin), enterprise data (data warehouse equivalent), and final product data (data mart equivalent). Data is stored in Parquet and Delta Ipers format for fast processing.</data>
    </node>
    <node id="7">
      <data key="d5">Glue Data Catalog</data>
      <data key="d6">Glue</data>
      <data key="d7">WORKLOAD_PEEK: Stores the catalog and metadata aspects of the data in S3.</data>
    </node>
    <node id="8">
      <data key="d5">Metrics Database</data>
      <data key="d6">RDS</data>
      <data key="d7">DATA_PEEK: Stores metrics related to the various processing steps happening in the architecture.</data>
    </node>
    <node id="9">
      <data key="d5">Data Mark Redshift Cluster</data>
      <data key="d6">RedShift</data>
      <data key="d7">WORKLOAD_PEEK: A read-optimized layer for data marts. Leverages Redshift Spectrum to extend queries to S3 for data not stored directly in Redshift.</data>
    </node>
    <node id="10">
      <data key="d5">Athena Query Engine</data>
      <data key="d6">Athena</data>
      <data key="d7">WORKLOAD_PEEK: Used for self-service analytics, allowing users to query data directly from S3 on the fly.</data>
    </node>
    <node id="11">
      <data key="d5">Analysts</data>
      <data key="d6">UserCompanyAnalyst</data>
      <data key="d7">Actor: Consumes and processes data for analysis.</data>
    </node>
    <node id="12">
      <data key="d5">Data Scientists</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Actor: Consumes and processes data for scientific modeling and insights.</data>
    </node>
    <node id="13">
      <data key="d5">Business Users</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Actor: Performs self-service analytics and generates reports from the data.</data>
    </node>
    <edge source="0" target="1">
      <data key="d8">0</data>
      <data key="d9">Secure transfer of on-premises data to AWS.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="1" target="2">
      <data key="d8">0</data>
      <data key="d9">Ingestion of data into the EC2 compute environment.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="2" target="3">
      <data key="d8">0</data>
      <data key="d9">EC2 uses Kafka for data processing and ingestion.</data>
      <data key="d10">2a</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="2" target="4">
      <data key="d8">0</data>
      <data key="d9">EC2 uses Talend for data processing and ingestion.</data>
      <data key="d10">2b</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="2" target="5">
      <data key="d8">0</data>
      <data key="d9">EC2 uses Databricks for data processing and ingestion.</data>
      <data key="d10">2c</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="2" target="8">
      <data key="d8">0</data>
      <data key="d9">Processing on EC2 sends metrics to RDS for storage.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="3" target="6">
      <data key="d8">0</data>
      <data key="d9">Kafka pumps processed data into the S3 Data Lake.</data>
      <data key="d10">3a</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="4" target="6">
      <data key="d8">0</data>
      <data key="d9">Talend pumps processed data into the S3 Data Lake.</data>
      <data key="d10">3b</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="5" target="6">
      <data key="d8">0</data>
      <data key="d9">Databricks pumps processed data into the S3 Data Lake.</data>
      <data key="d10">3c</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="6" target="7">
      <data key="d8">0</data>
      <data key="d9">S3 data has its metadata stored in Glue Data Catalog.</data>
      <data key="d10">6</data>
      <data key="d11">meta</data>
      <data key="d12">0</data>
    </edge>
    <edge source="6" target="9">
      <data key="d8">1</data>
      <data key="d9">Data for the read-optimized data mark is pumped from S3 into Redshift.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="7" target="6">
      <data key="d8">0</data>
      <data key="d9">Glue accesses S3 to infer schemas and catalog data. (reads S3 metadata)</data>
      <data key="d10">5</data>
      <data key="d11">meta</data>
      <data key="d12">0</data>
    </edge>
    <edge source="9" target="6">
      <data key="d8">1</data>
      <data key="d9">Redshift, using Spectrum, queries S3 directly for data not stored in Redshift.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="10" target="6">
      <data key="d8">1</data>
      <data key="d9">Athena queries S3 directly to fetch data for self-service analytics.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="11" target="9">
      <data key="d8">1</data>
      <data key="d9">Analysts query the Redshift data mark.</data>
      <data key="d10">1a</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="11" target="10">
      <data key="d8">1</data>
      <data key="d9">Analysts use Athena for self-service queries.</data>
      <data key="d10">3a</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="12" target="9">
      <data key="d8">1</data>
      <data key="d9">Data Scientists query the Redshift data mark.</data>
      <data key="d10">1b</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="12" target="10">
      <data key="d8">1</data>
      <data key="d9">Data Scientists use Athena for self-service queries.</data>
      <data key="d10">3b</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="13" target="9">
      <data key="d8">1</data>
      <data key="d9">Business Users query the Redshift data mark.</data>
      <data key="d10">1c</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="13" target="10">
      <data key="d8">1</data>
      <data key="d9">Business Users use Athena for self-service queries.</data>
      <data key="d10">3c</data>
      <data key="d11">data</data>
