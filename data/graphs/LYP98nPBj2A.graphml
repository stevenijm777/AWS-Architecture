  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="U0">
      <data key="d5">Mobile Users</data>
      <data key="d6">UserConsumerMobile</data>
      <data key="d7">End-users topping up their mobile services.</data>
    </node>
    <node id="U1">
      <data key="d5">Merchants</data>
      <data key="d6">UserCompanyAPI</data>
      <data key="d7">Merchants using the EMTU system, likely via an API, to facilitate top-ups.</data>
    </node>
    <node id="U2">
      <data key="d5">Singtel Management</data>
      <data key="d6">UserCompanyAnalyst</data>
      <data key="d7">Internal users who monitor analytics and performance of the EMTU application.</data>
    </node>
    <node id="U3">
      <data key="d5">Singtel Support</data>
      <data key="d6">UserCompanyAgent</data>
      <data key="d7">Internal users who handle technical queries and issues from EMTU users.</data>
    </node>
    <node id="N0">
      <data key="d5">Internet Gateway</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Handles external internet traffic for the EMTU application.</data>
    </node>
    <node id="N1">
      <data key="d5">Virtual Private Gateway</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Handles internal or secure partner traffic, likely for Singtel's internal users or trusted merchants, connected to the ALB as per diagram.</data>
    </node>
    <node id="N2">
      <data key="d5">Application Load Balancer</data>
      <data key="d6">ALB</data>
      <data key="d7">Fronts the application, distributing incoming traffic from both IGW and VGW to the EC2 instances. Provides high availability by failing over web front-end instances to another instance/AZ.</data>
    </node>
    <node id="N3">
      <data key="d5">Web Tier (AZ1)</data>
      <data key="d6">EC2</data>
      <data key="d7">WORKLOAD_PEEK: Primary deployment of the web front-end application layer for EMTU, handling user interface and initial request processing. Part of the 'web' component in the architecture. Capable of catering up to 50 transactions per second (peak).</data>
    </node>
    <node id="N4">
      <data key="d5">App Tier (AZ1)</data>
      <data key="d6">EC2</data>
      <data key="d7">WORKLOAD_PEEK: Primary deployment of the application layer for EMTU, handling core business logic and transaction processing. Part of the 'app' component in the architecture.</data>
    </node>
    <node id="N5">
      <data key="d5">Aurora (Primary)</data>
      <data key="d6">Aurora</data>
      <data key="d7">DATA_PEEK: Primary Amazon Aurora database instance, serving as the system of record for EMTU. Chosen for significant cost savings (especially licensing), positive high availability, and automation benefits over proprietary databases like Oracle.</data>
    </node>
    <node id="N6">
      <data key="d5">Web Tier (AZ2)</data>
      <data key="d6">EC2</data>
      <data key="d7">WORKLOAD_PEEK: High Availability / Failover deployment of the web front-end application layer for EMTU. This instance or set of instances is part of the redundant architecture to ensure no transaction loss during failures of the primary web front-end.</data>
    </node>
    <node id="N7">
      <data key="d5">App Tier (AZ2)</data>
      <data key="d6">EC2</data>
      <data key="d7">WORKLOAD_PEEK: High Availability / Failover deployment of the application layer for EMTU. Provides redundancy for the core application logic.</data>
    </node>
    <node id="N8">
      <data key="d5">Aurora (Replica)</data>
      <data key="d6">Aurora</data>
      <data key="d7">DATA_PEEK: High Availability / Failover database instance for Aurora, ensuring continuous operation and data durability for the system of record in case of primary database failure.</data>
    </node>
    <node id="N9">
      <data key="d5">SecurityHub</data>
      <data key="d6">SecurityHub</data>
      <data key="d7">Provides a centralized view of security alerts and automated security checks, part of the suite of security services for deep monitoring across the EMTU architecture.</data>
    </node>
    <node id="N10">
      <data key="d5">Macie</data>
      <data key="d6">Macie</data>
      <data key="d7">Used for data security and privacy, monitoring the end-to-end transactions for sensitive data anomalies and threats within the EMTU system.</data>
    </node>
    <node id="N11">
      <data key="d5">CloudWatch</data>
      <data key="d6">CloudWatch</data>
      <data key="d7">Provides deep monitoring capabilities for the entire architecture, collecting metrics and logs for analytics, performance insights, and operational queries by Singtel management and support.</data>
    </node>
    <edge source="U0" target="N0" id="0">
      <data key="d8">0</data>
      <data key="d9">Mobile users initiate top-up requests over the internet.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
