<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Student/Faculty Alexa Device</data>
      <data key="d6">UserConsumerAlexaGoogleHome</data>
      <data key="d7">WORKLOAD_PEEK: Interact with the bot to ask questions, e.g., library hours. DATA_PEEK: Sends natural language queries, receives bot responses.</data>
    </node>
    <node id="1">
      <data key="d5">Student/Faculty Web/Mobile App</data>
      <data key="d6">UserConsumerWebMobile</data>
      <data key="d7">WORKLOAD_PEEK: Interact with the bot via website or text messages. DATA_PEEK: Sends natural language queries, receives bot responses. Also provides feedback via 'thumbs down'.</data>
    </node>
    <node id="2">
      <data key="d5">Q&amp;A Chatbot</data>
      <data key="d6">Lex</data>
      <data key="d7">WORKLOAD_PEEK: Powers the core Q&amp;A bot. Handles natural language understanding, integrates with DynamoDB, Lambda, OpenSearch, Comprehend, and SNS for various functionalities. DATA_PEEK: Processes user questions, retrieves answers, sends requests to other services, and formats responses.</data>
    </node>
    <node id="3">
      <data key="d5">Building Hours DB</data>
      <data key="d6">DynamoDB</data>
      <data key="d7">DATA_PEEK: Stores building hours including default, holiday, and break hours. WORKLOAD_PEEK: Provides a powerful tool for content managers to set defaults and enter data via a GUI.</data>
    </node>
    <node id="4">
      <data key="d5">External Partner Integration</data>
      <data key="d6">Lambda</data>
      <data key="d7">WORKLOAD_PEEK: Reaches out to external partners (food vendor) to get up-to-date information. DATA_PEEK: Sends queries to external vendor, receives dining options.</data>
    </node>
    <node id="5">
      <data key="d5">External Food Vendor</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">DATA_PEEK: Provides up-to-date dining hall menu information. WORKLOAD_PEEK: Coordinated with the university to provide schedule and data.</data>
    </node>
    <node id="6">
      <data key="d5">Question Scoring (Elasticsearch)</data>
      <data key="d6">OpenSearch</data>
      <data key="d7">WORKLOAD_PEEK: Provides real-time scoring on all questions entered, showing what answer each question maps to. Used to test how the bot responds to new questions. DATA_PEEK: Stores question-answer mappings and scoring data for over 400 questions.</data>
    </node>
    <node id="7">
      <data key="d5">Keyword Honing</data>
      <data key="d6">Comprehend</data>
      <data key="d7">WORKLOAD_PEEK: Hones in on keywords (subjects, nouns, verbs) and ignores common linking words, ensuring the bot only answers expected questions. DATA_PEEK: Processes text for keyword extraction and sentiment.</data>
    </node>
    <node id="8">
      <data key="d5">Feedback Notification</data>
      <data key="d6">SNS</data>
      <data key="d7">WORKLOAD_PEEK: Sends email notifications to all content owners when a user leaves feedback (thumbs down). DATA_PEEK: Carries the question asked and the answer given by the bot.</data>
    </node>
    <node id="9">
      <data key="d5">Content Owners</data>
      <data key="d6">UserCompanyDeveloper</data>
      <data key="d7">WORKLOAD_PEEK: Enter building hours via a GUI on top of DynamoDB. Add questions in bulk and test them using OpenSearch. Receive email feedback from SNS to fix poor answers or add new ones.</data>
    </node>
    <edge source="0" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">Student asks a question (e.g., library hours) via Alexa device.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="0" target="2" id="1">
      <data key="d8">2</data>
      <data key="d9">Student leaves feedback (thumbs down) on a bot answer via Alexa device.</data>
      <data key="d10">7</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">Student asks a question via website.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="2" id="1">
      <data key="d8">1</data>
      <data key="d9">Student texts a question (e.g., dining hall menu) to the bot.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="2" id="2">
      <data key="d8">2</data>
      <data key="d9">Student leaves feedback (thumbs down) on a bot answer via web/mobile interface.</data>
      <data key="d10">6</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="3" id="0">
      <data key="d8">0</data>
      <data key="d9">Lex queries DynamoDB for building hours.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="0" id="0">
      <data key="d8">0</data>
      <data key="d9">Lex responds with the answer to the Alexa device.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">Lex responds with the answer to the website.</data>
      <data key="d10">5</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="1" id="1">
      <data key="d8">1</data>
      <data key="d9">Lex responds with dining options to the student via text.</data>
      <data key="d10">5</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="4" id="0">
      <data key="d8">1</data>
      <data key="d9">Lex triggers Lambda to query external food vendor.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="6" id="0">
      <data key="d8">2</data>
      <data key="d9">Lex sends questions to OpenSearch for scoring and testing.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="7" id="0">
      <data key="d8">2</data>
      <data key="d9">Lex sends text to Comprehend for keyword analysis.</data>
      <data key="d10">5</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="8" id="0">
      <data key="d8">2</data>
      <data key="d9">Lex sends feedback (question and given answer) to SNS.</data>
      <data key="d10">8</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">DynamoDB returns building hours to Lex.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="5" id="0">
      <data key="d8">1</data>
      <data key="d9">Lambda queries the external food vendor for menu information.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="2" id="0">
      <data key="d8">1</data>
      <data key="d9">Lambda returns dining information to Lex.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="4" id="0">
      <data key="d8">1</data>
      <data key="d9">External food vendor returns dining options to Lambda.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="6" target="2" id="0">
      <data key="d8">2</data>
      <data key="d9">OpenSearch provides real-time scoring feedback to Lex (Lex uses this for response mapping).</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="7" target="2" id="0">
      <data key="d8">2</data>
      <data key="d9">Comprehend provides keyword honing rules/analysis to Lex.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <edge source="8" target="9" id="0">
      <data key="d8">2</data>
      <data key="d9">SNS sends an email notification to content owners with the feedback.</data>
      <data key="d10">9</data>
      <data key="d11">data</data>
    </edge>
    <edge source="9" target="3" id="0">
      <data key="d8">2</data>
      <data key="d9">Content owners enter building hours data via a GUI on top of DynamoDB.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="9" target="6" id="0">
      <data key="d8">2</data>
      <data key="d9">Content owners add/test new questions in bulk with OpenSearch.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">St. Louis University: Using Amazon Lex to Answer Students' Questions Through Alexa and a Mobile App</data>
    <data key="d1">https://www.youtube.com/watch?v=LxeSC3-xMlk</data>
    <data key="d2">St. Louis University's Q&amp;A chatbot provides information to over 12,000 students and 2,000 faculty via multiple channels (Alexa devices, website, mobile text). The architecture leverages AWS Lex for natural language processing, DynamoDB for structured content like building hours, and Lambda for integrating with external data sources (e.g., food vendors). AWS OpenSearch (Elasticsearch) and Comprehend are used for real-time scoring of new questions and keyword analysis, ensuring the bot's accuracy and relevance. A user feedback mechanism (thumbs down) triggers SNS notifications to content owners for continuous improvement. Content owners use a GUI on top of DynamoDB for data entry.</data>
    <data key="d3">interactive, data_ingestion, compute_intensive, control</data>
    <data key="d4">True</data>
  </graph>
</graphml>
