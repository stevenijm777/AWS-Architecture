<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Publisher Account</data>
      <data key="d6">UserCompanyAPI</data>
      <data key="d7">WORKLOAD_PEEK: Account responsible for producing and uploading content. Integrates existing workflows to put assets into the central S3 bucket. Has write permissions to the central S3 bucket.</data>
    </node>
    <node id="1">
      <data key="d5">Central S3 Bucket (MX)</data>
      <data key="d6">S3</data>
      <data key="d7">DATA_PEEK: Backbone for file transfers, handling hundreds of gigabytes or terabytes of data. Acts as a secure, access-controlled staging area between publisher and subscriber. Configured with object creation notifications. Encrypted with AES-256 using AWS KMS keys. Stores access logs.</data>
    </node>
    <node id="2">
      <data key="d5">EventBridge</data>
      <data key="d6">EventBridge</data>
      <data key="d7">WORKLOAD_PEEK: Serverless event bus that receives object creation notifications from the central S3 bucket. Scales to handle many publishers and subscribers.</data>
    </node>
    <node id="3">
      <data key="d5">SNS</data>
      <data key="d6">SNS</data>
      <data key="d7">WORKLOAD_PEEK: Pub/sub service used by EventBridge to fan out object creation notifications to both publisher and subscriber accounts.</data>
    </node>
    <node id="4">
      <data key="d5">Subscriber Account</data>
      <data key="d6">UserCompanyAPI</data>
      <data key="d7">WORKLOAD_PEEK: Account responsible for receiving and consuming content. Integrates existing workflows to pick up assets from the central S3 bucket. Has read permissions to the central S3 bucket. Can trigger actions like transcoding based on notifications.</data>
    </node>
    <node id="5">
      <data key="d5">Access Log S3 Bucket</data>
      <data key="d6">S3</data>
      <data key="d7">DATA_PEEK: Stores access logs generated by read/write operations on the central S3 bucket. Used by publisher and subscriber for reporting and auditing purposes.</data>
    </node>
    <node id="6">
      <data key="d5">KMS</data>
      <data key="d6">KMS</data>
      <data key="d7">WORKLOAD_PEEK: Manages and generates encryption keys for objects stored in the central S3 bucket. Publisher and subscriber have access for encryption and decryption operations.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">Publisher copies files into the central S3 bucket.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="0" target="5" id="0">
      <data key="d8">1</data>
      <data key="d9">Publisher account accesses the log S3 bucket for reporting purposes.</data>
      <data key="d10">2a</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">S3 object creation event is sent to EventBridge.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="5" id="0">
      <data key="d8">1</data>
      <data key="d9">Central S3 bucket streams its access logs to the dedicated access log S3 bucket.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="3" id="0">
      <data key="d8">0</data>
      <data key="d9">EventBridge passes object creation notifications to SNS.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="0" id="0">
      <data key="d8">0</data>
      <data key="d9">SNS delivers notification to the publisher account.</data>
      <data key="d10">3a</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="4" id="0">
      <data key="d8">0</data>
      <data key="d9">SNS delivers notification to the subscriber account, allowing them to integrate their workflows (e.g., start transcoding).</data>
      <data key="d10">3b</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">Subscriber reads/picks up files from the central S3 bucket.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="5" id="0">
      <data key="d8">1</data>
      <data key="d9">Subscriber account accesses the log S3 bucket for reporting purposes.</data>
      <data key="d10">2b</data>
      <data key="d11">data</data>
    </edge>
    <edge source="6" target="1" id="0">
      <data key="d8">1</data>
      <data key="d9">KMS generates and provides encryption keys for objects stored in the central S3 bucket.</data>
      <data key="d10">0</data>
      <data key="d11">meta</data>
    </edge>
    <data key="d0">Secure Media File Transfer Architecture</data>
    <data key="d1">https://www.youtube.com/watch?v=Ly_UhX3LCCs</data>
    <data key="d2">This architecture enables secure, scalable, and cost-effective transfer of large media files (hundreds of gigabytes or terabytes) between a publisher and a subscriber. It leverages S3 as a central, shared staging area, with access controlled by IAM. EventBridge and SNS provide real-time notifications of object creation, allowing subscribers to automate their workflows (e.g., start transcoding immediately). All data in the central S3 bucket is encrypted using AES-256 and AWS KMS. S3 access logs are stored in a separate bucket for auditing and reporting.</data>
    <data key="d3">data_ingestion, control</data>
    <data key="d4">True</data>
  </graph>
</graphml>
