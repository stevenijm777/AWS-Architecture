    </edge>
    <edge source="16" target="15" id="0">
      <data key="d8">4</data>
      <data key="d9">UI Frontend provides real-time notifications and interaction to web users.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">Muller Water Products Real-time Notification Engine</data>
    <data key="d1">https://www.youtube.com/watch?v=MbkLJ62jtMc</data>
    <data key="d2">Muller Water Products built a 100% serverless, real-time notification engine for alerts from over a million IoT devices. The system delivers alerts via SMS to field technicians, email to customers/CSRs, and real-time updates to a web UI. Key design decisions include leveraging managed services for scalability and reduced operational costs.</data>
    <data key="d3">data_ingestion, interactive, control</data>
    <data key="d4">True</data>
  </graph>
