<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">IoT Alert API</data>
      <data key="d6">ApiGateway</data>
      <data key="d7">Entry point for alerts from upstream IoT platform services. WORKLOAD_PEEK: Handles communication from many different services.</data>
    </node>
    <node id="1">
      <data key="d5">Notification Topic</data>
      <data key="d6">SNS</data>
      <data key="d7">Receives alerts from API Gateway. Fans out messages to multiple SQS queues. Also used by Lambda-SMS for sending outgoing SMS notifications directly to mobile users. DATA_PEEK: Real-time alerts and system notifications.</data>
    </node>
    <node id="2">
      <data key="d5">SMS Queue</data>
      <data key="d6">SQS</data>
      <data key="d7">Receives messages for SMS notifications. Trigger for Lambda-SMS.</data>
    </node>
    <node id="3">
      <data key="d5">Email Queue</data>
      <data key="d6">SQS</data>
      <data key="d7">Receives messages for email notifications. Trigger for Lambda-Email.</data>
    </node>
    <node id="4">
      <data key="d5">Persistence Queue</data>
      <data key="d6">SQS</data>
      <data key="d7">Receives messages for persisting notification history. Trigger for Lambda-Persistence.</data>
    </node>
    <node id="5">
      <data key="d5">UI Queue</data>
      <data key="d6">SQS</data>
      <data key="d7">Receives messages for real-time UI updates. Trigger for Lambda-UI.</data>
    </node>
    <node id="6">
      <data key="d5">Lambda-SMS</data>
      <data key="d6">Lambda</data>
      <data key="d7">Contains logic for processing SMS notification requests. Reads SMS templates and subscriber lists from RDS. Uses SNS to send real-time notifications to field technicians.</data>
    </node>
    <node id="7">
      <data key="d5">Lambda-Email</data>
      <data key="d6">Lambda</data>
      <data key="d7">Contains logic for processing email notification requests. Reads HTML templates and subscriber lists from RDS. Uses SES to email customers.</data>
    </node>
    <node id="8">
      <data key="d5">Lambda-Persistence</data>
      <data key="d6">Lambda</data>
      <data key="d7">Contains logic for persisting notification history. Writes alert details into DynamoDB.</data>
    </node>
    <node id="9">
      <data key="d5">Lambda-UI</data>
      <data key="d6">Lambda</data>
      <data key="d7">Contains logic for triggering UI updates. Sends messages to the UI Frontend for real-time display.</data>
    </node>
    <node id="10">
      <data key="d5">User &amp; Template DB</data>
      <data key="d6">RDS</data>
      <data key="d7">Stores user information, HTML templates, SMS templates, and subscriber lists. Accessed by Lambdas for notification processing.</data>
    </node>
    <node id="11">
      <data key="d5">Notification History</data>
      <data key="d6">DynamoDB</data>
      <data key="d7">Stores a history of all notifications for auditing and lookup. DATA_PEEK: Persistent history of alerts.</data>
    </node>
    <node id="12">
      <data key="d5">Email Service</data>
      <data key="d6">SES</data>
      <data key="d7">Sends outgoing emails to customers. Used by Lambda-Email.</data>
    </node>
    <node id="13">
      <data key="d5">Technician Mobile</data>
      <data key="d6">UserCompanyAgent</data>
      <data key="d7">Field technicians receiving SMS notifications on their cell phones.</data>
    </node>
    <node id="14">
      <data key="d5">Customer Email Recipient</data>
      <data key="d6">UserCompanyAgent</data>
      <data key="d7">Customers and CSRs receiving email notifications.</data>
    </node>
    <node id="15">
      <data key="d5">Web UI User</data>
      <data key="d6">UserCompanyAgent</data>
      <data key="d7">CSRs and field technicians interacting with the front-end application to view and acknowledge notifications.</data>
    </node>
    <node id="16">
      <data key="d5">UI Frontend (Node.js/Socket.IO)</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Custom front-end application with a Node.js service running Socket.IO WebSockets to provide real-time updates to users. Displays notification bell and panel, allows acknowledgement.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">IoT platform services send alerts via API Gateway to SNS.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">SNS fans out messages to the SMS queue.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="3" id="0">
      <data key="d8">0</data>
      <data key="d9">SNS fans out messages to the Email queue.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="4" id="0">
      <data key="d8">0</data>
      <data key="d9">SNS fans out messages to the Persistence queue.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="5" id="0">
      <data key="d8">0</data>
      <data key="d9">SNS fans out messages to the UI queue.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="13" id="0">
      <data key="d8">1</data>
      <data key="d9">SNS delivers SMS notifications to field technicians' mobile phones.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="6" id="0">
      <data key="d8">1</data>
      <data key="d9">SMS queue triggers Lambda for SMS processing.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="7" id="0">
      <data key="d8">2</data>
      <data key="d9">Email queue triggers Lambda for email processing.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="8" id="0">
      <data key="d8">3</data>
      <data key="d9">Persistence queue triggers Lambda for persistence.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="9" id="0">
      <data key="d8">4</data>
      <data key="d9">UI queue triggers Lambda for UI updates.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="6" target="1" id="0">
      <data key="d8">1</data>
      <data key="d9">Lambda-SMS uses SNS to send real-time SMS notifications.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="7" target="12" id="0">
      <data key="d8">2</data>
      <data key="d9">Lambda-Email uses SES to send emails.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="8" target="11" id="0">
      <data key="d8">3</data>
      <data key="d9">Lambda-Persistence writes notification history to DynamoDB.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="9" target="16" id="0">
      <data key="d8">4</data>
      <data key="d9">Lambda-UI sends update trigger/data to the UI Frontend (Node.js service).</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="10" target="6" id="0">
      <data key="d8">1</data>
      <data key="d9">Lambda-SMS retrieves SMS templates and subscriber lists from RDS.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="10" target="7" id="0">
      <data key="d8">2</data>
      <data key="d9">Lambda-Email retrieves HTML templates and subscriber lists from RDS.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="12" target="14" id="0">
      <data key="d8">2</data>
      <data key="d9">SES delivers email notifications to customers.</data>
      <data key="d10">3</data>
