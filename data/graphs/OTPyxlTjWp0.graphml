<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Data Scientist / Portal</data>
      <data key="d6">UserCompanyAnalyst</data>
      <data key="d7">Initiates campaigns and views real-time execution status.</data>
    </node>
    <node id="1">
      <data key="d5">Orchestration Kafka Topic</data>
      <data key="d6">MSK</data>
      <data key="d7">Ingests initial batch transform execution triggers.</data>
    </node>
    <node id="2">
      <data key="d5">Orchestrator Consumer</data>
      <data key="d6">ECS</data>
      <data key="d7">Fargate-based task that determines the execution plan for the campaign.</data>
    </node>
    <node id="3">
      <data key="d5">Execution Kafka Topic</data>
      <data key="d6">MSK</data>
      <data key="d7">Coordinates operational workflow stages and step transitions.</data>
    </node>
    <node id="4">
      <data key="d5">Operational Consumer</data>
      <data key="d6">ECS</data>
      <data key="d7">Fargate task triggering EMR preprocessing or SageMaker model jobs.</data>
    </node>
    <node id="5">
      <data key="d5">EMR Cluster</data>
      <data key="d6">EMR</data>
      <data key="d7">Performs data ingestion and pre-processing on multi-format datasets.</data>
    </node>
    <node id="6">
      <data key="d5">SageMaker</data>
      <data key="d6">SageMaker</data>
      <data key="d7">Executes testing, training, and production batch transform jobs.</data>
    </node>
    <node id="7">
      <data key="d5">OpenSearch Service</data>
      <data key="d6">OpenSearch</data>
      <data key="d7">Metadata store tracking current campaign and job statuses.</data>
    </node>
    <node id="8">
      <data key="d5">Amazon EventBridge</data>
      <data key="d6">EventBridge</data>
      <data key="d7">Captures EMR and SageMaker state-change events.</data>
    </node>
    <node id="9">
      <data key="d5">EventBridge Consumer</data>
      <data key="d6">ECS</data>
      <data key="d7">Fargate task translating EventBridge triggers into sequential Kafka messages.</data>
    </node>
    <node id="10">
      <data key="d5">Notifier Consumer</data>
      <data key="d6">ECS</data>
      <data key="d7">Fargate task identifying batch completion and updating final status.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">Triggers campaign execution.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">Consumes launch message.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="3" id="0">
      <data key="d8">0</data>
      <data key="d9">Publishes operational execution plan.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="4" id="0">
      <data key="d8">0</data>
      <data key="d9">Dispatches individual job executions.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="10" id="0">
      <data key="d8">2</data>
      <data key="d9">Delivers completion events.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="5" id="0">
      <data key="d8">0</data>
      <data key="d9">Launches data prep.</data>
      <data key="d10">4a</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="6" id="0">
      <data key="d8">0</data>
      <data key="d9">Triggers model job.</data>
      <data key="d10">4b</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="7" id="0">
      <data key="d8">0</data>
      <data key="d9">Logs active execution state.</data>
      <data key="d10">5</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="8" id="0">
      <data key="d8">1</data>
      <data key="d9">Emits job state changes.</data>
      <data key="d10">0a</data>
      <data key="d11">meta</data>
    </edge>
    <edge source="6" target="8" id="0">
      <data key="d8">1</data>
      <data key="d9">Emits job state changes.</data>
      <data key="d10">0b</data>
      <data key="d11">meta</data>
    </edge>
    <edge source="8" target="9" id="0">
      <data key="d8">1</data>
      <data key="d9">Triggers response logic.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="9" target="3" id="0">
      <data key="d8">1</data>
      <data key="d9">Enqueues next pipeline action.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="10" target="7" id="0">
      <data key="d8">2</data>
      <data key="d9">Persists final status metadata.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="10" target="0" id="0">
      <data key="d8">2</data>
      <data key="d9">Notifies Portal and user of workflow termination.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">Experian Event-Driven MLOps Batch Transform Pipeline</data>
    <data key="d1">https://www.youtube.com/watch?v=OTPyxlTjWp0</data>
    <data key="d2">An event-driven machine learning platform executing tens of billions of model operations monthly. It leverages Amazon MSK as the backbone, orchestrating workloads across EMR and SageMaker using ECS Fargate tasks.</data>
    <data key="d3">compute_intensive, data_ingestion</data>
    <data key="d4">True</data>
  </graph>
