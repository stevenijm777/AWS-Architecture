<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d12" for="edge" attr.name="id" attr.type="string" />
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">External Content Source</data>
      <data key="d6">UserCompanyDataStream</data>
      <data key="d7">DATA_PEEK: Approximately 8 million posts per day, 70 million comments, and content from half a million celebrities and influencers. WORKLOAD_PEEK: Raw social media and influencer content related to the fashion, luxury, and beauty industry.</data>
    </node>
    <node id="1">
      <data key="d5">Ingestion Crawler (Spot Instances)</data>
      <data key="d6">EC2</data>
      <data key="d7">WORKLOAD_PEEK: Component responsible for crawling and ingesting vast amounts of external content. Runs on EC2 Spot Instances to achieve significant operational cost savings (75%).</data>
    </node>
    <node id="2">
      <data key="d5">Kinesis Data Stream</data>
      <data key="d6">Kinesis</data>
      <data key="d7">DATA_PEEK: Stores ingested content and acts as a buffer. WORKLOAD_PEEK: Used to coordinate tasks and ensure operations can be resumed after potential interruptions from EC2 Spot Instances.</data>
    </node>
    <node id="3">
      <data key="d5">SQS Queue</data>
      <data key="d6">SQS</data>
      <data key="d7">DATA_PEEK: Stores state information for processing. WORKLOAD_PEEK: Used to coordinate tasks and ensure operations can be resumed after potential interruptions from EC2 Spot Instances, providing fault tolerance.</data>
    </node>
    <node id="4">
      <data key="d5">Enrichment Processor (Spot Instances)</data>
      <data key="d6">EC2</data>
      <data key="d7">WORKLOAD_PEEK: Leverages SageMaker and custom-built AI models to enrich ingested data with meta-information such as brands, industries, sentiment, and languages. Runs on EC2 Spot Instances for cost efficiency (75% savings).</data>
    </node>
    <node id="5">
      <data key="d5">Aurora Database</data>
      <data key="d6">Aurora</data>
      <data key="d7">DATA_PEEK: Stores the enriched and processed data. WORKLOAD_PEEK: Serves as a foundational block for building customer insight products.</data>
    </node>
    <node id="6">
      <data key="d5">OpenSearch Cluster</data>
      <data key="d6">OpenSearch</data>
      <data key="d7">DATA_PEEK: Stores the enriched and processed data for search and analytics. WORKLOAD_PEEK: Used for powerful search capabilities to derive insights for customers.</data>
    </node>
    <edge source="0" target="1">
      <data key="d8">0</data>
      <data key="d9">External content (posts, comments, influencer data) is ingested by the crawler.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="1" target="2">
      <data key="d8">0</data>
      <data key="d9">Ingested content is streamed to Kinesis for initial storage and coordination.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="1" target="3">
      <data key="d8">0</data>
      <data key="d9">State information related to ingested content is queued in SQS for task coordination.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="2" target="4">
      <data key="d8">1</data>
      <data key="d9">Data from Kinesis is consumed by the enrichment processor for further processing.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="3" target="4">
      <data key="d8">1</data>
      <data key="d9">Tasks and state information from SQS are used by the enrichment processor to coordinate work and handle interruptions.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="4" target="5">
      <data key="d8">1</data>
      <data key="d9">Enriched data is stored in Aurora.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="4" target="6">
      <data key="d8">1</data>
      <data key="d9">Enriched data is stored in OpenSearch for search and analytical queries.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <data key="d0">Launchmetrics: How Launchmetrics Produces Fashion Luxury and Beauty Data Insights for 1B Users</data>
    <data key="d1">https://www.youtube.com/watch?v=PBa68gCG0Uk</data>
    <data key="d2">Launchmetrics processes massive volumes of social media data (8M posts/day, 70M comments) for the fashion, luxury, and beauty industries to provide market insights. The architecture emphasizes cost-efficiency through extensive use of EC2 Spot Instances for crawling and enrichment, with Kinesis and SQS providing fault tolerance for managing interruptions.</data>
    <data key="d3">data_ingestion, compute_intensive, other</data>
    <data key="d4">True</data>
  </graph>
</graphml>
