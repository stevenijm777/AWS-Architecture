<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Raw &amp; Refined Data Lake</data>
      <data key="d6">S3</data>
      <data key="d7">DATA_PEEK: Stores public and private weather data, flight data, and internal datasets (raw). Also stores ETL'd and cataloged data after processing by Glue and Lake Formation.</data>
    </node>
    <node id="1">
      <data key="d5">Data Lake Catalog</data>
      <data key="d6">LakeFormation</data>
      <data key="d7">WORKLOAD_PEEK: Used to serve and manage access to the data stored in S3, particularly after ETL processing. It acts as the data catalog.</data>
    </node>
    <node id="2">
      <data key="d5">Data ETL and Catalog Update</data>
      <data key="d6">Glue</data>
      <data key="d7">WORKLOAD_PEEK: Performs Extract, Transform, Load (ETL) operations on the raw data landing in S3. It also updates the data catalog managed by Lake Formation.</data>
    </node>
    <node id="3">
      <data key="d5">ML Model Training &amp; Prediction</data>
      <data key="d6">SageMaker</data>
      <data key="d7">WORKLOAD_PEEK: Builds and trains machine learning models to predict weather impact on specific flight segments 24 to 48 hours in advance. Processes data served by Lake Formation.</data>
    </node>
    <node id="4">
      <data key="d5">Predictive Data Storage</data>
      <data key="d6">S3</data>
      <data key="d7">DATA_PEEK: Stores the output of the ML models, which is the predictive weather impact data.</data>
    </node>
    <node id="5">
      <data key="d5">Predictive Data Query</data>
      <data key="d6">Athena</data>
      <data key="d7">WORKLOAD_PEEK: Used to query the predictive data stored in S3, making it available to various internal teams and for dashboarding.</data>
    </node>
    <node id="6">
      <data key="d5">Visual Dashboards</data>
      <data key="d6">QuickSight</data>
      <data key="d7">WORKLOAD_PEEK: Creates visual dashboards based on the predictive data queried via Athena, used for visualization by multiple internal teams.</data>
    </node>
    <node id="7">
      <data key="d5">Internal Data Users</data>
      <data key="d6">UserCompanyAnalyst</data>
      <data key="d7">WORKLOAD_PEEK: Represents the engineering team and executive team members who analyze and visualize predictive data for insights.</data>
    </node>
    <node id="8">
      <data key="d5">Operational Personnel</data>
      <data key="d6">UserCompanyAgent</data>
      <data key="d7">WORKLOAD_PEEK: Represents the operational personnel who are informed of predicted weather patterns to manage expectations and take proactive measures.</data>
    </node>
    <edge source="0" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">Raw weather, flight, and internal data lands in S3 and is made available for ETL.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="0" id="0">
      <data key="d8">0</data>
      <data key="d9">Lake Formation manages and catalogs the processed data, which remains stored in S3.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="3" id="0">
      <data key="d8">0</data>
      <data key="d9">SageMaker accesses the cataloged and prepared data from Lake Formation for model training and prediction.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">Glue processes the data and registers its schema and metadata with Lake Formation.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="4" id="0">
      <data key="d8">0</data>
      <data key="d9">The output of the ML models (predictive data) is stored in a separate S3 bucket.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="5" id="0">
      <data key="d8">1</data>
      <data key="d9">Athena queries the predictive data directly from the S3 storage.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="6" id="0">
      <data key="d8">1</data>
      <data key="d9">QuickSight consumes query results from Athena to generate visual dashboards.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="7" id="0">
      <data key="d8">1</data>
      <data key="d9">Internal data users (engineering, executives) directly query predictive data via Athena.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="8" id="0">
      <data key="d8">1</data>
      <data key="d9">Operational personnel directly query predictive data via Athena for timely information.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="6" target="7" id="0">
      <data key="d8">1</data>
      <data key="d9">Internal data users view predictive data through QuickSight dashboards.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <edge source="6" target="8" id="0">
      <data key="d8">1</data>
      <data key="d9">Operational personnel view predictive data through QuickSight dashboards for proactive notifications and decision-making.</data>
      <data key="d10">5</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">Predicting In-Flight Connectivity Weather Impact</data>
    <data key="d1">https://www.youtube.com/watch?v=Pc7_uOdlGKo</data>
    <data key="d2">Panasonic Avionics uses this architecture to predict severe weather impacts on in-flight internet connectivity 24-48 hours in advance. This allows them to proactively inform customers and set expectations for passengers and operational teams.</data>
    <data key="d3">data_ingestion, compute_intensive, interactive</data>
    <data key="d4">True</data>
  </graph>
</graphml>
