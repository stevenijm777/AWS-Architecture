<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Client</data>
      <data key="d6">UserConsumerWebMobile</data>
      <data key="d7">The end-user accessing the MindTickle platform.</data>
    </node>
    <node id="1">
      <data key="d5">CloudFront Distribution</data>
      <data key="d6">CloudFront</data>
      <data key="d7">DATA_PEEK: User requests for the platform content. WORKLOAD_PEEK: Initial entry point for user requests.</data>
    </node>
    <node id="2">
      <data key="d5">Lambda@Edge</data>
      <data key="d6">LambdaAtEdge</data>
      <data key="d7">WORKLOAD_PEEK: Determines the appropriate region for the user based on their access location, routing them accordingly.</data>
    </node>
    <node id="3">
      <data key="d5">Route 53 DNS Firewall</data>
      <data key="d6">Route53</data>
      <data key="d7">WORKLOAD_PEEK: Acts as a DNS firewall to block unwanted requests before they enter the core infrastructure. Ensures isolation across regions for compliance.</data>
    </node>
    <node id="4">
      <data key="d5">Application Load Balancer</data>
      <data key="d6">ALB</data>
      <data key="d7">WORKLOAD_PEEK: Routes requests to the underlying microservices running in EKS.</data>
    </node>
    <node id="5">
      <data key="d5">Elastic Kubernetes Service</data>
      <data key="d6">EKS</data>
      <data key="d7">WORKLOAD_PEEK: Hosts over 250 microservices, managing more than 1500 configuration variables per environment. This is where the core application logic resides.</data>
    </node>
    <node id="6">
      <data key="d5">AWS RDS Databases</data>
      <data key="d6">RDS</data>
      <data key="d7">DATA_PEEK: Stores SQL and NoSQL databases, primarily holding templates and master data essential for service functioning, explicitly not customer data due to compliance reasons. WORKLOAD_PEEK: Accessed by microservices in EKS for workflows.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">User request to access the platform.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">Request redirected from CloudFront to Lambda@Edge.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="3" id="0">
      <data key="d8">0</data>
      <data key="d9">Request routed through Route 53 after regional decision.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="4" id="0">
      <data key="d8">0</data>
      <data key="d9">Requests routed from Route 53 to the Application Load Balancer.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="5" id="0">
      <data key="d8">0</data>
      <data key="d9">Requests routed to microservices running in EKS.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="6" id="0">
      <data key="d8">0</data>
      <data key="d9">Microservices access databases in RDS.</data>
      <data key="d10">5</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">MindTickle Sales Readiness Platform</data>
    <data key="d1">https://www.youtube.com/watch?v=PgeQufaQy7I</data>
    <data key="d2">MindTickle is a market-leading sales readiness platform. This architecture describes a global deployment with quick replication across geographies, reducing deployment time from 6-8 months to 1 day. Key considerations for replication include infrastructure, application, and data automation. The system manages over 250 microservices and 1500 config variables. Data stored in RDS is primarily templates and master data, explicitly not customer data, for compliance reasons.</data>
    <data key="d3">interactive, compute_intensive</data>
    <data key="d4">True</data>
  </graph>
</graphml>
