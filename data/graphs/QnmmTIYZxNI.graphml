<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d12" for="edge" attr.name="id" attr.type="string" />
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">EKS Clusters</data>
      <data key="d6">EKS</data>
      <data key="d7">WORKLOAD_PEEK: Runs customer applications. Deployed within the reused CIDR block.</data>
    </node>
    <node id="1">
      <data key="d5">EC2 Instances</data>
      <data key="d6">EC2</data>
      <data key="d7">WORKLOAD_PEEK: Handles standard workloads. Deployed within the reused CIDR block.</data>
    </node>
    <node id="2">
      <data key="d5">NAT Gateway</data>
      <data key="d6">NAT</data>
      <data key="d7">DATA_PEEK: Performs source NAT for outbound traffic from compute clusters. Deployed in the routed CIDR block.</data>
    </node>
    <node id="3">
      <data key="d5">NLB</data>
      <data key="d6">NLB</data>
      <data key="d7">Handles inbound and routed network load balancing inside the routed block.</data>
    </node>
    <node id="4">
      <data key="d5">Transit Gateway</data>
      <data key="d6">TransitGateway</data>
      <data key="d7">Acts as the central regional routing hub interconnecting VPCs, Direct Connect, and VPNs.</data>
    </node>
    <node id="5">
      <data key="d5">Direct Connect</data>
      <data key="d6">DirectConnect</data>
      <data key="d7">On-premises high-speed connectivity connected to Transit Gateway.</data>
    </node>
    <node id="6">
      <data key="d5">VPN</data>
      <data key="d6">VPN</data>
      <data key="d7">Secure remote backup connection to Transit Gateway.</data>
    </node>
    <node id="7">
      <data key="d5">VPC Private Link</data>
      <data key="d6">PrivateLink</data>
      <data key="d7">Abstracts and exposes shared services securely to other VPCs inside the region.</data>
    </node>
    <edge source="0" target="2">
      <data key="d8">0</data>
      <data key="d9">Outbound traffic from EKS goes to NAT gateway.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="2" target="4">
      <data key="d8">0</data>
      <data key="d9">NATed traffic routed to Transit Gateway.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="4" target="7">
      <data key="d8">0</data>
      <data key="d9">Transit Gateway routes traffic to Shared Services via Private Link.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="5" target="4">
      <data key="d8">1</data>
      <data key="d9">On-premise network communication via Direct Connect.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="6" target="4">
      <data key="d8">1</data>
      <data key="d9">Hybrid connectivity backup via VPN.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <data key="d0">Adobe: Simplifying Networking Across Thousands of AWS Accounts with AWS Transit Gateway LIVE</data>
    <data key="d1">https://www.youtube.com/watch?v=QnmmTIYZxNI</data>
    <data key="d2">Adobe leverages AWS Transit Gateway as a regional hub to scale networking across thousands of accounts. They optimize IPv4 space by using reused CIDR blocks for compute (EKS/EC2) and routed CIDR blocks for external egress (NAT/NLB).</data>
    <data key="d3">control, other</data>
    <data key="d4">True</data>
  </graph>
</graphml>
