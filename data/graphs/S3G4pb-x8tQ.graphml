<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Data Provider</data>
      <data key="d6">UserCompanyInternalPlatform</data>
      <data key="d7">Source of multi-format unstructured raw data.</data>
    </node>
    <node id="1">
      <data key="d5">Raw Data Store</data>
      <data key="d6">S3</data>
      <data key="d7">Landing bucket for documents of any data format.</data>
    </node>
    <node id="2">
      <data key="d5">ETL Processor</data>
      <data key="d6">Lambda</data>
      <data key="d7">WORKLOAD_PEEK: Processes documents and generates embeddings. Highly customizable, interchangeable with AWS Glue.</data>
    </node>
    <node id="3">
      <data key="d5">Vector Database</data>
      <data key="d6">OpenSearch</data>
      <data key="d7">Stores indexed document embeddings for downstream semantic search.</data>
    </node>
    <node id="4">
      <data key="d5">Chatbot / App Client</data>
      <data key="d6">UserConsumerWebMobile</data>
      <data key="d7">User-facing application interface, e.g., Lex or custom web app.</data>
    </node>
    <node id="5">
      <data key="d5">Client API Gateway</data>
      <data key="d6">ApiGateway</data>
      <data key="d7">Gatekeeper for consumer-facing chat sessions.</data>
    </node>
    <node id="6">
      <data key="d5">Orchestrator Lambda</data>
      <data key="d6">Lambda</data>
      <data key="d7">WORKLOAD_PEEK: The brains of the operation. Orchestrates session history, semantic retrieval, and LLM prompting.</data>
    </node>
    <node id="7">
      <data key="d5">Session Store</data>
      <data key="d6">DynamoDB</data>
      <data key="d7">Maintains user chat state and history.</data>
    </node>
    <node id="8">
      <data key="d5">Amazon Bedrock</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Provides foundation models (LLMs) evaluated and configured for the specific business case.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">Ingest raw documents.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">Trigger ETL processing.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="3" id="0">
      <data key="d8">0</data>
      <data key="d9">Store computed vector embeddings.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="6" id="0">
      <data key="d8">1</data>
      <data key="d9">Return relevant document chunks.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="5" id="0">
      <data key="d8">1</data>
      <data key="d9">Send user query prompt.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="6" id="0">
      <data key="d8">1</data>
      <data key="d9">Invoke orchestrator function.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="4" id="0">
      <data key="d8">1</data>
      <data key="d9">Deliver final response payload.</data>
      <data key="d10">8</data>
      <data key="d11">data</data>
    </edge>
    <edge source="6" target="7" id="0">
      <data key="d8">1</data>
      <data key="d9">Fetch/Update user chat session state.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="6" target="3" id="0">
      <data key="d8">1</data>
      <data key="d9">Perform semantic search query.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="6" target="8" id="0">
      <data key="d8">1</data>
      <data key="d9">Send augmented context prompt to Bedrock LLM.</data>
      <data key="d10">5</data>
      <data key="d11">data</data>
    </edge>
    <edge source="6" target="5" id="0">
      <data key="d8">1</data>
      <data key="d9">Send final response back.</data>
      <data key="d10">7</data>
      <data key="d11">data</data>
    </edge>
    <edge source="8" target="6" id="0">
      <data key="d8">1</data>
      <data key="d9">Return model response generation.</data>
      <data key="d10">6</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">Tailwinds GenAI RAG Architecture</data>
    <data key="d1">https://www.youtube.com/watch?v=S3G4pb-x8tQ</data>
    <data key="d2">Tailwinds is a customizable, portable RAG solution deployed using IAC (SAM/Terraform). It supports flexible ingestion, pluggable vector/graph databases, and multi-model support via Bedrock.</data>
    <data key="d3">data_ingestion, interactive, compute_intensive</data>
    <data key="d4">True</data>
  </graph>
</graphml>
