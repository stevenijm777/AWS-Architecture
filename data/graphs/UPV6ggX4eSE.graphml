  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">MagellanTV Content Preparer</data>
      <data key="d6">UserCompanyAgent</data>
      <data key="d7">WORKLOAD_PEEK: Prepares content (video hours) based on distributor needs. DATA_PEEK: Drops content files into S3 to initiate the workflow.</data>
    </node>
    <node id="1">
      <data key="d5">Content Library Bucket</data>
      <data key="d6">S3</data>
      <data key="d7">DATA_PEEK: Stores raw documentary content files as input. DATA_PEEK: Stores final localized video files, sound files, and translated caption files as output.</data>
    </node>
    <node id="2">
      <data key="d5">Localization Workflow Orchestrator</data>
      <data key="d6">StepFunctions</data>
      <data key="d7">WORKLOAD_PEEK: Orchestrates the entire content localization pipeline, including the ML and human review stages. WORKLOAD_PEEK: Manages the flow of data and tasks between services.</data>
    </node>
    <node id="3">
      <data key="d5">Initial Content Split &amp; Translate</data>
      <data key="d6">Translate</data>
      <data key="d7">WORKLOAD_PEEK: Splits the input file into separate JSON objects for each speaker. Initiates a preliminary translation process before detailed Bedrock steps.</data>
    </node>
    <node id="4">
      <data key="d5">Idiom &amp; Slang Detection (English-to-English)</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">WORKLOAD_PEEK: Leverages Bedrock to identify and perform English-to-English translation for idioms and slang.</data>
    </node>
    <node id="5">
      <data key="d5">Sentence Shortening &amp; Language Translation</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">WORKLOAD_PEEK: Translates content to the target language and performs sentence shortening to fit timing windows, as some languages are longer.</data>
    </node>
    <node id="6">
      <data key="d5">Cultural Sensitivity Check</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">WORKLOAD_PEEK: Conducts a final cultural check for grammar, content, and sensitivities specific to the target region using Bedrock.</data>
    </node>
    <node id="7">
      <data key="d5">Text-to-Speech Generation</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">WORKLOAD_PEEK: Converts the translated scripts (from Bedrock) into speech files.</data>
    </node>
    <node id="8">
      <data key="d5">Human Translation Quality Checks</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">WORKLOAD_PEEK: Provides a human review loop for translators to perform quality checks on generated speech and translated content, especially for cultural issues.</data>
    </node>
    <node id="9">
      <data key="d5">Pipeline Deployment (CDK)</data>
      <data key="d6">CloudFormation</data>
      <data key="d7">WORKLOAD_PEEK: Used to instantiate and spin out multiple parallel pipeline nodes using CDK, enabling scaling for hundreds of hours of video content per month. Reduces cost from $20 to $1 per minute of video.</data>
    </node>
    <edge source="0" target="9" id="0">
      <data key="d8">0</data>
      <data key="d9">Developer/Architect uses CDK to deploy pipeline via CloudFormation</data>
      <data key="d10">0</data>
      <data key="d11">meta</data>
    </edge>
