  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Global DNS Edge Resolvers</data>
      <data key="d6">UserCompanyEdge</data>
      <data key="d7">Generates 530 billion transactions per day in compressed files.</data>
    </node>
    <node id="1">
      <data key="d5">S3 Ingest Bucket</data>
      <data key="d6">S3</data>
      <data key="d7">Receives 400,000 compressed files daily from edge locations.</data>
    </node>
    <node id="2">
      <data key="d5">Ingest SNS Topic</data>
      <data key="d6">SNS</data>
      <data key="d7">Triggers notifications upon S3 file uploads.</data>
    </node>
    <node id="3">
      <data key="d5">Ingest SQS Queue</data>
      <data key="d6">SQS</data>
      <data key="d7">Buffers incoming notification messages for transformers.</data>
    </node>
    <node id="4">
      <data key="d5">EC2 Transformers</data>
      <data key="d6">EC2</data>
      <data key="d7">Converts proprietary compressed files to Parquet format.</data>
    </node>
    <node id="5">
      <data key="d5">S3 Warehouse Bucket</data>
      <data key="d6">S3</data>
      <data key="d7">Stores transformed parquet raw data and aggregated level tables.</data>
    </node>
    <node id="6">
      <data key="d5">Warehouse SNS Topic</data>
      <data key="d6">SNS</data>
      <data key="d7">Triggers downstream aggregators upon raw file upload.</data>
    </node>
    <node id="7">
      <data key="d5">EC2 Aggregators</data>
      <data key="d6">EC2</data>
      <data key="d7">Rolls up raw data into minute, hour, and day aggregations.</data>
    </node>
    <node id="8">
      <data key="d5">Glue Data Catalog</data>
      <data key="d6">Glue</data>
      <data key="d7">Manages schema definitions for different aggregated tables.</data>
    </node>
    <node id="9">
      <data key="d5">Amazon Athena</data>
      <data key="d6">Athena</data>
      <data key="d7">Executes isolated ad-hoc and reporting queries without performance degradation.</data>
    </node>
    <node id="10">
      <data key="d5">Internal Analysts</data>
      <data key="d6">UserCompanyAnalyst</data>
      <data key="d7">Access reports and execute analytics queries.</data>
    </node>
    <node id="11">
      <data key="d5">External API Customers</data>
      <data key="d6">UserConsumerAPI</data>
      <data key="d7">Query DNS analytical endpoints.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">Upload compressed DNS resolver logs</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="2" id="0">
