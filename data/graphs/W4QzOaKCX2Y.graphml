      <data key="d10">0</data>
      <data key="d11">meta</data>
    </edge>
    <edge source="6" target="7" id="0">
      <data key="d8">1</data>
      <data key="d9">Trigger aggregator tasks</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="7" target="5" id="0">
      <data key="d8">1</data>
      <data key="d9">Fetch raw data and save aggregated views back to warehouse S3 paths</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="7" target="8" id="0">
      <data key="d8">1</data>
      <data key="d9">Update schemas and tables catalog</data>
      <data key="d10">3</data>
