    <edge source="11" target="12" id="0">
      <data key="d8">3</data>
      <data key="d9">Offloads EU web traffic logs.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">Fortinet FortiWeb Cloud WAF Serverless Architecture</data>
    <data key="d1">https://www.youtube.com/watch?v=Yju3yReAQtc</data>
    <data key="d2">Serverless WAF control plane with localized multi-region deployments for data sovereignty, low latency, and cost-effective traffic management. Machine learning engine filters threats locally and streams logs to Elasticsearch.</data>
    <data key="d3">compute_intensive, control</data>
    <data key="d4">True</data>
