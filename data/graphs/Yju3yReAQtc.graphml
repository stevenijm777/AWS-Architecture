  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">End User / Customer Portal</data>
      <data key="d6">UserConsumerWeb</data>
      <data key="d7">Accesses the FortiWeb WAF configuration dashboard or websites secured by WAF.</data>
    </node>
    <node id="1">
      <data key="d5">CloudFront</data>
      <data key="d6">CloudFront</data>
      <data key="d7">Acts as the global entry point to cache assets and accelerate API requests.</data>
    </node>
    <node id="2">
      <data key="d5">Static Content S3 (US)</data>
      <data key="d6">S3</data>
      <data key="d7">WORKLOAD_PEEK: Stores static web content for US region portal.</data>
    </node>
    <node id="3">
      <data key="d5">API Gateway (US)</data>
      <data key="d6">ApiGateway</data>
      <data key="d7">API entry point that fronts administrative configuration Lambda functions.</data>
    </node>
    <node id="4">
      <data key="d5">Config Lambda (US)</data>
      <data key="d6">Lambda</data>
      <data key="d7">Serverless execution logic to process customer configuration changes.</data>
    </node>
    <node id="5">
      <data key="d5">Configuration DynamoDB (US)</data>
      <data key="d6">DynamoDB</data>
      <data key="d7">DATA_PEEK: NoSQL store used to maintain WAF rules and schemas flexibly.</data>
    </node>
    <node id="6">
      <data key="d5">FortiWeb Cloud Cluster (US)</data>
      <data key="d6">EC2</data>
      <data key="d7">WORKLOAD_PEEK: Active WAF security appliance cluster running machine learning rules.</data>
    </node>
    <node id="7">
      <data key="d5">Static Content S3 (EU)</data>
      <data key="d6">S3</data>
      <data key="d7">WORKLOAD_PEEK: Stores static web content for EU region portal.</data>
    </node>
    <node id="8">
      <data key="d5">API Gateway (EU)</data>
      <data key="d6">ApiGateway</data>
      <data key="d7">API entry point that fronts administrative configuration Lambda functions in EU.</data>
    </node>
    <node id="9">
      <data key="d5">Config Lambda (EU)</data>
      <data key="d6">Lambda</data>
      <data key="d7">Serverless execution logic to process customer configuration changes in EU.</data>
    </node>
    <node id="10">
      <data key="d5">Configuration DynamoDB (EU)</data>
      <data key="d6">DynamoDB</data>
      <data key="d7">DATA_PEEK: NoSQL store used to maintain local WAF rules in EU.</data>
    </node>
    <node id="11">
      <data key="d5">FortiWeb Cloud Cluster (EU)</data>
      <data key="d6">EC2</data>
      <data key="d7">WORKLOAD_PEEK: Active WAF security appliance cluster in the EU region.</data>
    </node>
    <node id="12">
      <data key="d5">Elasticsearch Logging Cluster</data>
      <data key="d6">OpenSearch</data>
      <data key="d7">Centralized engine to offload log lookup and filtering for both regional WAF clusters.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">0</data>
