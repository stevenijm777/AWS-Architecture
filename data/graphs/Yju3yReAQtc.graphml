  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Customer Administrator</data>
      <data key="d6">UserCompanyDeveloper</data>
      <data key="d7">Interacts with management console to configure WAF rules and monitor logs.</data>
    </node>
    <node id="1">
      <data key="d5">CloudFront CDN</data>
      <data key="d6">CloudFront</data>
      <data key="d7">Caches static web content globally for fast UI load times.</data>
    </node>
    <node id="2">
      <data key="d5">S3 Static Assets (US)</data>
      <data key="d6">S3</data>
      <data key="d7">Stores static web console assets in US-WEST-1.</data>
    </node>
    <node id="3">
      <data key="d5">API Gateway (US)</data>
      <data key="d6">ApiGateway</data>
      <data key="d7">Ingests API configuration requests in US-WEST-1.</data>
    </node>
    <node id="4">
      <data key="d5">WAF Config Lambda (US)</data>
      <data key="d6">Lambda</data>
      <data key="d7">Processes WAF configuration changes and updates state.</data>
    </node>
    <node id="5">
      <data key="d5">DynamoDB (US)</data>
      <data key="d6">DynamoDB</data>
      <data key="d7">WORKLOAD_PEEK: Stores customer configurations with flexible schema.</data>
    </node>
    <node id="6">
      <data key="d5">FortiWeb Cloud Cluster (US)</data>
      <data key="d6">EC2</data>
      <data key="d7">WAF cluster running on EC2 that inspects payload and processes traffic.</data>
    </node>
    <node id="7">
      <data key="d5">S3 Static Assets (EU)</data>
      <data key="d6">S3</data>
      <data key="d7">Stores static web console assets in EU-CEN-1.</data>
    </node>
    <node id="8">
      <data key="d5">API Gateway (EU)</data>
      <data key="d6">ApiGateway</data>
      <data key="d7">Ingests API configuration requests in EU-CEN-1.</data>
    </node>
    <node id="9">
      <data key="d5">WAF Config Lambda (EU)</data>
      <data key="d6">Lambda</data>
      <data key="d7">Processes WAF configuration changes in EU-CEN-1.</data>
    </node>
    <node id="10">
      <data key="d5">DynamoDB (EU)</data>
      <data key="d6">DynamoDB</data>
      <data key="d7">Stores customer config data locally for EU compliance.</data>
    </node>
    <node id="11">
      <data key="d5">FortiWeb Cloud Cluster (EU)</data>
      <data key="d6">EC2</data>
      <data key="d7">WAF cluster in EU-CEN-1 for secure regional edge protection.</data>
    </node>
    <node id="12">
      <data key="d5">Elasticsearch Service</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">DATA_PEEK: Aggregates WAF security logs globally for fast lookup and filtering.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">User requests WAF management console.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="0" target="3" id="0">
      <data key="d8">1</data>
      <data key="d9">User modifies configurations via US endpoint API.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="0" target="8" id="0">
      <data key="d8">2</data>
      <data key="d9">User updates configurations on EU endpoint API.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">Retrieves UI assets from S3 US-West-1.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="0" id="0">
      <data key="d8">0</data>
      <data key="d9">Delivers console UI to user browser.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">Returns UI content.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="4" id="0">
      <data key="d8">1</data>
      <data key="d9">Triggers config handler Lambda.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="0" id="0">
      <data key="d8">1</data>
      <data key="d9">Returns success to client console.</data>
      <data key="d10">6</data>
      <data key="d11">meta</data>
    </edge>
    <edge source="4" target="5" id="0">
      <data key="d8">1</data>
      <data key="d9">Saves config settings to DynamoDB.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="6" id="0">
      <data key="d8">1</data>
      <data key="d9">Pushes updated WAF rules to FortiWeb cluster.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="3" id="0">
      <data key="d8">1</data>
      <data key="d9">Acknowledge completion.</data>
      <data key="d10">5</data>
      <data key="d11">meta</data>
    </edge>
    <edge source="6" target="12" id="0">
      <data key="d8">3</data>
      <data key="d9">Offloads US web traffic logs for rapid analysis.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="8" target="9" id="0">
      <data key="d8">2</data>
      <data key="d9">Triggers EU config handler Lambda.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="8" target="0" id="0">
      <data key="d8">2</data>
      <data key="d9">Returns success to client.</data>
      <data key="d10">6</data>
      <data key="d11">meta</data>
    </edge>
    <edge source="9" target="10" id="0">
      <data key="d8">2</data>
      <data key="d9">Stores settings locally in EU DynamoDB.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="9" target="11" id="0">
      <data key="d8">2</data>
      <data key="d9">Pushes rules to EU FortiWeb cluster.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <edge source="9" target="8" id="0">
      <data key="d8">2</data>
      <data key="d9">Ack response.</data>
      <data key="d10">5</data>
