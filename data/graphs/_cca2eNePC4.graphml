<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Authentication System</data>
      <data key="d6">UserCompanyAPI</data>
      <data key="d7">External system integrating with the fraud detection system for online e-commerce transactions. Originates the payment authentication flow.</data>
    </node>
    <node id="1">
      <data key="d5">Amazon CloudFront</data>
      <data key="d6">CloudFront</data>
      <data key="d7">DATA_PEEK: Serves customers throughout the region. Entry point for requests. WORKLOAD_PEEK: Handles requests for 180M+ card users.</data>
    </node>
    <node id="2">
      <data key="d5">AWS WAF</data>
      <data key="d6">WAF</data>
      <data key="d7">Helps secure against common web vulnerabilities, protecting the fraud detection system.</data>
    </node>
    <node id="3">
      <data key="d5">Elastic Load Balancing</data>
      <data key="d6">ELB</data>
      <data key="d7">Routes requests to backend services, ensuring scalability and distribution.</data>
    </node>
    <node id="4">
      <data key="d5">ECS Cluster (Fargate)</data>
      <data key="d6">ECS</data>
      <data key="d7">WORKLOAD_PEEK: The 'brains' of the system, running microservices for fraud detection. Utilizes AWS Fargate for serverless container orchestration, chosen to reduce operational overhead for a small team. Uses Graviton instances for better price-performance ratio. Microservices handle payment authentication and fraud detection logic, including interactions with various data stores. Supports 290+ rules for enhanced fraud detection.</data>
    </node>
    <node id="5">
      <data key="d5">Amazon Neptune</data>
      <data key="d6">Neptune</data>
      <data key="d7">DATA_PEEK: Stores complex transaction information, user information, device information, and historic anecdotes (e.g., card velocity). Used for traversing end-depth relationships with low latency for extended transactional insights.</data>
    </node>
    <node id="6">
      <data key="d5">Amazon DocumentDB</data>
      <data key="d6">DocumentDB</data>
      <data key="d7">DATA_PEEK: Stores policies and rules (e.g., the 290+ fraud detection rules). Also used to flatten information for different purposes.</data>
    </node>
    <node id="7">
      <data key="d5">Amazon RDS</data>
      <data key="d6">RDS</data>
      <data key="d7">DATA_PEEK: Stores traditional organization and user data. Used for CMS interfacing to manage this information.</data>
    </node>
    <node id="8">
      <data key="d5">Amazon MemoryDB for Redis</data>
      <data key="d6">MemoryDB</data>
      <data key="d7">DATA_PEEK: Provides microsecond latency caching. Specifically used for storing authentication information for microservices, which helps process subsequent requests very fast.</data>
    </node>
    <node id="9">
      <data key="d5">Amazon ECR</data>
      <data key="d6">ECR</data>
      <data key="d7">DATA_PEEK: Stores container images for microservices. The ECS cluster pulls these images during deployment.</data>
    </node>
    <node id="10">
      <data key="d5">Infinitium Developers</data>
      <data key="d6">UserCompanyDeveloper</data>
      <data key="d7">Responsible for developing microservices and managing the CI/CD process to deploy them.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">Initiates payment authentication flow for online e-commerce transactions.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">Requests routed to WAF for security checks against common web vulnerabilities.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="3" id="0">
      <data key="d8">0</data>
      <data key="d9">Requests routed from CloudFront to the Elastic Load Balancer.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">Request allowed by WAF to proceed back to CloudFront after security inspection.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="4" id="0">
      <data key="d8">0</data>
      <data key="d9">Requests distributed by the load balancer to microservices running on the ECS Fargate cluster.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="5" id="0">
      <data key="d8">0</data>
      <data key="d9">Microservices query Neptune for complex transaction analysis and historic data (e.g., card velocity).</data>
      <data key="d10">5a</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="6" id="0">
      <data key="d8">0</data>
      <data key="d9">Microservices access DocumentDB to retrieve/store policies and rules, and to flatten information.</data>
      <data key="d10">5b</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="7" id="0">
      <data key="d8">0</data>
      <data key="d9">Microservices access RDS for traditional organization and user data, often for CMS interfacing.</data>
      <data key="d10">5c</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="8" id="0">
      <data key="d8">0</data>
      <data key="d9">Microservices store and retrieve authentication information in MemoryDB for low-latency caching.</data>
      <data key="d10">5d</data>
      <data key="d11">data</data>
    </edge>
    <edge source="9" target="4" id="0">
      <data key="d8">1</data>
      <data key="d9">The ECS cluster pulls container images from ECR during deployment/updates.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="10" target="9" id="0">
      <data key="d8">1</data>
      <data key="d9">Developers deploy container images for microservices to ECR via a CI/CD process.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">Infinitium Fraud Detection System 2.0</data>
    <data key="d1">https://www.youtube.com/watch?v=_cca2eNePC4</data>
    <data key="d2">Infinitium, an online payments company, built a fraud detection system (FDS 2.0) to authenticate 180M+ card users, specifically for online e-commerce transactions. The system replaced an on-premises V1.0, overcoming scalability challenges and expanding rule processing from standard parameters to 290+ enhanced metrics. Key design choices include AWS Fargate for serverless container management, Graviton instances for cost-performance, and a mix of purpose-built databases (Neptune for graph analytics, DocumentDB for policies/rules, RDS for traditional data, MemoryDB for low-latency caching). The architecture is designed for PCI DSS compliance and regional customer reach.</data>
    <data key="d3">data_ingestion, interactive, compute_intensive, control</data>
    <data key="d4">True</data>
  </graph>
</graphml>
