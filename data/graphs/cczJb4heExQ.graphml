  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Cloud Operations Engineer</data>
      <data key="d6">UserCompanyInternalPlatform</data>
      <data key="d7">Interacts with Amazon Q to troubleshoot infrastructure issues.</data>
    </node>
    <node id="1">
      <data key="d5">AWS IAM Identity Center</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Authenticates operators and publishes the Amazon Q application portal.</data>
    </node>
    <node id="2">
      <data key="d5">Amazon Q Business</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">WORKLOAD_PEEK: Central Hub indexing documents and utilizing plugins for action execution.</data>
    </node>
    <node id="3">
      <data key="d5">Amazon S3</data>
      <data key="d6">S3</data>
      <data key="d7">DATA_PEEK: Stores PDFs and documentation indexed by Amazon Q.</data>
    </node>
    <node id="4">
      <data key="d5">Web Crawler</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Crawls specified web domains to ingest external support info.</data>
    </node>
    <node id="5">
      <data key="d5">Confluence</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Internal knowledge base and wiki indexed by Amazon Q.</data>
    </node>
    <node id="6">
      <data key="d5">ServiceNow CMDB</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">CMDB containing infrastructure state, integrated with AWS Config.</data>
    </node>
    <node id="7">
      <data key="d5">AWS Config</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Supplies resource state snapshots to the ServiceNow CMDB.</data>
    </node>
    <node id="8">
      <data key="d5">Jira</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Ticketing platform integrated with Amazon Q plugins for write actions.</data>
    </node>
