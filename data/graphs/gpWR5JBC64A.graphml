<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d12" for="edge" attr.name="id" attr.type="string" />
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Restaurant EPOS Machines</data>
      <data key="d6">UserConsumerPOS</data>
      <data key="d7">Used by restaurant staff across multiple kitchen sections. Leverages the Amplify SDK to stay in sync.</data>
    </node>
    <node id="1">
      <data key="d5">AWS AppSync</data>
      <data key="d6">AppSync</data>
      <data key="d7">Manages GraphQL subscriptions to provide real-time order syncing across all EPOS devices.</data>
    </node>
    <node id="2">
      <data key="d5">Lambda Resolvers</data>
      <data key="d6">Lambda</data>
      <data key="d7">Resolves AppSync queries, mutations, and subscriptions. Handles scaling during high peak order volumes.</data>
    </node>
    <node id="3">
      <data key="d5">Amazon DynamoDB</data>
      <data key="d6">DynamoDB</data>
      <data key="d7">Primary transactional database storing order states. Replaced Aurora to improve scaling with DynamoDB Streams enabled.</data>
    </node>
    <node id="4">
      <data key="d5">Amazon Kinesis Data Streams</data>
      <data key="d6">Kinesis</data>
      <data key="d7">Captures real-time changes from DynamoDB Streams to manage state and stream data to S3.</data>
    </node>
    <node id="5">
      <data key="d5">Amazon S3 Data Lake</data>
      <data key="d6">S3</data>
      <data key="d7">Stores historical order and transactional data for ETL and reporting.</data>
    </node>
    <node id="6">
      <data key="d5">Amazon QuickSight</data>
      <data key="d6">QuickSight</data>
      <data key="d7">Visualizes real-time performance insights for back-office and franchise managers.</data>
    </node>
    <node id="7">
      <data key="d5">Franchise &amp; Back Office Users</data>
      <data key="d6">UserCompanyAnalyst</data>
      <data key="d7">Analyzes daily restaurant stats and triggers marketing campaigns based on real-time data.</data>
    </node>
    <edge source="0" target="1">
      <data key="d8">0</data>
      <data key="d9">EPOS machines sync order states via GraphQL mutations using Amplify SDK.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="1" target="2">
      <data key="d8">0</data>
      <data key="d9">AppSync triggers Lambda resolvers to handle business logic.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="1" target="0">
      <data key="d8">0</data>
      <data key="d9">AppSync broadcasts order updates to all connected EPOS subscriptions.</data>
      <data key="d10">5</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="2" target="3">
      <data key="d8">0</data>
      <data key="d9">Lambda resolves the query and persists the order state into DynamoDB.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="2" target="1">
      <data key="d8">0</data>
      <data key="d9">Lambda returns the resolved order object.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="3" target="2">
      <data key="d8">0</data>
      <data key="d9">DynamoDB confirms success back to the Lambda resolver.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="3" target="4">
      <data key="d8">1</data>
      <data key="d9">DynamoDB Streams pushes database change events to Kinesis.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="4" target="5">
      <data key="d8">1</data>
      <data key="d9">Kinesis streams and dumps the transactional data into S3.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="5" target="6">
      <data key="d8">2</data>
      <data key="d9">S3 returns requested aggregate transactional dataset.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="6" target="5">
      <data key="d8">2</data>
      <data key="d9">QuickSight queries the S3 data lake to compute analytics.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="6" target="7">
      <data key="d8">2</data>
      <data key="d9">Renders real-time insights back to the analysts.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="7" target="6">
      <data key="d8">2</data>
      <data key="d9">Back-office and franchise users request reporting dashboards.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <data key="d0">FoodHub: Enabling Massive Scale Order Processing with Serverless Architecture</data>
    <data key="d1">https://www.youtube.com/watch?v=gpWR5JBC64A</data>
    <data key="d2">Food Hub handles over 63 million orders annually, with peak concurrency reaching 300 orders per minute. This fully serverless architecture allows them to scale seamlessly during weekend spikes while providing real-time synchronization across restaurant kitchen stations and instant operational dashboards for franchise owners.</data>
    <data key="d3">data_ingestion,interactive,compute_intensive</data>
    <data key="d4">True</data>
  </graph>
</graphml>
