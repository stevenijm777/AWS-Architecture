<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">SQL Server Farm</data>
      <data key="d6">OnPremDC</data>
      <data key="d7">Transactional databases storing jobs, job requests, and worker information.</data>
    </node>
    <node id="1">
      <data key="d5">AWS DMS</data>
      <data key="d6">DMS</data>
      <data key="d7">Migrates transactional databases to S3 landing bucket.</data>
    </node>
    <node id="2">
      <data key="d5">S3 Landing Bucket</data>
      <data key="d6">S3</data>
      <data key="d7">Accumulates Parquet files with inserts, updates, and deletes.</data>
    </node>
    <node id="3">
      <data key="d5">SQS Queues</data>
      <data key="d6">SQS</data>
      <data key="d7">Three queues configured to manage different table latencies (10m, 60m, 3h).</data>
    </node>
    <node id="4">
      <data key="d5">EventBridge Rules</data>
      <data key="d6">EventBridge</data>
      <data key="d7">Scheduled rules (10-minute, 60-minute, and 3-hour) to invoke downstream step functions.</data>
    </node>
    <node id="5">
      <data key="d5">AWS Step Functions</data>
      <data key="d6">StepFunctions</data>
      <data key="d7">Orchestrates AWS Glue workflows based on schedule triggers.</data>
    </node>
    <node id="6">
      <data key="d5">AWS Glue</data>
      <data key="d6">Glue</data>
      <data key="d7">WORKLOAD_PEEK: Serverless Spark jobs extracting metadata from SQS, reading raw Parquet from landing bucket, and upserting data to S3 Delta Lake.</data>
    </node>
    <node id="7">
      <data key="d5">S3 Delta Lake</data>
      <data key="d6">S3</data>
      <data key="d7">DATA_PEEK: Contains bronze, silver, and gold tiered views for downstream machine learning.</data>
    </node>
    <node id="8">
      <data key="d5">Data Scientists</data>
      <data key="d6">UserCompanyAnalyst</data>
      <data key="d7">Query bronze, silver, or gold tiers using PySpark SQL to build machine learning matching features.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">DMS replicates transactional data.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">DMS writes Parquet updates.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="3" id="0">
      <data key="d8">0</data>
      <data key="d9">S3 event notifications publish load metadata to SQS queues.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="5" id="0">
      <data key="d8">1</data>
      <data key="d9">EventBridge schedule triggers workflow execution.</data>
      <data key="d10">0</data>
      <data key="d11">meta</data>
    </edge>
    <edge source="5" target="6" id="0">
      <data key="d8">1</data>
      <data key="d9">Step Functions triggers AWS Glue ETL extractor jobs.</data>
      <data key="d10">1</data>
      <data key="d11">meta</data>
    </edge>
    <edge source="6" target="3" id="0">
      <data key="d8">1</data>
      <data key="d9">Glue job reads event messages to locate newly arrived files.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="6" target="2" id="0">
      <data key="d8">1</data>
      <data key="d9">Glue reads parquet tables from S3 landing zone.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="6" target="7" id="0">
      <data key="d8">1</data>
      <data key="d9">Glue upserts merged transactional records into Delta Lake.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <edge source="8" target="7" id="0">
      <data key="d8">2</data>
      <data key="d9">Querying raw and structured tiers using PySpark SQL for ML features.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">True Blue Serverless Data Lake</data>
    <data key="d1">https://www.youtube.com/watch?v=iKYvG5aiIn8</data>
    <data key="d2">Transitioned from long-running EMR clusters to a fully serverless Glue and Step Functions architecture to simplify management and keep Blue-Collar staffing matches near-real-time.</data>
    <data key="d3">data_ingestion</data>
    <data key="d4">True</data>
  </graph>
</graphml>
