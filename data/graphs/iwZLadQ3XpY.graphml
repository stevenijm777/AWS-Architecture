<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Players (Game Client)</data>
      <data key="d6">UserConsumerWebMobile</data>
      <data key="d7">Millions of League of Legends players globally across 20+ shards. Game clients interact with the EKS API to send player experience information. DATA_PEEK: Sending information about hero champions played, store engagement, etc.</data>
    </node>
    <node id="1">
      <data key="d5">Game API</data>
      <data key="d6">EKS</data>
      <data key="d7">Hosts an API that the game client connects to. This API is responsible for ingesting player experience data. DATA_PEEK: Receives approximately 8 terabytes of data per day, peaking at over 500,000 events per second.</data>
    </node>
    <node id="2">
      <data key="d5">On-Premise Data Centers (Game Servers)</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Hosts game servers globally in various data centers. Data generated by game servers is buffered locally in a Kafka cluster on-premise. WORKLOAD_PEEK: Uses MirrorMaker to replicate data from local Kafka to regional MSK clusters, specifically designed to handle network congestion and prioritize player ping during peak times.</data>
    </node>
    <node id="3">
      <data key="d5">Regional Kafka Buffer</data>
      <data key="d6">MSK</data>
      <data key="d7">Managed Streaming for Kafka, acting as a regional buffer across five different AWS regions. Collects and prepares data for processing. DATA_PEEK: Highly scalable and robust platform for handling high data flow from both EKS and on-premise Kafka clusters.</data>
    </node>
    <node id="4">
      <data key="d5">Spark Streaming Job</data>
      <data key="d6">EC2</data>
      <data key="d7">A Spark streaming job that consumes data from MSK. This compute component processes the incoming data before writing it to the Delta Lake in S3. WORKLOAD_PEEK: Significantly reduced time to obtain insights from 6-24 hours down to 5 minutes.</data>
    </node>
    <node id="5">
      <data key="d5">Delta Lake</data>
      <data key="d6">S3</data>
      <data key="d7">The primary data store, serving as a data lake where processed data is stored in a Delta Lake format. DATA_PEEK: Contains all collected player experience data, serving as the source for various downstream data consumers like analysts, designers, engineers, and executives.</data>
    </node>
    <node id="6">
      <data key="d5">Metastore &amp; Access Layer</data>
      <data key="d6">Glue</data>
      <data key="d7">Acts as the metastore for the Delta Lake in S3, providing information about logical tables and file locations within the S3 bucket. Functions as a permission and access layer for users acquiring data. WORKLOAD_PEEK: Enables secure, structured, and discoverable access to the raw and processed data in S3.</data>
    </node>
    <node id="7">
      <data key="d5">Data Consumers (Analysts, Engineers, Executives)</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Internal users including analysts, designers, engineers, and executives. They run queries and ETLs against the data in S3 to gain insights into game changes (e.g., champion performance, game length, tower fall times).</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">Game client sends player experience information (e.g., champion actions, store engagement) to the EKS API.</data>
      <data key="d10">0.0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="3" id="0">
      <data key="d8">0</data>
      <data key="d9">The EKS API streams ingested player data into regional MSK clusters for buffering.</data>
      <data key="d10">0.1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="3" id="0">
      <data key="d8">0</data>
      <data key="d9">On-premise game servers' local Kafka clusters replicate buffered data to regional MSK clusters using MirrorMaker, mitigating network challenges.</data>
      <data key="d10">0.2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="4" id="0">
      <data key="d8">0</data>
      <data key="d9">The Spark streaming job consumes raw data from MSK for real-time processing and transformation.</data>
      <data key="d10">0.3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="5" id="0">
      <data key="d8">0</data>
      <data key="d9">Processed data from the Spark job is written to the Delta Lake stored in S3, forming the data lake.</data>
      <data key="d10">0.4</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="6" id="0">
      <data key="d8">1</data>
      <data key="d9">Glue acts as the metastore, cataloging the schema and location of data files within the S3 Delta Lake.</data>
      <data key="d10">1.0</data>
      <data key="d11">meta</data>
    </edge>
    <edge source="7" target="6" id="0">
      <data key="d8">1</data>
      <data key="d9">Data consumers interact with Glue for metadata, permissions, and to discover tables available for querying.</data>
      <data key="d10">1.1</data>
      <data key="d11">meta</data>
    </edge>
    <edge source="7" target="5" id="0">
      <data key="d8">1</data>
      <data key="d9">Data consumers execute queries directly against the data in S3, leveraging Glue's metastore for schema and access control.</data>
      <data key="d10">1.2</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">Honno over IP - Riot Games League of Legends Data Ingest</data>
    <data key="d1">https://www.youtube.com/watch?v=iwZLadQ3XpY</data>
    <data key="d2">Riot Games' 'Honno over IP' is a new data ingest system for League of Legends. It's designed to collect player experience data (champion performance, game length, store engagement) from millions of players across 20+ global shards. The system processes approximately 8 terabytes of data per day, peaking at over 500,000 events per second. Key design decisions include a hybrid architecture using on-premise Kafka for buffering data from game servers, then replicating to AWS MSK. This approach mitigates network connectivity challenges and prioritizes player experience by not degrading ping during peak times. The data is then processed by a Spark streaming job and stored in an S3-based Delta Lake, significantly reducing the time to insights for analysts from 6-24 hours down to 5 minutes.</data>
    <data key="d3">data_ingestion, interactive, compute_intensive, control</data>
    <data key="d4">True</data>
  </graph>
</graphml>
