<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Website (WWW)</data>
      <data key="d6">UserConsumerWeb</data>
      <data key="d7">Represents the client website or mobile app where ad requests are triggered and tracked.</data>
    </node>
    <node id="1">
      <data key="d5">EC2 Spot (Bidding)</data>
      <data key="d6">EC2</data>
      <data key="d7">An autoscaling cluster of ~600 Spot instances across 3 regions globally, processing up to 1M requests/sec within a strict 100ms SLA.</data>
    </node>
    <node id="2">
      <data key="d5">EC2 Spot (Tracking)</data>
      <data key="d6">EC2</data>
      <data key="d7">Spot instances responsible for tracking user interactions with the ads (clicks, installs) and reconciling them with bid IDs.</data>
    </node>
    <node id="3">
      <data key="d5">ElastiCache (Redis)</data>
      <data key="d6">ElastiCache</data>
      <data key="d7">In-memory database storing hot bid data for 1 hour, handling 90% of tracking reconciliation requests.</data>
    </node>
    <node id="4">
      <data key="d5">SQS Queue</data>
      <data key="d6">SQS</data>
      <data key="d7">Buffers tracking reconciliation queries for events older than 1 hour.</data>
    </node>
    <node id="5">
      <data key="d5">Query Executor Lambda</data>
      <data key="d6">Lambda</data>
      <data key="d7">Triggered by SQS to execute asynchronous queries against historical cold data stored in S3 via Athena.</data>
    </node>
    <node id="6">
      <data key="d5">Athena</data>
      <data key="d6">Athena</data>
      <data key="d7">Serverless query engine used to scan cold partitioned Parquet files in S3.</data>
    </node>
    <node id="7">
      <data key="d5">S3 Bucket</data>
      <data key="d6">S3</data>
      <data key="d7">Stores historical log data, partitioned by minute. Raw JSON logs are converted to Parquet for cheap, efficient queries.</data>
    </node>
    <node id="8">
      <data key="d5">Parquet Converter Lambda</data>
      <data key="d6">Lambda</data>
      <data key="d7">Triggered automatically by new S3 JSON uploads to compress and convert the logs to Parquet format.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">Website triggers an ad auction/bidding request.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="0" target="2" id="0">
      <data key="d8">2</data>
      <data key="d9">User interacts with the ad, triggering a tracking request.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="3" id="0">
      <data key="d8">0</data>
      <data key="d9">Bidding server stores bid events in Redis with a unique auction ID.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="7" id="0">
      <data key="d8">0</data>
      <data key="d9">Raw bidding data is flushed to S3 every minute in JSON format.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="3" id="0">
      <data key="d8">2</data>
      <data key="d9">Retrieves bid data from Redis for hot events (within 1 hour).</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="4" id="0">
      <data key="d8">3</data>
      <data key="d9">Reconciliation requests older than 1 hour are enqueued in SQS.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="5" id="0">
      <data key="d8">3</data>
      <data key="d9">SQS triggers the Query Executor Lambda.</data>
      <data key="d10">1</data>
      <data key="d11">control</data>
    </edge>
    <edge source="5" target="6" id="0">
      <data key="d8">3</data>
      <data key="d9">Query Executor Lambda invokes a query in Athena.</data>
      <data key="d10">2</data>
      <data key="d11">control</data>
    </edge>
    <edge source="6" target="7" id="0">
      <data key="d8">3</data>
      <data key="d9">Athena queries historical cold data in S3 using partitioned Parquet files.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="7" target="8" id="0">
      <data key="d8">1</data>
      <data key="d9">New JSON files uploaded to S3 trigger the Parquet Converter Lambda.</data>
      <data key="d10">0</data>
      <data key="d11">control</data>
    </edge>
    <edge source="8" target="7" id="0">
      <data key="d8">1</data>
      <data key="d9">Lambda converts JSON files to Parquet format and saves them back to S3.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">Smadex Real-time Ad Bidding and Tracking Architecture</data>
    <data key="d1">https://www.youtube.com/watch?v=ERd0K_wW01s</data>
    <data key="d2">An elegant hybrid hot/cold storage architecture that reduces Redis costs by 90% while ensuring complete tracking coverage using SQS, Lambda, S3, and Athena.</data>
    <data key="d3">AdTech, Cost Optimization, Real-time Ingestion</data>
    <data key="d4">True</data>
  </graph>
</graphml>
