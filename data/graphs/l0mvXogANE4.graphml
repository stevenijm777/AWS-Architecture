<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">User</data>
      <data key="d6">UserConsumerWeb</data>
      <data key="d7">Represented by the green stick figure on the left.</data>
    </node>
    <node id="1">
      <data key="d5">www</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Web icon representing the external website/app visited by users.</data>
    </node>
    <node id="2">
      <data key="d5">EC2 SPOT (Bidding)</data>
      <data key="d6">EC2</data>
      <data key="d7">Top EC2 instance icon in the EC2 SPOT group representing the bidding layer.</data>
    </node>
    <node id="3">
      <data key="d5">EC2 SPOT (Tracking)</data>
      <data key="d6">EC2</data>
      <data key="d7">Bottom EC2 instance icon in the EC2 SPOT group representing the tracking layer.</data>
    </node>
    <node id="4">
      <data key="d5">ELASTICACHE</data>
      <data key="d6">ElastiCache</data>
      <data key="d7">ElastiCache (Redis) icon used as the fast hot-data memory cache layer.</data>
    </node>
    <node id="5">
      <data key="d5">S3</data>
      <data key="d6">S3</data>
      <data key="d7">S3 bucket icon representing the cold-data layer storage.</data>
    </node>
    <node id="6">
      <data key="d5">LAMBDA</data>
      <data key="d6">Lambda</data>
      <data key="d7">Lambda icon at the top right representing the function that converts files to Parquet.</data>
    </node>
    <node id="7">
      <data key="d5">SQS</data>
      <data key="d6">SQS</data>
      <data key="d7">SQS queue icon used to buffer old tracking requests.</data>
    </node>
    <node id="8">
      <data key="d5">ATHENA</data>
      <data key="d6">Athena</data>
      <data key="d7">Athena query engine icon representing search over cold-storage.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">User visits a website or application triggering an ad auction.</data>
      <data key="d10">0</data>
      <data key="d11">control</data>
    </edge>
    <edge source="0" target="3" id="0">
      <data key="d8">2</data>
      <data key="d9">User interactions with ads are tracked by sending events to the tracking layer.</data>
      <data key="d10">0</data>
      <data key="d11">control</data>
    </edge>
    <edge source="1" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">The auction request is sent to the bidding layer (under a 100ms constraint).</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="4" id="0">
      <data key="d8">0</data>
      <data key="d9">Saves the auction bid details in Redis with a unique ID.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="5" id="0">
      <data key="d8">1</data>
      <data key="d9">Flushes raw JSON bid logs to S3 on a minute interval.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="7" id="0">
      <data key="d8">2</data>
      <data key="d9">Enqueues event lookups older than one hour.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="3" id="0">
      <data key="d8">2</data>
      <data key="d9">The tracking layer reads matching bid information using the unique ID.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="6" id="0">
      <data key="d8">1</data>
      <data key="d9">S3 file upload triggers the Lambda conversion function.</data>
      <data key="d10">1</data>
      <data key="d11">control</data>
    </edge>
    <edge source="6" target="5" id="0">
      <data key="d8">1</data>
      <data key="d9">Lambda saves the optimized Parquet format files back into S3.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="7" target="8" id="0">
      <data key="d8">2</data>
      <data key="d9">Triggers a Lambda execution to run search queries in Athena.</data>
      <data key="d10">3</data>
      <data key="d11">control</data>
    </edge>
    <edge source="8" target="5" id="0">
      <data key="d8">2</data>
      <data key="d9">Athena queries raw log data from S3 partitioned by minute.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">Smadex Real-Time Programmatic Ad Bidding and Tracking Architecture</data>
    <data key="d1">https://www.youtube.com/watch?v=l0mvXogANE4</data>
    <data key="d2">Real-time programmatic bidding platform handling 1 million auctions/sec under 100ms constraint. Built on EC2 Spot Instances with a hot cache layer (ElastiCache Redis) and an SQS + Athena on S3 cold query layer to balance performance and storage cost optimization.</data>
    <data key="d3">data_ingestion, compute_intensive, other</data>
    <data key="d4">True</data>
  </graph>
</graphml>
