    </edge>
    <edge source="23" target="24" id="1">
      <data key="d8">4</data>
      <data key="d9">Based on worker reports, the orchestrator further influences the search by sending new instructions via RabbitMQ.</data>
      <data key="d10">9</data>
      <data key="d11">data</data>
    </edge>
