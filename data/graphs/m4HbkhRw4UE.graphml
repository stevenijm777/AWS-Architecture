  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Food Hub Consumers</data>
      <data key="d6">UserConsumerWebMobile</data>
      <data key="d7">Consumers placing orders, especially during peak weekend hours (Friday 5-7 PM).</data>
    </node>
    <node id="1">
      <data key="d5">Food Hub Order Resolvers</data>
      <data key="d6">Lambda</data>
      <data key="d7">WORKLOAD_PEEK: Handles order syncing, notifications, and dashboarding queries. Core compute for serverless order processing.</data>
    </node>
    <node id="2">
      <data key="d5">Food Hub Order Database</data>
      <data key="d6">DynamoDB</data>
      <data key="d7">DATA_PEEK: Stores order data. Moved from Aurora to DynamoDB for scale and managed services, particularly for handling peak order spikes. WORKLOAD_PEEK: Manages peak period scaling, especially on weekends.</data>
    </node>
    <node id="3">
      <data key="d5">Food Hub Restaurant Owners</data>
      <data key="d6">UserCompanyAgent</data>
      <data key="d7">Restaurant owners processing orders and needing daily insights/stats before closing their shops (around 11 PM).</data>
    </node>
    <node id="4">
      <data key="d5">Food Hub DynamoDB Stream</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Captures changes from the order database for downstream analytics.</data>
    </node>
    <node id="5">
      <data key="d5">Food Hub Data Stream</data>
      <data key="d6">Kinesis</data>
      <data key="d7">DATA_PEEK: Manages state for data coming from DynamoDB Streams before pushing to S3.</data>
    </node>
    <node id="6">
      <data key="d5">Food Hub Data Lake</data>
      <data key="d6">S3</data>
      <data key="d7">DATA_PEEK: Stores all raw and processed data from Kinesis. Serves as the source for daily stats and insights. WORKLOAD_PEEK: Subject to high concurrent access from 28,000+ restaurants at 11 PM.</data>
    </node>
    <node id="7">
      <data key="d5">Food Hub ETL Compute</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Runs ETLs over data in the S3 data lake for computing daily statistics. No specific AWS service (e.g., Glue, EMR, Lambda) was mentioned for the ETLs.</data>
    </node>
    <node id="8">
      <data key="d5">Food Hub Dashboarding</data>
      <data key="d6">QuickSight</data>
      <data key="d7">Predominant dashboarding tool for restaurant owners and internal back-office staff to view daily stats, earnings, and inform campaign decisions.</data>
    </node>
    <node id="9">
      <data key="d5">Food Hub Internal Back Office</data>
      <data key="d6">UserCompanyAnalyst</data>
      <data key="d7">Internal staff who use dashboards to understand restaurant performance and plan campaigns.</data>
    </node>
    <node id="10">
      <data key="d5">Freightways Drivers/Sources</data>
      <data key="d6">UserCompanyEdge</data>
      <data key="d7">Drivers and other sources generating package scans from edge devices.</data>
    </node>
    <node id="11">
      <data key="d5">Freightways Scan Ingestion API</data>
      <data key="d6">Fargate</data>
      <data key="d7">API service built on Fargate that consumes scans from different sources. WORKLOAD_PEEK: Handles up to 1500 scans per minute.</data>
    </node>
    <node id="12">
      <data key="d5">Freightways Scans Database</data>
      <data key="d6">DynamoDB</data>
      <data key="d7">Persists scan data. Chosen for ease of integration, performance, cost-effectiveness, and DynamoDB Streams capability. WORKLOAD_PEEK: Copes with different loads during the day.</data>
    </node>
    <node id="13">
      <data key="d5">Freightways DynamoDB Stream</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Feeds scan data to downstream services interested in the scans.</data>
    </node>
    <node id="14">
      <data key="d5">Freightways Scan Processor</data>
      <data key="d6">Lambda</data>
      <data key="d7">Picks up scan data from DynamoDB Streams and passes it to SNS for fan-out.</data>
    </node>
    <node id="15">
      <data key="d5">Freightways Scan Notifications</data>
      <data key="d6">SNS</data>
      <data key="d7">Fans out scan messages to multiple SQS queues for different processing services. Replaced Amazon MQ due to scaling issues (1500 scans/minute).</data>
    </node>
    <node id="16">
      <data key="d5">Freightways Image Processing Queue</data>
      <data key="d6">SQS</data>
      <data key="d7">One of multiple SQS queues interested in scan data, specifically for services that process images related to scans.</data>
    </node>
    <node id="17">
      <data key="d5">Freightways Image Processor Service</data>
      <data key="d6">Fargate</data>
      <data key="d7">Processes images that come through on the scans, consuming from an SQS queue. Allows rapid feature development.</data>
    </node>
    <node id="18">
      <data key="d5">Freightways Other Downstream Services Queue</data>
      <data key="d6">SQS</data>
      <data key="d7">Represents other SQS queues for various downstream services interested in scan data, enabling rapid feature development.</data>
    </node>
    <node id="19">
      <data key="d5">Vertex Chemists</data>
      <data key="d6">UserCompanyDeveloper</data>
      <data key="d7">Non-technical users (computational chemistry team) interacting with the platform via a client on their laptop to submit molecule search requests.</data>
    </node>
    <node id="20">
      <data key="d5">Vertex Molecule Search API</data>
      <data key="d6">ApiGateway</data>
      <data key="d7">Receives POST requests with JSON payload from chemists' clients, including search type and fleet size parameters.</data>
    </node>
    <node id="21">
      <data key="d5">Vertex Search Enricher/Environment Creator</data>
      <data key="d6">Lambda</data>
      <data key="d7">Enriches the search request with additional details from a relational database and dynamically creates the search environment (Fargate spot fleet) based on parameters.</data>
    </node>
    <node id="22">
      <data key="d5">Vertex Relational Database</data>
      <data key="d6">RDS</data>
      <data key="d7">Stores additional details used by Lambda to enrich molecule search requests.</data>
    </node>
    <node id="23">
      <data key="d5">Vertex Fargate Orchestrator Task</data>
      <data key="d6">ECS</data>
      <data key="d7">A single Fargate task (part of a Fargate spot fleet) spun up by Lambda, which drives the intelligent molecule search process by communicating with search workers.</data>
    </node>
    <node id="24">
      <data key="d5">Vertex RabbitMQ on Amazon MQ</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Used by the orchestrator to communicate with search workers, passing work and receiving updates. Facilitates an intelligent search pattern.</data>
    </node>
    <node id="25">
      <data key="d5">Vertex Fargate Search Worker Tasks</data>
      <data key="d6">ECS</data>
      <data key="d7">Part of the Fargate spot fleet, these tasks pick up work from MQ, execute the molecule search, and report back details to the orchestrator via MQ. Search is intelligent.</data>
    </node>
