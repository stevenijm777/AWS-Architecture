      <data key="d6">S3</data>
      <data key="d7">Stores completed summary reports</data>
    </node>
    <node id="10">
      <data key="d5">Retrieval Lambda</data>
      <data key="d6">Lambda</data>
      <data key="d7">Retrieves execution status and summaries</data>
    </node>
