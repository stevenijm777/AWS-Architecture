<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">GitLab CI Platform</data>
      <data key="d6">UserCompanyDeveloper</data>
      <data key="d7">Primary GitLab instance where developers commit code and trigger CI/CD builds.</data>
    </node>
    <node id="1">
      <data key="d5">GitLab Runners (Base Node Group)</data>
      <data key="d6">EKS</data>
      <data key="d7">Dedicated, always-on base node group running GitLab runners to queue and coordinate incoming build requests.</data>
    </node>
    <node id="2">
      <data key="d5">Build Jobs (Worker Node Group)</data>
      <data key="d6">EKS</data>
      <data key="d7">WORKLOAD_PEEK: Dynamically scales from 0 to 50 instances utilizing Spot instances (.16xlarge and .metal) in multiple AZ subnets to run Kubernetes build pods.</data>
    </node>
    <node id="3">
      <data key="d5">Artifact and Cache S3 Bucket</data>
      <data key="d6">S3</data>
      <data key="d7">DATA_PEEK: Stores cache and build artifacts up to 50GB in size. Accessed via VPC endpoint to achieve high throughput and 50-60% build speedups.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">GitLab triggers runner to start build.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">Runner schedules and spins up a Kubernetes job pod on the worker node group.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="0" id="0">
      <data key="d8">0</data>
      <data key="d9">Runner passes build results back to primary GitLab instance.</data>
      <data key="d10">6</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="3" id="0">
      <data key="d8">0</data>
      <data key="d9">Job pod queries S3 for existing cache/artifacts.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="3" id="1">
      <data key="d8">0</data>
      <data key="d9">Completed job uploads fresh build cache/artifacts back to S3.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">Job reports build completion status back to the coordinator runner.</data>
      <data key="d10">5</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">S3 returns cached items to speed up compilation and scanning.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">Age of Learning's Scalable EKS Build Architecture</data>
    <data key="d1">https://www.youtube.com/watch?v=t8JCvcnFX10</data>
    <data key="d2">Migrated from 150 individual VMs to an autoscaling EKS-based GitLab Runner architecture. Handles 20k to 25k builds per month, yielding 50-60% faster build times and significant cost savings via spot instances and S3 gateway caching.</data>
    <data key="d3">compute_intensive</data>
    <data key="d4">True</data>
  </graph>
</graphml>
