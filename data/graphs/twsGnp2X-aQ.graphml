<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Telephonic Systems</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Source of raw phone conversation data for Zillow.</data>
    </node>
    <node id="1">
      <data key="d5">Audio Ingestion Bucket</data>
      <data key="d6">S3</data>
      <data key="d7">A dedicated S3 bucket where raw phone conversation audio data is ingested. This bucket also serves as the source for replaying original call audio via pre-signed URLs.</data>
    </node>
    <node id="2">
      <data key="d5">Audio Analysis Workflow</data>
      <data key="d6">StepFunctions</data>
      <data key="d7">Orchestrates the audio analysis phase. Triggered by data ingestion into the S3 Audio Ingestion Bucket. Sequences calls to Transcribe, Comprehend, and custom NLP models for data enrichment.</data>
    </node>
    <node id="3">
      <data key="d5" />
      <data key="d6">Transcribe</data>
      <data key="d7">Performs speech-to-text conversion on the audio data. PII reduction functionality is turned on to remove consumer PII information from transcripts, ensuring compliance.</data>
    </node>
    <node id="4">
      <data key="d5" />
      <data key="d6">Comprehend</data>
      <data key="d7">Generates sentiment analysis for customer utterances within the call transcripts.</data>
    </node>
    <node id="5">
      <data key="d5">Data Lake Bucket</data>
      <data key="d6">S3</data>
      <data key="d7">Stores all intermediate and final processed results, including transcripts, sentiment data, and insights from custom NLP models. This location is used by analysts and data scientists for further analysis and model training.</data>
    </node>
    <node id="6">
      <data key="d5">Kinesis Firehose</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Acts as a buffering layer for processed data before it is pushed into the Elasticsearch cluster.</data>
    </node>
    <node id="7">
      <data key="d5">Search Cluster</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Amazon OpenSearch Service cluster. The final destination for processed speech analytics data. Primarily serves internal customers, enabling them to search phone conversations by various features. Utilizes auto-scaling functionality.</data>
    </node>
    <node id="8">
      <data key="d5" />
      <data key="d6">Cognito</data>
      <data key="d7">Manages user authentication and user management for internal customers accessing the speech analytics product.</data>
    </node>
    <node id="9">
      <data key="d5">Internal UI Users</data>
      <data key="d6">UserConsumerWeb</data>
      <data key="d7">Internal business units and customers at Zillow who interact with a web-based user interface to search for phone conversations and replay call recordings.</data>
    </node>
    <node id="10">
      <data key="d5">GraphQL API (Proposed)</data>
      <data key="d6">AppSync</data>
      <data key="d7">Proposed future enhancement to act as a GraphQL proxy, simplifying the backend API design and providing efficiency benefits. It will abstract access to various backend services.</data>
    </node>
    <node id="11">
      <data key="d5">AppSync Resolvers (Proposed)</data>
      <data key="d6">Lambda</data>
      <data key="d7">Proposed future enhancement. Lambda functions will serve as resolvers for AppSync, handling business logic and interacting with backend services like Elasticsearch and S3 for data retrieval and operations.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">Phone conversation data is grabbed and stored in S3.</data>
      <data key="d10">0.0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">S3 event triggers the Step Functions workflow for audio analysis.</data>
      <data key="d10">0.1</data>
      <data key="d11">meta</data>
    </edge>
    <edge source="1" target="9" id="0">
      <data key="d8">3</data>
      <data key="d9">Pre-signed URL for call replay is returned to the UI.</data>
      <data key="d10">3.1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="11" id="0">
      <data key="d8">4</data>
      <data key="d9">Future: S3 provides the pre-signed URL to the Lambda resolver.</data>
      <data key="d10">4.5</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="3" id="0">
      <data key="d8">0</data>
      <data key="d9">Step Functions orchestrates speech-to-text processing by Transcribe.</data>
      <data key="d10">0.2</data>
      <data key="d11">meta</data>
    </edge>
    <edge source="2" target="4" id="0">
      <data key="d8">0</data>
      <data key="d9">Step Functions orchestrates sentiment analysis by Comprehend.</data>
      <data key="d10">0.4</data>
      <data key="d11">meta</data>
    </edge>
    <edge source="2" target="5" id="0">
      <data key="d8">0</data>
      <data key="d9">All intermediate and final processed results (transcripts, sentiments, custom NLP model insights) are pushed into the S3 Data Lake Bucket.</data>
      <data key="d10">0.6</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">Transcripts (with PII redacted) are returned to the Step Functions workflow.</data>
      <data key="d10">0.3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">Sentiment data is returned to the Step Functions workflow.</data>
      <data key="d10">0.5</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="6" id="0">
      <data key="d8">1</data>
      <data key="d9">Processed data is moved from the S3 Data Lake to Kinesis Firehose for buffering.</data>
      <data key="d10">1.0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="6" target="7" id="0">
      <data key="d8">1</data>
      <data key="d9">Buffered data is delivered from Kinesis Firehose to the Elasticsearch cluster.</data>
      <data key="d10">1.1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="7" target="9" id="0">
      <data key="d8">2</data>
      <data key="d9">Search results are returned from Elasticsearch to the UI.</data>
      <data key="d10">2.2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="7" target="11" id="0">
      <data key="d8">4</data>
      <data key="d9">Future: Elasticsearch returns search results to the Lambda resolver.</data>
      <data key="d10">4.3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="9" target="8" id="0">
      <data key="d8">2</data>
      <data key="d9">Internal users authenticate and manage their profiles via Cognito.</data>
      <data key="d10">2.0</data>
      <data key="d11">meta</data>
    </edge>
    <edge source="9" target="7" id="0">
      <data key="d8">2</data>
      <data key="d9">User search criteria from the UI (transformed by an implicit backend) are sent as queries to Elasticsearch.</data>
      <data key="d10">2.1</data>
      <data key="d11">meta</data>
    </edge>
    <edge source="9" target="1" id="0">
      <data key="d8">3</data>
      <data key="d9">Users request pre-signed URLs from an implicit backend to replay original call audio stored in S3.</data>
      <data key="d10">3.0</data>
      <data key="d11">meta</data>
    </edge>
    <edge source="9" target="1" id="1">
      <data key="d8">3</data>
      <data key="d9">Users stream call audio directly from S3 using the pre-signed URL.</data>
      <data key="d10">3.2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="9" target="10" id="0">
      <data key="d8">4</data>
      <data key="d9">Future: UI sends API requests (e.g., search, comments, grabbing URLs) to the AppSync GraphQL endpoint.</data>
      <data key="d10">4.0</data>
      <data key="d11">meta</data>
    </edge>
    <edge source="10" target="11" id="0">
      <data key="d8">4</data>
      <data key="d9">Future: AppSync invokes Lambda resolvers to handle specific GraphQL operations.</data>
      <data key="d10">4.1</data>
      <data key="d11">meta</data>
    </edge>
    <edge source="10" target="9" id="0">
      <data key="d8">4</data>
      <data key="d9">Future: AppSync returns the API responses to the UI.</data>
      <data key="d10">4.7</data>
      <data key="d11">data</data>
    </edge>
    <edge source="11" target="7" id="0">
      <data key="d8">4</data>
      <data key="d9">Future: Lambda resolvers query Elasticsearch for search data.</data>
      <data key="d10">4.2</data>
      <data key="d11">meta</data>
    </edge>
    <edge source="11" target="1" id="0">
      <data key="d8">4</data>
      <data key="d9">Future: Lambda resolver generates pre-signed URLs for S3 audio files.</data>
      <data key="d10">4.4</data>
      <data key="d11">meta</data>
    </edge>
    <edge source="11" target="10" id="0">
      <data key="d8">4</data>
      <data key="d9">Future: Lambda resolvers return processed data to AppSync.</data>
      <data key="d10">4.6</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">Zillow: Building Speech Analytics Using AWS AI Services</data>
    <data key="d1">https://www.youtube.com/watch?v=twsGnp2X-aQ</data>
    <data key="d2">Zillow leverages AWS AI services to process and analyze phone conversation data from customers for internal quality control and customer support. The architecture captures audio data, converts speech to text with PII redaction, performs sentiment analysis, and enriches data with custom NLP models. Processed insights are stored in a data lake and then fed into an Elasticsearch cluster for searchable access by internal business units via a web UI. The solution includes user authentication via Cognito and plans to enhance its API layer using AppSync/GraphQL with Lambda resolvers for increased efficiency and simplified design.</data>
    <data key="d3">data_ingestion, interactive, compute_intensive</data>
    <data key="d4">True</data>
  </graph>
</graphml>
