<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">regulations.gov</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">External government regulations portal holding public comments.</data>
    </node>
    <node id="1">
      <data key="d5">Daily Ingestion Lambda</data>
      <data key="d6">Lambda</data>
      <data key="d7">Triggers daily to pull new comments from regulations.gov.</data>
    </node>
    <node id="2">
      <data key="d5">S3 Data Store</data>
      <data key="d6">S3</data>
      <data key="d7">DATA_PEEK: Stores raw comments, intermediate clean CSVs, and final model execution results.</data>
    </node>
    <node id="3">
      <data key="d5">SageMaker Notebooks</data>
      <data key="d6">SageMaker</data>
      <data key="d7">Cleans data (removing special characters, markdown), and hosts Scikit-learn (clustering form letters/grade level) and Hugging Face Flan UL2 models (sentiment analysis).</data>
    </node>
    <node id="4">
      <data key="d5">Amazon Bedrock (Titan)</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">WORKLOAD_PEEK: Leverages Titan model to run language complexity evaluation for expert designation.</data>
    </node>
    <node id="5">
      <data key="d5">Tableau</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Business intelligence tool that displays daily refreshed dashboards.</data>
    </node>
    <node id="6">
      <data key="d5">Campaign Analyst</data>
      <data key="d6">UserCompanyAnalyst</data>
      <data key="d7">Non-profit staff analyzing public campaign trends and identifying key regulatory experts.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">1</data>
      <data key="d9">Daily pull of regulatory comments.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="2" id="0">
      <data key="d8">1</data>
      <data key="d9">Saves raw comments to S3.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="5" id="0">
      <data key="d8">3</data>
      <data key="d9">Returns structured ML insights to Tableau.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="2" id="0">
      <data key="d8">2</data>
      <data key="d9">SageMaker pulls raw comments for pre-processing.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="2" id="1">
      <data key="d8">2</data>
      <data key="d9">Writes cleaned CSV back to S3.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="2" id="2">
      <data key="d8">2</data>
      <data key="d9">Saves combined ML analysis results as CSV in S3.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="4" id="0">
      <data key="d8">2</data>
      <data key="d9">Sends comments to Bedrock Titan for expert identification.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="3" id="0">
      <data key="d8">2</data>
      <data key="d9">Returns expert designation findings.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="2" id="0">
      <data key="d8">3</data>
      <data key="d9">Queries the daily refreshed CSV datasets from S3.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="6" id="0">
      <data key="d8">3</data>
      <data key="d9">Renders campaign insights, support/opposition trends, and expert highlights.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="6" target="5" id="0">
      <data key="d8">3</data>
      <data key="d9">Analyst accesses the Tableau reporting dashboard.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">Generative AI and ML-Powered Regulatory Comment Analysis</data>
    <data key="d1">https://www.youtube.com/watch?v=ulTevtklPHI</data>
    <data key="d2">Modernized campaign reporting using a blend of Amazon Bedrock (Titan), lightweight open-source models (Flan UL2 on SageMaker), and traditional Scikit-learn clustering. Scaled to ingest up to 250,000 to 500,000 regulatory comments in a 90-day period for a small non-profit.</data>
    <data key="d3">data_ingestion, compute_intensive</data>
    <data key="d4">True</data>
  </graph>
</graphml>
