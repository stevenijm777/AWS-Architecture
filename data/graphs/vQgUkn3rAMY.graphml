  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Assembly AI Clients</data>
      <data key="d6">UserCompanyAPI</data>
      <data key="d7">DATA_PEEK: Podcasting and telephony companies uploading raw or referenced audio files.</data>
    </node>
    <node id="1">
      <data key="d5">API Manager Container</data>
      <data key="d6">ECS</data>
      <data key="d7">WORKLOAD_PEEK: Validates, transcodes raw audio, and returns synchronous request acknowledgment.</data>
    </node>
    <node id="2">
      <data key="d5">Audio Storage Bucket</data>
      <data key="d6">S3</data>
      <data key="d7">DATA_PEEK: Stores transcoded audio. Implements strict lifecycle policies for SOC 2 data deletion.</data>
    </node>
    <node id="3">
      <data key="d5">Orchestrator Service</data>
      <data key="d6">ECS</data>
      <data key="d7">WORKLOAD_PEEK: Directs transcription pipelines, coordinates model orders, and initiates asynchronous scaling decisions.</data>
    </node>
    <node id="4">
      <data key="d5">Model Job Queues</data>
      <data key="d6">SQS</data>
      <data key="d7">WORKLOAD_PEEK: Multiple queues buffering jobs for different ML models (speech-to-text, sentiment analysis, etc.).</data>
    </node>
    <node id="5">
      <data key="d5">ML Inference Pipeline</data>
      <data key="d6">ECS</data>
      <data key="d7">WORKLOAD_PEEK: GPU-powered model instances (e.g. Conformer 2, LLMs) processing inference.</data>
    </node>
    <node id="6">
      <data key="d5">Metrics &amp; Auto Scaler</data>
      <data key="d6">CloudWatch</data>
      <data key="d7">WORKLOAD_PEEK: Tracks queue depth and custom predictive metrics to dynamically scale up GPU containers.</data>
    </node>
    <node id="7">
      <data key="d5">Completion SNS Topic</data>
      <data key="d6">SNS</data>
      <data key="d7">WORKLOAD_PEEK: Receives notifications upon completion of speech-to-text and NLP pipeline runs.</data>
    </node>
    <node id="8">
      <data key="d5">Webhook Notification Lambda</data>
      <data key="d6">Lambda</data>
      <data key="d7">WORKLOAD_PEEK: Dispatches HTTP notifications back to the customer client asynchronously.</data>
    </node>
