<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Independent Agents</data>
      <data key="d6">UserCompanyAgent</data>
      <data key="d7">Agents access the modern single-page application (SPA) to sell insurance policies.</data>
    </node>
    <node id="1">
      <data key="d5">CloudFront CDN</data>
      <data key="d6">CloudFront</data>
      <data key="d7">Caches and serves the static assets of the modernized SPA.</data>
    </node>
    <node id="2">
      <data key="d5">S3 Bucket</data>
      <data key="d6">S3</data>
      <data key="d7">Hosts the SPA single-page application static files.</data>
    </node>
    <node id="3">
      <data key="d5">API Gateway</data>
      <data key="d6">ApiGateway</data>
      <data key="d7">Acts as the unified entry point for all modern back-end API requests.</data>
    </node>
    <node id="4">
      <data key="d5">Lambda Authorizer</data>
      <data key="d6">Lambda</data>
      <data key="d7">Validates user permissions and access rights before hitting back-end services.</data>
    </node>
    <node id="5">
      <data key="d5">Serverless Python Lambda</data>
      <data key="d6">Lambda</data>
      <data key="d7">Executes backend logic. Scales up and down dynamically. Integrates with DynamoDB and legacy EC2 backend.</data>
    </node>
    <node id="6">
      <data key="d5">Legacy Tomcat Servers</data>
      <data key="d6">EC2</data>
      <data key="d7">Legacy Tomcat application hosting non-migrated features like user management.</data>
    </node>
    <node id="7">
      <data key="d5">DynamoDB Cache</data>
      <data key="d6">DynamoDB</data>
      <data key="d7">Regional DynamoDB instance used to cache user session state across multiple AZs.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">Agent requests single-page application</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="0" target="1" id="1">
      <data key="d8">1</data>
      <data key="d9">API call from SPA</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">Retrieves SPA assets from S3</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="0" id="0">
      <data key="d8">0</data>
      <data key="d9">Serves SPA to agent browser</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="0" id="1">
      <data key="d8">1</data>
      <data key="d9">Delivers dynamic update back to the agent UI</data>
      <data key="d10">12</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="3" id="0">
      <data key="d8">1</data>
      <data key="d9">Routes API call to backend API Gateway</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">Returns static assets</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="4" id="0">
      <data key="d8">1</data>
      <data key="d9">Invokes custom Lambda Authorizer</data>
      <data key="d10">3</data>
      <data key="d11">meta</data>
    </edge>
    <edge source="3" target="5" id="0">
      <data key="d8">1</data>
      <data key="d9">Routes validated request to business logic Lambda</data>
      <data key="d10">5</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="1" id="0">
      <data key="d8">1</data>
      <data key="d9">Passes response back to CDN</data>
      <data key="d10">11</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="3" id="0">
      <data key="d8">1</data>
      <data key="d9">Returns validation success token</data>
      <data key="d10">4</data>
      <data key="d11">meta</data>
    </edge>
    <edge source="5" target="7" id="0">
      <data key="d8">1</data>
      <data key="d9">Caches/Retrieves user state from DynamoDB</data>
      <data key="d10">6</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="6" id="0">
      <data key="d8">1</data>
      <data key="d9">Calls legacy Tomcat for non-modernized services</data>
      <data key="d10">8</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="3" id="0">
      <data key="d8">1</data>
      <data key="d9">Returns final API response payload</data>
      <data key="d10">10</data>
      <data key="d11">data</data>
    </edge>
    <edge source="6" target="5" id="0">
      <data key="d8">1</data>
      <data key="d9">Returns legacy execution result to Python Lambda</data>
      <data key="d10">9</data>
      <data key="d11">data</data>
    </edge>
    <edge source="7" target="5" id="0">
      <data key="d8">1</data>
      <data key="d9">Returns cached session data</data>
      <data key="d10">7</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">Modernizing Legacy Applications with Serverless on AWS</data>
    <data key="d1">https://www.youtube.com/watch?v=wjtSHyENv0I</data>
    <data key="d2">WORKLOAD_PEEK: Strangling a legacy Tomcat Java application by migrating features incrementally to serverless Python Lambdas. Shut down 25 on-prem servers and improved user satisfaction by 25%.</data>
    <data key="d3">interactive, control</data>
    <data key="d4">True</data>
  </graph>
