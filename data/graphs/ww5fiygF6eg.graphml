<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Drone Operations &amp; Image Processing</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">WORKLOAD_PEEK: Drones are flown by licensed third-party pilots to well pads on a routine basis. Imagery is loaded into this third-party software for processing. DATA_PEEK: Processes imagery and creates three separate files per well pad: an ortho mosaic (high-resolution top-down view), a digital terrain model, and a digital elevation model. Images are stored on this third-party server.</data>
    </node>
    <node id="1">
      <data key="d5">CloudWatch Event</data>
      <data key="d6">CloudWatch</data>
      <data key="d7">WORKLOAD_PEEK: Runs on a schedule basis to initiate the automated image ingestion workflow.</data>
    </node>
    <node id="2">
      <data key="d5">Image Ingestion Workflow</data>
      <data key="d6">StepFunctions</data>
      <data key="d7">WORKLOAD_PEEK: Consists of three separate Lambda functions to orchestrate the process of checking for, ingesting, and preparing drone imagery.</data>
    </node>
    <node id="3">
      <data key="d5">Lambda Function 1: Check New Images</data>
      <data key="d6">Lambda</data>
      <data key="d7">WORKLOAD_PEEK: Accesses the third-party software via an API to determine if new images and flights are available for ingestion.</data>
    </node>
    <node id="4">
      <data key="d5">Lambda Function 2: Ingest Images to S3</data>
      <data key="d6">Lambda</data>
      <data key="d7">WORKLOAD_PEEK: If new images are found by Lambda Function 1, this function retrieves those images from the third-party software and stores them in the AWS S3 bucket.</data>
    </node>
    <node id="5">
      <data key="d5">Drone Imagery Bucket</data>
      <data key="d6">S3</data>
      <data key="d7">DATA_PEEK: Stores the three separate image files per well pad (ortho mosaic, digital terrain model, digital elevation model) ingested from the third-party software. WORKLOAD_PEEK: Serves as the central repository for raw drone imagery within the AWS environment.</data>
    </node>
    <node id="6">
      <data key="d5">Lambda Function 3: Create Raster Proxy</data>
      <data key="d6">Lambda</data>
      <data key="d7">WORKLOAD_PEEK: Takes the drone images stored in S3 and creates 'raster proxies', which are URLs that the on-premise mapping software can interpret. This mechanism enables the on-premise application to effectively read directly from S3 via Storage Gateway.</data>
    </node>
    <node id="7">
      <data key="d5">On-prem Mapping Database</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">DATA_PEEK: Stores the raster proxies (URLs) generated by Lambda Function 3, providing the on-premise mapping software with references to the images in S3.</data>
    </node>
    <node id="8">
      <data key="d5">On-prem Mapping Software</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">WORKLOAD_PEEK: The internal mapping application used by Marathon Oil's operations teams. DATA_PEEK: Cannot directly read from S3 but leverages raster proxies and Storage Gateway to access imagery. Displays images for user analysis.</data>
    </node>
    <node id="9">
      <data key="d5">Storage Gateway</data>
      <data key="d6">StorageGateway</data>
      <data key="d7">WORKLOAD_PEEK: Facilitates seamless access for the on-premise mapping software to the S3 bucket. It allows the on-prem application to read image files directly from S3 using the raster proxy URLs, without requiring application changes.</data>
    </node>
    <node id="10">
      <data key="d5">Marathon Oil Operations Teams</data>
      <data key="d6">UserConsumerWeb</data>
      <data key="d7">WORKLOAD_PEEK: Includes maintenance and various other operations teams. They leverage the drone images to identify equipment issues, schedule preventative maintenance, and conduct overall health checks of well pads.</data>
    </node>
    <edge source="0" target="0" id="0">
      <data key="d8">0</data>
      <data key="d9">Drones capture imagery which is uploaded to the third-party software for processing and storage on its server.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="0" target="3" id="0">
      <data key="d8">1</data>
      <data key="d9">The third-party API responds to Lambda Function 1 with information about new images/flights.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="2" id="0">
      <data key="d8">1</data>
      <data key="d9">A scheduled CloudWatch Event triggers the Step Functions workflow.</data>
      <data key="d10">0</data>
      <data key="d11">meta</data>
    </edge>
    <edge source="2" target="3" id="0">
      <data key="d8">1</data>
      <data key="d9">Step Functions invokes Lambda Function 1 to check for new images.</data>
      <data key="d10">1</data>
      <data key="d11">meta</data>
    </edge>
    <edge source="3" target="0" id="0">
      <data key="d8">1</data>
      <data key="d9">Lambda Function 1 calls the third-party software's API to determine if new images or flights are available.</data>
      <data key="d10">2</data>
      <data key="d11">meta</data>
    </edge>
    <edge source="3" target="4" id="0">
      <data key="d8">1</data>
      <data key="d9">If new images are found, Lambda Function 1 invokes Lambda Function 2.</data>
      <data key="d10">4</data>
      <data key="d11">meta</data>
    </edge>
    <edge source="4" target="0" id="0">
      <data key="d8">1</data>
      <data key="d9">Lambda Function 2 retrieves the drone image files from the third-party software via its API.</data>
      <data key="d10">5</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="5" id="0">
      <data key="d8">1</data>
      <data key="d9">Lambda Function 2 stores the retrieved drone imagery into the S3 bucket.</data>
      <data key="d10">6</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="6" id="0">
      <data key="d8">2</data>
      <data key="d9">Lambda Function 3 processes new images stored in S3 to create raster proxies (URLs). This is likely event-driven or scheduled following S3 ingestion.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="9" id="0">
      <data key="d8">3</data>
      <data key="d9">S3 returns the image files to Storage Gateway.</data>
      <data key="d10">5</data>
      <data key="d11">data</data>
    </edge>
    <edge source="6" target="7" id="0">
      <data key="d8">2</data>
      <data key="d9">Lambda Function 3 stores the generated raster proxy (URL) in the on-premise mapping software's local database.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="7" target="8" id="0">
      <data key="d8">3</data>
      <data key="d9">The on-premise database returns the raster proxy URL to the mapping software.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="8" target="7" id="0">
      <data key="d8">3</data>
      <data key="d9">The on-premise mapping software queries its database for the raster proxy URL of the desired image.</data>
      <data key="d10">1</data>
      <data key="d11">meta</data>
    </edge>
    <edge source="8" target="9" id="0">
      <data key="d8">3</data>
      <data key="d9">The on-premise mapping software uses the raster proxy URL to access images through the Storage Gateway.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="8" target="10" id="0">
      <data key="d8">3</data>
      <data key="d9">The on-premise mapping software displays the drone images to the end user for analysis.</data>
      <data key="d10">7</data>
      <data key="d11">data</data>
    </edge>
    <edge source="9" target="5" id="0">
      <data key="d8">3</data>
      <data key="d9">Storage Gateway retrieves the actual image files from the S3 bucket based on the raster proxy URL.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <edge source="9" target="8" id="0">
      <data key="d8">3</data>
      <data key="d9">Storage Gateway passes the image files to the on-premise mapping software.</data>
      <data key="d10">6</data>
      <data key="d11">data</data>
    </edge>
    <edge source="10" target="8" id="0">
      <data key="d8">3</data>
      <data key="d9">Marathon Oil operations teams access the on-premise mapping software to view drone imagery.</data>
      <data key="d10">0</data>
      <data key="d11">meta</data>
    </edge>
    <data key="d0">Marathon Oil Drone Image Processing and On-Prem Integration</data>
    <data key="d1">https://www.youtube.com/watch?v=ww5fiygF6eg</data>
    <data key="d2">Marathon Oil uses drones to monitor well pads, moving from manual inspections to automated surveillance. Third-party pilots collect imagery and upload it to a third-party processing software. A serverless AWS architecture is used for ingestion and integration: a scheduled CloudWatch event triggers a Step Functions workflow. This workflow orchestrates three Lambda functions to check for new imagery from the third-party software, ingest it into S3, and then create 'raster proxies' (URLs) that are stored in an on-premise database. This enables existing on-premise mapping software to access the S3-stored imagery via an AWS Storage Gateway, providing maintenance and operations teams with vital well pad health data without requiring application changes.</data>
    <data key="d3">data_ingestion, interactive, compute_intensive, other</data>
    <data key="d4">True</data>
  </graph>
</graphml>
