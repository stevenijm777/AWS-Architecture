<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="node_0">
      <data key="d5">Mobile App</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Represents the mobile application used by riders and drivers to access Cabify's platform.</data>
    </node>
    <node id="node_1">
      <data key="d5">ROUTE53</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Used for DNS resolution and geolocalized routing during country-by-country migration.</data>
    </node>
    <node id="node_2">
      <data key="d5">ELB</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Distributes incoming client application traffic to backend services.</data>
    </node>
    <node id="node_3">
      <data key="d5">EC2</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Hosts the legacy Nomad container platform representing over 700 services.</data>
    </node>
    <node id="node_4">
      <data key="d5">EKS</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">The new target managed Kubernetes cluster to which services are being migrated.</data>
    </node>
    <node id="node_5">
      <data key="d5">SPOT</data>
      <data key="d6">EC2</data>
      <data key="d7">Used to cost-effectively run services and test resiliency against instance terminations.</data>
    </node>
    <node id="node_6">
      <data key="d5">RDS</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Hosts independent MySQL database instances for service persistence.</data>
    </node>
    <node id="node_7">
      <data key="d5">S3</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Used for long-term cold data archiving of trip information.</data>
    </node>
    <edge source="node_0" target="node_1" id="0">
      <data key="d8">0</data>
      <data key="d9">App resolves domain using Route 53 IP geolocalisation.</data>
      <data key="d10">0</data>
      <data key="d11">control</data>
    </edge>
    <edge source="node_0" target="node_2" id="0">
      <data key="d8">0</data>
      <data key="d9">App traffic goes to the load balancers.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="node_2" target="node_3" id="0">
      <data key="d8">0</data>
      <data key="d9">Traffic distributed to services running on Nomad on EC2.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="node_2" target="node_4" id="0">
      <data key="d8">0</data>
      <data key="d9">Traffic distributed to services running on EKS.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="node_3" target="node_4" id="0">
      <data key="d8">1</data>
      <data key="d9">Visual representation of the migration process from Nomad (EC2) to EKS.</data>
      <data key="d10">0</data>
      <data key="d11">control</data>
    </edge>
    <edge source="node_3" target="node_6" id="0">
      <data key="d8">2</data>
      <data key="d9">Nomad-hosted services writing persistent data to RDS databases.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="node_4" target="node_6" id="0">
      <data key="d8">2</data>
      <data key="d9">EKS-hosted services writing persistent data to RDS databases.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">Cabify Platform Migration from Nomad to Amazon EKS</data>
    <data key="d1">https://www.youtube.com/watch?v=x76BIV88j_M</data>
    <data key="d2">Cabify migrates 700+ microservices from a legacy Nomad platform hosted on EC2 to a managed Amazon EKS cluster, leveraging Spot instances for cost resiliency and RDS MySQL databases per service.</data>
    <data key="d3">interactive, other</data>
    <data key="d4">True</data>
  </graph>
</graphml>
