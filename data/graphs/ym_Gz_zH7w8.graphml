  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Peloton Bike Client</data>
      <data key="d6">UserConsumerIOT</data>
      <data key="d7">Triggers workout recommendations.</data>
    </node>
    <node id="1">
      <data key="d5">Hydration Service</data>
      <data key="d6">EKS</data>
      <data key="d7">WORKLOAD_PEEK: Backend microservice that initiates recommendation orchestration.</data>
    </node>
    <node id="2">
      <data key="d5">Recommendation Service</data>
      <data key="d6">EKS</data>
      <data key="d7">WORKLOAD_PEEK: Core orchestrator microservice.</data>
    </node>
    <node id="3">
      <data key="d5">Feature Store</data>
      <data key="d6">DynamoDB</data>
      <data key="d7">DATA_PEEK: Low-latency store holding user preferences and historical behavior.</data>
    </node>
    <node id="4">
      <data key="d5">Graph Database</data>
      <data key="d6">Neptune</data>
      <data key="d7">DATA_PEEK: Stores relational graph of members, classes, and taken rides.</data>
    </node>
    <node id="5">
      <data key="d5">Inference Service</data>
      <data key="d6">EKS</data>
      <data key="d7">WORKLOAD_PEEK: Scores candidate workouts using machine learning models.</data>
    </node>
    <node id="6">
      <data key="d5">Event Logging Stream</data>
      <data key="d6">MSK</data>
      <data key="d7">Streams real-time metadata and telemetry back to S3.</data>
    </node>
    <node id="7">
      <data key="d5">Data Lake &amp; Model Registry</data>
      <data key="d6">S3</data>
      <data key="d7">DATA_PEEK: Houses historical datasets, logged events, and model artifacts.</data>
    </node>
    <node id="8">
      <data key="d5">EMR Spark Clusters</data>
      <data key="d6">EMR</data>
      <data key="d7">WORKLOAD_PEEK: Performs offline batch preprocessing and low-latency store sync.</data>
    </node>
    <node id="9">
      <data key="d5">EKS GPU Model Training Cluster</data>
      <data key="d6">EKS</data>
      <data key="d7">WORKLOAD_PEEK: Runs GPU-accelerated training workloads.</data>
    </node>
    <node id="10">
      <data key="d5">MWAA (Airflow)</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Orchestrates batch pre-processing and model training pipelines.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">Requests recommendations.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">Dispatches request to recommendation orchestrator.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="0" id="0">
      <data key="d8">0</data>
      <data key="d9">Returns recommendations to rider screen.</data>
      <data key="d10">10</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="3" id="0">
      <data key="d8">0</data>
      <data key="d9">Fetches user features.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="4" id="0">
      <data key="d8">0</data>
      <data key="d9">Fetches class candidate list.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="7" id="0">
      <data key="d8">0</data>
      <data key="d9">Retrieves target model.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="5" id="0">
      <data key="d8">0</data>
      <data key="d9">Pushes candidates, features, and model for scoring.</data>
      <data key="d10">5</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="6" id="0">
      <data key="d8">0</data>
      <data key="d9">Asynchronously streams logging telemetry.</data>
      <data key="d10">7</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">Sends hydration-ready recommendations.</data>
      <data key="d10">9</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">Returns scored candidate list.</data>
      <data key="d10">6</data>
      <data key="d11">data</data>
    </edge>
    <edge source="6" target="7" id="0">
      <data key="d8">0</data>
      <data key="d9">Persists streamed data for future training loop.</data>
      <data key="d10">8</data>
      <data key="d11">data</data>
    </edge>
    <edge source="8" target="7" id="0">
      <data key="d8">1</data>
      <data key="d9">Reads raw logged events.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="8" target="3" id="0">
      <data key="d8">1</data>
      <data key="d9">Hydrates Feature Store with batch metrics.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="8" target="4" id="0">
      <data key="d8">1</data>
      <data key="d9">Hydrates Graph Database with updated relationships.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <edge source="9" target="7" id="0">
      <data key="d8">1</data>
      <data key="d9">Pulls historical dataset for training.</data>
      <data key="d10">5</data>
      <data key="d11">data</data>
    </edge>
    <edge source="9" target="7" id="1">
      <data key="d8">1</data>
      <data key="d9">Registers trained model artifacts.</data>
      <data key="d10">6</data>
      <data key="d11">data</data>
    </edge>
    <edge source="10" target="8" id="0">
      <data key="d8">1</data>
      <data key="d9">Triggers EMR preprocessing.</data>
      <data key="d10">0</data>
