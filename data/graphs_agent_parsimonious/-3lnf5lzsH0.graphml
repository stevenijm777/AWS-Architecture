    <node id="0">
      <data key="d5">AWS Log Sources</data>
      <data key="d6">S3</data>
      <data key="d7">DATA_PEEK: Pulls telemetry from S3, SNS, SQS, CloudTrail, and GuardDuty.</data>
    </node>
    <node id="1">
      <data key="d5">On-Prem Sources</data>
      <data key="d6">OnPremDC</data>
      <data key="d7">DATA_PEEK: Real-time on-premises telemetry ingested using syslog or Kafka.</data>
    </node>
    <node id="2">
      <data key="d5">Apache Metron</data>
      <data key="d6">EC2</data>
      <data key="d7">WORKLOAD_PEEK: Converts diverse log formats to standardized JSON. Performs stream profiling and enrichment.</data>
    </node>
    <node id="3">
      <data key="d5">Amazon EMR</data>
      <data key="d6">EMR</data>
      <data key="d7">WORKLOAD_PEEK: EMR jobs migrate and transform persistent HDFS data from Apache Metron into S3.</data>
    </node>
    <node id="4">
      <data key="d5">Security Data Lake</data>
      <data key="d6">S3</data>
      <data key="d7">DATA_PEEK: Horizontally scalable telemetry storage holding months of history.</data>
