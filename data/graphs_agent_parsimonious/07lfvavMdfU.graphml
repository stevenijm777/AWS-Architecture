  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Video Creators / Users</data>
      <data key="d6">UserConsumerWeb</data>
      <data key="d7">Upload raw video footage to the ingest bucket.</data>
    </node>
    <node id="1">
      <data key="d5">S3 Ingest Bucket</data>
      <data key="d6">S3</data>
      <data key="d7">DATA_PEEK: Raw video files in various production formats.</data>
    </node>
    <node id="2">
      <data key="d5">Orchestration</data>
      <data key="d6">StepFunctions</data>
      <data key="d7">WORKLOAD_PEEK: Coordinates transcoding, metadata extraction, and AI analysis steps.</data>
    </node>
    <node id="3">
      <data key="d5">Elemental MediaConvert</data>
      <data key="d6">MediaConvert</data>
      <data key="d7">Generates low-bitrate web proxies for browser-based video playback and previewing.</data>
    </node>
    <node id="4">
      <data key="d5">Rekognition</data>
      <data key="d6">Rekognition</data>
      <data key="d7">Extracts visual metadata including celebrities, content moderation flags, and timestamps.</data>
    </node>
    <node id="5">
      <data key="d5">Transcribe</data>
      <data key="d6">Transcribe</data>
      <data key="d7">Converts audio tracks from ingested videos into text transcripts.</data>
    </node>
    <node id="6">
      <data key="d5">Comprehend</data>
      <data key="d6">Comprehend</data>
      <data key="d7">Performs sentiment analysis and entity extraction on the transcripts.</data>
    </node>
    <node id="7">
      <data key="d5">Temporary Metadata Store</data>
      <data key="d6">DynamoDB</data>
      <data key="d7">DATA_PEEK: Serves as a staging database to aggregate technical and AI-generated metadata.</data>
    </node>
    <node id="8">
      <data key="d5">Reach Engine (EKS)</data>
      <data key="d6">EKS</data>
      <data key="d7">Runs the containerized orchestration and search workflows for Reach Engine.</data>
    </node>
    <node id="9">
      <data key="d5">Reach Engine (EC2)</data>
      <data key="d6">EC2</data>
      <data key="d7">Runs application workloads and user interface instances for media management.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">Upload raw media files.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">Triggers processing state machine on file upload.</data>
      <data key="d10">1</data>
      <data key="d11">meta</data>
    </edge>
    <edge source="2" target="3" id="0">
      <data key="d8">0</data>
      <data key="d9">Initiates proxy generation transcodes.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="4" id="0">
      <data key="d8">1</data>
      <data key="d9">Triggers visual analysis.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="5" id="0">
      <data key="d8">1</data>
      <data key="d9">Triggers audio transcription.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="7" id="0">
      <data key="d8">1</data>
      <data key="d9">Saves object and celebrity labels with timecodes.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="6" id="0">
      <data key="d8">1</data>
      <data key="d9">Feeds transcribed text for NLP analysis.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="6" target="7" id="0">
      <data key="d8">1</data>
      <data key="d9">Saves extracted text entities and analysis.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <edge source="7" target="8" id="0">
      <data key="d8">2</data>
      <data key="d9">Pulls unified metadata into the Reach Engine application layer.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="7" target="9" id="0">
      <data key="d8">2</data>
      <data key="d9">Pulls unified metadata into Reach Engine portal.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">Levels Beyond: Media to Cloud Video Processing and Metadata Extraction Pipeline</data>
    <data key="d1">https://www.youtube.com/watch?v=07lfvavMdfU</data>
    <data key="d2">A serverless media processing pipeline that uses AWS Step Functions to orchestrate video transcoding via MediaConvert and parallel AI metadata extraction (Rekognition, Transcribe, Comprehend). Extracted metadata is unified in DynamoDB before being indexed into the Reach Engine system hosted on EKS and EC2.</data>
    <data key="d3">data_ingestion, compute_intensive</data>
    <data key="d4">True</data>
  </graph>
</graphml>
