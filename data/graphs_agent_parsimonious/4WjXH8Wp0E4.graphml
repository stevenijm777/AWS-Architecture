<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Clinicians / Care Workers</data>
      <data key="d6">UserCompanyAgent</data>
      <data key="d7">Access the platform through secure N3/HSCN NHS network.</data>
    </node>
    <node id="1">
      <data key="d5">AWS Direct Connect</data>
      <data key="d6">DirectConnect</data>
      <data key="d7">Secures data flows into AWS environment from the NHS network.</data>
    </node>
    <node id="2">
      <data key="d5">Integration Service</data>
      <data key="d6">EC2</data>
      <data key="d7">WORKLOAD_PEEK: Microservice handling initial requests and third-party data retrieval.</data>
    </node>
    <node id="3">
      <data key="d5">Integration RDS</data>
      <data key="d6">RDS</data>
      <data key="d7">PostgreSQL instance for integration metadata.</data>
    </node>
    <node id="4">
      <data key="d5">FHIR Service</data>
      <data key="d6">EC2</data>
      <data key="d7">WORKLOAD_PEEK: Standardizes healthcare data into the FHIR format.</data>
    </node>
    <node id="5">
      <data key="d5">FHIR RDS</data>
      <data key="d6">RDS</data>
      <data key="d7">DATA_PEEK: Postgres RDS storing standardized FHIR records.</data>
    </node>
    <node id="6">
      <data key="d5">AWS Storage Gateway</data>
      <data key="d6">StorageGateway</data>
      <data key="d7">Bridges local healthcare systems to mirror unstructured documents.</data>
    </node>
    <node id="7">
      <data key="d5">S3 Bucket</data>
      <data key="d6">S3</data>
      <data key="d7">DATA_PEEK: Stores raw and processed clinical documents.</data>
    </node>
    <node id="8">
      <data key="d5">SQS Queue</data>
      <data key="d6">SQS</data>
      <data key="d7">Orchestrates event-driven document processing.</data>
    </node>
    <node id="9">
      <data key="d5">Lambda Function</data>
      <data key="d6">Lambda</data>
      <data key="d7">WORKLOAD_PEEK: Processes queue messages to trigger metadata ingestion.</data>
    </node>
    <node id="10">
      <data key="d5">Document Service</data>
      <data key="d6">EC2</data>
      <data key="d7">WORKLOAD_PEEK: Microservice managing document metadata and content locations.</data>
    </node>
    <node id="11">
      <data key="d5">Document RDS</data>
      <data key="d6">RDS</data>
      <data key="d7">PostgreSQL instance storing document metadata.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">Clinicians log in and request patient records.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">Forwards requests to Integration Service.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="3" id="0">
      <data key="d8">0</data>
      <data key="d9">Stores temporary integration state.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="4" id="0">
      <data key="d8">0</data>
      <data key="d9">Forwards retrieved data for standardization.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="5" id="0">
      <data key="d8">0</data>
      <data key="d9">Stores standardized structured FHIR records.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <edge source="6" target="7" id="0">
      <data key="d8">1</data>
      <data key="d9">Mirrors local documents (discharge letters) into S3.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="7" target="8" id="0">
      <data key="d8">1</data>
      <data key="d9">Triggers processing event on object creation.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="8" target="9" id="0">
      <data key="d8">1</data>
      <data key="d9">Triggers Lambda processor.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="9" target="10" id="0">
      <data key="d8">1</data>
      <data key="d9">Calls Document Service to process ingested file.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="10" target="11" id="0">
      <data key="d8">1</data>
      <data key="d9">Persists document metadata.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <edge source="10" target="7" id="0">
      <data key="d8">1</data>
      <data key="d9">Saves processed clinical document to production S3 bucket.</data>
      <data key="d10">5</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">Kainos Multi-Tenant Healthcare Interoperability Platform</data>
    <data key="d1">https://www.youtube.com/watch?v=4WjXH8Wp0E4</data>
    <data key="d2">Microservices platform handling FHIR structured patient data and unstructured documents for 650,000 patients with 2,000 concurrent active care workers.</data>
    <data key="d3">data_ingestion, compute_intensive</data>
    <data key="d4">True</data>
  </graph>
</graphml>
