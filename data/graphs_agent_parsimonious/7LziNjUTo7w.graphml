<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Instructor</data>
      <data key="d6">UserConsumerDeveloper</data>
      <data key="d7">Initiates deployment of the training class environments.</data>
    </node>
    <node id="1">
      <data key="d5">CloudFormation</data>
      <data key="d6">CloudFormation</data>
      <data key="d7">Orchestrates environment resources and custom image creation.</data>
    </node>
    <node id="2">
      <data key="d5">Custom Resource Lambda</data>
      <data key="d6">Lambda</data>
      <data key="d7">Triggers Systems Manager within execution limits to configure AppStream images.</data>
    </node>
    <node id="3">
      <data key="d5">Systems Manager</data>
      <data key="d6">SystemsManager</data>
      <data key="d7">Executes remote configuration scripts on the EC2 instances.</data>
    </node>
    <node id="4">
      <data key="d5">License Server &amp; Script Executor</data>
      <data key="d6">EC2</data>
      <data key="d7">Executes image customization scripts and hosts application licensing.</data>
    </node>
    <node id="5">
      <data key="d5">Students</data>
      <data key="d6">UserConsumerWeb</data>
      <data key="d7">Access petrotechnical training applications directly via browser streaming URLs.</data>
    </node>
    <node id="6">
      <data key="d5">AppStream 2.0</data>
      <data key="d6">AppStream</data>
      <data key="d7">Streams GPU-intensive application sessions to student browsers.</data>
    </node>
    <node id="7">
      <data key="d5">FSx for Windows File Server</data>
      <data key="d6">FSX</data>
      <data key="d7">DATA_PEEK: Stores user project files mounted dynamically.</data>
    </node>
    <node id="8">
      <data key="d5">RDS SQL Express</data>
      <data key="d6">RDS</data>
      <data key="d7">Database running SQL Server Express to optimize licensing costs.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">Launches the CloudFormation stack.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">Invokes custom resource Lambda.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="6" id="0">
      <data key="d8">0</data>
      <data key="d9">Deploys final AppStream fleet and stack.</data>
      <data key="d10">6</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="3" id="0">
      <data key="d8">0</data>
      <data key="d9">Triggers Run Command.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="4" id="0">
      <data key="d8">0</data>
      <data key="d9">Executes script on EC2 instance.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="6" id="0">
      <data key="d8">0</data>
      <data key="d9">Remotes into Image Builder to configure session script.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">Sends success signal to CloudFormation wait condition.</data>
      <data key="d10">5</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="6" id="0">
      <data key="d8">1</data>
      <data key="d9">Connects to training application via web browser.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="6" target="4" id="0">
      <data key="d8">1</data>
      <data key="d9">Checks license server during session.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="6" target="7" id="0">
      <data key="d8">1</data>
      <data key="d9">Mounts storage folder dynamically.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="6" target="8" id="0">
      <data key="d8">1</data>
      <data key="d9">Connects to application database.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">Virtual Software Training with Amazon AppStream 2.0</data>
    <data key="d1">https://www.youtube.com/watch?v=7LziNjUTo7w</data>
    <data key="d2">Automates the provisioning of high-performance GPU virtual training environments for petrotechnical software using CloudFormation, Lambda, and AppStream 2.0.</data>
    <data key="d3">compute_intensive, interactive</data>
    <data key="d4">True</data>
  </graph>
</graphml>
