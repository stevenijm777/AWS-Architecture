<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Vizio Smart TVs</data>
      <data key="d6">UserConsumerTV</data>
      <data key="d7">WORKLOAD_PEEK: Millions of connected devices, billions of telemetry events (logs, performance, user data) per month.</data>
    </node>
    <node id="1">
      <data key="d5">Kinesis Data Streams</data>
      <data key="d6">Kinesis</data>
      <data key="d7">DATA_PEEK: Real-time ingestion front door configured with an 8-shard pipeline.</data>
    </node>
    <node id="2">
      <data key="d5">Kinesis Data Firehose</data>
      <data key="d6">Firehose</data>
      <data key="d7">Handles ingestion as-is without requiring upfront schema enforcement.</data>
    </node>
    <node id="3">
      <data key="d5">Amazon S3</data>
      <data key="d6">S3</data>
      <data key="d7">Long-term raw data store for future reuse, migration buffer, and historical archives.</data>
    </node>
    <node id="4">
      <data key="d5">Amazon Redshift</data>
      <data key="d6">RedShift</data>
      <data key="d7">Columnar data warehouse optimized for massive aggregations over billions of rows.</data>
    </node>
    <node id="5">
      <data key="d5">Amazon QuickSight</data>
      <data key="d6">QuickSight</data>
      <data key="d7">Provides interactive dashboards using Spice in-memory engine and custom SQL.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">Sends raw log, performance, and user telemetry directly to Kinesis.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">Pipes streaming data into Firehose.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="3" id="0">
      <data key="d8">0</data>
      <data key="d9">Persists raw data long-term in S3.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="4" id="0">
      <data key="d8">0</data>
      <data key="d9">Loads structured subsets into Redshift.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="5" id="0">
      <data key="d8">0</data>
      <data key="d9">Queries data via custom SQL into QuickSight Spice engine.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">Vizio Telemetry Analytics Pipeline</data>
    <data key="d1">https://www.youtube.com/watch?v=BlCXEMp_lqY</data>
    <data key="d2">Ingests billions of telemetry events monthly from millions of connected TVs. Uses Kinesis Streams and Firehose for real-time buffering, storing raw data long-term in S3, structured data in Redshift, and visualizing with QuickSight.</data>
    <data key="d3">data_ingestion, interactive</data>
    <data key="d4">True</data>
  </graph>
</graphml>
