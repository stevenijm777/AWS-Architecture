<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">iOS Client</data>
      <data key="d6">UserConsumerMobile</data>
      <data key="d7">Initiates snap upload requests.</data>
    </node>
    <node id="1">
      <data key="d5">Android Client</data>
      <data key="d6">UserConsumerMobile</data>
      <data key="d7">Receives notifications and retrieves snaps.</data>
    </node>
    <node id="2">
      <data key="d5">EKS API Gateway</data>
      <data key="d6">EKS</data>
      <data key="d7">Central ingress routing for active client sessions.</data>
    </node>
    <node id="3">
      <data key="d5">Media Delivery Service</data>
      <data key="d6">EKS</data>
      <data key="d7">Handles processing and routing of incoming snap media.</data>
    </node>
    <node id="4">
      <data key="d5">Friend Graph</data>
      <data key="d6">EKS</data>
      <data key="d7">Computes user relationships and delivery targets.</data>
    </node>
    <node id="5">
      <data key="d5">Snap DB</data>
      <data key="d6">EKS</data>
      <data key="d7">Custom caching/transaction layer to optimize DynamoDB workloads.</data>
    </node>
    <node id="6">
      <data key="d5">Messaging Connection Service</data>
      <data key="d6">EKS</data>
      <data key="d7">Manages persistent connections to clients for real-time delivery.</data>
    </node>
    <node id="7">
      <data key="d5">CloudFront CDN</data>
      <data key="d6">CloudFront</data>
      <data key="d7">Caches regional media closer to users for ultra-low latency retrieval.</data>
    </node>
    <node id="8">
      <data key="d5">Amazon S3</data>
      <data key="d6">S3</data>
      <data key="d7">Persistent object storage for ephemeral snap media files.</data>
    </node>
    <node id="9">
      <data key="d5">ElastiCache Redis</data>
      <data key="d6">ElastiCache</data>
      <data key="d7">Stores active server-to-client connection mappings.</data>
    </node>
    <node id="10">
      <data key="d5">Amazon DynamoDB</data>
      <data key="d6">DynamoDB</data>
      <data key="d7">DATA_PEEK: Stores 400TB+ metadata. Nightly scans read 2B rows/minute to prune expired data.</data>
    </node>
    <edge source="0" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">Sends snap request.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="3" id="0">
      <data key="d8">0</data>
      <data key="d9">Routes media upload request.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="6" id="0">
      <data key="d8">1</data>
      <data key="d9">Routes delivery request.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="7" id="0">
      <data key="d8">0</data>
      <data key="d9">Uploads snap media.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="4" id="0">
      <data key="d8">0</data>
      <data key="d9">Triggers friend distribution lookup.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="5" id="0">
      <data key="d8">0</data>
      <data key="d9">Passes metadata transaction.</data>
      <data key="d10">5</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="10" id="0">
      <data key="d8">0</data>
      <data key="d9">Writes snap metadata.</data>
      <data key="d10">6</data>
      <data key="d11">data</data>
    </edge>
    <edge source="6" target="9" id="0">
      <data key="d8">1</data>
      <data key="d9">Queries connection details.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="6" target="1" id="0">
      <data key="d8">1</data>
      <data key="d9">Pushes message payload.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="7" target="8" id="0">
      <data key="d8">0</data>
      <data key="d9">Persists media.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">Snapchat High-Scale Ephemeral Messaging Architecture</data>
    <data key="d1">https://www.youtube.com/watch?v=Cgv0kfp_6xQ</data>
    <data key="d2">Snap's backend runs across 900+ EKS clusters, serving over 300 million daily active users. Snap DB abstracts DynamoDB to handle TTL, transactions, and ephemeral logic.</data>
    <data key="d3">data_ingestion, compute_intensive</data>
    <data key="d4">True</data>
  </graph>
</graphml>
