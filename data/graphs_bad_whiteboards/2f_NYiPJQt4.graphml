<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d12" for="edge" attr.name="id" attr.type="string" />
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">DevOps Engineers</data>
      <data key="d6">UserCompanyDeveloper</data>
      <data key="d7">Appway's cloud automation team managing client accounts.</data>
    </node>
    <node id="1">
      <data key="d5">Management Console UI</data>
      <data key="d6">S3</data>
      <data key="d7">Hosts React-based single-page application.</data>
    </node>
    <node id="2">
      <data key="d5">Management API Gateway</data>
      <data key="d6">ApiGateway</data>
      <data key="d7">Receives calls from the management frontend.</data>
    </node>
    <node id="3">
      <data key="d5">Account Provisioner &amp; Deployment</data>
      <data key="d6">Lambda</data>
      <data key="d7">Executes DevOps tasks like creating accounts and software updates.</data>
    </node>
    <node id="4">
      <data key="d5">AWS Organizations</data>
      <data key="d6">Organizations</data>
      <data key="d7">Manages dedicated AWS accounts per customer.</data>
    </node>
    <node id="5">
      <data key="d5">AWS Control Tower</data>
      <data key="d6">ControlTower</data>
      <data key="d7">Enforces security policies and guardrails consistently.</data>
    </node>
    <node id="6">
      <data key="d5">Bank Staff / End Users</data>
      <data key="d6">UserCompanyAgent</data>
      <data key="d7">Users onboarding bank clients every 30 seconds.</data>
    </node>
    <node id="7">
      <data key="d5">Amazon Cognito</data>
      <data key="d6">Cognito</data>
      <data key="d7">Handles user auth, federated with AD/Okta if needed.</data>
    </node>
    <node id="8">
      <data key="d5">Application Load Balancer</data>
      <data key="d6">ALB</data>
      <data key="d7">Handles request routing and SSL offloading.</data>
    </node>
    <node id="9">
      <data key="d5">Appway Cluster Instances</data>
      <data key="d6">EC2</data>
      <data key="d7">Runs Java-based web application with Tomcat and Hazelcast.</data>
    </node>
    <node id="10">
      <data key="d5">Amazon EFS</data>
      <data key="d6">EFS</data>
      <data key="d7">Central cluster storage supporting growing data needs.</data>
    </node>
    <node id="11">
      <data key="d5">Site-to-Site VPN</data>
      <data key="d6">VPN</data>
      <data key="d7">Provides dedicated secure channel to customer network.</data>
    </node>
    <node id="12">
      <data key="d5">On-Premises Bank Systems</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">External systems such as core banking, AD/Okta, or document archives.</data>
    </node>
    <edge source="0" target="1">
      <data key="d8">0</data>
      <data key="d9">Developer loads management console web app.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="0" target="2">
      <data key="d8">0</data>
      <data key="d9">Invokes provisioning and update commands.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="1" target="0">
      <data key="d8">0</data>
      <data key="d9">UI is loaded in browser.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="2" target="3">
      <data key="d8">0</data>
      <data key="d9">Triggers administrative serverless functions.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="2" target="0">
      <data key="d8">0</data>
      <data key="d9">Returns operation confirmation.</data>
      <data key="d10">7</data>
      <data key="d11">meta</data>
      <data key="d12">0</data>
    </edge>
    <edge source="3" target="4">
      <data key="d8">0</data>
      <data key="d9">Sets up and manages dedicated tenant accounts.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="3" target="9">
      <data key="d8">0</data>
      <data key="d9">Applies software updates and configuration changes.</data>
      <data key="d10">5</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="5" target="4">
      <data key="d8">0</data>
      <data key="d9">Applies organization guardrails and policies.</data>
      <data key="d10">6</data>
      <data key="d11">meta</data>
      <data key="d12">0</data>
    </edge>
    <edge source="6" target="7">
      <data key="d8">1</data>
      <data key="d9">Logs in and requests authentication token.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="6" target="8">
      <data key="d8">1</data>
      <data key="d9">Accesses Appway cluster application.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="7" target="6">
      <data key="d8">1</data>
      <data key="d9">Returns token.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="8" target="9">
      <data key="d8">1</data>
      <data key="d9">Routes traffic to active EC2 instances.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="8" target="6">
      <data key="d8">1</data>
      <data key="d9">Delivers dynamic content back to the end-user.</data>
      <data key="d10">10</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="9" target="10">
      <data key="d8">1</data>
      <data key="d9">Reads and writes to shared cluster file system.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="9" target="11">
      <data key="d8">1</data>
      <data key="d9">Routes on-premise requests securely.</data>
      <data key="d10">5</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="9" target="8">
      <data key="d8">1</data>
      <data key="d9">Sends application response back to load balancer.</data>
      <data key="d10">9</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="11" target="12">
      <data key="d8">1</data>
      <data key="d9">Connects to bank's core system / IdP.</data>
      <data key="d10">6</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="11" target="9">
      <data key="d8">1</data>
      <data key="d9">Passes data back to Appway application.</data>
      <data key="d10">8</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="12" target="11">
      <data key="d8">1</data>
      <data key="d9">Returns sensitive data/identity confirmations.</data>
      <data key="d10">7</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <data key="d0">Appway: Securing Sensitive Banking Workflows with Isolated Architecture on AWS</data>
    <data key="d1">https://www.youtube.com/watch?v=2f_NYiPJQt4</data>
    <data key="d2">Ensures strong customer isolation using AWS Organizations for single-tenant accounts per client. Appway operates as a multi-node Tomcat cluster in ASG using Hazelcast for synchronization and EFS for shared cluster storage.</data>
    <data key="d3">compute_intensive, interactive</data>
    <data key="d4">True</data>
  </graph>
</graphml>
