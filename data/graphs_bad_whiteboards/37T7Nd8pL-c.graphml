<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d12" for="edge" attr.name="id" attr.type="string" />
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">E-Learning Creators</data>
      <data key="d6">UserConsumerWebMobile</data>
      <data key="d7">Upload business documents, scientific papers, or presentations.</data>
    </node>
    <node id="1">
      <data key="d5">Input S3 Bucket</data>
      <data key="d6">S3</data>
      <data key="d7">Stores uploaded raw PDFs and intermediate converted images.</data>
    </node>
    <node id="2">
      <data key="d5">Main Event Bus</data>
      <data key="d6">EventBridge</data>
      <data key="d7">Handles decoupled asynchronous communication across the application.</data>
    </node>
    <node id="3">
      <data key="d5">Processing Orchestrator</data>
      <data key="d6">StepFunctions</data>
      <data key="d7">State machine that manages the lifecycle and sequencing of document clean-up tasks.</data>
    </node>
    <node id="4">
      <data key="d5">Page-to-Image Converter</data>
      <data key="d6">Lambda</data>
      <data key="d7">Converts each page of the document into a separate image.</data>
    </node>
    <node id="5">
      <data key="d5">SageMaker Real-Time Endpoint</data>
      <data key="d6">SageMaker</data>
      <data key="d7">Hosts custom ML model to recognize page structure and layout.</data>
    </node>
    <node id="6">
      <data key="d5">Amazon Textract</data>
      <data key="d6">Textract</data>
      <data key="d7">Extracts text content and raw structures from documents.</data>
    </node>
    <node id="7">
      <data key="d5">Post-Processor</data>
      <data key="d6">Lambda</data>
      <data key="d7">Validates reading order, performs semantic analysis, and filters noise.</data>
    </node>
    <edge source="0" target="1">
      <data key="d8">0</data>
      <data key="d9">Uploads PDF documents.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="1" target="2">
      <data key="d8">0</data>
      <data key="d9">Triggers file upload event.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="2" target="3">
      <data key="d8">0</data>
      <data key="d9">Triggers state machine execution.</data>
      <data key="d10">2</data>
      <data key="d11">meta</data>
      <data key="d12">0</data>
    </edge>
    <edge source="2" target="0">
      <data key="d8">1</data>
      <data key="d9">Notifies the creator system that clean document is ready.</data>
      <data key="d10">6</data>
      <data key="d11">meta</data>
      <data key="d12">0</data>
    </edge>
    <edge source="3" target="4">
      <data key="d8">1</data>
      <data key="d9">Invokes page conversion task.</data>
      <data key="d10">0</data>
      <data key="d11">meta</data>
      <data key="d12">0</data>
    </edge>
    <edge source="3" target="5">
      <data key="d8">1</data>
      <data key="d9">Sends page images for layout analysis.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="3" target="6">
      <data key="d8">1</data>
      <data key="d9">Calls managed text extraction.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="3" target="7">
      <data key="d8">1</data>
      <data key="d9">Triggers semantic analyzer.</data>
      <data key="d10">4</data>
      <data key="d11">meta</data>
      <data key="d12">0</data>
    </edge>
    <edge source="4" target="1">
      <data key="d8">1</data>
      <data key="d9">Stores converted page images.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="7" target="2">
      <data key="d8">1</data>
      <data key="d9">Sends event signifying processing completion.</data>
      <data key="d10">5</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <data key="d0">Docebo: How to Create Compelling e-Learning Videos from Documents via AI ML Services</data>
    <data key="d1">https://www.youtube.com/watch?v=37T7Nd8pL-c</data>
    <data key="d2">Handles 10-20 complex documents a day, processing 30-50 pages per minute. Successfully reduces document noise by about 80% to generate bite-sized e-learning courses.</data>
    <data key="d3">data_ingestion, compute_intensive</data>
    <data key="d4">True</data>
  </graph>
</graphml>
