  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">NHS Clinicians &amp; Care Workers</data>
      <data key="d6">UserConsumerHospital</data>
      <data key="d7">WORKLOAD_PEEK: 10,000 total users, 2,000 active concurrent users accessing patient records.</data>
    </node>
    <node id="1">
      <data key="d5">AWS Direct Connect</data>
      <data key="d6">DirectConnect</data>
      <data key="d7">Provides secure network ingestion from the NHS N3 network into AWS.</data>
    </node>
    <node id="2">
      <data key="d5">Integration Engine Microservice</data>
      <data key="d6">EC2</data>
      <data key="d7">Orchestrates microservice workflows and coordinates queries to external healthcare silos.</data>
    </node>
    <node id="3">
      <data key="d5">NHS External Systems</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Siloed healthcare systems containing external patient databases.</data>
    </node>
    <node id="4">
      <data key="d5">FHIR Service Microservice</data>
      <data key="d6">EC2</data>
      <data key="d7">Standardizes raw data inputs into standard HL7 FHIR records.</data>
    </node>
    <node id="5">
      <data key="d5">Amazon RDS PostgreSQL</data>
      <data key="d6">RDS</data>
      <data key="d7">DATA_PEEK: Stores normalized patient FHIR data models and unstructured document metadata.</data>
    </node>
    <node id="6">
      <data key="d5">AWS Storage Gateway</data>
      <data key="d6">StorageGateway</data>
      <data key="d7">Bridges on-premises hospital environments to replicate local files to AWS.</data>
    </node>
    <node id="7">
      <data key="d5">Amazon S3</data>
      <data key="d6">S3</data>
      <data key="d7">Stores both raw incoming document content and final standardized patient letters/summaries.</data>
    </node>
    <node id="8">
      <data key="d5">Amazon SQS</data>
      <data key="d6">SQS</data>
      <data key="d7">Acts as a message buffer and orchestrator for raw document ingestion events.</data>
    </node>
    <node id="9">
      <data key="d5">Ingestion Lambda</data>
      <data key="d6">Lambda</data>
      <data key="d7">Processes document metadata extraction and handles orchestration steps.</data>
    </node>
    <node id="10">
      <data key="d5">Document Service Microservice</data>
      <data key="d6">EC2</data>
      <data key="d7">Manages patient document content and associates metadata records.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">User queries patient file over secure N3 network.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="0" target="1" id="1">
      <data key="d8">2</data>
      <data key="d9">User requests patient document view.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">Route request to internal Integration Engine.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="0" id="0">
      <data key="d8">0</data>
      <data key="d9">Deliver the standardized patient record view.</data>
      <data key="d10">9</data>
      <data key="d11">data</data>
