    <edge source="2" target="3" id="0">
      <data key="d8">0</data>
      <data key="d9">Query patient clinical data across external silos.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="4" id="0">
      <data key="d8">0</data>
      <data key="d9">Forward raw data to FHIR standardization service.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">Transmit medical view payload back.</data>
      <data key="d10">8</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">Return external record content to integration engine.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="5" id="0">
      <data key="d8">0</data>
      <data key="d9">Persist standardized FHIR data in PostgreSQL.</data>
      <data key="d10">5</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">Hand off clean medical record structure to Integration Engine.</data>
      <data key="d10">7</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="4" id="0">
      <data key="d8">0</data>
      <data key="d9">Return confirmed patient structured profile.</data>
      <data key="d10">6</data>
      <data key="d11">data</data>
    </edge>
    <edge source="6" target="7" id="0">
      <data key="d8">1</data>
      <data key="d9">Mirror local clinical documents to raw S3 bucket.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="7" target="8" id="0">
      <data key="d8">1</data>
      <data key="d9">Trigger S3 upload notification to SQS queue.</data>
      <data key="d10">1</data>
      <data key="d11">meta</data>
