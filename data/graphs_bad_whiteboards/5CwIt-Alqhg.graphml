  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">IoT Sensors</data>
      <data key="d6">UserConsumerIOT</data>
      <data key="d7">Monitors shipping conditions such as temperature on farms and trucks.</data>
    </node>
    <node id="1">
      <data key="d5">AWS IoT Core</data>
      <data key="d6">IoTCore</data>
      <data key="d7">Ingests high-volume telemetry securely from edge devices.</data>
    </node>
    <node id="2">
      <data key="d5">Threshold Processor</data>
      <data key="d6">Lambda</data>
      <data key="d7">Evaluates incoming data points against predefined safety rules.</data>
    </node>
    <node id="3">
      <data key="d5">Application Load Balancer</data>
      <data key="d6">ELB</data>
      <data key="d7">Balances requests to the private blockchain network.</data>
    </node>
    <node id="4">
      <data key="d5">Hyperledger Fabric EKS Cluster</data>
      <data key="d6">EKS</data>
      <data key="d7">Runs containerized blockchain nodes and smart contracts.</data>
    </node>
    <node id="5">
      <data key="d5">Off-Chain Datastore</data>
      <data key="d6">DynamoDB</data>
      <data key="d7">DATA_PEEK: Real-time cache of blockchain ledger data for high-performance reads.</data>
    </node>
    <node id="6">
      <data key="d5">Supply Chain Managers</data>
      <data key="d6">UserCompanyAnalyst</data>
      <data key="d7">Views real-time analytics dashboards for shipment tracking.</data>
    </node>
    <node id="7">
      <data key="d5">Alert Notifications</data>
      <data key="d6">SNS</data>
      <data key="d7">Triggers push notifications when thresholds are crossed.</data>
    </node>
    <node id="8">
      <data key="d5">Truck Driver</data>
      <data key="d6">UserCompanyAgent</data>
      <data key="d7">Receives rerouting notifications in case of shipment spoilage.</data>
    </node>
    <node id="9">
      <data key="d5">CloudHSM</data>
      <data key="d6">CloudHSM</data>
      <data key="d7">Secures cryptographic keys and integrates with on-premise HSMs.</data>
    </node>
    <node id="10">
      <data key="d5">CloudWatch</data>
      <data key="d6">CloudWatch</data>
      <data key="d7">Monitors EKS containers and tracks ledger health.</data>
    </node>
