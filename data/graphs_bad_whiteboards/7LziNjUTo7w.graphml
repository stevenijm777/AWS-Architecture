  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Instructor</data>
      <data key="d6">UserCompanyAgent</data>
      <data key="d7">Triggers environment setup using CloudFormation.</data>
    </node>
    <node id="1">
      <data key="d5">CloudFormation</data>
      <data key="d6">CloudFormation</data>
      <data key="d7">Orchestrates creation of RDS, FSx, and AppStream resources.</data>
    </node>
    <node id="2">
      <data key="d5">Lambda</data>
      <data key="d6">Lambda</data>
      <data key="d7">Triggered by Custom Resource to initiate configuration.</data>
    </node>
    <node id="3">
      <data key="d5">Systems Manager</data>
      <data key="d6">SystemsManager</data>
      <data key="d7">Executes remote configuration command on EC2.</data>
    </node>
    <node id="4">
      <data key="d5">EC2 / License Server</data>
      <data key="d6">EC2</data>
      <data key="d7">Acts as the license server and executes the session-mount configuration scripts.</data>
    </node>
    <node id="5">
      <data key="d5">AppStream 2.0</data>
      <data key="d6">AppStream</data>
      <data key="d7">Delivers petrotechnical software to students via browser streams.</data>
    </node>
    <node id="6">
      <data key="d5">FSx</data>
      <data key="d6">FSX</data>
      <data key="d7">Stores project files, dynamically mounted to student sessions.</data>
    </node>
    <node id="7">
      <data key="d5">RDS SQL Express</data>
      <data key="d6">RDS</data>
      <data key="d7">Low-cost SQL Express database for training session metadata.</data>
    </node>
    <node id="8">
      <data key="d5">Student</data>
      <data key="d6">UserConsumerWeb</data>
      <data key="d7">Accesses the software training environment via web browser.</data>
    </node>
    <edge source="0" target="1">
      <data key="d8">0</data>
