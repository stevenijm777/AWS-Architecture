<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d12" for="edge" attr.name="id" attr.type="string" />
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Clients</data>
      <data key="d6">UserConsumerWeb</data>
      <data key="d7">Clients accessing their dedicated data storage buckets.</data>
    </node>
    <node id="1">
      <data key="d5">Client S3 Buckets</data>
      <data key="d6">S3</data>
      <data key="d7">Individual S3 buckets where data is shared with respective clients.</data>
    </node>
    <node id="2">
      <data key="d5">S3 Access Logs Bucket</data>
      <data key="d6">S3</data>
      <data key="d7">DATA_PEEK: Centralized bucket receiving access logs from all individual client buckets.</data>
    </node>
    <node id="3">
      <data key="d5">Log Parser &amp; Enricher Lambda</data>
      <data key="d6">Lambda</data>
      <data key="d7">WORKLOAD_PEEK: Processes 18-20 million logs per month. Parses S3 access logs, maps IP addresses to country numeric IDs via a geolocation database, and appends custom metadata like client name.</data>
    </node>
    <node id="4">
      <data key="d5">Amazon Elasticsearch Service</data>
      <data key="d6">OpenSearch</data>
      <data key="d7">Uses built-in anomaly detector feature to build historical access models per client and detect unusual access patterns or origin country changes.</data>
    </node>
    <node id="5">
      <data key="d5">AWS SNS</data>
      <data key="d6">SNS</data>
      <data key="d7">Sends real-time email notifications when anomalies are detected.</data>
    </node>
    <node id="6">
      <data key="d5">Service Team</data>
      <data key="d6">UserCompanyAnalyst</data>
      <data key="d7">Receives email alerts and performs investigations on anomalous access activities.</data>
    </node>
    <edge source="0" target="1">
      <data key="d8">0</data>
      <data key="d9">Clients access their data.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="1" target="2">
      <data key="d8">0</data>
      <data key="d9">Access triggers server access logs delivered to log bucket.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="2" target="3">
      <data key="d8">1</data>
      <data key="d9">Log object creation triggers Lambda function.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="3" target="4">
      <data key="d8">1</data>
      <data key="d9">Lambda inserts enriched log records into Elasticsearch.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="4" target="5">
      <data key="d8">1</data>
      <data key="d9">Anomaly detector triggers SNS alert upon suspicious activity.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="5" target="6">
      <data key="d8">1</data>
      <data key="d9">SNS delivers email notification to the service team.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <data key="d0">Mobilewalla: S3 Access Monitoring Using ML</data>
    <data key="d1">https://www.youtube.com/watch?v=8s0wGRkiDrw</data>
    <data key="d2">A near real-time anomaly detection system built on AWS to monitor data access patterns of clients. It processes 18-20 million access log records per month, utilizing Lambda to enrich logs and Amazon Elasticsearch (OpenSearch) anomaly detector to learn patterns and spot anomalies like compromised keys or unusual geo-locations.</data>
    <data key="d3">data_ingestion, control</data>
    <data key="d4">True</data>
  </graph>
</graphml>
