<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d12" for="edge" attr.name="id" attr.type="string" />
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Internal Developer</data>
      <data key="d6">UserCompanyDeveloper</data>
      <data key="d7">Requests new AWS accounts through a self-developed web portal.</data>
    </node>
    <node id="1">
      <data key="d5">API Gateway</data>
      <data key="d6">ApiGateway</data>
      <data key="d7">Receives the portal metadata and routes requests.</data>
    </node>
    <node id="2">
      <data key="d5">Step Functions (AVM)</data>
      <data key="d6">StepFunctions</data>
      <data key="d7">Account Vending Machine orchestrating account provisioning steps.</data>
    </node>
    <node id="3">
      <data key="d5">DynamoDB</data>
      <data key="d6">DynamoDB</data>
      <data key="d7">DATA_PEEK: Stores target state, CIDR ranges, and account IDs to ensure idempotency.</data>
    </node>
    <node id="4">
      <data key="d5">Control Tower</data>
      <data key="d6">ControlTower</data>
      <data key="d7">Provisions new accounts via a custom Service Catalog item.</data>
    </node>
    <node id="5">
      <data key="d5">Step Functions (Blueprint)</data>
      <data key="d6">StepFunctions</data>
      <data key="d7">Deploys customized blueprints (IAM, security, network configurations).</data>
    </node>
    <node id="6">
      <data key="d5">SES Email Service</data>
      <data key="d6">SES</data>
      <data key="d7">Sends details and responsibilities to the account owner.</data>
    </node>
    <node id="7">
      <data key="d5">Vended AWS Account</data>
      <data key="d6">Organizations</data>
      <data key="d7">The target environment deployed for internal teams.</data>
    </node>
    <node id="8">
      <data key="d5">CodePipeline</data>
      <data key="d6">CodePipeline</data>
      <data key="d7">Deploys blueprint changes centrally to customer accounts within 3 hours.</data>
    </node>
    <edge source="0" target="1">
      <data key="d8">0</data>
      <data key="d9">User submits network configurations and metadata.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="1" target="2">
      <data key="d8">0</data>
      <data key="d9">Triggers Account Vending Machine workflow.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="2" target="3">
      <data key="d8">0</data>
      <data key="d9">Saves state and fetches CIDR block ranges.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="2" target="4">
      <data key="d8">0</data>
      <data key="d9">Launches custom service catalog item to provision account.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="2" target="5">
      <data key="d8">0</data>
      <data key="d9">Initiates blueprint application stage.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="5" target="7">
      <data key="d8">0</data>
      <data key="d9">Applies IAM, security, and networking configs to the account.</data>
      <data key="d10">5</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="5" target="6">
      <data key="d8">0</data>
      <data key="d9">Triggers email notification upon completion.</data>
      <data key="d10">6</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="6" target="0">
      <data key="d8">0</data>
      <data key="d9">Delivers account details to developer.</data>
      <data key="d10">7</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="8" target="7">
      <data key="d8">1</data>
      <data key="d9">Pushes updated blueprints directly across dev, QA, and prod accounts.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <data key="d0">Vitesco Technologies Cloud Foundation: A Scalable and Automated Cloud Landing Zone</data>
    <data key="d1">https://www.youtube.com/watch?v=9-a9Y5THTYo</data>
    <data key="d2">Automated cloud lending zone allowing internal users to create AWS accounts. Scale: Over 850 accounts created. Platform managed by only four engineers using automated blueprints.</data>
    <data key="d3">control</data>
    <data key="d4">True</data>
  </graph>
</graphml>
