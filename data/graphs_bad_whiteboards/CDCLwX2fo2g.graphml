<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">E-commerce Customers</data>
      <data key="d6">UserConsumerWeb</data>
      <data key="d7">Over 250,000 users accessing website.</data>
    </node>
    <node id="1">
      <data key="d5">CloudWatch Scheduler</data>
      <data key="d6">CloudWatch</data>
      <data key="d7">Schedules daily ML model training.</data>
    </node>
    <node id="2">
      <data key="d5">P2 Training Instance</data>
      <data key="d6">EC2</data>
      <data key="d7">WORKLOAD_PEEK: Retrains ML model daily.</data>
    </node>
    <node id="3">
      <data key="d5">Recommendations DB</data>
      <data key="d6">DynamoDB</data>
      <data key="d7">DATA_PEEK: Stores precomputed user recommendations. Configured with auto-scaling.</data>
    </node>
    <node id="4">
      <data key="d5">Load Balancer</data>
      <data key="d6">ELB</data>
      <data key="d7">Distributes frontend incoming traffic.</data>
    </node>
    <node id="5">
      <data key="d5">Fargate Microservices API</data>
      <data key="d6">ECS</data>
      <data key="d7">Runs API containers under Fargate. Auto-scales based on traffic.</data>
    </node>
    <node id="6">
      <data key="d5">Model Bucket</data>
      <data key="d6">S3</data>
      <data key="d7">DATA_PEEK: Stores trained model artifacts.</data>
    </node>
    <edge source="0" target="4" id="0">
      <data key="d8">1</data>
      <data key="d9">Requests website content</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">Triggers daily retraining</data>
      <data key="d10">0</data>
      <data key="d11">meta</data>
    </edge>
    <edge source="1" target="2" id="1">
      <data key="d8">2</data>
      <data key="d9">Daily trigger</data>
      <data key="d10">0</data>
      <data key="d11">meta</data>
    </edge>
    <edge source="2" target="3" id="0">
      <data key="d8">0</data>
      <data key="d9">Writes precomputed recommendations per user</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="6" id="0">
      <data key="d8">2</data>
      <data key="d9">Uploads new ML model file</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="5" id="0">
      <data key="d8">2</data>
      <data key="d9">Triggers ECS Rolling Deployment</data>
      <data key="d10">2</data>
      <data key="d11">meta</data>
    </edge>
    <edge source="3" target="5" id="0">
      <data key="d8">1</data>
      <data key="d9">Returns recommendation data</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="5" id="0">
      <data key="d8">1</data>
      <data key="d9">Passes user context and ID</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="0" id="0">
      <data key="d8">1</data>
      <data key="d9">Displays recommended products</data>
      <data key="d10">5</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="3" id="0">
      <data key="d8">1</data>
      <data key="d9">Fetches recommendations using User ID</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="4" id="0">
      <data key="d8">1</data>
      <data key="d9">Sends API response</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="6" id="0">
      <data key="d8">2</data>
      <data key="d9">New tasks load trained model artifact on startup</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">Ztore: Building a Recommendation System on AWS (Cantonese)</data>
    <data key="d1">https://www.youtube.com/watch?v=CDCLwX2fo2g</data>
    <data key="d2">E-commerce recommendation engine scaling to 100x current traffic. Uses DynamoDB and ECS Fargate for auto-scaling capabilities.</data>
    <data key="d3">compute_intensive, interactive</data>
    <data key="d4">True</data>
  </graph>
