<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d12" for="edge" attr.name="id" attr.type="string" />
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Customer Mobile Phone</data>
      <data key="d6">UserConsumerMobile</data>
      <data key="d7">End-user device for navigating the Zulily app.</data>
    </node>
    <node id="1">
      <data key="d5">Clickstream Pipeline</data>
      <data key="d6">Kinesis</data>
      <data key="d7">DATA_PEEK: Records all customer interactions (page views, clicks) from the mobile app.</data>
    </node>
    <node id="2">
      <data key="d5">Search Keyword Filter</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Filters out specific search keywords from the massive clickstream dataset in real-time using a simple SQL statement. WORKLOAD_PEEK: Serverless and scales automatically.</data>
    </node>
    <node id="3">
      <data key="d5">Search Keywords Stream</data>
      <data key="d6">Kinesis</data>
      <data key="d7">Receives filtered search keywords from Kinesis Data Analytics.</data>
    </node>
    <node id="4">
      <data key="d5">Transformer Lambda</data>
      <data key="d6">Lambda</data>
      <data key="d7">Transforms search keywords into corresponding brands and product categories. WORKLOAD_PEEK: For every search keyword, it calls the internal Search API and then writes to DocumentDB.</data>
    </node>
    <node id="5">
      <data key="d5">Internal Search API</data>
      <data key="d6">ApiGateway</data>
      <data key="d7">An internal Zulily API endpoint that provides related brands and product categories for a given search keyword. Called by the Transformer Lambda.</data>
    </node>
    <node id="6">
      <data key="d5">Search Suggestion Data Store</data>
      <data key="d6">DocumentDB</data>
      <data key="d7">DATA_PEEK: Stores search suggestion documents, approximately 650 million documents. WORKLOAD_PEEK: Handles less than 1000 Transactions Per Second (TPS). Has a 7-day TTL (Time To Live) on documents. Configured with 3 Availability Zones (primary and two replicas).</data>
    </node>
    <node id="7">
      <data key="d5">Scheduler/Reader Lambda</data>
      <data key="d6">Lambda</data>
      <data key="d7">Runs on a schedule (every X minutes) to pull data from DocumentDB. WORKLOAD_PEEK: Performs a lookup against the Inventory API for every search keyword, brand, and product category to ensure products are in stock before suggesting them. Writes processed data to ElastiCache for Redis.</data>
    </node>
    <node id="8">
      <data key="d5">Internal Inventory API</data>
      <data key="d6">ApiGateway</data>
      <data key="d7">An internal Zulily API endpoint to check if products are in stock. Crucial for Zulily's business model where products rotate frequently (typically available for up to 72 hours). Called by the Scheduler/Reader Lambda.</data>
    </node>
    <node id="9">
      <data key="d5">Search Suggestions Cache (Redis)</data>
      <data key="d6">ElastiCache</data>
      <data key="d7">Stores finalized search suggestions, ensuring high-speed retrieval for the customer-facing search API. Implemented using Redis.</data>
    </node>
    <node id="10">
      <data key="d5">Customer Search API</data>
      <data key="d6">ApiGateway</data>
      <data key="d7">The public-facing API endpoint that serves search suggestions to customers on their mobile devices by retrieving data from ElastiCache.</data>
    </node>
    <edge source="0" target="1">
      <data key="d8">0</data>
      <data key="d9">Customer app navigation and clicks are recorded</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="0" target="10">
      <data key="d8">3</data>
      <data key="d9">Customer initiates a search request from the mobile app</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="1" target="2">
      <data key="d8">0</data>
      <data key="d9">Clickstream data is filtered for search events</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="2" target="3">
      <data key="d8">0</data>
      <data key="d9">Filtered search keywords are written to a new stream</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="3" target="4">
      <data key="d8">1</data>
      <data key="d9">Search keywords are consumed for transformation</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="4" target="5">
      <data key="d8">1</data>
      <data key="d9">Lambda calls the internal Search API for related brands and categories</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="4" target="6">
      <data key="d8">1</data>
      <data key="d9">Transformed search suggestion document is written to DocumentDB</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="6" target="7">
      <data key="d8">2</data>
      <data key="d9">Scheduler/Reader Lambda pulls data from DocumentDB on a schedule</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="7" target="8">
      <data key="d8">2</data>
      <data key="d9">Lambda performs lookup against internal Inventory API</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="7" target="9">
      <data key="d8">2</data>
      <data key="d9">Processed and validated data is written to ElastiCache</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="9" target="10">
      <data key="d8">3</data>
      <data key="d9">ElastiCache returns search suggestions to the Customer Search API</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="10" target="9">
      <data key="d8">3</data>
      <data key="d9">Customer Search API fetches suggestions from ElastiCache</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="10" target="0">
      <data key="d8">3</data>
      <data key="d9">Customer Search API returns results to the mobile app</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <data key="d0">Zulily: A Compelling Suggestive Search Experience Using Amazon DocumentDB with MongoDB Compatibility</data>
    <data key="d1">https://www.youtube.com/watch?v=Ccutfm_Srzw</data>
    <data key="d2">Zulily's architecture for a suggestive search experience, inspired by customer app navigation and clickstream data. The solution uses serverless components for real-time filtering and transformation, a DocumentDB for persistent storage of search suggestions, and ElastiCache for fast retrieval for customer-facing APIs. Key design decisions include focusing on business logic over database management by choosing DocumentDB (managed service) due to team familiarity with MongoDB.</data>
    <data key="d3">data_ingestion, interactive, compute_intensive</data>
    <data key="d4">True</data>
  </graph>
</graphml>
