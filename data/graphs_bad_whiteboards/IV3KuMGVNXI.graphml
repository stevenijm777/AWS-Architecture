<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d12" for="edge" attr.name="id" attr.type="string" />
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Deep Instinct Agent</data>
      <data key="d6">UserCompanyAgent</data>
      <data key="d7">WORKLOAD_PEEK: Millions of agents, making hundreds of millions of requests daily. Uses signed requests with unique identifiers to CloudFront for security and identification.</data>
    </node>
    <node id="1">
      <data key="d5">Deep Instinct CDN</data>
      <data key="d6">CloudFront</data>
      <data key="d7">Provides information and updates to agents. Acts as the primary entry point for agent requests. Caches content from S3 and triggers Lambda@Edge functions on viewer request and origin response events.</data>
    </node>
    <node id="2">
      <data key="d5">Viewer Request Handler</data>
      <data key="d6">LambdaAtEdge</data>
      <data key="d7">WORKLOAD_PEEK: Triggered on every viewer request. Key functions include: capturing real-time statistics, reading unique agent identifiers from signed requests, handling rate limiting, and managing rolling upgrade logic (e.g., checking for updates, potentially short-circuiting responses to agents).</data>
    </node>
    <node id="3">
      <data key="d5">Real-time Statistics DB</data>
      <data key="d6">DynamoDB</data>
      <data key="d7">DATA_PEEK: Stores real-time statistics collected from agent requests. Chosen for its ease of use, simplicity, and flexibility to change data models on the fly without hindrance for statistics processing.</data>
    </node>
    <node id="4">
      <data key="d5">Agent Upgrade &amp; State DB</data>
      <data key="d6">DynamoDB</data>
      <data key="d7">DATA_PEEK: Stores state information for agent rolling upgrades and specific agent configurations. Used by both Viewer Request and Origin Response Lambda@Edge functions to track and control update distribution.</data>
    </node>
    <node id="5">
      <data key="d5">Content and Upgrade Files Origin</data>
      <data key="d6">S3</data>
      <data key="d7">DATA_PEEK: Stores static agent information and upgrade packages. Serves as the origin for CloudFront, providing the base content before any Lambda@Edge modifications.</data>
    </node>
    <node id="6">
      <data key="d5">Origin Response Modifier</data>
      <data key="d6">LambdaAtEdge</data>
      <data key="d7">WORKLOAD_PEEK: Triggered on the origin response event. Reads agent-specific state from DynamoDB (e.g., unique identifier, requested file, update status) to manipulate the content received from S3 before it is delivered to the agent. This enables gradual rollouts and tailored updates for different customers.</data>
    </node>
    <edge source="0" target="1">
      <data key="d8">0</data>
      <data key="d9">Agent sends signed request with unique identifier for content or update.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="1" target="2">
      <data key="d8">0</data>
      <data key="d9">CloudFront triggers Lambda@Edge (Viewer Request) on incoming request.</data>
      <data key="d10">1</data>
      <data key="d11">meta</data>
      <data key="d12">0</data>
    </edge>
    <edge source="1" target="5">
      <data key="d8">0</data>
      <data key="d9">If not short-circuited, CloudFront forwards request to S3 origin for content/update.</data>
      <data key="d10">5</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="1" target="6">
      <data key="d8">0</data>
      <data key="d9">CloudFront triggers Lambda@Edge (Origin Response) on receiving content from origin.</data>
      <data key="d10">7</data>
      <data key="d11">meta</data>
      <data key="d12">0</data>
    </edge>
    <edge source="1" target="0">
      <data key="d8">0</data>
      <data key="d9">CloudFront delivers the (potentially modified) content or update to the agent.</data>
      <data key="d10">9</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="2" target="3">
      <data key="d8">0</data>
      <data key="d9">Lambda@Edge injects real-time statistics (including agent ID) into DynamoDB.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="2" target="4">
      <data key="d8">0</data>
      <data key="d9">Lambda@Edge logs agent upgrade request and state for tracking rolling upgrades.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="2" target="0">
      <data key="d8">0</data>
      <data key="d9">Conditional: Lambda@Edge sends short-circuited response to agent if no update is available.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="5" target="1">
      <data key="d8">0</data>
      <data key="d9">S3 provides the requested content or update files to CloudFront.</data>
      <data key="d10">6</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="6" target="4">
      <data key="d8">0</data>
      <data key="d9">Lambda@Edge retrieves agent-specific state from DynamoDB for content manipulation.</data>
      <data key="d10">8</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <data key="d0">Deep Instinct: Collecting RT Statistics and Applying RT Decisions with Lambda@Edge</data>
    <data key="d1">https://www.youtube.com/watch?v=IV3KuMGVNXI</data>
    <data key="d2">Deep Instinct leverages AWS to provide real-time zero-day attack prevention to millions of client agents. The architecture focuses on efficient content delivery (agent information, upgrades) and real-time statistics collection using CloudFront, Lambda@Edge, and DynamoDB. Key design decisions include using Lambda@Edge for both viewer request and origin response events to gather real-time data, manage agent rollouts, and customize content based on unique agent identifiers. DynamoDB is chosen for its flexibility in real-time statistics and agent state management.</data>
    <data key="d3">data_ingestion, interactive, compute_intensive, control</data>
    <data key="d4">True</data>
  </graph>
</graphml>
