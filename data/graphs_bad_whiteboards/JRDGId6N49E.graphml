<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d12" for="edge" attr.name="id" attr.type="string" />
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Object Recognition Team</data>
      <data key="d6">UserCompanyDeveloper</data>
      <data key="d7">WORKLOAD_PEEK: Requires high performance compute and storage for massive machine learning training for object recognition.</data>
    </node>
    <node id="1">
      <data key="d5">EC2 P3 Instances (Region 1)</data>
      <data key="d6">EC2</data>
      <data key="d7">WORKLOAD_PEEK: High performance compute cluster utilizing NVIDIA V100 chips, configured in an EC2 Placement Group for massive ML training workloads.</data>
    </node>
    <node id="2">
      <data key="d5">FSx for Luster (Region 1)</data>
      <data key="d6">FSX</data>
      <data key="d7">DATA_PEEK: High performance data storage solution for massive ML training requirements, providing the necessary throughput and low latency.</data>
    </node>
    <node id="3">
      <data key="d5">S3 Bucket (Region 1)</data>
      <data key="d6">S3</data>
      <data key="d7">DATA_PEEK: Stores training data, intermediate results, and final models. Configured for S3 cross-region replication to Region 2.</data>
    </node>
    <node id="4">
      <data key="d5">S3 Bucket (Region 2)</data>
      <data key="d6">S3</data>
      <data key="d7">DATA_PEEK: Receives replicated data from S3 Bucket (Region 1). Used as data source/sink for ML training workloads in Region 2.</data>
    </node>
    <node id="5">
      <data key="d5">CloudFormation</data>
      <data key="d6">CloudFormation</data>
      <data key="d7">WORKLOAD_PEEK: Used to programmatically spin up an entire ML cluster (EC2 and FSx for Luster) in Region 2 when compute resources in Region 1 are exhausted, ensuring scalability and resource availability.</data>
    </node>
    <node id="6">
      <data key="d5">EC2 P3 Instances (Region 2)</data>
      <data key="d6">EC2</data>
      <data key="d7">WORKLOAD_PEEK: High performance compute cluster provisioned by CloudFormation in Region 2 as a scale-out mechanism, utilizing NVIDIA V100 chips for ML training.</data>
    </node>
    <node id="7">
      <data key="d5">FSx for Luster (Region 2)</data>
      <data key="d6">FSX</data>
      <data key="d7">DATA_PEEK: High performance data storage provisioned by CloudFormation in Region 2 to support ML training workloads as part of the scale-out strategy.</data>
    </node>
    <node id="8">
      <data key="d5">Service Catalog</data>
      <data key="d6">ServiceCatalog</data>
      <data key="d7">WORKLOAD_PEEK: Used to share the standardized infrastructure as well as knowledge with TRI, their sister company, to reduce development time and improve software quality.</data>
    </node>
    <node id="9">
      <data key="d5">TRI (Sister Company)</data>
      <data key="d6">UserCompanyInternalPlatform</data>
      <data key="d7">WORKLOAD_PEEK: Consumes shared infrastructure and knowledge from Service Catalog, leveraging established patterns and reducing their own development effort.</data>
    </node>
    <edge source="0" target="1">
      <data key="d8">0</data>
      <data key="d9">Object Recognition Team initiates/manages ML training on EC2 P3 instances in Region 1.</data>
      <data key="d10">0</data>
      <data key="d11">meta</data>
      <data key="d12">0</data>
    </edge>
    <edge source="1" target="2">
      <data key="d8">0</data>
      <data key="d9">EC2 P3 instances read/write high-performance training data from/to FSx for Luster.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="1" target="3">
      <data key="d8">0</data>
      <data key="d9">EC2 P3 instances store training outputs, models, and results in S3 Bucket (Region 1).</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="2" target="1">
      <data key="d8">0</data>
      <data key="d9">FSx for Luster provides training data to EC2 P3 instances for compute.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="3" target="4">
      <data key="d8">1</data>
      <data key="d9">S3 cross-region replication ensures data availability and redundancy by copying data from Region 1 to Region 2.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="5" target="6">
      <data key="d8">1</data>
      <data key="d9">CloudFormation provisions the EC2 P3 compute cluster in Region 2 when resources in Region 1 are depleted.</data>
      <data key="d10">1</data>
      <data key="d11">meta</data>
      <data key="d12">0</data>
    </edge>
    <edge source="5" target="7">
      <data key="d8">1</data>
      <data key="d9">CloudFormation provisions FSx for Luster high-performance storage in Region 2 as part of the new cluster deployment.</data>
      <data key="d10">2</data>
      <data key="d11">meta</data>
      <data key="d12">0</data>
    </edge>
    <edge source="6" target="7">
      <data key="d8">1</data>
      <data key="d9">Newly provisioned EC2 instances in Region 2 read/write training data from/to FSx for Luster in Region 2.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="6" target="4">
      <data key="d8">1</data>
      <data key="d9">EC2 instances in Region 2 store training outputs, models, and results in S3 Bucket (Region 2).</data>
      <data key="d10">5</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="7" target="6">
      <data key="d8">1</data>
      <data key="d9">FSx for Luster in Region 2 provides training data to EC2 instances in Region 2.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="8" target="9">
      <data key="d8">2</data>
      <data key="d9">Service Catalog shares pre-approved and standardized infrastructure definitions and knowledge with TRI.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <data key="d0">TRI-AD: Large-Scale and High-Performance Distributed Training Platform</data>
    <data key="d1">https://www.youtube.com/watch?v=JRDGId6N49E</data>
    <data key="d2">TRID, a company formed by Toyota, Denso, and Aishen, focuses on autonomous driving. This architecture describes their machine learning training environment for object recognition. It emphasizes high-performance compute with EC2 P3 instances (NVIDIA V100) and high-performance storage with FSx for Luster. Scalability is achieved via a multi-region setup with S3 replication and CloudFormation for provisioning. Service Catalog is used to share this architecture with their sister company, TRI, to improve development efficiency.</data>
    <data key="d3">compute_intensive, data_ingestion, control</data>
    <data key="d4">True</data>
  </graph>
</graphml>
