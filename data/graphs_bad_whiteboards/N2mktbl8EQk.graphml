<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">DeepRacer Customer</data>
      <data key="d6">UserConsumerWeb</data>
      <data key="d7">The end user interacting with the AWS DeepRacer console to manage and monitor their RL training jobs.</data>
    </node>
    <node id="1">
      <data key="d5">DeepRacer Console/Service</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">WORKLOAD_PEEK: The user-facing console and backend service that orchestrates the entire DeepRacer experience. It 'runs all these services' in the background for the customer.</data>
    </node>
    <node id="2">
      <data key="d5">SageMaker RL Training</data>
      <data key="d6">SageMaker</data>
      <data key="d7">WORKLOAD_PEEK: Dedicated to reinforcement learning training. Uses Proximate Policy Optimization (PPO) to create an agent model and a critic model. It ingests simulation experiences, updates neural network weights (3 CNN layers, fully connected layers), and stores updated models. Runs within a customer's VPC. DATA_PEEK: Inputs 160x120 images, outputs actions. Stores/reads model weights, hyperparameters.</data>
    </node>
    <node id="3">
      <data key="d5">RoboMaker Simulation</data>
      <data key="d6">RoboMaker</data>
      <data key="d7">WORKLOAD_PEEK: Provides the simulation environment for the DeepRacer car. Contains a pre-configured physics engine that determines car behavior based on sensor input and actions. Generates new 'experiences' (state, next state, action, reward) for SageMaker to learn from. Runs within a customer's VPC.</data>
    </node>
    <node id="4">
      <data key="d5">S3 DeepRacer Storage</data>
      <data key="d6">S3</data>
      <data key="d7">DATA_PEEK: Stores crucial information for the DeepRacer service, including:
  - Presets (hardware parameters).
  - Trained models and their versions.
  - Environment details.
  - User-defined reward function logic.
  - Neural network architecture definitions.
  - Hyperparameters for training.
  - Generated simulation experiences (state, next state, action, reward) from RoboMaker.</data>
    </node>
    <node id="5">
      <data key="d5">Kinesis Video Streams</data>
      <data key="d6">KinesisVideo</data>
      <data key="d7">DATA_PEEK: Captures and streams the 'windshield view' (first-person perspective video) from the DeepRacer car within the RoboMaker simulation environment, allowing users to observe the car's behavior during trial and error learning.</data>
    </node>
    <node id="6">
      <data key="d5">CloudWatch Monitoring</data>
      <data key="d6">CloudWatch</data>
      <data key="d7">WORKLOAD_PEEK: Collects logs and metrics from both SageMaker and RoboMaker. Used to track algorithm phases (exploration vs. exploitation), plot reward functions, monitor car progress, and track the overall exploration status during training.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">User interacts with the DeepRacer console to configure, start, and monitor training jobs.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="4" id="0">
      <data key="d8">0</data>
      <data key="d9">DeepRacer service stores user-defined reward functions, model architectures, and hyperparameters into S3 for SageMaker and RoboMaker to use.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="2" id="0">
      <data key="d8">1</data>
      <data key="d9">DeepRacer service initiates and manages the SageMaker reinforcement learning training job.</data>
      <data key="d10">0</data>
      <data key="d11">meta</data>
    </edge>
    <edge source="2" target="4" id="0">
      <data key="d8">1</data>
      <data key="d9">SageMaker reads initial model, reward function logic, hyperparameters, and environment information from S3 to begin training.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="4" id="1">
      <data key="d8">1</data>
      <data key="d9">SageMaker stores the updated agent model weights back into S3 after learning from new experiences.</data>
      <data key="d10">5</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="3" id="0">
      <data key="d8">1</data>
      <data key="d9">SageMaker orchestrates and interacts with RoboMaker to run simulations, providing the current policy/model for the agent in the simulation.</data>
      <data key="d10">2</data>
      <data key="d11">meta</data>
    </edge>
    <edge source="2" target="6" id="0">
      <data key="d8">2</data>
      <data key="d9">SageMaker sends logs and metrics (e.g., reward function plot, algorithm exploration/exploitation phases) to CloudWatch for monitoring.</data>
      <data key="d10">2</data>
      <data key="d11">meta</data>
    </edge>
    <edge source="3" target="4" id="0">
      <data key="d8">1</data>
      <data key="d9">RoboMaker generates and stores new simulation experiences (state, next state, action, reward) in S3 for SageMaker to consume.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="5" id="0">
      <data key="d8">2</data>
      <data key="d9">RoboMaker streams the real-time 'windshield view' video of the DeepRacer car during simulation to Kinesis Video Streams.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="6" id="0">
      <data key="d8">2</data>
      <data key="d9">RoboMaker sends logs and metrics (e.g., car progress, exploration status) to CloudWatch for monitoring.</data>
      <data key="d10">1</data>
      <data key="d11">meta</data>
    </edge>
    <edge source="4" target="2" id="0">
      <data key="d8">1</data>
      <data key="d9">SageMaker retrieves new simulation experiences from S3 to update its agent model weights.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">An Under the Hood Tune Up with AWS DeepRacer</data>
    <data key="d1">https://www.youtube.com/watch?v=N2mktbl8EQk</data>
    <data key="d2">This architecture details how AWS DeepRacer facilitates reinforcement learning for autonomous vehicle training. It enables customers to define reward functions, train models using simulation, and observe the learning process. Key design aspects include the tight integration between SageMaker (for RL training) and RoboMaker (for simulation), with S3 serving as the central repository for models, configurations, and simulation experiences. Kinesis Video provides real-time visual feedback, and CloudWatch captures comprehensive logs and metrics for monitoring and analysis of the learning process.</data>
    <data key="d3">data_ingestion, interactive, compute_intensive, control</data>
    <data key="d4">True</data>
  </graph>
</graphml>
