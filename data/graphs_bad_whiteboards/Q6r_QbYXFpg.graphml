    <edge source="10" target="11" id="0">
      <data key="d8">2</data>
      <data key="d9">Deploys, monitors, and stops workspaces.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">Synchronet Amazon WorkSpaces Provisioning Automation</data>
    <data key="d1">https://www.youtube.com/watch?v=Q6r_QbYXFpg</data>
    <data key="d2">Automates the deployment, modification, and deletion of Amazon WorkSpaces at enterprise scale (thousands of workspaces) using event-driven serverless orchestration.</data>
    <data key="d3">control,interactive</data>
    <data key="d4">True</data>
  </graph>
