  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Administrators &amp; Users</data>
      <data key="d6">UserCompanyDeveloper</data>
      <data key="d7">Access the self-service console.</data>
    </node>
    <node id="1">
      <data key="d5">Console S3 Bucket</data>
      <data key="d6">S3</data>
      <data key="d7">Hosts the frontend administration console.</data>
    </node>
    <node id="2">
      <data key="d5">Amazon Cognito</data>
      <data key="d6">Cognito</data>
      <data key="d7">Secures login with SAML federation.</data>
    </node>
    <node id="3">
      <data key="d5">SAML IdP</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Customer identity provider.</data>
    </node>
    <node id="4">
      <data key="d5">Customer Directory Lambda</data>
      <data key="d6">Lambda</data>
      <data key="d7">Discovers and queries directory users/groups inside customer account.</data>
    </node>
    <node id="5">
      <data key="d5">API Gateway</data>
      <data key="d6">ApiGateway</data>
      <data key="d7">Receives directory synchronization payloads.</data>
    </node>
    <node id="6">
      <data key="d5">CRUD &amp; Automation Lambda</data>
      <data key="d6">Lambda</data>
      <data key="d7">Executes CRUD operations and calculates provisioning deltas.</data>
    </node>
    <node id="7">
      <data key="d5">RDS Database</data>
      <data key="d6">RDS</data>
      <data key="d7">Stores directory and user state.</data>
    </node>
    <node id="8">
      <data key="d5">SQS Queue</data>
      <data key="d6">SQS</data>
      <data key="d7">Buffers provisioning and lifecycle tasks.</data>
    </node>
    <node id="9">
      <data key="d5">Step Function Trigger Lambda</data>
      <data key="d6">Lambda</data>
      <data key="d7">Processes SQS events and starts state machines.</data>
    </node>
    <node id="10">
      <data key="d5">Step Functions</data>
      <data key="d6">StepFunctions</data>
      <data key="d7">Orchestrates multi-step provisioning tasks and handles long-running wait states.</data>
    </node>
    <node id="11">
      <data key="d5">Amazon WorkSpaces</data>
      <data key="d6">WorkSpaces</data>
      <data key="d7">Virtual desktops provisioned in the customer account.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">Loads console UI.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="0" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">Authenticates session.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="3" id="0">
      <data key="d8">0</data>
      <data key="d9">Federates with customer IdP.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="5" id="0">
      <data key="d8">1</data>
      <data key="d9">Sends directory updates.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="6" id="0">
      <data key="d8">1</data>
      <data key="d9">Triggers synchronization backend.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="6" target="7" id="0">
      <data key="d8">1</data>
      <data key="d9">Persists state updates.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="6" target="8" id="0">
      <data key="d8">1</data>
      <data key="d9">Enqueues required provisioning jobs.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="8" target="9" id="0">
      <data key="d8">2</data>
      <data key="d9">Triggers execution.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="9" target="10" id="0">
      <data key="d8">2</data>
      <data key="d9">Initiates workflow execution.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
