<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Client Display</data>
      <data key="d6">UserConsumerWeb</data>
      <data key="d7">Code running in the browser for the IVAP application. Uses WebAssembly for data decompression from the backend. Builds seismic data display on an HTML5 Canvas element. Initiates login, search, and display requests.</data>
    </node>
    <node id="1">
      <data key="d5">IVAP Backend</data>
      <data key="d6">EC2</data>
      <data key="d7">WORKLOAD_PEEK: Runs a Node.js instance, acts as the main IVAP reverse proxy. Hosts custom-built microservice 'adapters' for connecting to various data sources, including OSDU. Performs service authorization and manages project configuration. Incorporates native code with AVX extension instructions for highly optimized data compression (6x speedup, 4-13x compression ratio) before sending to the client. Handles parallel S3 queries to access seismic data.</data>
    </node>
    <node id="2">
      <data key="d5">User Management</data>
      <data key="d6">Cognito</data>
      <data key="d7">Provides user management and authentication services for login, controlling access to sensitive geoscience data. Account, user, and role management are handled by the customer or AWS.</data>
    </node>
    <node id="3">
      <data key="d5">Project Configuration DB</data>
      <data key="d6">RDS</data>
      <data key="d7">A Postgres instance running on Amazon RDS. Stores project configuration settings, defined data sources, and role-based access control rights, determining which users have access to specific projects and data.</data>
    </node>
    <node id="4">
      <data key="d5">OSDU API Gateway</data>
      <data key="d6">ApiGateway</data>
      <data key="d7">The API gateway for the OSDU (Open Subsurface Data Universe) consortium's APIs. Used by IVAP's adapters to remotely access geoscience data, particularly for search operations. Part of the external OSDU system.</data>
    </node>
    <node id="5">
      <data key="d5">OSDU Seismic Data Store</data>
      <data key="d6">S3</data>
      <data key="d7">DATA_PEEK: Stores extremely large seismic data sets, ranging from terabytes to petabytes for a single dataset. Accessed by IVAP adapters through byte offsets and parallel queries to handle the massive scale and irregular nature of the data. Part of the external OSDU system.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">User initiates login request to the IVAP backend (reverse proxy).</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="0" target="1" id="1">
      <data key="d8">1</data>
      <data key="d9">User performs a search for seismic data, sending a request to the IVAP backend (OSDU adapter).</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="0" target="1" id="2">
      <data key="d8">1</data>
      <data key="d9">After receiving search results, the client requests the IVAP backend to build a data display, requiring specific data traces.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">IVAP backend sends login request to Amazon Cognito for user authentication and management.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="3" id="0">
      <data key="d8">0</data>
      <data key="d9">IVAP Node.js instance interacts with RDS to store and retrieve project configuration, data sources, and access control rights.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="4" id="0">
      <data key="d8">1</data>
      <data key="d9">IVAP OSDU adapter sends the data search request to the OSDU API Gateway.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="5" id="0">
      <data key="d8">1</data>
      <data key="d9">IVAP OSDU adapter computes byte offsets for required data traces and performs parallel access requests to OSDU's S3 bucket.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="0" id="0">
      <data key="d8">1</data>
      <data key="d9">IVAP OSDU adapter sends the compressed seismic data to the Client Display for decompression and visualization.</data>
      <data key="d10">6</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="1" id="0">
      <data key="d8">1</data>
      <data key="d9">OSDU API Gateway returns search results back to the IVAP OSDU adapter.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="1" id="0">
      <data key="d8">1</data>
      <data key="d9">OSDU S3 returns the requested seismic data traces to the IVAP OSDU adapter. Data is then compressed on EC2.</data>
      <data key="d10">5</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">INT IVAP Seismic Data Visualization</data>
    <data key="d1">https://www.youtube.com/watch?v=QM96Fv_NAnw</data>
    <data key="d2">Architecture for INT's IVAP solution, visualizing large-scale geoscience (seismic) data up to petabytes. Key design principles include secure access via Cognito and RDS, custom microservices (adapters) running on EC2 for interacting with external data sources like OSDU, and efficient data retrieval/compression for massive datasets from S3 via parallel queries and native code optimization.</data>
    <data key="d3">data_ingestion, interactive, compute_intensive, control</data>
    <data key="d4">True</data>
  </graph>
</graphml>
