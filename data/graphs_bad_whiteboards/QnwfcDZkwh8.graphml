<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">On-Prem Editorial System</data>
      <data key="d6">OnPremDC</data>
      <data key="d7">System used by editorial teams to open/close voting sessions and receive final results.</data>
    </node>
    <node id="1">
      <data key="d5">Site-to-Site VPN</data>
      <data key="d6">VPN</data>
      <data key="d7">Secures management commands from on-prem to AWS.</data>
    </node>
    <node id="2">
      <data key="d5">Fargate Backend Admin</data>
      <data key="d6">Fargate</data>
      <data key="d7">Private service that manages session states in MemoryDB.</data>
    </node>
    <node id="3">
      <data key="d5">MemoryDB for Redis</data>
      <data key="d6">MemoryDB</data>
      <data key="d7">DATA_PEEK: Stores session states and voting counters. Uses Lua scripts to ensure concurrent consistency.</data>
    </node>
    <node id="4">
      <data key="d5">Voting Audience</data>
      <data key="d6">UserConsumerWebMobile</data>
      <data key="d7">Voters sending traffic from SMS, web, mobile, and smart TVs.</data>
    </node>
    <node id="5">
      <data key="d5">AWS WAF</data>
      <data key="d6">WAF</data>
      <data key="d7">Filters geographic locations to block non-Italian votes.</data>
    </node>
    <node id="6">
      <data key="d5">Application Load Balancer</data>
      <data key="d6">ALB</data>
      <data key="d7">Distributes incoming voting traffic to frontend containers.</data>
    </node>
    <node id="7">
      <data key="d5">Fargate Frontend API</data>
      <data key="d6">Fargate</data>
      <data key="d7">WORKLOAD_PEEK: Scales with scheduled/auto-scaling policies to handle vote spikes.</data>
    </node>
    <node id="8">
      <data key="d5">CloudWatch Logs</data>
      <data key="d6">CloudWatch</data>
      <data key="d7">Centralizes access and application logs.</data>
    </node>
    <node id="9">
      <data key="d5">Kinesis Data Firehose</data>
      <data key="d6">Firehose</data>
      <data key="d7">Streams real-time logs for persistent archival.</data>
    </node>
    <node id="10">
      <data key="d5">Amazon S3</data>
      <data key="d6">S3</data>
      <data key="d7">DATA_PEEK: Long-term audit and certification storage.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">Session command sent via VPN.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">Routes command to administrative backend.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="0" id="0">
      <data key="d8">0</data>
      <data key="d9">Presents voting tallies to TV conductors.</data>
      <data key="d10">5</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="3" id="0">
      <data key="d8">0</data>
      <data key="d9">Opens/closes voting session.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">Sends results back through VPN.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">Retrieves finalized results.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="7" id="0">
      <data key="d8">1</data>
      <data key="d9">Transaction response with remaining voter limits.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="5" id="0">
      <data key="d8">1</data>
      <data key="d9">Vote submission requests.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="6" id="0">
      <data key="d8">1</data>
      <data key="d9">Geographical checks approved.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="6" target="7" id="0">
      <data key="d8">1</data>
      <data key="d9">Balances requests to frontend.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="6" target="8" id="0">
      <data key="d8">2</data>
      <data key="d9">Access logging.</data>
      <data key="d10">0</data>
      <data key="d11">meta</data>
    </edge>
    <edge source="7" target="3" id="0">
      <data key="d8">1</data>
      <data key="d9">Lua script execution to increment counters.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="7" target="4" id="0">
      <data key="d8">1</data>
      <data key="d9">Fast transaction receipt delivered under 10ms.</data>
      <data key="d10">5</data>
      <data key="d11">data</data>
    </edge>
    <edge source="7" target="8" id="0">
      <data key="d8">2</data>
      <data key="d9">Application level logging.</data>
      <data key="d10">1</data>
      <data key="d11">meta</data>
    </edge>
    <edge source="8" target="9" id="0">
      <data key="d8">2</data>
      <data key="d9">Log streaming.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="9" target="10" id="0">
      <data key="d8">2</data>
      <data key="d9">Saves structured raw files.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">Mediaset Real-Time Voting Architecture</data>
    <data key="d1">https://www.youtube.com/watch?v=QnwfcDZkwh8</data>
    <data key="d2">Handles high-concurrency spiky traffic with five million votes per episode using MemoryDB and Fargate. End-to-end latency is under 10ms.</data>
    <data key="d3">data_ingestion, interactive, compute_intensive</data>
    <data key="d4">True</data>
