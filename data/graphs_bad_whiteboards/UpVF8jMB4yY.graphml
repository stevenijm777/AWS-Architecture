<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">IT Systems</data>
      <data key="d6">UserCompanyInternalPlatform</data>
      <data key="d7">Internal IT systems producing telemetry and meter files.</data>
    </node>
    <node id="1">
      <data key="d5">Data-Producing REST APIs</data>
      <data key="d6">UserCompanyAPI</data>
      <data key="d7">External REST APIs exposing metrics data.</data>
    </node>
    <node id="2">
      <data key="d5">Utility Customers</data>
      <data key="d6">UserConsumerWeb</data>
      <data key="d7">End-users viewing reports and metrics.</data>
    </node>
    <node id="3">
      <data key="d5">Web Hosting</data>
      <data key="d6">CloudFront</data>
      <data key="d7">Serves the Angular web application.</data>
    </node>
    <node id="4">
      <data key="d5">AWS WAF</data>
      <data key="d6">WAF</data>
      <data key="d7">Secures both CloudFront and API Gateway.</data>
    </node>
    <node id="5">
      <data key="d5">API Gateway Wrapper</data>
      <data key="d6">ApiGateway</data>
      <data key="d7">Secures backend access for web app queries.</data>
    </node>
    <node id="6">
      <data key="d5">Keycloak</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Handles customer authentication.</data>
    </node>
    <node id="7">
      <data key="d5">Ingestion Bucket</data>
      <data key="d6">S3</data>
      <data key="d7">Raw landing zone for pushed files.</data>
    </node>
    <node id="8">
      <data key="d5">S3 Ingestion Loader</data>
      <data key="d6">Lambda</data>
      <data key="d7">Triggered by S3 events; loads data to Redshift.</data>
    </node>
    <node id="9">
      <data key="d5">API Pull Ingester</data>
      <data key="d6">Lambda</data>
      <data key="d7">Pulls data from partner REST APIs.</data>
    </node>
    <node id="10">
      <data key="d5">Xylem Data Lake</data>
      <data key="d6">RedShift</data>
      <data key="d7">WORKLOAD_PEEK: 11 clusters globally segregated to ensure customer data governance.</data>
    </node>
    <node id="11">
      <data key="d5">EventBridge Scheduler</data>
      <data key="d6">EventBridge</data>
      <data key="d7">Triggers recurring serverless batch pipelines.</data>
    </node>
    <node id="12">
      <data key="d5">Batch Job Handler</data>
      <data key="d6">Lambda</data>
      <data key="d7">Extracts report datasets from Redshift.</data>
    </node>
    <node id="13">
      <data key="d5">Simple Email Service</data>
      <data key="d6">SES</data>
      <data key="d7">Sends generated reports to customers.</data>
    </node>
    <node id="14">
      <data key="d5">AWS SFTP Transfer</data>
      <data key="d6">TransferFamily</data>
      <data key="d7">Exposes files securely to SFTP clients using SSH/CyberArk.</data>
    </node>
    <node id="15">
      <data key="d5">Reporting Query API</data>
      <data key="d6">Lambda</data>
      <data key="d7">Queries Redshift to retrieve reports for portal users.</data>
    </node>
    <edge source="0" target="7" id="0">
      <data key="d8">0</data>
      <data key="d9">IT systems push files.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="3" id="0">
      <data key="d8">3</data>
      <data key="d9">Accesses frontend web application via WAF.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="5" id="0">
      <data key="d8">3</data>
      <data key="d9">API requests sent through API Gateway.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="6" id="0">
      <data key="d8">3</data>
      <data key="d9">Authenticates customer session.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="15" id="0">
      <data key="d8">3</data>
      <data key="d9">Invokes reporting Query API.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="2" id="0">
      <data key="d8">3</data>
      <data key="d9">Renders report data in the browser.</data>
      <data key="d10">7</data>
      <data key="d11">data</data>
    </edge>
    <edge source="7" target="8" id="0">
      <data key="d8">0</data>
      <data key="d9">S3 event notification triggers loader.</data>
      <data key="d10">1</data>
      <data key="d11">meta</data>
    </edge>
    <edge source="8" target="10" id="0">
      <data key="d8">0</data>
      <data key="d9">Loader inserts data into Redshift.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="9" target="1" id="0">
      <data key="d8">1</data>
      <data key="d9">Lambda pulls from REST APIs.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="9" target="10" id="0">
      <data key="d8">1</data>
      <data key="d9">Inserts pulled metrics into Redshift.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="10" target="12" id="0">
      <data key="d8">2</data>
      <data key="d9">Returns dataset.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="10" target="15" id="0">
      <data key="d8">3</data>
      <data key="d9">Returns metrics payload.</data>
      <data key="d10">5</data>
      <data key="d11">data</data>
    </edge>
    <edge source="11" target="12" id="0">
      <data key="d8">2</data>
      <data key="d9">Triggers batch jobs.</data>
      <data key="d10">0</data>
      <data key="d11">meta</data>
    </edge>
    <edge source="12" target="10" id="0">
      <data key="d8">2</data>
      <data key="d9">Queries data for reporting.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="12" target="13" id="0">
      <data key="d8">2</data>
      <data key="d9">Emails report files.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="12" target="14" id="0">
      <data key="d8">2</data>
      <data key="d9">Publishes to SFTP server.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <edge source="15" target="10" id="0">
      <data key="d8">3</data>
      <data key="d9">Queries metrics.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <edge source="15" target="5" id="0">
      <data key="d8">3</data>
      <data key="d9">Returns response payload.</data>
      <data key="d10">6</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">Xylem Utility Data Lake</data>
    <data key="d1">https://www.youtube.com/watch?v=UpVF8jMB4yY</data>
    <data key="d2">Serverless analytics and batch delivery platform serving water utility data. Uses 11 distinct regional Redshift clusters to fulfill strict customer data isolation requirements.</data>
    <data key="d3">data_ingestion, interactive, compute_intensive</data>
    <data key="d4">True</data>
  </graph>
