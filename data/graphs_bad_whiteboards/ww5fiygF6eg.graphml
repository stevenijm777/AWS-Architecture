<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d12" for="edge" attr.name="id" attr.type="string" />
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Drone Image Host</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Third-party platform hosting processed ortho mosaics and elevation models.</data>
    </node>
    <node id="1">
      <data key="d5">CloudWatch Events</data>
      <data key="d6">CloudWatch</data>
      <data key="d7">Cron-style trigger to initiate the workflow scheduler.</data>
    </node>
    <node id="2">
      <data key="d5">Orchestrator</data>
      <data key="d6">StepFunctions</data>
      <data key="d7">Coordinates the multi-phase execution of the Lambda functions.</data>
    </node>
    <node id="3">
      <data key="d5">Check Flights Lambda</data>
      <data key="d6">Lambda</data>
      <data key="d7">Queries the third-party software API to identify new imagery flights.</data>
    </node>
    <node id="4">
      <data key="d5">Ingestion Lambda</data>
      <data key="d6">Lambda</data>
      <data key="d7">Pulls identified drone images from the third party and writes them to S3.</data>
    </node>
    <node id="5">
      <data key="d5">Raster Proxy Lambda</data>
      <data key="d6">Lambda</data>
      <data key="d7">Generates proxy links mapping the on-premises server to S3.</data>
    </node>
    <node id="6">
      <data key="d5">Drone Imagery Bucket</data>
      <data key="d6">S3</data>
      <data key="d7">Stores high-resolution images, digital terrain, and digital elevation models.</data>
    </node>
    <node id="7">
      <data key="d5">Mapping Server</data>
      <data key="d6">OnPremDC</data>
      <data key="d7">On-premises mapping software that queries local DB and displays images.</data>
    </node>
    <node id="8">
      <data key="d5">On-Premises Database</data>
      <data key="d6">OnPremDC</data>
      <data key="d7">Stores index metadata and raster proxy URL links.</data>
    </node>
    <node id="9">
      <data key="d5">File Gateway</data>
      <data key="d6">StorageGateway</data>
      <data key="d7">Exposes S3 buckets to the local mapping server as a network file share.</data>
    </node>
    <node id="10">
      <data key="d5">Maintenance &amp; Ops Teams</data>
      <data key="d6">UserCompanyAgent</data>
      <data key="d7">Internal users examining imagery for well pad equipment monitoring.</data>
    </node>
    <edge source="1" target="2">
      <data key="d8">0</data>
      <data key="d9">Triggers step function on schedule</data>
      <data key="d10">0</data>
      <data key="d11">meta</data>
      <data key="d12">0</data>
    </edge>
    <edge source="2" target="3">
      <data key="d8">0</data>
      <data key="d9">Starts checking step</data>
      <data key="d10">1</data>
      <data key="d11">meta</data>
      <data key="d12">0</data>
    </edge>
    <edge source="2" target="4">
      <data key="d8">0</data>
      <data key="d9">Starts ingestion step</data>
      <data key="d10">3</data>
      <data key="d11">meta</data>
      <data key="d12">0</data>
    </edge>
    <edge source="2" target="5">
      <data key="d8">1</data>
      <data key="d9">Starts indexing proxy step</data>
      <data key="d10">0</data>
      <data key="d11">meta</data>
      <data key="d12">0</data>
    </edge>
    <edge source="3" target="0">
      <data key="d8">0</data>
      <data key="d9">Checks API for new drone flights</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="4" target="0">
      <data key="d8">0</data>
      <data key="d9">Retrieves high-resolution image files</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="4" target="6">
      <data key="d8">0</data>
      <data key="d9">Saves original raw images</data>
      <data key="d10">5</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="5" target="6">
      <data key="d8">1</data>
      <data key="d9">Inspects uploaded S3 image properties</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="5" target="8">
      <data key="d8">1</data>
      <data key="d9">Inserts raster proxy URL mapping details</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="7" target="8">
      <data key="d8">2</data>
      <data key="d9">Fetches raster proxy database reference</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="7" target="9">
      <data key="d8">2</data>
      <data key="d9">Requests file paths through mounted gateway</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="9" target="6">
      <data key="d8">2</data>
      <data key="d9">Translates file system request to S3 GET</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="10" target="7">
      <data key="d8">2</data>
      <data key="d9">Views well pad imagery via map client</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <data key="d0">Marathon Oil: Automating Drone Image Processing to Monitor Equipment Health</data>
    <data key="d1">https://www.youtube.com/watch?v=ww5fiygF6eg</data>
    <data key="d2">Automated pipeline transferring drone aerial photos to local GIS systems without modifying legacy on-prem software, leveraging AWS Storage Gateway and Step Functions orchestration.</data>
    <data key="d3">data_ingestion, compute_intensive</data>
    <data key="d4">True</data>
  </graph>
