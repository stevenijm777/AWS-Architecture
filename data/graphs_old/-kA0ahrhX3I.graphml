  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Production Data S3 Bucket 1</data>
      <data key="d6">S3</data>
      <data key="d7">DATA_PEEK: Contains sensitive data for Oportun members (SSNs, ITINs, government IDs) in an AWS production account. Macie inventories and scans these buckets for PII.</data>
    </node>
    <node id="1">
      <data key="d5">Macie in Production Account 1</data>
      <data key="d6">Macie</data>
      <data key="d7">WORKLOAD_PEEK: Macie instance connected to a production AWS account to inventory and scan S3 buckets for sensitive data. Stores findings metadata in a central findings S3 bucket.</data>
    </node>
    <node id="2">
      <data key="d5">Production Data S3 Bucket 2</data>
      <data key="d6">S3</data>
      <data key="d7">DATA_PEEK: Contains sensitive data for Oportun members (SSNs, ITINs, government IDs) in another AWS production account. Macie inventories and scans these buckets for PII.</data>
    </node>
    <node id="3">
      <data key="d5">Macie in Production Account 2</data>
      <data key="d6">Macie</data>
      <data key="d7">WORKLOAD_PEEK: Macie instance connected to a production AWS account to inventory and scan S3 buckets for sensitive data. Stores findings metadata in a central findings S3 bucket.</data>
    </node>
    <node id="4">
      <data key="d5">Macie Findings S3 Bucket</data>
      <data key="d6">S3</data>
      <data key="d7">DATA_PEEK: Stores metadata from Macie findings (e.g., count of SSNs, ITINs, date of birth in a bucket). No original PII or sensitive information from source data is stored here, only metadata. This bucket is owned by Oportun and resides in the central AWS account.</data>
    </node>
    <node id="5">
      <data key="d5">Macie Findings Processing</data>
      <data key="d6">Macie</data>
      <data key="d7">WORKLOAD_PEEK: Represents Macie's role in processing and consolidating findings metadata collected from scans across multiple accounts, populating the central findings S3 bucket. Automated sensitive data discovery achieves 95% accuracy for critical sensitive types like SSNs and ITINs.</data>
    </node>
    <node id="6">
      <data key="d5">Amazon Athena for Findings Analysis</data>
      <data key="d6">Athena</data>
      <data key="d7">WORKLOAD_PEEK: SQL-based query tool that directly queries the findings metadata stored in the Macie Findings S3 Bucket. Used by security engineers to analyze findings, identify bucket owners, and plan remediation strategies.</data>
    </node>
    <node id="7">
      <data key="d5">MySQL Data Lake</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">DATA_PEEK: A self-built MySQL data lake where processed and aggregated findings data is stored. Provides a structured repository for presenting findings rather than raw CSV/Excel files, improving the narrative for data owners.</data>
    </node>
    <node id="8">
      <data key="d5">AWS Glue for Findings ETL</data>
      <data key="d6">Glue</data>
      <data key="d7">WORKLOAD_PEEK: Used for automations to get, load, and aggregate findings data from the Macie Findings S3 Bucket. It orchestrates the process of preparing findings for Athena, loading into the MySQL data lake, and overall data transformation before reporting to data owners.</data>
    </node>
    <node id="9">
      <data key="d5">Amazon QuickSight Dashboard</data>
      <data key="d6">QuickSight</data>
      <data key="d7">WORKLOAD_PEEK: Business intelligence tool used to create interactive dashboards. Visualizes aggregated findings data (e.g., top 10/20/30 risky buckets by PII type, with owners) sourced from Athena or the MySQL data lake. This dashboard is crucial for security engineers to drive remediation efforts.</data>
    </node>
    <node id="10">
      <data key="d5">Security Engineers</data>
      <data key="d6">UserConsumerWeb</data>
      <data key="d7">WORKLOAD_PEEK: Oportun's security team members. They use QuickSight dashboards to view and understand sensitive data findings across S3 buckets. Their role involves identifying data owners and collaborating on remediation actions (e.g., delete the data, archive it, remove the bucket if no longer in use).</data>
    </node>
