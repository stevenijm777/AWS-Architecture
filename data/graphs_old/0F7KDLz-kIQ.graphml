<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d12" for="edge" attr.name="id" attr.type="string" />
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Zigbang App Users</data>
      <data key="d6">UserConsumerWebMobile</data>
      <data key="d7">End users accessing real-estate information, search, and push alerts.</data>
    </node>
    <node id="1">
      <data key="d5">Global CDN</data>
      <data key="d6">CloudFront</data>
      <data key="d7">Caches static assets and handles global request entry.</data>
    </node>
    <node id="2">
      <data key="d5">Internal Route 53</data>
      <data key="d6">Route53</data>
      <data key="d7">Used for dynamic weighted traffic routing between ECS and Serverless paths.</data>
    </node>
    <node id="3">
      <data key="d5">API Gateway</data>
      <data key="d6">ApiGateway</data>
      <data key="d7">Exposes endpoints for the serverless compute path.</data>
    </node>
    <node id="4">
      <data key="d5">Application Lambda</data>
      <data key="d6">Lambda</data>
      <data key="d7">Scales instantly to absorb rapid traffic spikes during marketing events.</data>
    </node>
    <node id="5">
      <data key="d5">ECS Fargate Cluster</data>
      <data key="d6">ECS</data>
      <data key="d7">Handles main steady-state application load cost-effectively.</data>
    </node>
    <node id="6">
      <data key="d5">ElastiCache (Redis)</data>
      <data key="d6">ElastiCache</data>
      <data key="d7">Caches transient/volatile data for high-speed query response.</data>
    </node>
    <node id="7">
      <data key="d5">DocumentDB</data>
      <data key="d6">DocumentDB</data>
      <data key="d7">Stores highly read or unstructured document data.</data>
    </node>
    <node id="8">
      <data key="d5">RDS Database</data>
      <data key="d6">RDS</data>
      <data key="d7">Handles standard relational transactional CRUD workloads.</data>
    </node>
    <node id="9">
      <data key="d5">Elasticsearch Service</data>
      <data key="d6">OpenSearch</data>
      <data key="d7">Powers apartment address searches and stores application troubleshooting logs.</data>
    </node>
    <node id="10">
      <data key="d5">CloudWatch Monitoring</data>
      <data key="d6">CloudWatch</data>
      <data key="d7">Tracks ECS load metrics to evaluate scaling conditions.</data>
    </node>
    <node id="11">
      <data key="d5">Route 53 Weight Updater</data>
      <data key="d6">Lambda</data>
      <data key="d7">Triggered by metrics to dynamically update Route 53 weighted record sets via SDK.</data>
    </node>
    <edge source="0" target="1">
      <data key="d8">0</data>
      <data key="d9">User requests route through CloudFront.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="1" target="2">
      <data key="d8">0</data>
      <data key="d9">Requests directed to internal dynamic weight router.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="1" target="0">
      <data key="d8">0</data>
      <data key="d9">Delivers final response back to mobile/web clients.</data>
      <data key="d10">7</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="2" target="3">
      <data key="d8">0</data>
      <data key="d9">Routes spike traffic to API Gateway.</data>
      <data key="d10">2a</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="2" target="5">
      <data key="d8">0</data>
      <data key="d9">Routes steady-state traffic directly to container fleet.</data>
      <data key="d10">2b</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="3" target="4">
      <data key="d8">0</data>
      <data key="d9">Triggers serverless app logic.</data>
      <data key="d10">3a</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="3" target="1">
      <data key="d8">0</data>
      <data key="d9">Relays response to CDN.</data>
      <data key="d10">6a</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="4" target="6">
      <data key="d8">0</data>
      <data key="d9">Queries/writes transient cache data.</data>
      <data key="d10">4a</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="4" target="7">
      <data key="d8">0</data>
      <data key="d9">Queries/writes unstructured data.</data>
      <data key="d10">4b</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="4" target="8">
      <data key="d8">0</data>
      <data key="d9">Relational transactions.</data>
      <data key="d10">4c</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="4" target="9">
      <data key="d8">0</data>
      <data key="d9">Performs search or writes application logs.</data>
      <data key="d10">4d</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="4" target="3">
      <data key="d8">0</data>
      <data key="d9">Returns response payload.</data>
      <data key="d10">5a</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="5" target="6">
      <data key="d8">0</data>
      <data key="d9">Queries/writes transient cache data.</data>
      <data key="d10">3b_1</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="5" target="7">
      <data key="d8">0</data>
      <data key="d9">Queries/writes unstructured data.</data>
      <data key="d10">3b_2</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="5" target="8">
      <data key="d8">0</data>
      <data key="d9">Relational transactions.</data>
      <data key="d10">3b_3</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="5" target="9">
      <data key="d8">0</data>
      <data key="d9">Performs search or writes application logs.</data>
      <data key="d10">3b_4</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="5" target="1">
      <data key="d8">0</data>
      <data key="d9">Returns response payload directly to CDN.</data>
      <data key="d10">4b_resp</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="5" target="10">
      <data key="d8">1</data>
      <data key="d9">Emits CPU/memory utilization metrics.</data>
      <data key="d10">0</data>
      <data key="d11">meta</data>
      <data key="d12">0</data>
    </edge>
    <edge source="10" target="11">
      <data key="d8">1</data>
      <data key="d9">Triggers Route 53 controller when threshold bounds are exceeded.</data>
      <data key="d10">1</data>
      <data key="d11">meta</data>
      <data key="d12">0</data>
    </edge>
    <edge source="11" target="2">
      <data key="d8">1</data>
      <data key="d9">Dynamically shifts weighted routing rules to shield ECS during peak spikes.</data>
      <data key="d10">2</data>
      <data key="d11">meta</data>
      <data key="d12">0</data>
    </edge>
    <data key="d0">Zigbang: A Hybrid API of Serverless and ECS, Infra as a Code via CDK</data>
    <data key="d1">https://www.youtube.com/watch?v=0F7KDLz-kIQ</data>
    <data key="d2">Hybrid architecture using ECS on Fargate and AWS Lambda to balance cost, performance, and scaling limits. Real-time weighted routing is managed dynamically by CloudWatch and Lambda based on active compute load.</data>
    <data key="d3">interactive, control</data>
    <data key="d4">True</data>
  </graph>
