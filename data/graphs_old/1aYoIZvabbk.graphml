<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d12" for="edge" attr.name="id" attr.type="string" />
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Developer</data>
      <data key="d6">UserCompanyDeveloper</data>
      <data key="d7">Triggers environment replication requests on the Orion portal.</data>
    </node>
    <node id="1">
      <data key="d5">Route 53</data>
      <data key="d6">Route53</data>
      <data key="d7">Provides DNS resolution for the Orion portal.</data>
    </node>
    <node id="2">
      <data key="d5">Application Load Balancer</data>
      <data key="d6">ALB</data>
      <data key="d7">Routes portal requests to application pods.</data>
    </node>
    <node id="3">
      <data key="d5">Amazon EKS</data>
      <data key="d6">EKS</data>
      <data key="d7">WORKLOAD_PEEK: Handles 10,000+ pods. Orchestrates the microservice replication process.</data>
    </node>
    <node id="4">
      <data key="d5">Spot Instances</data>
      <data key="d6">EC2</data>
      <data key="d7">WORKLOAD_PEEK: 100% Spot-backed node groups running transient Kubernetes jobs to deploy microservices.</data>
    </node>
    <node id="5">
      <data key="d5">Amazon SNS</data>
      <data key="d6">SNS</data>
      <data key="d7">Receives tracking state events when microservice jobs are triggered.</data>
    </node>
    <node id="6">
      <data key="d5">Amazon SQS</data>
      <data key="d6">SQS</data>
      <data key="d7">Buffers job progress states, ensuring outstanding work is resumed if nodes terminate.</data>
    </node>
    <edge source="0" target="1">
      <data key="d8">0</data>
      <data key="d9">Developer accesses Orion portal</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="1" target="2">
      <data key="d8">0</data>
      <data key="d9">Resolves DNS to ALB</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="2" target="3">
      <data key="d8">0</data>
      <data key="d9">Forwards request to Orion app on EKS</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="2" target="0">
      <data key="d8">0</data>
      <data key="d9">Delivers final response to Developer</data>
      <data key="d10">8</data>
      <data key="d11">meta</data>
      <data key="d12">0</data>
    </edge>
    <edge source="3" target="4">
      <data key="d8">0</data>
      <data key="d9">Launches jobs on EC2 Spot instances to provision microservices</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="3" target="2">
      <data key="d8">0</data>
      <data key="d9">Returns provisioning status ack</data>
      <data key="d10">7</data>
      <data key="d11">meta</data>
      <data key="d12">0</data>
    </edge>
    <edge source="4" target="5">
      <data key="d8">0</data>
      <data key="d9">Publishes task tracking state on execution</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="5" target="6">
      <data key="d8">0</data>
      <data key="d9">Fans out task states to queue</data>
      <data key="d10">5</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="6" target="4">
      <data key="d8">0</data>
      <data key="d9">Replacement jobs read pending states from SQS queue</data>
      <data key="d10">6</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <data key="d0">OLX Autos: Building Developer Platform for Rapid Global Expansion</data>
    <data key="d1">https://www.youtube.com/watch?v=1aYoIZvabbk</data>
    <data key="d2">OLX Autos manages replica development environments on an internal platform. They achieve high cost optimization by running 100% Spot instances, utilizing AWS Node Termination Handler alongside SNS/SQS to safely resume disrupted Kubernetes jobs.</data>
    <data key="d3">compute_intensive,control</data>
    <data key="d4">True</data>
  </graph>
</graphml>
