  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Smart Plugs</data>
      <data key="d6">UserConsumerIOT</data>
      <data key="d7">Custom developed smart plug, measures power consumption of AC units. Based on ESP board with FreeRTOS. Connects directly to AWS IoT Core via Wi-Fi and MQTT.</data>
    </node>
    <node id="1">
      <data key="d5">Temperature and Humidity Sensors</data>
      <data key="d6">UserConsumerIOT</data>
      <data key="d7">Custom developed temperature and humidity sensor. Based on ESP board with FreeRTOS. Connects directly to AWS IoT Core via Wi-Fi and MQTT.</data>
    </node>
    <node id="2">
      <data key="d5">AWS IoT Core</data>
      <data key="d6">IoTCore</data>
      <data key="d7">Ingests data via MQTT (certificate-based authentication). Manages device state using Device Shadow and stores device metadata (placement, building, apartment, room) in Device Registry. Uses Rules Engine for data routing to various downstream services and for sending control commands back to devices.</data>
    </node>
    <node id="3">
      <data key="d5">AWS IoT Analytics</data>
      <data key="d6">IoTAnalytics</data>
      <data key="d7">Receives data from IoT Core Rules Engine for aggregation and historical analysis. Used for QuickSight dashboards. Provides aggregated insights, not close to real-time data.</data>
    </node>
    <node id="4">
      <data key="d5">Amazon QuickSight</data>
      <data key="d6">QuickSight</data>
      <data key="d7">Generates dashboards from IoT Analytics data for aggregated views, typically for building management.</data>
    </node>
    <node id="5">
      <data key="d5">Amazon Elasticsearch Service</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Receives data from IoT Core Rules Engine for near real-time analysis and correlation (e.g., power consumption vs. temperature). Used for Kibana dashboards to detect potential faults or anomalies (e.g., AC on but no power or temperature change).</data>
    </node>
    <node id="6">
      <data key="d5">Kibana</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Generates near real-time dashboards from Elasticsearch data, enabling immediate fault detection and monitoring for operational insights.</data>
    </node>
    <node id="7">
      <data key="d5">Lambda (Device Metrics Processor)</data>
      <data key="d6">Lambda</data>
      <data key="d7">Triggered by IoT Core Rules Engine to process specific device metrics, such as device turn on/off times and state changes, before storing them in DynamoDB.</data>
    </node>
    <node id="8">
      <data key="d5">Amazon DynamoDB</data>
      <data key="d6">DynamoDB</data>
      <data key="d7">Stores processed device metrics and state changes (e.g., 'when was it turned on, turned off?', duration in a specific state).</data>
    </node>
    <node id="9">
      <data key="d5">Amazon RDS</data>
      <data key="d6">RDS</data>
      <data key="d7">Stores the structural layout of devices, buildings, apartments, and rooms. This database represents the physical layout of different apartment types (studio, one-bedroom, two-bedroom, etc.) for context.</data>
    </node>
    <node id="10">
      <data key="d5">Resident</data>
      <data key="d6">UserConsumerWebMobile</data>
      <data key="d7">Apartment resident who interacts with the smart home solution primarily via Alexa voice commands for control (e.g., AC on/off) and queries (e.g., temperature, maintenance requests, package notifications, visitor alerts).</data>
    </node>
    <node id="11">
      <data key="d5">Alexa for Business (A4B)</data>
      <data key="d6">AlexaForBusiness</data>
      <data key="d7">Centralized management system for Alexa devices within the apartments. It helps identify the apartment and building context for voice commands and routes requests to custom Alexa skills.</data>
    </node>
    <node id="12">
      <data key="d5">Lambda (Resident Skill)</data>
      <data key="d6">Lambda</data>
      <data key="d7">Backend for the custom 'Resident Skill'. This Lambda function processes voice commands from residents, interacts with IoT Core (Device Shadow) for status/control, DynamoDB for historical data, and RDS for apartment context.</data>
    </node>
    <node id="13">
      <data key="d5">Stonehenge Management</data>
      <data key="d6">UserCompanyInternalPlatform</data>
      <data key="d7">Stonehenge management and office staff who use the Alexa Office Skill and various dashboards (QuickSight, Kibana) to oversee building operations, property management, and respond to maintenance needs.</data>
    </node>
    <node id="14">
      <data key="d5">Lambda (Office Skill)</data>
      <data key="d6">Lambda</data>
      <data key="d7">Backend for the custom 'Office Skill'. This Lambda function processes voice commands from management (e.g., querying unit availability) and interacts with RDS and potentially Salesforce for internal business information.</data>
    </node>
    <node id="15">
      <data key="d5">EC2 (Web Servers)</data>
      <data key="d6">EC2</data>
      <data key="d7">Hosts multiple web servers, potentially for mobile applications, internal platforms, or web interfaces. Also involved in enterprise data processing for Salesforce.</data>
    </node>
    <node id="16">
      <data key="d5">Amazon S3</data>
      <data key="d6">S3</data>
      <data key="d7">Used for enterprise backup and restoration. Specifically, nightly backups from a back-end SQL instance (financial reporting system) are stored here.</data>
    </node>
    <node id="17">
      <data key="d5">Back-end Financial Reporting System</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">An external or internal SQL instance that serves as a core financial reporting system. Its data is backed up to S3 and processed for integration with Salesforce.</data>
    </node>
    <node id="18">
      <data key="d5">Salesforce</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Customer Relationship Management (CRM) system. Receives manipulated data from the financial reporting system for presentation and analytics. Implied interaction with Office Skill for querying unit availability.</data>
    </node>
    <node id="19">
      <data key="d5">Einstein Analytics</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Part of Salesforce, used for advanced analytics and generating presentations/reports for investors and partners, based on processed financial and operational data.</data>
    </node>
    <node id="20">
      <data key="d5">Investors/Partners</data>
      <data key="d6">UserCompanyAnalyst</data>
      <data key="d7">External stakeholders who consume analytics and reports, primarily through Einstein Analytics, to gain insights into Stonehenge's properties and financial performance.</data>
    </node>
