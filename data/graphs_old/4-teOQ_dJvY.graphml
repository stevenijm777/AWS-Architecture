    <edge source="2" target="3" id="0">
      <data key="d8">0</data>
      <data key="d9">Streams data for real-time analytics</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="4" id="0">
      <data key="d8">0</data>
      <data key="d9">Forwards filtered telemetry</data>
