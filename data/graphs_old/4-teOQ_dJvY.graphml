  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Train &amp; Track Sensors</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">DATA_PEEK: Produces ~3 million raw samples per train daily.</data>
    </node>
    <node id="1">
      <data key="d5">Ingestion Lambda</data>
      <data key="d6">Lambda</data>
      <data key="d7">WORKLOAD_PEEK: Simple serverless function translating and forwarding variable-format raw IoT data.</data>
    </node>
    <node id="2">
      <data key="d5">Raw Data Stream</data>
      <data key="d6">KinesisDataStream</data>
      <data key="d7">Buffers the raw ingest data stream.</data>
    </node>
    <node id="3">
      <data key="d5">Kinesis Data Analytics</data>
      <data key="d6">KinesisAnalytics</data>
      <data key="d7">Filters and reduces incoming sensor data to critical parameters.</data>
    </node>
    <node id="4">
      <data key="d5">Normalized Stream</data>
      <data key="d6">KinesisDataStream</data>
      <data key="d7">Aggregates filtered and structured digital twin data from multiple sources.</data>
    </node>
    <node id="5">
      <data key="d5">Data Manager Lambda</data>
      <data key="d6">Lambda</data>
      <data key="d7">Manages writes to DynamoDB and handles read queries via API Gateway.</data>
    </node>
    <node id="6">
      <data key="d5">Digital Twin Database</data>
      <data key="d6">DynamoDB</data>
      <data key="d7">Stores current status and health history of train components.</data>
    </node>
    <node id="7">
      <data key="d5">API Gateway</data>
      <data key="d6">ApiGateway</data>
      <data key="d7">Exposes endpoints for algorithms to query train health status.</data>
    </node>
    <node id="8">
      <data key="d5">Analysis Algorithms</data>
      <data key="d6">UserCompanyInternalPlatform</data>
      <data key="d7">Consuming system determining if trains need immediate maintenance.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">Sends sensor telemetry</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">Writes raw telemetry</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
