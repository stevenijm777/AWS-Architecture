  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Cloud Provider Events</data>
      <data key="d6">UserCompanyDataStream</data>
      <data key="d7">Real-time event logs from AWS, Azure, and GCP.</data>
    </node>
    <node id="1">
      <data key="d5">Kinesis (Collection)</data>
      <data key="d6">KinesisDataStream</data>
      <data key="d7">DATA_PEEK: Collects billions of resource state events daily.</data>
    </node>
    <node id="2">
      <data key="d5">Amazon Neptune</data>
      <data key="d6">Neptune</data>
      <data key="d7">WORKLOAD_PEEK: Graph DB holding 50M+ interconnected resources.</data>
    </node>
    <node id="3">
      <data key="d5">Elasticsearch</data>
      <data key="d6">OpenSearch</data>
      <data key="d7">Powers searching, analytical aggregations, and reporting.</data>
    </node>
    <node id="4">
      <data key="d5">DynamoDB (Backing Store)</data>
      <data key="d6">DynamoDB</data>
      <data key="d7">Tracks resource configuration history.</data>
    </node>
    <node id="5">
      <data key="d5">CloudWatch</data>
      <data key="d6">CloudWatch</data>
      <data key="d7">Gathers CPU/memory performance metrics.</data>
    </node>
    <node id="6">
      <data key="d5">Sharder Service</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Dynamically coordinates Neptune write limits.</data>
    </node>
    <node id="7">
      <data key="d5">Kinesis (Rules Engine)</data>
      <data key="d6">KinesisDataStream</data>
      <data key="d7">Triggers rules execution on resource changes.</data>
    </node>
    <node id="8">
      <data key="d5">DynamoDB (Violations)</data>
      <data key="d6">DynamoDB</data>
      <data key="d7">Stores detected security policy violations.</data>
    </node>
    <node id="9">
      <data key="d5">Email Notifications</data>
      <data key="d6">SES</data>
      <data key="d7">Dispatches security alerts to clients.</data>
    </node>
    <node id="10">
      <data key="d5">Slack &amp; Splunk Alerts</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Routes real-time alerts to third-party tools.</data>
    </node>
    <edge source="0" target="1">
      <data key="d8">0</data>
      <data key="d9">Ingests raw event streams.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="1" target="2">
