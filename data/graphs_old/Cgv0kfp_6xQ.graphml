<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Mobile Clients (iOS / Android)</data>
      <data key="d6">UserConsumerMobile</data>
      <data key="d7">Hundreds of millions of daily active users sending and receiving snaps.</data>
    </node>
    <node id="1">
      <data key="d5">Gateway (GW)</data>
      <data key="d6">EKS</data>
      <data key="d7">EKS-based API gateway managing user connections and API routing.</data>
    </node>
    <node id="2">
      <data key="d5">Media Service (MEDIA)</data>
      <data key="d6">EKS</data>
      <data key="d7">EKS microservice responsible for media processing and delivery initiation.</data>
    </node>
    <node id="3">
      <data key="d5">Messaging Core Service (MCS)</data>
      <data key="d6">EKS</data>
      <data key="d7">EKS microservice managing messaging logic and orchestrating recipient notification flows.</data>
    </node>
    <node id="4">
      <data key="d5">SnapDB</data>
      <data key="d6">EKS</data>
      <data key="d7">Custom database layer built on EKS to handle transactions, TTL, and ephemeral data logic.</data>
    </node>
    <node id="5">
      <data key="d5">Friend Graph</data>
      <data key="d6">EKS</data>
      <data key="d7">EKS microservice handling friend relationship mapping.</data>
    </node>
    <node id="6">
      <data key="d5">CloudFront</data>
      <data key="d6">CloudFront</data>
      <data key="d7">Global CDN providing low-latency media caching and distribution.</data>
    </node>
    <node id="7">
      <data key="d5">S3</data>
      <data key="d6">S3</data>
      <data key="d7">Object storage storing the snap media payload.</data>
    </node>
    <node id="8">
      <data key="d5">ElastiCache</data>
      <data key="d6">ElastiCache</data>
      <data key="d7">Stores persistent connection mapping (server and connection IDs) for push routing.</data>
    </node>
    <node id="9">
      <data key="d5">DynamoDB</data>
      <data key="d6">DynamoDB</data>
      <data key="d7">DATA_PEEK: 400TB metadata storage. WORKLOAD_PEEK: Runs nightly scans processing 2B rows/minute for suggestions and cleaning ephemeral data.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">Client initiates snap upload request.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="0" target="6" id="0">
      <data key="d8">3</data>
      <data key="d9">Recipient requests media download.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">Gateway routes upload request to Media Service.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="3" id="0">
      <data key="d8">1</data>
      <data key="d9">Gateway forwards message metadata to MCS.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="0" id="0">
      <data key="d8">2</data>
      <data key="d9">Gateway pushes message notification to recipient client.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="6" id="0">
      <data key="d8">0</data>
      <data key="d9">Media Service uploads media file.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="5" id="0">
      <data key="d8">0</data>
      <data key="d9">Queries Friend Graph to validate messaging relations.</data>
      <data key="d10">5</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="4" id="0">
      <data key="d8">1</data>
      <data key="d9">Forwards transactional writes and metadata.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="8" id="0">
      <data key="d8">2</data>
      <data key="d9">Queries cache for recipient's active connection and server ID.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="1" id="0">
      <data key="d8">2</data>
      <data key="d9">Routes message notification payload to target gateway server.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="9" id="0">
      <data key="d8">1</data>
      <data key="d9">Saves structured snap metadata to DynamoDB.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="6" target="7" id="0">
      <data key="d8">0</data>
      <data key="d9">Media is persisted in S3 close to the recipient.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <edge source="6" target="7" id="1">
      <data key="d8">3</data>
      <data key="d9">Retrieves snap image/video payload from S3.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">Snap: Journey of a Snap on Snapchat Using AWS</data>
    <data key="d1">https://www.youtube.com/watch?v=Cgv0kfp_6xQ</data>
    <data key="d2">Handles 300M+ DAUs and 5B+ Snaps/day. Leverages a custom database layer (SnapDB) on EKS to manage transaction layers and ephemeral data before persisting metadata in DynamoDB. Connection states are cached in ElastiCache to enable fast, real-time message pushing.</data>
    <data key="d3">interactive, data_ingestion</data>
    <data key="d4">True</data>
  </graph>
</graphml>
