<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d12" for="edge" attr.name="id" attr.type="string" />
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Internal Stakeholders</data>
      <data key="d6">UserCompanyInternalPlatform</data>
      <data key="d7">Incident response, customer care, and on-call teams checking system status.</data>
    </node>
    <node id="1">
      <data key="d5">Amplify Status Page Frontend</data>
      <data key="d6">Amplify</data>
      <data key="d7">Hosts the single page application status dashboard for internal stakeholders.</data>
    </node>
    <node id="2">
      <data key="d5">AppSync GraphQL API</data>
      <data key="d6">AppSync</data>
      <data key="d7">Provides a unified GraphQL API layer for fetching monitoring metrics.</data>
    </node>
    <node id="3">
      <data key="d5">Status Resolver Lambda</data>
      <data key="d6">Lambda</data>
      <data key="d7">Uses AWS SDK to pull canary status, history, alerts, and S3 artifact links.</data>
    </node>
    <node id="4">
      <data key="d5">CloudWatch Synthetics &amp; Alerts</data>
      <data key="d6">CloudWatch</data>
      <data key="d7">Runs Canaries every 1-5 minutes to simulate client behavior and generate alerts.</data>
    </node>
    <node id="5">
      <data key="d5">Artifact Storage S3 Bucket</data>
      <data key="d6">S3</data>
      <data key="d7">Stores test run artifacts including HAR files and step screenshots.</data>
    </node>
    <edge source="0" target="1">
      <data key="d8">1</data>
      <data key="d9">Stakeholder accesses the status dashboard url.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="0" target="2">
      <data key="d8">1</data>
      <data key="d9">Browser app sends GraphQL queries to fetch canary statuses.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="1" target="0">
      <data key="d8">1</data>
      <data key="d9">Status page interface loads in stakeholder's browser.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="2" target="3">
      <data key="d8">1</data>
      <data key="d9">AppSync invokes Lambda resolver to gather status data.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="2" target="0">
      <data key="d8">1</data>
      <data key="d9">AppSync resolves query and displays real-time system status on user dashboard.</data>
      <data key="d10">7</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="3" target="4">
      <data key="d8">1</data>
      <data key="d9">Lambda queries CloudWatch for canary execution history and alarm statuses.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="3" target="5">
      <data key="d8">1</data>
      <data key="d9">Lambda retrieves HAR files and screenshots from S3 bucket.</data>
      <data key="d10">5</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="3" target="2">
      <data key="d8">1</data>
      <data key="d9">Lambda returns compiled status data payload.</data>
      <data key="d10">6</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="4" target="5">
      <data key="d8">0</data>
      <data key="d9">Canaries write execution artifacts (HAR files, screenshots) to S3.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <data key="d0">HBO Max: Using Canaries for Outside-in Validation</data>
    <data key="d1">https://www.youtube.com/watch?v=D9qTotVJYss</data>
    <data key="d2">Serverless experience monitoring framework. CloudWatch Canaries simulate user behavior across global regions, storing detailed run artifacts in S3. Internal stakeholders access these insights via a custom status page built with Amplify, AppSync, and Lambda.</data>
    <data key="d3">control, interactive</data>
    <data key="d4">True</data>
  </graph>
</graphml>
