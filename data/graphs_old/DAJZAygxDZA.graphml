<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Data Scientist</data>
      <data key="d6">UserCompanyDomainExpert</data>
      <data key="d7">Creates ML models using SageMaker and approves them in the SageMaker Model Registry to initiate the deployment process.</data>
    </node>
    <node id="1">
      <data key="d5">SageMaker Model Training</data>
      <data key="d6">SageMaker</data>
      <data key="d7">WORKLOAD_PEEK: Used by data scientists in automated pipelines to create ML models.</data>
    </node>
    <node id="2">
      <data key="d5">Model Registry</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">DATA_PEEK: Stores ML models after creation by automated pipelines. Models are approved here by data scientists before deployment.</data>
    </node>
    <node id="3">
      <data key="d5">ML Engineer</data>
      <data key="d6">UserCompanyDeveloper</data>
      <data key="d7">Responsible for operationalization of production models. Invokes the EXAMT deployment API to deploy models to QA and Production accounts.</data>
    </node>
    <node id="4">
      <data key="d5">EXAMT Deployment API</data>
      <data key="d6">ApiGateway</data>
      <data key="d7">WORKLOAD_PEEK: Acts as the deployment API for the EXAMT serverless application. Invoked by ML engineers to trigger cross-account model deployments.</data>
    </node>
    <node id="5">
      <data key="d5">EXAMT Orchestrator</data>
      <data key="d6">StepFunctions</data>
      <data key="d7">WORKLOAD_PEEK: Orchestrates the cross-account model deployment process for EXAMT, including fetching artifacts and deploying to SageMaker endpoints. EXAMT is a serverless application.</data>
    </node>
    <node id="6">
      <data key="d5">SageMaker QA Endpoint</data>
      <data key="d6">SageMaker</data>
      <data key="d7">WORKLOAD_PEEK: Endpoint in the QA account where models are deployed first for load and accuracy testing.</data>
    </node>
    <node id="7">
      <data key="d5">SageMaker Prod Endpoint</data>
      <data key="d6">SageMaker</data>
      <data key="d7">WORKLOAD_PEEK: Endpoint in the Production account where validated models are deployed for serving predictions to the scouting app. DATA_PEEK: Receives images and returns predictions via a REST interface.</data>
    </node>
    <node id="8">
      <data key="d5">Xavio Scouting App</data>
      <data key="d6">UserConsumerMobile</data>
      <data key="d7">Represents farmers using the Xavio Scouting app to take photos and receive predictions for identifying diseases and weeds. Application has over 6.5 million users from 100+ countries.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">Data scientists use SageMaker to create ML models.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="0" target="2" id="0">
      <data key="d8">1</data>
      <data key="d9">Data scientists approve models in the Model Registry, notifying ML engineers.</data>
      <data key="d10">0</data>
      <data key="d11">meta</data>
    </edge>
    <edge source="1" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">Automated pipelines register created ML models into SageMaker Model Registry.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="4" id="0">
      <data key="d8">1</data>
      <data key="d9">ML engineer invokes the EXAMT Deployment API to deploy models to the QA account.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="4" id="1">
      <data key="d8">1</data>
      <data key="d9">After QA testing, ML engineer invokes the EXAMT Deployment API again for deployment to the Production account.</data>
      <data key="d10">5</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="5" id="0">
      <data key="d8">1</data>
      <data key="d9">API Gateway triggers Step Functions for EXAMT orchestration.</data>
      <data key="d10">2</data>
      <data key="d11">meta</data>
    </edge>
    <edge source="4" target="5" id="1">
      <data key="d8">1</data>
      <data key="d9">API Gateway triggers Step Functions for EXAMT orchestration for production deployment.</data>
      <data key="d10">6</data>
      <data key="d11">meta</data>
    </edge>
    <edge source="5" target="2" id="0">
      <data key="d8">1</data>
      <data key="d9">Step Functions fetches the model artifact from the SageMaker Model Registry.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="6" id="0">
      <data key="d8">1</data>
      <data key="d9">Step Functions deploys the model to the SageMaker endpoint in the QA account.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="6" id="1">
      <data key="d8">1</data>
      <data key="d9">Step Functions fetches the validated model artifact from the QA account (from its endpoint's underlying storage or the endpoint itself).</data>
      <data key="d10">7</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="7" id="0">
      <data key="d8">1</data>
      <data key="d9">Step Functions deploys the model to the SageMaker endpoint in the Production account.</data>
      <data key="d10">8</data>
      <data key="d11">data</data>
    </edge>
    <edge source="7" target="8" id="0">
      <data key="d8">2</data>
      <data key="d9">The SageMaker Production endpoint creates and returns the prediction back to the scouting app (via middleware).</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="8" target="7" id="0">
      <data key="d8">2</data>
      <data key="d9">A farmer takes a photo with the scouting app, which is posted to the SageMaker Production endpoint.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">BASF Digital Farming: Productionizing ML with a Cross-Account Model Deployment Solution</data>
    <data key="d1">https://www.youtube.com/watch?v=DAJZAygxDZA</data>
    <data key="d2">BASF Digital Farming uses EXAMT (Cross-Account Model Deployment Tool) to reliably deploy ML models for their Xavio Scouting image recognition app across Data Science, QA, and Production AWS accounts. The app helps farmers identify diseases/weeds and has over 6.5 million users. EXAMT is a serverless application orchestrated by API Gateway and Step Functions, enabling automated model transitions after data scientists register and approve models.</data>
    <data key="d3">data_ingestion, compute_intensive, control</data>
    <data key="d4">True</data>
  </graph>
</graphml>
