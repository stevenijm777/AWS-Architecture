      <data key="d9">EMR jobs read raw data for processing and curation.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="9" target="10">
      <data key="d8">2</data>
      <data key="d9">EMR writes curated data to the S3 curated layer.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="9" target="11">
      <data key="d8">2</data>
      <data key="d9">EMR loads 'hot data' (last 5-6 months) from S3 curated layer into Redshift.</data>
      <data key="d10">3</data>
