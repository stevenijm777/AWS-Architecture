<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d12" for="edge" attr.name="id" attr.type="string" />
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">E-Commerce Users</data>
      <data key="d6">UserConsumerWebMobile</data>
      <data key="d7">The end customer using the Domino's or Dunkin' Donuts mobile app or website to place orders.</data>
    </node>
    <node id="1">
      <data key="d5">E-Commerce Platform</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">DATA_PEEK: Handles transactions from the mobile app, mobile website, and desktop website. Flows transactions to the POS System for fulfillment and stores them in the E-Commerce Database.</data>
    </node>
    <node id="2">
      <data key="d5">POS Agents</data>
      <data key="d6">UserCompanyAgent</data>
      <data key="d7">Employees at the 1,200 restaurants using Point-of-Sale machines.</data>
    </node>
    <node id="3">
      <data key="d5">POS System</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">DATA_PEEK: Point-of-sale machines in 1,200 restaurants handling transactions. Receives e-commerce transactions for serving and stores its own transactions in the POS Database.</data>
    </node>
    <node id="4">
      <data key="d5">E-Commerce Database</data>
      <data key="d6">RDS</data>
      <data key="d7">WORKLOAD_PEEK: A MySQL system storing e-commerce transaction data.</data>
    </node>
    <node id="5">
      <data key="d5">POS Database</data>
      <data key="d6">RDS</data>
      <data key="d7">WORKLOAD_PEEK: A 'consolidation server' database hosted on AWS cloud, storing data from POS machines. This is the source for custom ETL scripts.</data>
    </node>
    <node id="6">
      <data key="d5">Database Migration Service</data>
      <data key="d6">DMS</data>
      <data key="d7">Used to migrate data from the E-Commerce Database into the S3 Raw Layer (data lake).</data>
    </node>
    <node id="7">
      <data key="d5">Custom ETL Process</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">WORKLOAD_PEEK: Custom ETL scripts developed by Jubilant Foodworks. They transform and load data specifically from the POS Database into the S3 Raw Layer. (Transcript overrides diagram here for POS data path).</data>
    </node>
    <node id="8">
      <data key="d5">S3 Raw Layer (Data Lake)</data>
      <data key="d6">S3</data>
      <data key="d7">DATA_PEEK: The initial raw data dump, forming the data lake. All data from various sources lands here first.</data>
    </node>
    <node id="9">
      <data key="d5">EMR Jobs</data>
      <data key="d6">EMR</data>
      <data key="d7">WORKLOAD_PEEK: Used for two main purposes: (1) moving and transforming data from the S3 Raw Layer into the S3 Curated Layer, and (2) loading 'hot data' (last 5-6 months) from the S3 Curated Layer into Redshift.</data>
    </node>
    <node id="10">
      <data key="d5">S3 Curated Layer</data>
      <data key="d6">S3</data>
      <data key="d7">DATA_PEEK: Contains transformed and curated data. Serves as a source for Redshift, Athena, and third-party services. Stores years of cold/warm data.</data>
    </node>
    <node id="11">
      <data key="d5">Redshift Data Warehouse</data>
      <data key="d6">RedShift</data>
      <data key="d7">DATA_PEEK: Stores 'hot data' (last 5-6 months) for high-performance daily analytics and reporting. Part of the data warehouse solution.</data>
    </node>
    <node id="12">
      <data key="d5">Redshift Spectrum</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">WORKLOAD_PEEK: A serverless query engine that allows Redshift to transparently query and join data residing in the S3 Curated Layer with data in Redshift itself. Provides cost savings and performance enhancement for queries involving cold/warm data.</data>
    </node>
    <node id="13">
      <data key="d5">Athena Ad-Hoc Analytics</data>
      <data key="d6">Athena</data>
      <data key="d7">WORKLOAD_PEEK: 'Lifesaver' for business. Data analysts fire hundreds of ad-hoc SQL-like queries daily directly into the S3 Curated Layer to get insights on years of historical data (e.g., year-on-year growth).</data>
    </node>
    <node id="14">
      <data key="d5">Data Analysts</data>
      <data key="d6">UserCompanyAnalyst</data>
      <data key="d7">Queries data in Redshift and Athena to provide insights to business stakeholders.</data>
    </node>
    <node id="15">
      <data key="d5">External Services</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Other third-party services that consume curated data directly from the S3 Curated Layer.</data>
    </node>
    <node id="16">
      <data key="d5">HRIS System (Future Source)</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Future data source for human resource information, planned for integration into the S3 Raw Layer.</data>
    </node>
    <node id="17">
      <data key="d5">SAP System (Future Source)</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Future data source for inventory data from SAP, planned for integration into the S3 Raw Layer.</data>
    </node>
    <node id="18">
      <data key="d5">SageMaker (Future ML)</data>
      <data key="d6">SageMaker</data>
      <data key="d7">Planned for future use to build, train, and deploy machine learning models. Will use years of historical data from the S3 Curated Layer as training data.</data>
    </node>
    <node id="19">
      <data key="d5">Forecasting &amp; Personalization Engines (Future)</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Future systems to be powered by SageMaker's ML models. Aims to enhance consumer experience through better forecasting and personalization.</data>
    </node>
