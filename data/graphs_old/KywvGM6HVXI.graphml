<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d12" for="edge" attr.name="id" attr.type="string" />
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Configurers</data>
      <data key="d6">UserCompanyDeveloper</data>
      <data key="d7">Users who define events, event attributes, validations, and workflows for their tenants within the Capillary platform.</data>
    </node>
    <node id="1">
      <data key="d5">Application Load Balancer</data>
      <data key="d6">ALB</data>
      <data key="d7">Entry point for platform configurers to access Capillary's APIs for event definition.</data>
    </node>
    <node id="2">
      <data key="d5">API Kubernetes Cluster</data>
      <data key="d6">EKS</data>
      <data key="d7">Hosts Capillary's internal APIs, which allow configurers to define custom events. These APIs run on a Kubernetes cluster.</data>
    </node>
    <node id="3">
      <data key="d5">Event Meta Store</data>
      <data key="d6">DynamoDB</data>
      <data key="d7">Persists event definitions, attributes, validations, and workflow configurations created by platform configurers.</data>
    </node>
    <node id="4">
      <data key="d5">End User</data>
      <data key="d6">UserConsumerWebMobile</data>
      <data key="d7">Customers of retailers/brands who perform actions (e.g., rating a product) that generate events.</data>
    </node>
    <node id="5">
      <data key="d5">Event Integration System</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">External third-party applications where retailers/brands register webhooks provided by Capillary to send customer events.</data>
    </node>
    <node id="6">
      <data key="d5">API Gateway</data>
      <data key="d6">ApiGateway</data>
      <data key="d7">Ingestion point for incoming customer events from third-party systems via webhooks.</data>
    </node>
    <node id="7">
      <data key="d5">Webhook Lambda</data>
      <data key="d6">Lambda</data>
      <data key="d7">Processes incoming webhook events. Reads event metadata from DynamoDB (Event Meta Store) for authentication and tenant identification. Highly scalable to handle unpredictable bursts in event volumes (e.g., flash sales). WORKLOAD_PEEK: Scales up/down very fast. DATA_PEEK: Handles bursts that can swell to 10M events in an hour.</data>
    </node>
    <node id="8">
      <data key="d5">Event Queue</data>
      <data key="d6">SQS</data>
      <data key="d7">Buffers incoming events from the Webhook Lambda. Decouples event ingestion from processing, handling significant spikes in volume. DATA_PEEK: Normally sees up to 10 million events a day, can swell to same volume within an hour during bursts.</data>
    </node>
    <node id="9">
      <data key="d5">Processor Lambda</data>
      <data key="d6">Lambda</data>
      <data key="d7">Consumes events from SQS. Determines actions based on event definitions. Has multiple responsibilities, with plans to break down into more granular Lambdas orchestrated by Step Functions. WORKLOAD_PEEK: Scales up/down at a slower pace than Webhook Lambda, depending on SQS queue size.</data>
    </node>
    <node id="10">
      <data key="d5">Event Analysis Store</data>
      <data key="d6">DynamoDB</data>
      <data key="d7">Persists a subset of processed events for pure analysis.</data>
    </node>
    <node id="11">
      <data key="d5">Event Stream</data>
      <data key="d6">KinesisDataStream</data>
      <data key="d7">Receives events from the Processor Lambda that require further processing by downstream workers.</data>
    </node>
    <node id="12">
      <data key="d5">Worker Kubernetes Cluster</data>
      <data key="d6">EKS</data>
      <data key="d7">Hosts Capillary's internal workers that consume from Kinesis. These workers facilitate various actions such as allocating points, sending thank you messages, offering promotions, or unlocking game stages. The team plans to evaluate Amazon Kubernetes management (EKS) for offloading infrastructure management.</data>
    </node>
    <edge source="0" target="1">
      <data key="d8">0</data>
      <data key="d9">Configurers access the platform via ALB to define events.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="1" target="2">
      <data key="d8">0</data>
      <data key="d9">ALB routes requests to the Kubernetes cluster running Capillary's APIs.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="2" target="3">
      <data key="d8">0</data>
      <data key="d9">APIs persist event definitions, attributes, validations, and workflows into the event meta store.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="4" target="5">
      <data key="d8">1</data>
      <data key="d9">End users perform actions that are captured by the retailer's third-party event integration system.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="5" target="6">
      <data key="d8">1</data>
      <data key="d9">The third-party system sends customer events to Capillary's API Gateway via a registered webhook.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="6" target="7">
      <data key="d8">1</data>
      <data key="d9">API Gateway routes incoming event requests to the Webhook Lambda.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="7" target="3">
      <data key="d8">1</data>
      <data key="d9">Webhook Lambda reads event metadata from the Event Meta Store for authentication and tenant identification.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="7" target="8">
      <data key="d8">1</data>
      <data key="d9">After initial processing, the Webhook Lambda passes the event to the SQS queue.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="8" target="9">
      <data key="d8">1</data>
      <data key="d9">The Processor Lambda consumes events from the SQS queue for further processing.</data>
      <data key="d10">5</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="9" target="10">
      <data key="d8">1</data>
      <data key="d9">Processor Lambda persists some events directly into the Event Analysis Store for future analysis.</data>
      <data key="d10">6a</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="9" target="11">
      <data key="d8">1</data>
      <data key="d9">Processor Lambda flows other events into Kinesis for real-time processing by downstream workers.</data>
      <data key="d10">6b</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="11" target="12">
      <data key="d8">1</data>
      <data key="d9">Workers running on a Kubernetes cluster consume events from Kinesis to perform various customer engagement actions.</data>
      <data key="d10">7</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <data key="d0">Capillary Technologies: Building an OmniChannel Data Ingestion Platform</data>
    <data key="d1">https://www.youtube.com/watch?v=KywvGM6HVXI</data>
    <data key="d2">Capillary operates a multi-tenanted SaaS platform for customer engagement, leveraging AI/ML. This architecture focuses on understanding customer behavior by processing diverse event types. The system handles significant burst volumes, scaling to 10 million events per hour during peaks. A key design decision is using serverless components (API Gateway, Lambda, SQS) to manage unpredictable event traffic and scale.</data>
    <data key="d3">data_ingestion, interactive, compute_intensive</data>
    <data key="d4">True</data>
  </graph>
</graphml>
