<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d12" for="edge" attr.name="id" attr.type="string" />
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="user_company_agent">
      <data key="d5">Supply Chain Participants</data>
      <data key="d6">UserCompanyAgent</data>
      <data key="d7">Actors like project managers, suppliers, distributors, utility companies, and contractors who initiate purchase orders, handle assets, and receive critical alerts regarding supply chain events and anomalies.</data>
    </node>
    <node id="sap_erp">
      <data key="d5">SAP ERP System</data>
      <data key="d6">SAP</data>
      <data key="d7">WORKLOAD_PEEK: Existing enterprise resource planning (ERP) system used by utility companies. Initiates the supply chain process by ordering new materials (e.g., pipes). Integrates with the blockchain solution via an API call.</data>
    </node>
    <node id="managed_blockchain">
      <data key="d5">Amazon Managed Blockchain (Hyperledger Fabric)</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">DATA_PEEK: Hosts a shared, immutable ledger (Hyperledger Fabric 1.2) containing supply chain information, purchase orders, asset tracking data, and workflow state. WORKLOAD_PEEK: Executes smart contracts (chain code) to manage workflow progression, validate actions, and maintain privacy between parties. Serves as the single source of truth.</data>
    </node>
    <node id="iot_core">
      <data key="d5">AWS IoT Core</data>
      <data key="d6">IoTCore</data>
      <data key="d7">DATA_PEEK: Ingests telemetry data (e.g., location, movement, sensor readings) from physical assets and supply chain handoffs. WORKLOAD_PEEK: Configured with specific thresholds for location and movement. When thresholds are met or anomalies detected, it triggers updates to the blockchain and sends notifications.</data>
    </node>
    <node id="user_consumer_mobile">
      <data key="d5">Mobile App User</data>
      <data key="d6">UserConsumerMobile</data>
      <data key="d7">End-users (utility company personnel, contractors) interacting with a mobile application to receive critical notifications and perform 'Actions' that update the blockchain state.</data>
    </node>
    <edge source="user_company_agent" target="sap_erp">
      <data key="d8">0</data>
      <data key="d9">Project managers initiate purchase orders for new supplies within the SAP ERP system.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="user_company_agent" target="managed_blockchain">
      <data key="d8">0</data>
      <data key="d9">Different supply chain parties perform 'intended actions' that update the workflow status and information on the blockchain.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="user_company_agent" target="iot_core">
      <data key="d8">1</data>
      <data key="d9">Physical assets (associated with supply chain participants) send telemetry data (location, movement, sensor readings) to AWS IoT Core.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="sap_erp" target="managed_blockchain">
      <data key="d8">0</data>
      <data key="d9">Information from SAP (e.g., purchase order details) is sent via a simple API call to be recorded on the blockchain, kicking off the process.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="managed_blockchain" target="user_consumer_mobile">
      <data key="d8">2</data>
      <data key="d9">Chain code updates on the blockchain trigger notifications to mobile app users, e.g., for workflow progression or if a 'wrong actor tries to do something'.</data>
      <data key="d10">2</data>
      <data key="d11">meta</data>
      <data key="d12">0</data>
    </edge>
    <edge source="managed_blockchain" target="user_company_agent">
      <data key="d8">2</data>
      <data key="d9">Chain code updates on the blockchain trigger notifications to contractors or utility companies, e.g., for workflow progression or unauthorized actions.</data>
      <data key="d10">3</data>
      <data key="d11">meta</data>
      <data key="d12">0</data>
    </edge>
    <edge source="iot_core" target="managed_blockchain">
      <data key="d8">1</data>
      <data key="d9">IoT Core adds information (e.g., location updates, event data) onto the blockchain based on predefined thresholds and sensor readings.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="iot_core" target="user_consumer_mobile">
      <data key="d8">2</data>
      <data key="d9">IoT sensors (via IoT Core) send mobile notifications to users when asset anomalies or unusual movements are detected based on thresholds.</data>
      <data key="d10">0</data>
      <data key="d11">meta</data>
      <data key="d12">0</data>
    </edge>
    <edge source="iot_core" target="user_company_agent">
      <data key="d8">2</data>
      <data key="d9">IoT sensors (via IoT Core) send notifications to contractors or utility companies when asset anomalies are detected.</data>
      <data key="d10">1</data>
      <data key="d11">meta</data>
      <data key="d12">0</data>
    </edge>
    <edge source="user_consumer_mobile" target="managed_blockchain">
      <data key="d8">2</data>
      <data key="d9">Users interact with the mobile app to perform 'Actions' which update the chain code and blockchain state.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <data key="d0">PwC: Streamlining Asset Tracking with Amazon Managed Blockchain</data>
    <data key="d1">https://www.youtube.com/watch?v=KzJKdUZ3Ba4</data>
    <data key="d2">This architecture addresses material traceability and supply chain transparency for utility companies. Key requirements include end-to-end transparency, maintaining data privacy between parties, and integration with existing workflows like SAP. The platform combats authenticity issues and reduces manual reconciliation processes by creating a shared, immutable digital ledger.</data>
    <data key="d3">data_ingestion, interactive, control</data>
    <data key="d4">True</data>
  </graph>
</graphml>
