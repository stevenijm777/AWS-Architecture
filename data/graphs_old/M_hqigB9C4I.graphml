<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d12" for="edge" attr.name="id" attr.type="string" />
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Hospitals</data>
      <data key="d6">UserConsumerHospital</data>
      <data key="d7">DATA_PEEK: Source of EHR data from various systems and clinics. WORKLOAD_PEEK: Data extracted from 500 different geographical facilities.</data>
    </node>
    <node id="1">
      <data key="d5">S3 Bucket</data>
      <data key="d6">S3</data>
      <data key="d7">DATA_PEEK: Landing zone for raw EHR data extracted from hospitals.</data>
    </node>
    <node id="2">
      <data key="d5">EMR Jobs</data>
      <data key="d6">EMR</data>
      <data key="d7">WORKLOAD_PEEK: Extracts data from S3, performs data parsing, massaging, and transformation into a unified canonical data model. Previously used Hadoop ecosystem with Spark on EC2. Significantly reduced costs.</data>
    </node>
    <node id="3">
      <data key="d5">Neo4j</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">WORKLOAD_PEEK: Utilized as a correlation engine for patient deduplication and indexing. Uses algorithms like Levenstein, weighted Levenstein, and fuzzy matching to uniquely identify patients across different data sources.</data>
    </node>
    <node id="4">
      <data key="d5">Redshift</data>
      <data key="d6">RedShift</data>
      <data key="d7">DATA_PEEK: OLAP system for processed and analyzed data.</data>
    </node>
    <node id="5">
      <data key="d5">Aurora</data>
      <data key="d6">Aurora</data>
      <data key="d7">DATA_PEEK: Application data store, synced with processed data from Redshift, used to power front-end applications.</data>
    </node>
    <node id="6">
      <data key="d5">Innovasr Applications</data>
      <data key="d6">EC2</data>
      <data key="d7">WORKLOAD_PEEK: Powers applications used by care providers. Utilizes data from Aurora. Future plans include migrating to a multi-tenant SaaS platform using ECR and EKS.</data>
    </node>
    <node id="7">
      <data key="d5">Amazon Connect</data>
      <data key="d6">Connect</data>
      <data key="d7">WORKLOAD_PEEK: Used for automated patient outreach. Triggered when the data system identifies patients requiring medical intervention (e.g., calls to remind patients for visits or medication).</data>
    </node>
    <node id="8">
      <data key="d5">Care Provider</data>
      <data key="d6">UserCompanyAgent</data>
      <data key="d7">WORKLOAD_PEEK: End-users of the Innovasr applications, including doctors and health coaches, who consume data and get insights about patients.</data>
    </node>
    <edge source="0" target="1">
      <data key="d8">0</data>
      <data key="d9">Data extraction from EHR systems and placement into S3.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="1" target="2">
      <data key="d8">0</data>
      <data key="d9">EMR jobs extract data from S3 for processing.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="2" target="4">
      <data key="d8">0</data>
      <data key="d9">Processed and transformed data is put into Redshift.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="2" target="3">
      <data key="d8">0</data>
      <data key="d9">EMR system pushes data to Neo4j for correlation.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="3" target="5">
      <data key="d8">0</data>
      <data key="d9">Correlation engine results contribute to the application data store (inferred from diagram and 'once all data has been processed...data is synced into our application data store. That is Aurora').</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="4" target="5">
      <data key="d8">0</data>
      <data key="d9">Processed data from Redshift is synced into Aurora to power applications.</data>
      <data key="d10">5</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="5" target="6">
      <data key="d8">1</data>
      <data key="d9">Applications utilize information from Aurora.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="6" target="8">
      <data key="d8">1</data>
      <data key="d9">Care providers use the applications to gain insights.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="6" target="7">
      <data key="d8">2</data>
      <data key="d9">Workflow triggered by the data system (applications) calls a contact flow in Connect.</data>
      <data key="d10">0</data>
      <data key="d11">meta</data>
      <data key="d12">0</data>
    </edge>
    <data key="d0">Innovaccer: Deriving Insights from Healthcare Data to Empower Care Teams</data>
    <data key="d1">https://www.youtube.com/watch?v=M_hqigB9C4I</data>
    <data key="d2">Innovasr provides a healthcare data platform that extracts, transforms, and unifies patient health records from 500 geographical facilities, managing 10 million patients and 20 billion records for 10,000 care providers. The core challenge is integrating data from multiple EHR systems with diverse data models. The platform processes raw data, performs patient deduplication and correlation, and powers applications for healthcare providers. It also includes an automated patient outreach system. Future plans involve migrating to a multi-tenant SaaS platform using EKS/ECR and integrating SageMaker for predictive analytics.</data>
    <data key="d3">data_ingestion, compute_intensive, interactive</data>
    <data key="d4">True</data>
  </graph>
</graphml>
