  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Customer</data>
      <data key="d6">UserConsumerWebMobile</data>
      <data key="d7">DATA_PEEK: Handles over 1 million phone calls per month. WORKLOAD_PEEK: Previously 81,000 interaction pathways, simplified to 200 intents through Lex. Interacts via synchronous chat and voice.</data>
    </node>
    <node id="1">
      <data key="d5">Contact Center Solution</data>
      <data key="d6">Connect</data>
      <data key="d7">WORKLOAD_PEEK: Core of the contact center solution, handling 1 million+ calls/month. Processes synchronous chat and voice. Utilizes Contact Lens for sentiment analysis, transcription, CTR attributes, and contact flow logs. Configured by universal, modular contact flows.</data>
    </node>
    <node id="2">
      <data key="d5">Intent Matching</data>
      <data key="d6">Lex</data>
      <data key="d7">WORKLOAD_PEEK: Simplified 81,000 interaction pathways to 200 intents for billing, sales, product requests. Used for both chat and voice interactions with Connect.</data>
    </node>
    <node id="3">
      <data key="d5">Contact Flow Configurator</data>
      <data key="d6">Lambda</data>
      <data key="d7">WORKLOAD_PEEK: Supplies dynamic configuration logic for Connect's universal contact flows, stitching them together based on customer interaction and Lex intents.</data>
    </node>
    <node id="4">
      <data key="d5">Contact Flow Configuration Store</data>
      <data key="d6">DynamoDB</data>
      <data key="d7">DATA_PEEK: Stores configuration data for Connect's universal contact flows, retrieved by Lambda.</data>
    </node>
    <node id="5">
      <data key="d5">Data Warehouse (Snowflake)</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">DATA_PEEK: Aggregates contact data from Connect (Contact Lens outputs, CTR attributes, contact flow logs) and provides a single view of customer information.</data>
    </node>
    <node id="6">
      <data key="d5">Operational Dashboard</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">WORKLOAD_PEEK: Provides insights to agents, team leads, and developers on customer interactions and product performance. Critical for continuous information feedback and measuring improvements.</data>
    </node>
    <node id="7">
      <data key="d5">Agents</data>
      <data key="d6">UserCompanyAgent</data>
      <data key="d7">WORKLOAD_PEEK: Over 2,500 agents across three geographic locations. Queries the Operational Dashboard for insights into customer interactions and performance.</data>
    </node>
    <node id="8">
      <data key="d5">Team Leads</data>
      <data key="d6">UserCompanyAnalyst</data>
      <data key="d7">Queries the Operational Dashboard for insights and to understand how customers are interacting with products.</data>
    </node>
    <node id="9">
      <data key="d5">Developers</data>
      <data key="d6">UserCompanyDeveloper</data>
      <data key="d7">Queries the Operational Dashboard for insights and to be informed about how changes impact customers. Interacts with DevTools for Infrastructure as Code deployments.</data>
    </node>
    <node id="10">
      <data key="d5">Developer Tooling</data>
      <data key="d6">DevTools</data>
      <data key="d7">WORKLOAD_PEEK: Provides the interface for developers to implement infrastructure as code for automated, no-touch, tested deployments.</data>
    </node>
    <node id="11">
      <data key="d5">Infrastructure as Code (Terraform)</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">WORKLOAD_PEEK: Used by developers via DevTools to automatically promote/deploy Connect flows, Lex intents, Lambda functions, DynamoDB tables, and other AWS services.</data>
    </node>
    <edge source="0" target="1">
      <data key="d8">0</data>
      <data key="d9">Customer initiates contact (phone call or chat) with the contact center.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
