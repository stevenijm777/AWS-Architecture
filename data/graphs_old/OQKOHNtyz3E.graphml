      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="1" target="3">
      <data key="d8">0</data>
      <data key="d9">Connect requests dynamic configuration for the universal contact flow based on the customer's intent.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="1" target="5">
      <data key="d8">1</data>
      <data key="d9">Connect pumps out contact data, including Contact Lens outputs (sentiment, transcription), CTR attributes, and contact flow logs to the Snowflake data warehouse.</data>
