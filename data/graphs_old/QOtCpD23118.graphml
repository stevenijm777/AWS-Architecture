  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Vehicle IoT Devices</data>
      <data key="d6">UserConsumerIOT</data>
      <data key="d7">DATA_PEEK: Vehicle speed, GPS, G-forces, and car computer telemetry.</data>
    </node>
    <node id="1">
      <data key="d5">Ingestion Lambda</data>
      <data key="d6">Lambda</data>
      <data key="d7">WORKLOAD_PEEK: Ingests raw telematics from IoT devices.</data>
    </node>
    <node id="2">
      <data key="d5">Raw Data Lake S3</data>
      <data key="d6">S3</data>
      <data key="d7">DATA_PEEK: Raw telemetry records.</data>
    </node>
    <node id="3">
      <data key="d5">Ingestion Queue</data>
      <data key="d6">SQS</data>
      <data key="d7">WORKLOAD_PEEK: Manages performance and ensures durability using fixed batch sizes.</data>
    </node>
    <node id="4">
      <data key="d5">Enrichment Lambda</data>
      <data key="d6">Lambda</data>
      <data key="d7">WORKLOAD_PEEK: Merges telemetry data with map data.</data>
    </node>
    <node id="5">
      <data key="d5">OpenStreetMaps S3</data>
      <data key="d6">S3</data>
      <data key="d7">DATA_PEEK: Pre-chunked OSM map data in 5,000 1-degree chunks.</data>
    </node>
    <node id="6">
      <data key="d5">Kinesis Stream</data>
      <data key="d6">Kinesis</data>
      <data key="d7">WORKLOAD_PEEK: Sliding window queries to detect events like speeding.</data>
    </node>
    <node id="7">
      <data key="d5">Processed Events S3</data>
      <data key="d6">S3</data>
      <data key="d7">DATA_PEEK: Speeding, seat belt violations, and acceleration events.</data>
    </node>
    <node id="8">
      <data key="d5">Glue ETL</data>
      <data key="d6">Glue</data>
      <data key="d7">WORKLOAD_PEEK: Consolidates event reports and exports them.</data>
    </node>
    <node id="9">
      <data key="d5">Athena Query Engine</data>
      <data key="d6">Athena</data>
      <data key="d7">WORKLOAD_PEEK: Runs queries on raw data for summaries (e.g., mileage).</data>
    </node>
    <node id="10">
      <data key="d5">On-Premises Data Center</data>
      <data key="d6">OnPremDC</data>
      <data key="d7">DATA_PEEK: Customer reports, dashboards, and driver scorecards.</data>
    </node>
    <edge source="0" target="1">
      <data key="d8">0</data>
      <data key="d9">Sends raw vehicle telemetry data.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="1" target="2">
      <data key="d8">0</data>
      <data key="d9">Saves raw records into data lake.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="2" target="3">
      <data key="d8">0</data>
      <data key="d9">Batches raw data into SQS.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="2" target="9">
      <data key="d8">2</data>
      <data key="d9">Analyzes raw telemetry for trip summaries.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="3" target="4">
      <data key="d8">1</data>
      <data key="d9">Triggers processing Lambda.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="4" target="6">
      <data key="d8">1</data>
      <data key="d9">Pushes matched telemetry and map data.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="5" target="4">
      <data key="d8">1</data>
      <data key="d9">Fetches local 1-degree map chunk.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
