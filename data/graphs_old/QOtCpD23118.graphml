    <edge source="7" target="8">
      <data key="d8">2</data>
      <data key="d9">Reads safety events.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="8" target="10">
      <data key="d8">2</data>
      <data key="d9">Loads final reports to on-prem data store.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
