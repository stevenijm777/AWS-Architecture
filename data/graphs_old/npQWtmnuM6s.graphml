<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">SwiftX Engineers</data>
      <data key="d6">UserCompanyDeveloper</data>
      <data key="d7">Developer working on local machine, initiating pull requests and code reviews.</data>
    </node>
    <node id="1">
      <data key="d5">GitHub</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Source control and pull request platform triggering CI/CD pipelines.</data>
    </node>
    <node id="2">
      <data key="d5">CI/CD Account - Tekton EKS Cluster</data>
      <data key="d6">EKS</data>
      <data key="d7">Kubernetes cluster running Tekton to build images, run tests, and perform security checks.</data>
    </node>
    <node id="3">
      <data key="d5">Elastic Container Registry (ECR)</data>
      <data key="d6">ECR</data>
      <data key="d7">Centralized registry in CI/CD account storing secure, signed container images.</data>
    </node>
    <node id="4">
      <data key="d5">Playground EKS Clusters</data>
      <data key="d6">EKS</data>
      <data key="d7">Hosts ephemeral feature-branch environments for product manager and stakeholder review.</data>
    </node>
    <node id="5">
      <data key="d5">Development EKS Cluster</data>
      <data key="d6">EKS</data>
      <data key="d7">Initial promotion environment to validate built images before production.</data>
    </node>
    <node id="6">
      <data key="d5">Production EKS Cluster</data>
      <data key="d6">EKS</data>
      <data key="d7">Highly secure production workspace running live exchange workloads.</data>
    </node>
    <node id="7">
      <data key="d5">AWS Control Tower</data>
      <data key="d6">ControlTower</data>
      <data key="d7">Manages 14+ AWS accounts to ensure consistent security baselines and configuration.</data>
    </node>
    <node id="8">
      <data key="d5">Amazon Security Lake</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Aggregates security logs globally in a centralized security account.</data>
    </node>
    <node id="9">
      <data key="d5">Amazon GuardDuty</data>
      <data key="d6">GuardDuty</data>
      <data key="d7">Monitors threat behavior and forwards events to Security Lake.</data>
    </node>
    <node id="10">
      <data key="d5">VPC Flow Logs</data>
      <data key="d6">VPC</data>
      <data key="d7">Collects network traffic details, feeding them to Security Lake.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">Developer pushes code to feature branch and opens a PR.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="0" target="1" id="1">
      <data key="d8">1</data>
      <data key="d9">Two reviewers approve the PR, prompting a merge to main.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">PR triggers Tekton pipeline within EKS.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="2" id="1">
      <data key="d8">1</data>
      <data key="d9">Merge triggers final production pipeline on Tekton.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="3" id="0">
      <data key="d8">0</data>
      <data key="d9">Tekton builds, tests, and pushes the signed image to ECR.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="3" id="1">
      <data key="d8">1</data>
      <data key="d9">Builds and stores highly vetted image in ECR.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="4" id="0">
      <data key="d8">0</data>
      <data key="d9">Promoted via IAM roles to ephemeral Playground environments.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="5" id="0">
      <data key="d8">1</data>
      <data key="d9">IAM role-based push to Development environment EKS.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="0" id="0">
      <data key="d8">0</data>
      <data key="d9">Stakeholders and developers review running feature environments.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="6" id="0">
      <data key="d8">1</data>
      <data key="d9">Promoted to Production EKS after passing automated development tests.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <edge source="6" target="0" id="0">
      <data key="d8">1</data>
      <data key="d9">Successful production deployment notification.</data>
      <data key="d10">5</data>
      <data key="d11">meta</data>
    </edge>
    <edge source="6" target="8" id="0">
      <data key="d8">2</data>
      <data key="d9">Application and audit logs from EKS forwarded to Security Lake.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="9" target="8" id="0">
      <data key="d8">2</data>
      <data key="d9">GuardDuty logs sent to centralized Security Lake.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="10" target="8" id="0">
      <data key="d8">2</data>
      <data key="d9">VPC Flow Logs forwarded to Security Lake.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">Swyftx: Building Automated, Secure, and Attestable Pipelines from Engineers to Production</data>
    <data key="d1">https://www.youtube.com/watch?v=npQWtmnuM6s</data>
    <data key="d2">SwiftX manages billions in customer funds. They use AWS Control Tower to manage 14+ segregated accounts. Code pipelines run inside EKS using Tekton, promoting signed container images via IAM roles across Playground, Dev, and Prod. Security Lake consolidates audit logs.</data>
    <data key="d3">compute_intensive, control</data>
    <data key="d4">True</data>
  </graph>
</graphml>
