<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Security Administrator</data>
      <data key="d6">UserCompanyAnalyst</data>
      <data key="d7">Configures security profiles, monitors compliance, and reviews threat reports.</data>
    </node>
    <node id="1">
      <data key="d5">Aqua SaaS Management Console</data>
      <data key="d6">EKS</data>
      <data key="d7">DATA_PEEK: Central management plane for security analysis, alerts, policy definitions, and reporting.</data>
    </node>
    <node id="2">
      <data key="d5">Customer Application Pods</data>
      <data key="d6">EKS</data>
      <data key="d7">WORKLOAD_PEEK: Core containerized applications running on customer's managed EKS worker nodes.</data>
    </node>
    <node id="3">
      <data key="d5">Aqua Enforcer DaemonSet</data>
      <data key="d6">EKS</data>
      <data key="d7">WORKLOAD_PEEK: Deployed on each EKS node to perform real-time kernel, network, and process monitoring and inline blocking.</data>
    </node>
    <node id="4">
      <data key="d5">Customer End User</data>
      <data key="d6">UserConsumerWeb</data>
      <data key="d7">Interacts with the customer's cloud application.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">Analyst defines and deploys security policies on the SaaS console.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="3" id="0">
      <data key="d8">0</data>
      <data key="d9">SaaS console distributes policies to Enforcers running on customer EKS nodes.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="0" id="0">
      <data key="d8">0</data>
      <data key="d9">Analyst views security alerts and compliance reports in the dashboard.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="4" id="0">
      <data key="d8">1</data>
      <data key="d9">Allowed application traffic continues to serve the customer end user.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">Enforcer monitors process execution, syscalls, and network activities.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="2" id="1">
      <data key="d8">1</data>
      <data key="d9">Enforcer detects and blocks anomalous/unauthorized processes inside the container dynamically while preserving application uptime.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">Enforcer streams security telemetry and audit logs back to SaaS console.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="2" id="0">
      <data key="d8">1</data>
      <data key="d9">End user requests access to containerized application features.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">Aqua Security: Enabling Real Time Blocking, Scalability, and High Availability in Containers</data>
    <data key="d1">https://www.youtube.com/watch?v=s4eerNhXf84</data>
    <data key="d2">Aqua Security uses a daemonset-based Enforcer agent to secure workloads running on customer EKS clusters in real-time, offering deep visibility and active blocking without impacting application availability.</data>
    <data key="d3">compute_intensive, interactive, control</data>
    <data key="d4">True</data>
  </graph>
</graphml>
