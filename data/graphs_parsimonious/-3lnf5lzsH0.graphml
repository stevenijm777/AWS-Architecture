<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">AWS Services</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Various AWS public cloud services (S3, SNS, SQS, CloudTrail, GuardDuty) generating telemetry events for security analysis.</data>
    </node>
    <node id="1">
      <data key="d5">On-Premise Data Sources</data>
      <data key="d6">OnPremDC</data>
      <data key="d7">On-premise ecosystem generating telemetry events, integrated via standard syslog or Kafka.</data>
    </node>
    <node id="2">
      <data key="d5">Apache Metron</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">The heart of the next-gen SOC, performing real-time parsing, enrichment, and profiling of telemetry data from hybrid sources. Converts logs into a standardized JSON format.</data>
    </node>
    <node id="3">
      <data key="d5">EMR</data>
      <data key="d6">EMR</data>
      <data key="d7">Used to transform persistent data, initially from Apache Metron's HDFS backbone, into S3 for the security data lake.</data>
    </node>
    <node id="4">
      <data key="d5">Security Data Lake S3</data>
      <data key="d6">S3</data>
      <data key="d7">Serverless security data lake housing telemetry events for months or years, supporting horizontally scalable storage. Also feeds data back to Metron for profile generation.</data>
    </node>
    <node id="5">
      <data key="d5">Athena</data>
      <data key="d6">Athena</data>
      <data key="d7">Leveraged on S3 data for SQL queries, analytics, log mining, and forensics.</data>
    </node>
    <node id="6">
      <data key="d5">Blitz SOAR Platform</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Security orchestration and response platform ('Blitz') dealing with incident response and automation. Takes alerts from Metron, adds contextual info, and presents them to analysts.</data>
    </node>
    <node id="7">
      <data key="d5">SOC Analysts</data>
      <data key="d6">UserConsumerWeb</data>
      <data key="d7">Security Operations Center analysts who receive alerts and take automated or semi-automated actions to mitigate threats, via a single pane of glass or integrations like Jira.</data>
    </node>
    <node id="8">
      <data key="d5">WAF / Firewall</data>
      <data key="d6">WAF</data>
      <data key="d7">Target for automated response actions initiated by SOC analysts or the SOAR platform, e.g., blocking malicious source IPs.</data>
    </node>
    <node id="9">
      <data key="d5">Apache NIFI</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Used to build workflows and pull telemetry events from various AWS services into Apache Metron.</data>
    </node>
    <edge source="0" target="9" id="0">
      <data key="d8">0</data>
      <data key="d9">Telemetry events from AWS services are pulled by NIFI.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="2" id="0">
      <data key="d8">2</data>
      <data key="d9">On-prem events are ingested into Apache Metron via syslog or Kafka.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="3" id="0">
      <data key="d8">3</data>
      <data key="d9">Persistent data from Apache Metron (originally HDFS) is picked up by EMR.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="6" id="0">
      <data key="d8">7</data>
      <data key="d9">Alerts generated by Apache Metron are sent to the SOAR platform.</data>
      <data key="d10">7</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="4" id="0">
      <data key="d8">4</data>
      <data key="d9">EMR transforms and stores processed data into S3 for the security data lake.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="5" id="0">
      <data key="d8">5</data>
      <data key="d9">Athena queries and analyzes the data residing in S3.</data>
      <data key="d10">5</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="2" id="0">
      <data key="d8">6</data>
      <data key="d9">A feedback loop from the security data lake (S3) to Apache Metron to generate more accurate profiles/models over long periods.</data>
      <data key="d10">6</data>
      <data key="d11">data</data>
    </edge>
    <edge source="6" target="7" id="0">
      <data key="d8">8</data>
      <data key="d9">SOAR presents alerts and contextual information to SOC analysts.</data>
      <data key="d10">8</data>
      <data key="d11">data</data>
    </edge>
    <edge source="7" target="8" id="0">
      <data key="d8">9</data>
      <data key="d9">SOC analysts initiate response actions (e.g., blocking threats) via integrations like WAF or firewalls.</data>
      <data key="d10">9</data>
      <data key="d11">data</data>
    </edge>
    <edge source="9" target="2" id="0">
      <data key="d8">1</data>
      <data key="d9">NIFI pulls telemetry events into Apache Metron.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">Next-Gen Security Operations Center (SOC) at MakeMyTrip</data>
    <data key="d1">https://www.youtube.com/watch?v=-3lnf5lzsH0</data>
    <data key="d2">MakeMyTrip's Next-Gen SOC system detects and responds to advanced security threats by analyzing hybrid data from AWS cloud and on-premise sources. It leverages Apache Metron for real-time processing and enrichment, a serverless security data lake (S3, EMR, Athena) for long-term storage and advanced profiling, and a SOAR platform for automated and semi-automated incident response actions.</data>
    <data key="d3">data_ingestion, interactive, compute_intensive, control</data>
    <data key="d4">True</data>
  </graph>
</graphml>
