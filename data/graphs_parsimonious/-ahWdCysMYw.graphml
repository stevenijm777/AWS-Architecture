<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">EKS Pods</data>
      <data key="d6">EKS</data>
      <data key="d7">WORKLOAD_PEEK: Multi-tenant SaaS application running isolated pods per tenant.</data>
    </node>
    <node id="1">
      <data key="d5">Postgres Aurora</data>
      <data key="d6">Aurora</data>
      <data key="d7">DATA_PEEK: Database with separate schemas per tenant to prevent data commingling.</data>
    </node>
    <node id="2">
      <data key="d5">Transit Gateway</data>
      <data key="d6">TransitGateway</data>
      <data key="d7">Peers QuickSight tenant VPCs with Postgres Aurora to fetch database views.</data>
    </node>
    <node id="3">
      <data key="d5">Control Tower</data>
      <data key="d6">ControlTower</data>
      <data key="d7">Uses Account Factory for Terraform to automatically provision new accounts.</data>
    </node>
    <node id="4">
      <data key="d5">QuickSight</data>
      <data key="d6">QuickSight</data>
      <data key="d7">Single-tenant reporting and BI tool pre-provisioned in each client account.</data>
    </node>
    <node id="5">
      <data key="d5">VPN</data>
      <data key="d6">VPN</data>
      <data key="d7">Securely connects QuickSight to community banks' on-premises data databases.</data>
    </node>
    <node id="6">
      <data key="d5">Customer On-Prem DB</data>
      <data key="d6">OnPremDC</data>
      <data key="d7">DATA_PEEK: Customer data hosted on-premises by external community banks.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">EKS pods write transactional data to tenant-isolated Postgres Aurora schemas.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="2" id="0">
      <data key="d8">2</data>
      <data key="d9">Transit Gateway bridges connections from Aurora database schemas.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="4" id="0">
      <data key="d8">2</data>
      <data key="d9">Delivers Aurora reporting data to QuickSight dashboards.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="4" id="0">
      <data key="d8">1</data>
      <data key="d9">Control Tower automatically provisions dedicated client AWS accounts containing QuickSight.</data>
      <data key="d10">0</data>
      <data key="d11">meta</data>
    </edge>
    <edge source="5" target="4" id="0">
      <data key="d8">3</data>
      <data key="d9">Funnels bank's on-premises source data into QuickSight to join with SaaS platform metrics.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="6" target="5" id="0">
      <data key="d8">3</data>
      <data key="d9">Pipes on-premises customer databases through VPN tunnel.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">Multi-Tenant SaaS Loan Origination with Single Tenant Data Reporting</data>
    <data key="d1">https://www.youtube.com/watch?v=-ahWdCysMYw</data>
    <data key="d2">A multi-tenant SaaS architecture running on EKS and Aurora PostgreSQL. Isolates analytical reporting for single tenants by automated provisioning of dedicated AWS accounts with QuickSight via AWS Control Tower.</data>
    <data key="d3">data_ingestion, compute_intensive, control</data>
    <data key="d4">True</data>
  </graph>
</graphml>
