<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Security Engineers</data>
      <data key="d6">UserCompanyDeveloper</data>
      <data key="d7">Internal security teams responsible for reviewing Macie findings, identifying data owners, and working on remediation strategies (e.g., deleting, archiving, or removing buckets).</data>
    </node>
    <node id="1">
      <data key="d5">Amazon Macie</data>
      <data key="d6">Macie</data>
      <data key="d7">A data discovery and security service used to identify sensitive data (PII) in S3 buckets across multiple AWS production accounts. It performs inventory and scans, generating findings as metadata.</data>
    </node>
    <node id="2">
      <data key="d5">S3 Source Data Buckets</data>
      <data key="d6">S3</data>
      <data key="d7">S3 buckets in various AWS accounts containing Opportune's production data, including sensitive member information (SSNs, ITINs, government IDs) that Macie scans.</data>
    </node>
    <node id="3">
      <data key="d5">S3 Macie Findings Bucket</data>
      <data key="d6">S3</data>
      <data key="d7">A dedicated S3 bucket where Amazon Macie outputs its metadata findings after scanning the source data buckets. This bucket contains information about sensitive data detected, but not the sensitive data itself.</data>
    </node>
    <node id="4">
      <data key="d5">Amazon Athena</data>
      <data key="d6">Athena</data>
      <data key="d7">A serverless interactive query service that uses standard SQL to analyze and query the metadata findings stored in the S3 Macie Findings Bucket.</data>
    </node>
    <node id="5">
      <data key="d5">AWS Glue</data>
      <data key="d6">Glue</data>
      <data key="d7">A serverless data integration service used for automations, getting, loading, and aggregating data from the Macie findings, likely preparing it for the data lake and reporting.</data>
    </node>
    <node id="6">
      <data key="d5">MySQL Data Lake</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">A custom-built data lake using MySQL where processed and aggregated findings data is dropped by Athena and Glue for further analysis and retention.</data>
    </node>
    <node id="7">
      <data key="d5">Amazon QuickSight</data>
      <data key="d6">QuickSight</data>
      <data key="d7">A scalable, serverless, machine learning-powered business intelligence (BI) service used to create interactive dashboards and visualize the Macie findings, helping tell a better story for remediation efforts.</data>
    </node>
    <edge source="0" target="7" id="0">
      <data key="d8">2</data>
      <data key="d9">Security Engineers access QuickSight dashboards to view and analyze Macie findings for remediation.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">Macie connects to and scans S3 source data buckets to discover sensitive information.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="3" id="0">
      <data key="d8">0</data>
      <data key="d9">Macie outputs its metadata findings (e.g., number of SSNs, ITINs) to a dedicated S3 findings bucket.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="4" id="0">
      <data key="d8">1</data>
      <data key="d9">Athena queries the metadata findings stored in the S3 findings bucket.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="5" id="0">
      <data key="d8">1</data>
      <data key="d9">Glue processes findings data from the S3 findings bucket for automations, loading, and aggregation.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="6" id="0">
      <data key="d8">2</data>
      <data key="d9">Athena drops processed findings data into the MySQL data lake.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="7" id="0">
      <data key="d8">2</data>
      <data key="d9">Athena provides data to QuickSight for dashboard creation and visualization.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="6" id="0">
      <data key="d8">2</data>
      <data key="d9">Glue loads and aggregates findings data into the MySQL data lake.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">Opportune's Sensitive Data Discovery and Protection with Macie</data>
    <data key="d1" />
    <data key="d2">Opportune uses Amazon Macie to discover and protect sensitive member data (PII like SSNs, ITINs) across multiple AWS accounts. Macie scans S3 buckets containing production data and outputs metadata findings to a dedicated S3 bucket. Amazon Athena and AWS Glue process these findings, which are then stored in a MySQL data lake. Amazon QuickSight is used to visualize the findings, allowing Security Engineers to identify and remediate risky buckets and data owners to improve data security posture management (DSPM).</data>
    <data key="d3">data_ingestion, control, interactive</data>
    <data key="d4">True</data>
  </graph>
</graphml>
