<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d12" for="edge" attr.name="id" attr.type="string" />
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Security Engineers</data>
      <data key="d6">UserCompanyAnalyst</data>
      <data key="d7">Reviews dashboards to identify bucket owners and remediate sensitive data exposures.</data>
    </node>
    <node id="1">
      <data key="d5">S3 Findings Bucket</data>
      <data key="d6">S3</data>
      <data key="d7">DATA_PEEK: Stores central metadata of Macie findings (no raw PII).</data>
    </node>
    <node id="2">
      <data key="d5">Amazon Macie (Central)</data>
      <data key="d6">Macie</data>
      <data key="d7">Scans S3 buckets within the central security account.</data>
    </node>
    <node id="3">
      <data key="d5">Amazon Athena</data>
      <data key="d6">Athena</data>
      <data key="d7">Enables SQL querying over the S3 findings metadata.</data>
    </node>
    <node id="4">
      <data key="d5">MySQL Data Lake</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Stores aggregated findings data for custom reporting.</data>
    </node>
    <node id="5">
      <data key="d5">AWS Glue</data>
      <data key="d6">Glue</data>
      <data key="d7">WORKLOAD_PEEK: Automates ETL pipelines to load and aggregate findings into MySQL.</data>
    </node>
    <node id="6">
      <data key="d5">Amazon QuickSight</data>
      <data key="d6">QuickSight</data>
      <data key="d7">Visualizes findings to show top risky S3 buckets by PII type.</data>
    </node>
    <node id="7">
      <data key="d5">Amazon Macie (Prod 1)</data>
      <data key="d6">Macie</data>
      <data key="d7">Discovers sensitive data (SSNs, IDs) in production account 1.</data>
    </node>
    <node id="8">
      <data key="d5">Amazon S3 (Prod 1)</data>
      <data key="d6">S3</data>
      <data key="d7">DATA_PEEK: Production storage containing members' sensitive financial details.</data>
    </node>
    <node id="9">
      <data key="d5">Amazon Macie (Prod 2)</data>
      <data key="d6">Macie</data>
      <data key="d7">Discovers sensitive data in production account 2.</data>
    </node>
    <node id="10">
      <data key="d5">Amazon S3 (Prod 2)</data>
      <data key="d6">S3</data>
      <data key="d7">DATA_PEEK: Production S3 bucket in a separate account.</data>
    </node>
    <edge source="0" target="6">
      <data key="d8">1</data>
      <data key="d9">Analyzes dashboards for remediation.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="1" target="3">
      <data key="d8">1</data>
      <data key="d9">Returns query results.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="1" target="4">
      <data key="d8">1</data>
      <data key="d9">Loads processed data into MySQL.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="2" target="1">
      <data key="d8">0</data>
      <data key="d9">Sends local findings to central S3 bucket.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="3" target="1">
      <data key="d8">1</data>
      <data key="d9">Queries findings metadata.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="6" target="1">
      <data key="d8">1</data>
      <data key="d9">QuickSight queries findings directly from S3 via Athena.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="7" target="8">
      <data key="d8">0</data>
      <data key="d9">Scans S3 bucket for sensitive data.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="7" target="1">
      <data key="d8">0</data>
      <data key="d9">Sends metadata findings to central S3 bucket.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="9" target="10">
      <data key="d8">0</data>
      <data key="d9">Scans S3 bucket for sensitive data.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="9" target="1">
      <data key="d8">0</data>
      <data key="d9">Sends metadata findings to central S3 bucket.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <data key="d0">Oportun: Increasing the Accuracy of SensitiveData Discovery Using Amazon Macie</data>
    <data key="d1">https://www.youtube.com/watch?v=-kA0ahrhX3I</data>
    <data key="d2">Architected a DSPM solution to scan and discover PII across multiple production S3 buckets using Amazon Macie, centralizing metadata findings into an S3 bucket for SQL querying via Athena and reporting with QuickSight.</data>
    <data key="d3">data_ingestion, control</data>
    <data key="d4">True</data>
  </graph>
</graphml>
