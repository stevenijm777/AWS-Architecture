<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Migration Team</data>
      <data key="d6">UserCompanyDeveloper</data>
      <data key="d7">Triggers and manages the migration workflow.</data>
    </node>
    <node id="1">
      <data key="d5">Slack</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">ChatOps interface for executing migration orchestrations.</data>
    </node>
    <node id="2">
      <data key="d5">On-Premises Server</data>
      <data key="d6">OnPremDC</data>
      <data key="d7">Source system targeted for migration to AWS.</data>
    </node>
    <node id="3">
      <data key="d5">App Discovery Service</data>
      <data key="d6">AppDiscovery</data>
      <data key="d7">DATA_PEEK: Collects server TCP dependencies and performance metrics.</data>
    </node>
    <node id="4">
      <data key="d5">DynamoDB</data>
      <data key="d6">DynamoDB</data>
      <data key="d7">DATA_PEEK: Stores RTO/RPO limits, custom tags, and destination network configs.</data>
    </node>
    <node id="5">
      <data key="d5">Migration Factory</data>
      <data key="d6">EC2</data>
      <data key="d7">WORKLOAD_PEEK: Orchestration hub managing the migration lifecycle APIs.</data>
    </node>
    <node id="6">
      <data key="d5">EC2 Hot Replica</data>
      <data key="d6">EC2</data>
      <data key="d7">Receives continuous block-level updates from on-premises source.</data>
    </node>
    <node id="7">
      <data key="d5">CloudEndure</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Handles block-by-block volume replication orchestration.</data>
    </node>
    <node id="8">
      <data key="d5">Bake AMI</data>
      <data key="d6">AMI</data>
      <data key="d7">Target image baked from the replication volume.</data>
    </node>
    <node id="9">
      <data key="d5">Shared AMI</data>
      <data key="d6">AMI</data>
      <data key="d7">Baked AMI shared with the destination AWS account.</data>
    </node>
    <node id="10">
      <data key="d5">Target EC2 Instance</data>
      <data key="d6">EC2</data>
      <data key="d7">Final migrated instance launched with configuration applied.</data>
    </node>
    <edge source="0" target="4" id="0">
      <data key="d8">1</data>
      <data key="d9">Registers target metadata and sizing tags.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="0" target="1" id="0">
      <data key="d8">1</data>
      <data key="d9">Triggers migration via ChatOps slash commands.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="5" id="0">
      <data key="d8">1</data>
      <data key="d9">Invokes Migration Factory orchestration.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="3" id="0">
      <data key="d8">0</data>
      <data key="d9">Discovers metadata and connection dependencies.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="6" id="0">
      <data key="d8">0</data>
      <data key="d9">Replicates live storage blocks.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="3" id="0">
      <data key="d8">2</data>
      <data key="d9">Gathers TCP connection and profiling dependencies.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="7" id="0">
      <data key="d8">2</data>
      <data key="d9">Triggers final replication cut-off.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="8" id="0">
      <data key="d8">2</data>
      <data key="d9">Initiates volume AMI baking.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="9" id="0">
      <data key="d8">2</data>
      <data key="d9">Shares AMI with destination AWS account.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="10" id="0">
      <data key="d8">2</data>
      <data key="d9">Launches EC2 instance applying DynamoDB configs.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <edge source="7" target="6" id="0">
      <data key="d8">0</data>
      <data key="d9">Coordinates the replication process.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">Automated Server Migration Factory</data>
    <data key="d1">https://www.youtube.com/watch?v=-wLEkq21cvA</data>
    <data key="d2">Reduces migration time from 4 hours to 10 minutes per server by automating agent discovery, continuous replication, AMI baking, cross-account sharing, and launch orchestration.</data>
    <data key="d3">compute_intensive,control</data>
    <data key="d4">True</data>
  </graph>
</graphml>
