  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Data Scientists</data>
      <data key="d6">UserCompanyDeveloper</data>
      <data key="d7">Upload model artifacts, python files, and library dependencies.</data>
    </node>
    <node id="1">
      <data key="d5">UI Portal</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Custom UI interface for data scientist interaction.</data>
    </node>
    <node id="2">
      <data key="d5">AWS Fargate (Platform API)</data>
      <data key="d6">Fargate</data>
      <data key="d7">API layer processing model metadata and artifact uploads.</data>
    </node>
    <node id="3">
      <data key="d5">Amazon OpenSearch Service</data>
      <data key="d6">OpenSearch</data>
      <data key="d7">Serves as the model registry data store.</data>
    </node>
    <node id="4">
      <data key="d5">Amazon S3</data>
      <data key="d6">S3</data>
      <data key="d7">Stores uploaded raw model artifacts and Python serialized files.</data>
    </node>
    <node id="5">
      <data key="d5">Amazon MSK</data>
      <data key="d6">MSK</data>
      <data key="d7">Event-driven backbone coordinating build and status messaging.</data>
    </node>
    <node id="6">
      <data key="d5">Amazon EC2 (Build Machine)</data>
      <data key="d6">EC2</data>
      <data key="d7">Runs Docker-based build processes to containerize ML models.</data>
    </node>
    <node id="7">
      <data key="d5">Amazon ECR</data>
      <data key="d6">ECR</data>
      <data key="d7">Stores SageMaker-compatible container images.</data>
    </node>
    <node id="8">
      <data key="d5">Amazon SageMaker</data>
      <data key="d6">SageMaker</data>
      <data key="d7">Hosts deployed models as autoscaling endpoints.</data>
    </node>
    <node id="9">
      <data key="d5">Amazon EventBridge</data>
      <data key="d6">EventBridge</data>
      <data key="d7">Monitors SageMaker endpoint changes and forwards events.</data>
    </node>
    <node id="10">
      <data key="d5">AWS Lambda</data>
      <data key="d6">Lambda</data>
      <data key="d7">Processes endpoint update events and writes notifications to MSK.</data>
    </node>
    <node id="11">
      <data key="d5">AWS Fargate (Status Consumer)</data>
      <data key="d6">Fargate</data>
      <data key="d7">Consumes build/deployment status events and updates registries.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">Initiate model upload</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">Forward upload request</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="3" id="0">
      <data key="d8">0</data>
      <data key="d9">Write model metadata</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="4" id="0">
      <data key="d8">0</data>
      <data key="d9">Upload artifacts to S3</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="5" id="0">
      <data key="d8">0</data>
      <data key="d9">Write build event</data>
      <data key="d10">5</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="6" id="0">
      <data key="d8">1</data>
      <data key="d9">Trigger build process</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="11" id="0">
      <data key="d8">2</data>
      <data key="d9">Consume status message</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <edge source="6" target="4" id="0">
      <data key="d8">1</data>
      <data key="d9">Fetch artifacts</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="6" target="7" id="0">
      <data key="d8">1</data>
      <data key="d9">Push built Docker image</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="6" target="8" id="0">
      <data key="d8">1</data>
      <data key="d9">Create SageMaker endpoint</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <edge source="8" target="9" id="0">
      <data key="d8">2</data>
      <data key="d9">Emit endpoint change event</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="9" target="10" id="0">
      <data key="d8">2</data>
      <data key="d9">Trigger Lambda handler</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="10" target="5" id="0">
      <data key="d8">2</data>
      <data key="d9">Publish status notification</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="11" target="3" id="0">
      <data key="d8">2</data>
      <data key="d9">Update registry status</data>
      <data key="d10">5</data>
      <data key="d11">data</data>
    </edge>
    <edge source="11" target="1" id="0">
      <data key="d8">2</data>
      <data key="d9">Push status back to UI Portal</data>
      <data key="d10">6</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">Experian: Automated Machine Learning Model Deployment</data>
    <data key="d1">https://www.youtube.com/watch?v=-yCol_7qH2U</data>
    <data key="d2">Automates onboarding of client ML models. Reduces time to market from months to days by using SageMaker for hosted endpoints, EC2 for automated container builds, and MSK for event-driven coordination.</data>
    <data key="d3">data_ingestion, compute_intensive, control</data>
    <data key="d4">True</data>
