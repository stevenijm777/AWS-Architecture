<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">User</data>
      <data key="d6">UserConsumerWebMobile</data>
      <data key="d7">Uploads photos and views animated results.</data>
    </node>
    <node id="1">
      <data key="d5">API Server</data>
      <data key="d6">EC2</data>
      <data key="d7">WORKLOAD_PEEK: Handles initial request, generates pre-signed S3 URLs, and handles status polling.</data>
    </node>
    <node id="2">
      <data key="d5">S3 Bucket</data>
      <data key="d6">S3</data>
      <data key="d7">DATA_PEEK: Stores raw source images and completed video artifacts.</data>
    </node>
    <node id="3">
      <data key="d5">Main Queue</data>
      <data key="d6">SQS</data>
      <data key="d7">Queues incoming animation tasks.</data>
    </node>
    <node id="4">
      <data key="d5">Routing Lambda</data>
      <data key="d6">Lambda</data>
      <data key="d7">Dynamically routes animation tasks to different regions based on Spot capacity.</data>
    </node>
    <node id="5">
      <data key="d5">GPU Fleet</data>
      <data key="d6">EC2</data>
      <data key="d7">WORKLOAD_PEEK: Spot/On-Demand ASG running G5/P3 GPU instances processing deep-learning model.</data>
    </node>
    <node id="6">
      <data key="d5">Notification Queue</data>
      <data key="d6">SQS</data>
      <data key="d7">Queues completions and status messages.</data>
    </node>
    <node id="7">
      <data key="d5">State Manager</data>
      <data key="d6">EC2</data>
      <data key="d7">Consumes completed events to update database.</data>
    </node>
    <node id="8">
      <data key="d5">MySQL Database</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Stores metadata and status details.</data>
    </node>
    <node id="9">
      <data key="d5">CloudFront CDN</data>
      <data key="d6">CloudFront</data>
      <data key="d7">Serves results globally using signed URLs.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">Requests animation job.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="0" target="1" id="1">
      <data key="d8">2</data>
      <data key="d9">Polls status.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="0" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">Uploads source image directly to S3.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="0" target="9" id="0">
      <data key="d8">2</data>
      <data key="d9">Downloads video via signed CloudFront URL.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">Generates pre-signed URL.</data>
      <data key="d10">1</data>
      <data key="d11">meta</data>
    </edge>
    <edge source="1" target="3" id="0">
      <data key="d8">0</data>
      <data key="d9">Enqueues job message.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="8" id="0">
      <data key="d8">2</data>
      <data key="d9">Reads status state.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="4" id="0">
      <data key="d8">1</data>
      <data key="d9">Triggers routing function.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="5" id="0">
      <data key="d8">1</data>
      <data key="d9">Routes task to GPU instance.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="2" id="0">
      <data key="d8">1</data>
      <data key="d9">Uploads finished animation.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="6" id="0">
      <data key="d8">1</data>
      <data key="d9">Enqueues completion message.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="6" target="7" id="0">
      <data key="d8">2</data>
      <data key="d9">Consumes task outcome.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="7" target="8" id="0">
      <data key="d8">2</data>
      <data key="d9">Saves state update.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="9" target="2" id="0">
      <data key="d8">2</data>
      <data key="d9">Fetches asset from bucket cache.</data>
      <data key="d10">5</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">MyHeritage - Scaling Deep Nostalgia with Multi-Region Spot Instances</data>
    <data key="d1">https://www.youtube.com/watch?v=0-db3wFRfSc</data>
    <data key="d2">Handles over 50M animations in two weeks. Implements multi-region GPU auto-scaling with G5 spot instances, managed via an intelligent Lambda router to optimize cost and avoid cross-region data transfer fees.</data>
    <data key="d3">compute_intensive, interactive</data>
    <data key="d4">True</data>
  </graph>
</graphml>
