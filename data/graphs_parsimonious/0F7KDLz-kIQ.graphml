  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Route 53 (External)</data>
      <data key="d6">Route53</data>
      <data key="d7">Handles initial client requests and maps to CloudFront.</data>
    </node>
    <node id="1">
      <data key="d5">CloudFront</data>
      <data key="d6">CloudFront</data>
      <data key="d7">Global CDN caching content and routing requests to internal DNS.</data>
    </node>
    <node id="2">
      <data key="d5">Route 53 (Internal)</data>
      <data key="d6">Route53</data>
      <data key="d7">Performs dynamic weight-based traffic division between ECS and Lambda.</data>
    </node>
    <node id="3">
      <data key="d5">ECS</data>
      <data key="d6">ECS</data>
      <data key="d7">Orchestrates microservices for stable core traffic.</data>
    </node>
    <node id="4">
      <data key="d5">Fargate</data>
      <data key="d6">Fargate</data>
      <data key="d7">Serverless container compute engine running the main applications.</data>
    </node>
    <node id="5">
      <data key="d5">API Gateway</data>
      <data key="d6">ApiGateway</data>
      <data key="d7">Ingests burst traffic during major events.</data>
    </node>
    <node id="6">
      <data key="d5">Lambda (Execution)</data>
      <data key="d6">Lambda</data>
      <data key="d7">Serverless backend compute protecting ECS from scaling bottlenecks.</data>
    </node>
    <node id="7">
      <data key="d5">AWS SDK Lambda</data>
      <data key="d6">Lambda</data>
      <data key="d7">Calculates and dynamically updates Route 53 weights based on server load.</data>
    </node>
    <node id="8">
      <data key="d5">CloudWatch</data>
      <data key="d6">CloudWatch</data>
      <data key="d7">Monitors ECS Fargate CPU and memory utilization.</data>
    </node>
    <node id="9">
      <data key="d5">ElastiCache</data>
      <data key="d6">ElastiCache</data>
      <data key="d7">Caches volatile data for rapid response times.</data>
    </node>
    <node id="10">
      <data key="d5">DocumentDB</data>
      <data key="d6">DocumentDB</data>
      <data key="d7">Stores high-read semi-structured and unstructured data.</data>
    </node>
    <node id="11">
      <data key="d5">RDS</data>
      <data key="d6">RDS</data>
      <data key="d7">Houses relational structural data for core transaction processes.</data>
    </node>
    <node id="12">
      <data key="d5">Elasticsearch</data>
      <data key="d6">OpenSearch</data>
      <data key="d7">Performs address indexing/searches and centralizes application logs.</data>
    </node>
    <node id="13">
      <data key="d5">AWS CDK</data>
      <data key="d6">CloudFormation</data>
      <data key="d7">Enforces Infrastructure as Code for environment deployments.</data>
    </node>
    <edge source="0" target="1">
      <data key="d8">0</data>
      <data key="d9">DNS routing to CDN.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="1" target="2">
      <data key="d8">0</data>
      <data key="d9">Forwards traffic to weight-calculating internal load balancer layer.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="2" target="3">
      <data key="d8">0</data>
      <data key="d9">Sends a dynamic percentage of stable traffic to the container cluster.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="2" target="5">
      <data key="d8">0</data>
      <data key="d9">Routes burst overflow traffic to serverless endpoint.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="3" target="4">
      <data key="d8">1</data>
      <data key="d9">Launches and assigns work to containers.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="4" target="9">
      <data key="d8">1</data>
      <data key="d9">Fetches cached query items.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
