      <data key="d9">Forwards raw payload to parsing engine.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="4" id="0">
      <data key="d8">1</data>
      <data key="d9">Triggers routing mechanism.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="3" id="0">
      <data key="d8">0</data>
      <data key="d9">Saves normalized JSON into the ad metadata table.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="5" id="0">
      <data key="d8">1</data>
      <data key="d9">Reads active admin rules and target system credentials.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="6" target="3" id="0">
