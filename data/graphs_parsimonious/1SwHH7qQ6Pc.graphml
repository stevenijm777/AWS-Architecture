<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d12" for="edge" attr.name="id" attr.type="string" />
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">SalesForce</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Trigger source for completed product and creative data.</data>
    </node>
    <node id="1">
      <data key="d5">API Gateway</data>
      <data key="d6">ApiGateway</data>
      <data key="d7">Entry point for Salesforce triggers.</data>
    </node>
    <node id="2">
      <data key="d5">Config Table</data>
      <data key="d6">DynamoDB</data>
      <data key="d7">Stores routing configurations and downstream credentials.</data>
    </node>
    <node id="3">
      <data key="d5">Ad Data Table</data>
      <data key="d6">DynamoDB</data>
      <data key="d7">Stores parsed and standardized creative ad data.</data>
    </node>
    <node id="4">
      <data key="d5">Frontend App S3</data>
      <data key="d6">S3</data>
      <data key="d7">Hosts the front-end application for creative designers.</data>
    </node>
    <node id="5">
      <data key="d5">Parser Lambda</data>
      <data key="d6">Lambda</data>
      <data key="d7">Parses, standardizes, and formats Salesforce input before storing.</data>
    </node>
    <node id="6">
      <data key="d5">Routing Lambda</data>
      <data key="d6">Lambda</data>
      <data key="d7">Determines destination and credentials for ads based on Config Table.</data>
    </node>
    <node id="7">
      <data key="d5">Workflow Lambda</data>
      <data key="d6">Lambda</data>
      <data key="d7">Executes business logic for creative ad workflows.</data>
    </node>
    <node id="8">
      <data key="d5">Amazon Cognito</data>
      <data key="d6">Cognito</data>
      <data key="d7">Handles secure authentication and single sign-on (SSO) user pools.</data>
    </node>
    <node id="9">
      <data key="d5">Creative Designers</data>
      <data key="d6">UserConsumerMobile</data>
      <data key="d7">Creative users who build and proof ads using the front-end app.</data>
    </node>
    <edge source="0" target="1">
      <data key="d8">0</data>
      <data key="d9">Triggers sent from Salesforce upon completion of product data.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="1" target="5">
      <data key="d8">1</data>
      <data key="d9">Routes raw payload to Parser Lambda.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="1" target="6">
      <data key="d8">2</data>
      <data key="d9">Routes payload to Routing Lambda.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="2" target="6">
      <data key="d8">2</data>
      <data key="d9">Provides routing credentials and downstream configurations.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="3" target="9">
      <data key="d8">3</data>
      <data key="d9">Reads ad data.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="4" target="9">
      <data key="d8">3</data>
      <data key="d9">Hosts front-end app for the user.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="5" target="3">
      <data key="d8">1</data>
      <data key="d9">Stores parsed and standardized ad data.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="6" target="2">
      <data key="d8">2</data>
      <data key="d9">Updates config/routing state.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="8" target="9">
      <data key="d8">4</data>
      <data key="d9">Returns session token.</data>
      <data key="d10">1</data>
      <data key="d11">meta</data>
      <data key="d12">0</data>
    </edge>
    <edge source="9" target="8">
      <data key="d8">4</data>
      <data key="d9">Authenticates with user pools.</data>
      <data key="d10">0</data>
      <data key="d11">meta</data>
      <data key="d12">0</data>
    </edge>
    <edge source="9" target="4">
      <data key="d8">3</data>
      <data key="d9">Accesses S3 hosted front-end.</data>
      <data key="d10">0</data>
      <data key="d11">meta</data>
      <data key="d12">0</data>
    </edge>
    <edge source="9" target="3">
      <data key="d8">3</data>
      <data key="d9">Queries ad data.</data>
      <data key="d10">2</data>
      <data key="d11">meta</data>
      <data key="d12">0</data>
    </edge>
    <edge source="9" target="7">
      <data key="d8">3</data>
      <data key="d9">Triggers business logic workflows.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <data key="d0">Advance Local: Automating CrossTeam Collaboration with AWS Lambda</data>
    <data key="d1">https://www.youtube.com/watch?v=1SwHH7qQ6Pc</data>
    <data key="d2">Advanced Local automated their ad creative workflow by integrating Salesforce triggers with AWS serverless services. Salesforce data is received by API Gateway and parsed/standardized by Lambda, then stored in a DynamoDB ad data table. A routing Lambda function reads configuration and credentials from a config DynamoDB table to route ads. Creative designers authenticate via Cognito, access a front-end app hosted on S3, read ad data from DynamoDB, and execute workflow logic via another Lambda function.</data>
    <data key="d3">data_ingestion, interactive</data>
    <data key="d4">True</data>
  </graph>
</graphml>
