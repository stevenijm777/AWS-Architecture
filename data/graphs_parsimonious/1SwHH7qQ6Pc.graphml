  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">SFDC (Salesforce)</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Captures sales product and creative metadata; triggers workflow when marked complete.</data>
    </node>
    <node id="1">
      <data key="d5">Creative API</data>
      <data key="d6">ApiGateway</data>
      <data key="d7">Serves as the entry point for Salesforce integration and front-end interactions.</data>
    </node>
    <node id="2">
      <data key="d5">Parsing Lambda</data>
      <data key="d6">Lambda</data>
      <data key="d7">Parses unstructured Salesforce data into a standardized JSON format.</data>
    </node>
    <node id="3">
      <data key="d5">Ad Data DynamoDB</data>
      <data key="d6">DynamoDB</data>
      <data key="d7">DATA_PEEK: Stores parsed ad and creative metadata for downstream design teams.</data>
    </node>
    <node id="4">
      <data key="d5">Routing Lambda</data>
      <data key="d6">Lambda</data>
      <data key="d7">Retrieves routing rules and platform credentials to direct ads to correct designers.</data>
    </node>
    <node id="5">
      <data key="d5">Config DynamoDB</data>
      <data key="d6">DynamoDB</data>
      <data key="d7">Stores administration routing tables and backend API credentials.</data>
    </node>
    <node id="6">
      <data key="d5">Workflow Lambda</data>
      <data key="d6">Lambda</data>
      <data key="d7">Handles business logic for the creative front-end app including proofing and fulfillment status.</data>
    </node>
    <node id="7">
      <data key="d5">Creative Users &amp; Admins</data>
      <data key="d6">UserCompanyAgent</data>
      <data key="d7">Interacts with the system via front-end to build, proof, and publish ads.</data>
    </node>
    <node id="8">
      <data key="d5">Web Hosting S3</data>
      <data key="d6">S3</data>
      <data key="d7">Hosts the single-page front-end application.</data>
    </node>
    <node id="9">
      <data key="d5">Amazon Cognito</data>
      <data key="d6">Cognito</data>
      <data key="d7">Manages authentication, user pools, and single sign-on (SSO) integration.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">Triggers creative pipeline upon Salesforce deal completion.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="2" id="0">
