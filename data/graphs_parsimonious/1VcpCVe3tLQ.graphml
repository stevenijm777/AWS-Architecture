  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Swimmer Data Stream</data>
      <data key="d6">UserCompanyDataStream</data>
      <data key="d7">Data stream of swimmer performances.</data>
    </node>
    <node id="1">
      <data key="d5">AWS Glue</data>
      <data key="d6">Glue</data>
      <data key="d7">ETL tool used to curate and process raw data.</data>
    </node>
    <node id="2">
      <data key="d5">Landing Bucket</data>
      <data key="d6">S3</data>
      <data key="d7">Landing bucket for raw swimmer data.</data>
    </node>
    <node id="3">
      <data key="d5">Archive Bucket</data>
      <data key="d6">S3</data>
      <data key="d7">Stores archived swimmer data.</data>
    </node>
    <node id="4">
      <data key="d5">Curated Bucket</data>
      <data key="d6">S3</data>
      <data key="d7">Stores curated swimmer data ready for analytics.</data>
    </node>
    <node id="5">
      <data key="d5">AWS Step Functions</data>
      <data key="d6">StepFunctions</data>
      <data key="d7">Orchestrates the training and retraining pipeline.</data>
    </node>
    <node id="6">
      <data key="d5">Amazon Aurora</data>
      <data key="d6">Aurora</data>
      <data key="d7">Stores swimmer and standing records.</data>
    </node>
    <node id="7">
      <data key="d5">Amazon Athena</data>
      <data key="d6">Athena</data>
      <data key="d7">Queries curated data in S3 for model training.</data>
    </node>
    <node id="8">
      <data key="d5">Amazon SageMaker</data>
      <data key="d6">SageMaker</data>
      <data key="d7">Builds, trains, and hosts swim prediction models.</data>
    </node>
    <node id="9">
      <data key="d5">Model Verification Lambda</data>
      <data key="d6">Lambda</data>
      <data key="d7">Verifies predictions before exposing to the endpoint.</data>
    </node>
    <node id="10">
      <data key="d5">Amazon API Gateway</data>
      <data key="d6">ApiGateway</data>
      <data key="d7">Exposes prediction APIs to the client app.</data>
    </node>
    <node id="11">
      <data key="d5">Coaches App</data>
      <data key="d6">UserConsumerMobile</data>
      <data key="d7">Coach application used to query swim predictions.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">Swimmer performances streamed to Glue.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="2" id="0">
