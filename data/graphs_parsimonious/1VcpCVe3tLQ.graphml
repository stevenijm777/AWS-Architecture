<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Race Data Sources</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">External sources providing race results and athlete information in XML/JSON format. DATA_PEEK: Raw race results and athlete information.</data>
    </node>
    <node id="1">
      <data key="d5">Data Ingestion &amp; Transformation</data>
      <data key="d6">Glue</data>
      <data key="d7">WORKLOAD_PEEK: Loads data from sources into S3, performs conversion from XML/JSON to an optimized structure, and transforms data to create curated views. DATA_PEEK: Handles data in XML/JSON initially, converts it for optimal querying.</data>
    </node>
    <node id="2">
      <data key="d5">S3 Landing Bucket</data>
      <data key="d6">S3</data>
      <data key="d7">DATA_PEEK: Stores raw data loaded from external sources. Format is XML/JSON, 'not optimal for coding'.</data>
    </node>
    <node id="3">
      <data key="d5">Orchestration</data>
      <data key="d6">StepFunctions</data>
      <data key="d7">WORKLOAD_PEEK: Orchestrates the data pipeline (Glue jobs) and the machine learning model training and deployment pipeline (SageMaker jobs). Handles failure and retry logic.</data>
    </node>
    <node id="4">
      <data key="d5">S3 Data Lake (Optimized)</data>
      <data key="d6">S3</data>
      <data key="d7">DATA_PEEK: Stores data in an optimized structure for the data lake after initial transformation by Glue.</data>
    </node>
    <node id="5">
      <data key="d5">S3 Curated Bucket</data>
      <data key="d6">S3</data>
      <data key="d7">DATA_PEEK: Stores curated views of the data, optimized for consumption by machine learning model training and for Athena queries.</data>
    </node>
    <node id="6">
      <data key="d5">Web Application Database</data>
      <data key="d6">Aurora</data>
      <data key="d7">WORKLOAD_PEEK: Backs the web application, providing data for display and interaction for coaches. DATA_PEEK: Stores historical performance, results, and rankings.</data>
    </node>
    <node id="7">
      <data key="d5">Data Science Query Interface</data>
      <data key="d6">Athena</data>
      <data key="d7">WORKLOAD_PEEK: Provides a SQL interface for data scientists to query data directly from the S3 Curated bucket for machine learning model development and training in SageMaker.</data>
    </node>
    <node id="8">
      <data key="d5">ML Model Training &amp; Inference</data>
      <data key="d6">SageMaker</data>
      <data key="d7">WORKLOAD_PEEK: Data scientists train and deploy machine learning models (e.g., LightGBM, XGBoost) to predict individual swim times, team standings, and suggest optimal relay lineups. Deploys models as API endpoints for inference. Model retraining can be triggered by coaches when new data is available.</data>
    </node>
    <node id="9">
      <data key="d5">Coach's Web Application UI</data>
      <data key="d6">UserConsumerWeb</data>
      <data key="d7">WORKLOAD_PEEK: Coaches interact with the web-based application to select teams, request relay orders, view historical data, results, and rankings. Allows manipulation of parameters for 'what-if' scenarios.</data>
    </node>
    <node id="10">
      <data key="d5">Inference API Gateway</data>
      <data key="d6">ApiGateway</data>
      <data key="d7">WORKLOAD_PEEK: Provides an API endpoint for the web application to request machine learning inference for relay order predictions.</data>
    </node>
    <node id="11">
      <data key="d5">Inference Handler</data>
      <data key="d6">Lambda</data>
      <data key="d7">WORKLOAD_PEEK: Invoked by API Gateway to call the SageMaker model endpoint for inference and return the results to the web application.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">Race results and athlete information are loaded into the cloud.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">Raw data is written to the landing S3 bucket.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="4" id="0">
      <data key="d8">0</data>
      <data key="d9">Transformed data is stored in an optimized structure in the data lake.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="5" id="0">
      <data key="d8">0</data>
      <data key="d9">Curated views are stored for model training and consumption.</data>
      <data key="d10">5</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">Glue reads raw data from the landing bucket for transformation.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">Step Functions orchestrates Glue jobs for data processing.</data>
      <data key="d10">2</data>
      <data key="d11">meta</data>
    </edge>
    <edge source="3" target="8" id="0">
      <data key="d8">1</data>
      <data key="d9">Step Functions automates the ML pipeline, including SageMaker training and deployment to an endpoint.</data>
      <data key="d10">2</data>
      <data key="d11">meta</data>
    </edge>
    <edge source="5" target="7" id="0">
      <data key="d8">1</data>
      <data key="d9">Data scientists use Athena to query curated data from S3 for ML model building.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="6" id="0">
      <data key="d8">0</data>
      <data key="d9">Curated data is used to populate and back the Aurora database for the web application.</data>
      <data key="d10">6</data>
      <data key="d11">data</data>
    </edge>
    <edge source="7" target="8" id="0">
      <data key="d8">1</data>
      <data key="d9">Athena provides data to SageMaker for model training.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="8" target="11" id="0">
      <data key="d8">2</data>
      <data key="d9">SageMaker returns the inference results (best relay order) to Lambda.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <edge source="9" target="6" id="0">
      <data key="d8">2</data>
      <data key="d9">Coaches' web application fetches and displays results, rankings, and historical data from Aurora.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="9" target="10" id="0">
      <data key="d8">2</data>
      <data key="d9">Coaches request relay order inference from the web UI to API Gateway.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="10" target="11" id="0">
      <data key="d8">2</data>
      <data key="d9">API Gateway invokes the Lambda function to handle the inference request.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="10" target="9" id="0">
      <data key="d8">2</data>
      <data key="d9">API Gateway returns the inference results to the coaches' web application.</data>
      <data key="d10">6</data>
      <data key="d11">data</data>
    </edge>
    <edge source="11" target="8" id="0">
      <data key="d8">2</data>
      <data key="d9">Lambda calls the SageMaker endpoint for relay order inference.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="11" target="10" id="0">
      <data key="d8">2</data>
      <data key="d9">Lambda returns the inference results to API Gateway.</data>
      <data key="d10">5</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">Australian National Swim Team Relay App</data>
    <data key="d1">https://www.youtube.com/watch?v=1VcpCVe3tLQ</data>
    <data key="d2">This architecture supports the Australian National Swim Team ('The Dolphins') in selecting optimal relay teams. It involves ingesting race results and athlete data, transforming it into a data lake, training and deploying machine learning models to predict swim times and optimal relay lineups, and providing a web application for coaches to interact with the data and models. The system allows for quick data refresh during competitions and helps coaches make informed decisions for team selection and training strategies.</data>
    <data key="d3">data_ingestion, interactive, compute_intensive</data>
    <data key="d4">True</data>
  </graph>
</graphml>
