    <edge source="2" target="3" id="0">
      <data key="d8">0</data>
      <data key="d9">Archived data flow.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="4" id="0">
      <data key="d8">0</data>
      <data key="d9">Curated dataset storage.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="6" id="0">
      <data key="d8">1</data>
      <data key="d9">Syncs curated data to Aurora DB.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="7" id="0">
      <data key="d8">2</data>
      <data key="d9">Queries curated data in S3 via Athena.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="7" target="8" id="0">
      <data key="d8">2</data>
      <data key="d9">Pulls data into SageMaker for model building.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="8" target="9" id="0">
      <data key="d8">3</data>
      <data key="d9">Exposes model to verification step.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="9" target="8" id="0">
      <data key="d8">3</data>
      <data key="d9">Model verification checks.</data>
      <data key="d10">2</data>
      <data key="d11">meta</data>
    </edge>
    <edge source="9" target="10" id="0">
      <data key="d8">3</data>
      <data key="d9">Exposes verified model endpoint to API Gateway.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <edge source="10" target="9" id="0">
      <data key="d8">3</data>
      <data key="d9">Routes user request to verified model.</data>
      <data key="d10">1</data>
