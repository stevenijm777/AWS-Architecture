<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Developer</data>
      <data key="d6">UserCompanyDeveloper</data>
      <data key="d7">Requests new environment creation on Orion portal.</data>
    </node>
    <node id="1">
      <data key="d5">Route 53</data>
      <data key="d6">Route53</data>
      <data key="d7">Resolves DNS queries for the Orion portal.</data>
    </node>
    <node id="2">
      <data key="d5">ALB</data>
      <data key="d6">ALB</data>
      <data key="d7">Distributes incoming traffic to the EKS cluster.</data>
    </node>
    <node id="3">
      <data key="d5">EKS</data>
      <data key="d6">EKS</data>
      <data key="d7">DATA_PEEK: Runs 10,000+ pods. Orchestrates microservices and jobs.</data>
    </node>
    <node id="4">
      <data key="d5">Spot Instances</data>
      <data key="d6">AutoScaling</data>
      <data key="d7">WORKLOAD_PEEK: 100% Spot instances utilizing AWS Node Termination Handler.</data>
    </node>
    <node id="5">
      <data key="d5">SNS</data>
      <data key="d6">SNS</data>
      <data key="d7">Receives events when microservice jobs are created.</data>
    </node>
    <node id="6">
      <data key="d5">SQS</data>
      <data key="d6">SQS</data>
      <data key="d7">Stores unfinished job state to ensure consistent execution.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">Accesses Orion portal URL.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">Resolves DNS to ALB.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="3" id="0">
      <data key="d8">0</data>
      <data key="d9">Routes creation requests to EKS workloads.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="4" id="0">
      <data key="d8">1</data>
      <data key="d9">Launches jobs running on Spot instances.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="5" id="0">
      <data key="d8">1</data>
      <data key="d9">Triggers event on job launch or interruption.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="6" id="0">
      <data key="d8">1</data>
      <data key="d9">Fans out job messages to queue.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="6" target="4" id="0">
      <data key="d8">1</data>
      <data key="d9">New jobs watch queue to resume interrupted tasks.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">OLX Autos Global Internal Developer Platform</data>
    <data key="d1">https://www.youtube.com/watch?v=1aYoIZvabbk</data>
    <data key="d2">Internal developer platform (Orion) hosting replicas of production environments on 100% Spot instances, scaling from 100 to 10,000+ pods.</data>
    <data key="d3">compute_intensive, control</data>
    <data key="d4">True</data>
  </graph>
</graphml>
