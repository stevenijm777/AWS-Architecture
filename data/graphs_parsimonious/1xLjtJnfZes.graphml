<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Users</data>
      <data key="d6">UserConsumerMobile</data>
      <data key="d7">Fitness club members or event attendees uploading their verification credentials.</data>
    </node>
    <node id="1">
      <data key="d5">Credential</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">My Vaccine Pass credentials in the form of a screenshot, PDF, or photo.</data>
    </node>
    <node id="2">
      <data key="d5">ELB</data>
      <data key="d6">ELB</data>
      <data key="d7">Elastic Load Balancer routing incoming verification requests.</data>
    </node>
    <node id="3">
      <data key="d5">WAF</data>
      <data key="d6">WAF</data>
      <data key="d7">Performs sanity checks, drops unauthorized headers, and validates content length.</data>
    </node>
    <node id="4">
      <data key="d5">Shield Advanced</data>
      <data key="d6">ShieldAdvanced</data>
      <data key="d7">Protects infrastructure against DDoS attacks during high-traffic launch events.</data>
    </node>
    <node id="5">
      <data key="d5">EKS</data>
      <data key="d6">EKS</data>
      <data key="d7">WORKLOAD_PEEK: Runs the core Verifier API microservices.</data>
    </node>
    <node id="6">
      <data key="d5">Auto Scaling</data>
      <data key="d6">AutoScaling</data>
      <data key="d7">Automatically scales microservices out and in based on traffic peak requirements.</data>
    </node>
    <node id="7">
      <data key="d5">Terraform</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Infrastructure as Code tool used to consistently replicate and deploy environments.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">User provides their digital vaccine credential.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">Credential photo or document is sent to the Verifier API endpoint.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="3" id="0">
      <data key="d8">0</data>
      <data key="d9">ELB passes traffic requests to AWS WAF for header inspection.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="4" id="0">
      <data key="d8">0</data>
      <data key="d9">Shield Advanced ensures incoming peaks are not flagged as DDoS attacks.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="5" id="0">
      <data key="d8">0</data>
      <data key="d9">Clean traffic is forwarded to microservices running on EKS.</data>
      <data key="d10">5</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="6" id="0">
      <data key="d8">0</data>
      <data key="d9">Auto Scaling manages the EKS worker nodes to handle load changes.</data>
      <data key="d10">6</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">Matter: Verifier API for Digital Identity</data>
    <data key="d1">https://www.youtube.com/watch?v=1xLjtJnfZes</data>
    <data key="d2">Matter built a Verifier API to pre-verify digital credentials (like the New Zealand My Vaccine Pass) before events. The architecture scales automatically to handle hundreds of thousands of requests using EKS and AWS Shield Advanced.</data>
    <data key="d3">compute_intensive, control</data>
    <data key="d4">True</data>
  </graph>
</graphml>
