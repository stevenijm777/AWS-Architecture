<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">End User Files</data>
      <data key="d6">UserConsumerWeb</data>
      <data key="d7">Rich PDF files containing text and images uploaded by users.</data>
    </node>
    <node id="1">
      <data key="d5">S3 Bucket</data>
      <data key="d6">S3</data>
      <data key="d7">DATA_PEEK: Stores the uploaded PDF documents.</data>
    </node>
    <node id="2">
      <data key="d5">EventBridge</data>
      <data key="d6">EventBridge</data>
      <data key="d7">Main event bus coordinating document ingestion and process completion notifications.</data>
    </node>
    <node id="3">
      <data key="d5">Step Functions</data>
      <data key="d6">StepFunctions</data>
      <data key="d7">Orchestrates the serverless document processing workflow.</data>
    </node>
    <node id="4">
      <data key="d5">Lambda</data>
      <data key="d6">Lambda</data>
      <data key="d7">Converts document pages to images and coordinates post-processing semantic analysis.</data>
    </node>
    <node id="5">
      <data key="d5">SageMaker Endpoint</data>
      <data key="d6">SageMaker</data>
      <data key="d7">WORKLOAD_PEEK: Real-time ML endpoint executing a custom model to identify page layout and noise.</data>
    </node>
    <node id="6">
      <data key="d5">Managed Textract</data>
      <data key="d6">Textract</data>
      <data key="d7">Extracts raw text data from PDF pages.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">Uploads raw PDFs.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="0" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">Sends file reference event to main event bus.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="3" id="0">
      <data key="d8">0</data>
      <data key="d9">Workflow retrieves PDF files for processing.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="3" id="0">
      <data key="d8">0</data>
      <data key="d9">Triggers Step Functions workflow.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="6" id="0">
      <data key="d8">1</data>
      <data key="d9">Performs text extraction on document content.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="2" id="0">
      <data key="d8">1</data>
      <data key="d9">Publishes process completion events back to the main event bus.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="5" id="0">
      <data key="d8">1</data>
      <data key="d9">Analyzes page images for layout layout structure and noise filtering.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">Docebo Serverless Document Noise Reduction Pipeline</data>
    <data key="d1">https://www.youtube.com/watch?v=37T7Nd8pL-c</data>
    <data key="d2">Serverless pipeline that reduces document noise by 80% to generate 5-minute e-learning modules. Processes 30 to 50 pages per minute.</data>
    <data key="d3">data_ingestion, compute_intensive</data>
    <data key="d4">True</data>
  </graph>
</graphml>
