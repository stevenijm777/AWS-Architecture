  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Web/Mobile Users</data>
      <data key="d6">UserConsumerWebMobile</data>
      <data key="d7">1.5M registered users creating fantasy teams.</data>
    </node>
    <node id="1">
      <data key="d5">API Gateway</data>
      <data key="d6">ApiGateway</data>
      <data key="d7">Receives player requests and routes them to regional Lambdas.</data>
    </node>
    <node id="2">
      <data key="d5">AWS Lambda</data>
      <data key="d6">Lambda</data>
      <data key="d7">Orchestrates API requests, data ingestion, and S3 dumps.</data>
    </node>
    <node id="3">
      <data key="d5">CloudWatch Events</data>
      <data key="d6">CloudWatch</data>
      <data key="d7">Triggers periodic match-data archival flows.</data>
    </node>
    <node id="4">
      <data key="d5">Game APIs</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">External live score providers.</data>
    </node>
    <node id="5">
      <data key="d5">MongoDB</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Primary transactional database for game state and users.</data>
    </node>
    <node id="6">
      <data key="d5">Amazon S3</data>
      <data key="d6">S3</data>
      <data key="d7">DATA_PEEK: Core data lake for raw game events and match metrics.</data>
    </node>
    <node id="7">
      <data key="d5">Amazon EMR</data>
      <data key="d6">EMR</data>
      <data key="d7">WORKLOAD_PEEK: Runs Apache Spark jobs to compute rankings and winnings.</data>
    </node>
    <node id="8">
      <data key="d5">Amazon Redshift</data>
      <data key="d6">RedShift</data>
      <data key="d7">Performs user behavior analytics to optimize promotional campaigns.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">Users query APIs to join contests and check status.</data>
