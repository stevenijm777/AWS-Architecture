  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Users &amp; Devices</data>
      <data key="d6">UserConsumerWebMobile</data>
      <data key="d7">WORKLOAD_PEEK: Drag-and-drop web users or connected physical devices uploading geospatial data.</data>
    </node>
    <node id="1">
      <data key="d5">Data EKS</data>
      <data key="d6">EKS</data>
      <data key="d7">WORKLOAD_PEEK: Handles data streaming back to users from the main data account.</data>
    </node>
    <node id="2">
      <data key="d5">Data S3 Bucket</data>
      <data key="d6">S3</data>
      <data key="d7">DATA_PEEK: Single source of truth S3 bucket storing large, high-precision geospatial datasets.</data>
    </node>
    <node id="3">
      <data key="d5">VPC Peering</data>
      <data key="d6">VPCPeering</data>
      <data key="d7">Enables secure and private connection across multiple AWS accounts over the AWS backbone.</data>
    </node>
    <node id="4">
      <data key="d5">UX &amp; Processing EKS</data>
      <data key="d6">EKS</data>
      <data key="d7">WORKLOAD_PEEK: Runs user experience logic and coordinate ingestion queues.</data>
    </node>
    <node id="5">
      <data key="d5">Processing SQS</data>
      <data key="d6">SQS</data>
      <data key="d7">Buffers incoming upload notifications and processing jobs.</data>
    </node>
    <node id="6">
      <data key="d5">Upload/Output S3</data>
      <data key="d6">S3</data>
      <data key="d7">DATA_PEEK: Holds direct user uploads and final processed output assets.</data>
    </node>
    <node id="7">
      <data key="d5">EC2 ASG</data>
      <data key="d6">AutoScaling</data>
      <data key="d7">WORKLOAD_PEEK: Runs pipeline containers on EC2 instances tailored for specific CPU/Memory profiles.</data>
    </node>
    <edge source="0" target="6" id="0">
      <data key="d8">1</data>
      <data key="d9">Direct file upload using pre-signed S3 URL.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="3" id="0">
      <data key="d8">0</data>
      <data key="d9">Streams data through VPC Peering.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">Reads data from central S3 storage.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="4" id="0">
      <data key="d8">0</data>
      <data key="d9">Delivers data to the user-facing EKS cluster.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="5" id="0">
      <data key="d8">1</data>
      <data key="d9">EKS container listens to SQS queue and coordinates tasks.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="7" id="0">
      <data key="d8">1</data>
      <data key="d9">Dispatches jobs to pipeline EC2 instances.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="6" target="5" id="0">
      <data key="d8">1</data>
      <data key="d9">S3 Event Notification triggers queue message.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="7" target="6" id="0">
      <data key="d8">1</data>
      <data key="d9">Saves final processed outputs back to S3.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">Hexagon Digital Reality Geospatial Platform</data>
    <data key="d1">https://www.youtube.com/watch?v=3yJZ6rPoZfg</data>
    <data key="d2">Hexagon's cloud-based platform for storing geospatial data and processing user uploads. It separates data storage from processing using VPC peering for secure, low-latency access, and scales compute-heavy processing using EC2 Auto Scaling Groups.</data>
    <data key="d3">data_ingestion, compute_intensive</data>
    <data key="d4">True</data>
  </graph>
</graphml>
