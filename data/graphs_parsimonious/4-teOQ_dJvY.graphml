<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d12" for="edge" attr.name="id" attr.type="string" />
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Locomotive Producer</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">DATA_PEEK: Generates approximately 3 million samples daily per locomotive.</data>
    </node>
    <node id="1">
      <data key="d5">Ingestion Lambda</data>
      <data key="d6">Lambda</data>
      <data key="d7">WORKLOAD_PEEK: Converts source-specific locomotive message structures into a standard payload format.</data>
    </node>
    <node id="2">
      <data key="d5">Raw Ingest Stream</data>
      <data key="d6">Kinesis</data>
      <data key="d7">Buffer for incoming high-volume telemetry data.</data>
    </node>
    <node id="3">
      <data key="d5">Telemetry Filter</data>
      <data key="d6">KinesisAnalytics</data>
      <data key="d7">WORKLOAD_PEEK: Filters noise and reduces data volume to only the essential metrics needed for digital twin.</data>
    </node>
    <node id="4">
      <data key="d5">Track Sensors Producer</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Represents the alternate hand-drawn sensor pipeline on the track.</data>
    </node>
    <node id="5">
      <data key="d5">Normalized Stream</data>
      <data key="d6">Kinesis</data>
      <data key="d7">Consolidated stream collecting processed telemetry from all sensors.</data>
    </node>
    <node id="6">
      <data key="d5">State Handler Lambda</data>
      <data key="d6">Lambda</data>
      <data key="d7">WORKLOAD_PEEK: Dual-purpose function managing read/write operations to DynamoDB.</data>
    </node>
    <node id="7">
      <data key="d5">Digital Twin Database</data>
      <data key="d6">DynamoDB</data>
      <data key="d7">Stores current state of freight trains and physical components.</data>
    </node>
    <node id="8">
      <data key="d5">Query API</data>
      <data key="d6">ApiGateway</data>
      <data key="d7">Provides access endpoint for internal processing algorithms.</data>
    </node>
    <node id="9">
      <data key="d5">Analysis Consumer</data>
      <data key="d6">UserCompanyInternalPlatform</data>
      <data key="d7">Runs decision logic to evaluate train safety and parts condition.</data>
    </node>
    <edge source="0" target="1">
      <data key="d8">0</data>
      <data key="d9">Ingests raw telemetry</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="1" target="2">
      <data key="d8">0</data>
      <data key="d9">Pushes transformed data</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="2" target="3">
      <data key="d8">0</data>
      <data key="d9">Streams data for real-time analytics</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="3" target="5">
      <data key="d8">0</data>
      <data key="d9">Sends filtered events to normalized queue</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="4" target="5">
      <data key="d8">1</data>
      <data key="d9">Pushes secondary cloned track pipeline output</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="5" target="6">
      <data key="d8">2</data>
      <data key="d9">Triggers database write handler</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="6" target="7">
      <data key="d8">2</data>
      <data key="d9">Saves state data</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="6" target="8">
      <data key="d8">3</data>
      <data key="d9">Returns payload response</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="7" target="6">
      <data key="d8">3</data>
      <data key="d9">Reads train status</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="8" target="6">
      <data key="d8">3</data>
      <data key="d9">Triggers retrieval request</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="8" target="9">
      <data key="d8">3</data>
      <data key="d9">Delivers query results to consumer</data>
      <data key="d10">5</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="9" target="8">
      <data key="d8">3</data>
      <data key="d9">Queries condition data</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <data key="d0">SBB Cargo: Data Collection and Processing with Serverless Analytics Services</data>
    <data key="d1">https://www.youtube.com/watch?v=4-teOQ_dJvY</data>
    <data key="d2">Serverless ingestion and processing pipeline designed using infrastructure-as-code (IaC) templates for easily cloning additional ingestion sources (e.g., track-side sensors) and consolidating them into a unified digital twin state store.</data>
    <data key="d3">data_ingestion, compute_intensive</data>
    <data key="d4">True</data>
  </graph>
</graphml>
