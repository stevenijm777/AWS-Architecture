  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Content Originators</data>
      <data key="d6">UserConsumerWebMobile</data>
      <data key="d7">Advertisers and brand publishers uploading original video assets.</data>
    </node>
    <node id="1">
      <data key="d5">Media Outlets</data>
      <data key="d6">UserConsumerWebMobile</data>
      <data key="d7">Broadcasters and destination endpoints retrieving finished ads.</data>
    </node>
    <node id="2">
      <data key="d5">Elastic Load Balancer</data>
      <data key="d6">ELB</data>
      <data key="d7">Balances entry traffic from UI and API uploads.</data>
    </node>
    <node id="3">
      <data key="d5">WAF</data>
      <data key="d6">WAF</data>
      <data key="d7">Web Application Firewall monitoring ELB traffic.</data>
    </node>
    <node id="4">
      <data key="d5">Application Servers</data>
      <data key="d6">EC2</data>
      <data key="d7">Front-end web tier for API/UI interactions.</data>
    </node>
    <node id="5">
      <data key="d5">QC / Transcoding</data>
      <data key="d6">EC2</data>
      <data key="d7">Custom EC2 fleet for quality control and transcoding.</data>
    </node>
    <node id="6">
      <data key="d5">Batch Servers</data>
      <data key="d6">EC2</data>
      <data key="d7">Custom EC2 batch applications orchestrating work.</data>
    </node>
    <node id="7">
      <data key="d5">Simple Queue Service</data>
      <data key="d6">SQS</data>
      <data key="d7">Asynchronous high/low priority queues for workloads.</data>
    </node>
    <node id="8">
      <data key="d5">S3 Cloud Storage</data>
      <data key="d6">S3</data>
      <data key="d7">Direct source of truth and distribution storage.</data>
    </node>
    <node id="9">
      <data key="d5">CloudFront CDN</data>
      <data key="d6">CloudFront</data>
      <data key="d7">Delivers digital video ads to consumers/destinations.</data>
    </node>
    <edge source="0" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">Originators send metadata / api requests through ELB.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="0" target="8" id="0">
      <data key="d8">0</data>
      <data key="d9">Direct file upload from Java Media Uploader to S3.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="2" id="0">
      <data key="d8">1</data>
      <data key="d9">Media Outlets query system for available deliveries.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="8" id="0">
      <data key="d8">1</data>
      <data key="d9">Direct download of TV files from S3.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="9" id="0">
      <data key="d8">1</data>
      <data key="d9">Digital ad distribution via CDN.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="3" id="0">
      <data key="d8">0</data>
      <data key="d9">Traffic filtered and verified by WAF.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="4" id="0">
      <data key="d8">0</data>
      <data key="d9">Traffic routed to Application EC2 instances.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="7" id="0">
      <data key="d8">0</data>
      <data key="d9">App tier queues transcoding work in SQS.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="8" id="0">
      <data key="d8">0</data>
      <data key="d9">Processed/QC transcoded files saved back to S3.</data>
      <data key="d10">7</data>
      <data key="d11">data</data>
    </edge>
    <edge source="7" target="5" id="0">
      <data key="d8">0</data>
      <data key="d9">Transcoding fleet polls SQS for tasks.</data>
      <data key="d10">5</data>
