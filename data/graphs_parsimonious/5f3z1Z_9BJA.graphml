<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d12" for="edge" attr.name="id" attr.type="string" />
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Netezza DB</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">WORKLOAD_PEEK: On-premises database holding 20TB historical data.</data>
    </node>
    <node id="1">
      <data key="d5">Storage Gateway</data>
      <data key="d6">StorageGateway</data>
      <data key="d7">Handles daily incremental transfers (100GB/day) via NFS.</data>
    </node>
    <node id="2">
      <data key="d5">Direct Connect</data>
      <data key="d6">DirectConnect</data>
      <data key="d7">2x10G aggregated links for high-speed transfer.</data>
    </node>
    <node id="3">
      <data key="d5">Landing S3</data>
      <data key="d6">S3</data>
      <data key="d7">DATA_PEEK: Real-time landing zone with 2-day retention policy.</data>
    </node>
    <node id="4">
      <data key="d5">Quality Cleansing</data>
      <data key="d6">EC2</data>
      <data key="d7">Runs quality check and cleansing scripts driven by RDS metadata.</data>
    </node>
    <node id="5">
      <data key="d5">RDS Postgres</data>
      <data key="d6">RDS</data>
      <data key="d7">Stores ELT pipeline metadata and transformation scripts.</data>
    </node>
    <node id="6">
      <data key="d5">Transformation S3</data>
      <data key="d6">S3</data>
      <data key="d7">DATA_PEEK: Stores cleansed intermediate data. 1-day retention.</data>
    </node>
    <node id="7">
      <data key="d5">Transformation</data>
      <data key="d6">EC2</data>
      <data key="d7">Executes final data structuring and dimensions transformation.</data>
    </node>
    <node id="8">
      <data key="d5">Redshift</data>
      <data key="d6">RedShift</data>
      <data key="d7">Target data warehouse for analytics and ad-hoc Spectrum queries.</data>
    </node>
    <node id="9">
      <data key="d5">Publish S3</data>
      <data key="d6">S3</data>
      <data key="d7">DATA_PEEK: Stores daily dashboards data. Retained for 1 year &amp; 1 month.</data>
    </node>
    <node id="10">
      <data key="d5">Glacier</data>
      <data key="d6">S3</data>
      <data key="d7">Long-term archive storage for compliance and history.</data>
    </node>
    <edge source="0" target="1">
      <data key="d8">0</data>
      <data key="d9">Incremental updates extracted</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="1" target="2">
      <data key="d8">0</data>
      <data key="d9">NFS traffic sent over Direct Connect</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="2" target="3">
      <data key="d8">0</data>
      <data key="d9">Data lands in S3 bucket</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="3" target="4">
      <data key="d8">0</data>
      <data key="d9">Cleansing nodes pull raw data</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="4" target="6">
      <data key="d8">0</data>
      <data key="d9">Writes cleansed staging data</data>
      <data key="d10">5</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="5" target="4">
      <data key="d8">0</data>
      <data key="d9">Retrieves cleansing scripts</data>
      <data key="d10">4</data>
      <data key="d11">meta</data>
      <data key="d12">0</data>
    </edge>
    <edge source="5" target="7">
      <data key="d8">0</data>
      <data key="d9">Retrieves transformation scripts</data>
      <data key="d10">7</data>
      <data key="d11">meta</data>
      <data key="d12">0</data>
    </edge>
    <edge source="6" target="7">
      <data key="d8">0</data>
      <data key="d9">Transformation nodes pull cleansed data</data>
      <data key="d10">6</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="7" target="8">
      <data key="d8">0</data>
      <data key="d9">Loads final tables into Redshift</data>
      <data key="d10">8</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="8" target="9">
      <data key="d8">0</data>
      <data key="d9">Publishes reporting data via Redshift Spectrum</data>
      <data key="d10">9</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="9" target="10">
      <data key="d8">0</data>
      <data key="d9">Lifecycle policy archives old files</data>
      <data key="d10">10</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <data key="d0">Capgemini: Refactoring a Data Warehouse to Amazon Redshift</data>
    <data key="d1">https://www.youtube.com/watch?v=5f3z1Z_9BJA</data>
    <data key="d2">HIPAA-compliant ELT architecture migrating 20TB of historical data and 100GB daily increments from on-premises Netezza to AWS Redshift.</data>
    <data key="d3">data_ingestion, compute_intensive</data>
    <data key="d4">True</data>
  </graph>
</graphml>
