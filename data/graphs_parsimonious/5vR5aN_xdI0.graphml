<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Customer Data Source</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Traditional HEC data sources sending log and event streams.</data>
    </node>
    <node id="1">
      <data key="d5">Customer Lambda</data>
      <data key="d6">Lambda</data>
      <data key="d7">Serverless data ingest directly to Splunk HTTP Event Collector.</data>
    </node>
    <node id="2">
      <data key="d5">Kinesis Firehose</data>
      <data key="d6">Firehose</data>
      <data key="d7">Streams data directly to Splunk using sticky sessions.</data>
    </node>
    <node id="3">
      <data key="d5">ELB (HEC)</data>
      <data key="d6">ELB</data>
      <data key="d7">Balances incoming HEC data streams.</data>
    </node>
    <node id="4">
      <data key="d5">ELB (Sticky)</data>
      <data key="d6">ELB</data>
      <data key="d7">Elastic Load Balancer configured with sticky sessions for Kinesis Firehose.</data>
    </node>
    <node id="5">
      <data key="d5">EC2 Indexers</data>
      <data key="d6">EC2</data>
      <data key="d7">Splunk indexers in an ASG managing a fast local cache tier.</data>
    </node>
    <node id="6">
      <data key="d5">Splunk S3 (SmartStore)</data>
      <data key="d6">S3</data>
      <data key="d7">Storage tier for warm and cold data, providing cost savings and resilience.</data>
    </node>
    <node id="7">
      <data key="d5">Splunk Glacier</data>
      <data key="d6">S3</data>
      <data key="d7">Archival tier allowing direct UI-based data rehydration.</data>
    </node>
    <node id="8">
      <data key="d5">Customer S3 Bucket</data>
      <data key="d6">S3</data>
      <data key="d7">Destination bucket for dynamic data self-storage export.</data>
    </node>
    <edge source="0" target="3" id="0">
      <data key="d8">0</data>
      <data key="d9">Ingest standard HEC data.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="3" id="0">
      <data key="d8">0</data>
      <data key="d9">Ingest via serverless functions.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="4" id="0">
      <data key="d8">1</data>
      <data key="d9">Stream data through sticky session load balancer.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="5" id="0">
      <data key="d8">0</data>
      <data key="d9">Route traffic to Splunk EC2 Indexers.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="5" id="0">
      <data key="d8">1</data>
      <data key="d9">Route sticky traffic to EC2 indexers.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="6" id="0">
      <data key="d8">2</data>
      <data key="d9">Shuttle inactive cache data to Splunk S3.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="7" id="0">
      <data key="d8">2</data>
      <data key="d9">Archive data to Glacier.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="6" target="8" id="0">
      <data key="d8">3</data>
      <data key="d9">Dynamic Data Self-Storage export to customer account S3.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">Splunk Cloud SmartStore Architecture</data>
    <data key="d1">https://www.youtube.com/watch?v=5vR5aN_xdI0</data>
    <data key="d2">Decoupled storage and compute using a smart caching tier on EC2 and backing it with S3 and Glacier, resulting in significant performance improvements and cost savings.</data>
    <data key="d3">data_ingestion, compute_intensive</data>
    <data key="d4">True</data>
  </graph>
</graphml>
