<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Internal User</data>
      <data key="d6">UserCompanyDeveloper</data>
      <data key="d7">Internal stakeholders who trigger automated self-service AWS account creation.</data>
    </node>
    <node id="1">
      <data key="d5">ITSM Tool</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Triggers the account baseline and provisioning workflows upon approval.</data>
    </node>
    <node id="2">
      <data key="d5">Control Tower</data>
      <data key="d6">ControlTower</data>
      <data key="d7">Launches the account factory to provision a fresh, baselined AWS account.</data>
    </node>
    <node id="3">
      <data key="d5">Service Catalog</data>
      <data key="d6">ServiceCatalog</data>
      <data key="d7">Provisions a tagged VPC and standard resources in the newly vended account.</data>
    </node>
    <node id="4">
      <data key="d5">Vended VPC</data>
      <data key="d6">VPC</data>
      <data key="d7">VPC deployed in the vended account containing tag metadata for network configuration.</data>
    </node>
    <node id="5">
      <data key="d5">Vended Transit Gateway</data>
      <data key="d6">TransitGateway</data>
      <data key="d7">Local TGW attachment automatically configured using tag metadata.</data>
    </node>
    <node id="6">
      <data key="d5">Core Transit Gateway</data>
      <data key="d6">TransitGateway</data>
      <data key="d7">Central hub TGW residing in the Network account to connect the entire estate.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">Initiates automated account provisioning request.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">Kicks off account factory baseline creation.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="4" id="0">
      <data key="d8">1</data>
      <data key="d9">Deploys VPC with tags into vended account.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="6" id="0">
      <data key="d8">1</data>
      <data key="d9">Creates TGW attachment from vended VPC to core central network.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">DISH Network Automated Self-Service Account and Network Provisioning</data>
    <data key="d1">https://www.youtube.com/watch?v=62E9ggjGS8I</data>
    <data key="d2">Automates account and VPC provisioning for hundreds of accounts within six months using Control Tower, Service Catalog, and Transit Gateway.</data>
    <data key="d3">control, interactive</data>
    <data key="d4">True</data>
  </graph>
</graphml>
