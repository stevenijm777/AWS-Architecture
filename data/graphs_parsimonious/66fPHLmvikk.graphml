<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Data Scientist</data>
      <data key="d6">UserCompanyDeveloper</data>
      <data key="d7">Data scientists at Content Wise responsible for building custom ML models, analyzing data, and coordinating training via SageMaker notebooks.</data>
    </node>
    <node id="1">
      <data key="d5">ECR Container Registry</data>
      <data key="d6">ECR</data>
      <data key="d7">Stores custom Docker images extended from SageMaker's base images, used for both training and endpoint deployment.</data>
    </node>
    <node id="2">
      <data key="d5">S3 Dataset Bucket</data>
      <data key="d6">S3</data>
      <data key="d7">Centralized storage for datasets used during the machine learning model training phase.</data>
    </node>
    <node id="3">
      <data key="d5">S3 Model Bucket</data>
      <data key="d6">S3</data>
      <data key="d7">Storage for trained machine learning model artifacts after the training phase is complete.</data>
    </node>
    <node id="4">
      <data key="d5">SageMaker Training &amp; Notebooks</data>
      <data key="d6">SageMaker</data>
      <data key="d7">Used for data analysis, custom model building, training through notebooks, and hyperparameter optimization (HPO) on scalable infrastructure.</data>
    </node>
    <node id="5">
      <data key="d5">SageMaker Endpoint</data>
      <data key="d6">SageMaker</data>
      <data key="d7">Deploys trained models for real-time predictions. Models undergo performance and quality evaluation before being used in production.</data>
    </node>
    <node id="6">
      <data key="d5">Lambda Enricher</data>
      <data key="d6">Lambda</data>
      <data key="d7">Processes and enriches the raw prediction responses received from SageMaker Endpoints before delivering them to the production application.</data>
    </node>
    <node id="7">
      <data key="d5">EC2 Production Application</data>
      <data key="d6">EC2</data>
      <data key="d7">Hosts Content Wise's production application infrastructure, which consumes the enriched predictions for personalization services.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">Data scientists deposit custom Docker images into ECR.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="0" target="4" id="0">
      <data key="d8">0</data>
      <data key="d9">Data scientists coordinate training and model building using SageMaker notebooks.</data>
      <data key="d10">1</data>
      <data key="d11">meta</data>
    </edge>
    <edge source="2" target="4" id="0">
      <data key="d8">0</data>
      <data key="d9">SageMaker accesses datasets from S3 for training machine learning models.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">SageMaker pulls custom Docker images from ECR for model training and endpoint deployment.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="3" id="0">
      <data key="d8">0</data>
      <data key="d9">SageMaker stores trained model artifacts into an S3 bucket.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="5" id="0">
      <data key="d8">1</data>
      <data key="d9">SageMaker deploys the trained model to a SageMaker Endpoint for real-time inference.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="6" target="5" id="0">
      <data key="d8">1</data>
      <data key="d9">Lambda calls the SageMaker Endpoint to retrieve raw machine learning predictions.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="7" target="6" id="0">
      <data key="d8">1</data>
      <data key="d9">The production application on EC2 calls Lambda to get personalized predictions.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">Content Wise ML Personalization Architecture</data>
    <data key="d1">https://www.youtube.com/watch?v=66fPHLmvikk</data>
    <data key="d2">Content Wise leverages AWS for personalizing digital content delivery using machine learning. The architecture focuses on an efficient workflow for training, deploying, and serving ML models. Data scientists use SageMaker notebooks, custom Docker images from ECR, and S3 for datasets and model artifacts. SageMaker handles model training and deployment to SageMaker Endpoints. A Lambda function acts as an intermediary for production applications running on EC2, enriching raw predictions from the endpoints before serving them.</data>
    <data key="d3">data_ingestion, compute_intensive, interactive</data>
    <data key="d4">True</data>
  </graph>
</graphml>
