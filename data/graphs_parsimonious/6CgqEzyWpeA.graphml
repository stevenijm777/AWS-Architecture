<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d12" for="edge" attr.name="id" attr.type="string" />
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Viewer</data>
      <data key="d6">UserConsumerWebMobile</data>
      <data key="d7">Viewer requesting and playing personalized videos.</data>
    </node>
    <node id="1">
      <data key="d5">Amazon CloudFront</data>
      <data key="d6">CloudFront</data>
      <data key="d7">Caches and delivers video segments from S3 origin to viewers.</data>
    </node>
    <node id="2">
      <data key="d5">API Gateway</data>
      <data key="d6">ApiGateway</data>
      <data key="d7">Receives video rendering requests with usage plans and API keys.</data>
    </node>
    <node id="3">
      <data key="d5">RAS Frontend Lambda</data>
      <data key="d6">Lambda</data>
      <data key="d7">Validates requests, pushes jobs to SQS, and pulls statuses.</data>
    </node>
    <node id="4">
      <data key="d5">Spot Handler Lambda</data>
      <data key="d6">Lambda</data>
      <data key="d7">Triggered by spot interruptions to drain EC2 instances.</data>
    </node>
    <node id="5">
      <data key="d5">Autoscaling Lambda</data>
      <data key="d6">Lambda</data>
      <data key="d7">Checks CloudWatch metrics and triggers ASG scaling.</data>
    </node>
    <node id="6">
      <data key="d5">Render Jobs Queue</data>
      <data key="d6">SQS</data>
      <data key="d7">Holds video rendering instructions.</data>
    </node>
    <node id="7">
      <data key="d5">Status Feedback Queue</data>
      <data key="d6">SQS</data>
      <data key="d7">Receives quick updates from rendering engines.</data>
    </node>
    <node id="8">
      <data key="d5">Rendering ASG Spot Instances</data>
      <data key="d6">EC2</data>
      <data key="d7">Auto Scaling Group of spot instances rendering video segments.</data>
    </node>
    <node id="9">
      <data key="d5">Step Functions Orchestrator</data>
      <data key="d6">StepFunctions</data>
      <data key="d7">Runs every 15 seconds to trigger scaling checks.</data>
    </node>
    <node id="10">
      <data key="d5">Amazon CloudWatch</data>
      <data key="d6">CloudWatch</data>
      <data key="d7">Gathers engine metrics and handles spot interruption notices.</data>
    </node>
    <node id="11">
      <data key="d5">Video Segments Bucket</data>
      <data key="d6">S3</data>
      <data key="d7">Stores uploaded video segments and playlist files.</data>
    </node>
    <edge source="0" target="2">
      <data key="d8">0</data>
      <data key="d9">Requests personalized video.</data>
      <data key="d10">0</data>
      <data key="d11">meta</data>
      <data key="d12">0</data>
    </edge>
    <edge source="0" target="1">
      <data key="d8">3</data>
      <data key="d9">Plays video segments.</data>
      <data key="d10">0</data>
      <data key="d11">meta</data>
      <data key="d12">0</data>
    </edge>
    <edge source="1" target="11">
      <data key="d8">3</data>
      <data key="d9">Pulls segments from origin.</data>
      <data key="d10">1</data>
      <data key="d11">meta</data>
      <data key="d12">0</data>
    </edge>
    <edge source="1" target="0">
      <data key="d8">3</data>
      <data key="d9">Plays segment to viewer.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="2" target="3">
      <data key="d8">0</data>
      <data key="d9">Triggers frontend validation.</data>
      <data key="d10">1</data>
      <data key="d11">meta</data>
      <data key="d12">0</data>
    </edge>
    <edge source="3" target="6">
      <data key="d8">0</data>
      <data key="d9">Pushes rendering instructions.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="3" target="0">
      <data key="d8">2</data>
      <data key="d9">Returns video playlist link.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="4" target="8">
      <data key="d8">4</data>
      <data key="d9">Signals engine to stop taking jobs and drain.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="5" target="10">
      <data key="d8">5</data>
      <data key="d9">Queries instances and load metrics.</data>
      <data key="d10">1</data>
      <data key="d11">meta</data>
      <data key="d12">0</data>
    </edge>
    <edge source="5" target="8">
      <data key="d8">5</data>
      <data key="d9">Signals ASG to scale up/down.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="6" target="8">
      <data key="d8">1</data>
      <data key="d9">Engines pull jobs from queue when they have capacity.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="7" target="3">
      <data key="d8">2</data>
      <data key="d9">Pulls status response.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="8" target="11">
      <data key="d8">1</data>
      <data key="d9">Uploads rendered video segments.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="8" target="7">
      <data key="d8">1</data>
      <data key="d9">Pushes response to status feedback queue.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="9" target="5">
      <data key="d8">5</data>
      <data key="d9">Triggers scaling calculation Lambda every 15s.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="10" target="4">
      <data key="d8">4</data>
      <data key="d9">Triggers on spot interruption event.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="10" target="5">
      <data key="d8">5</data>
      <data key="d9">Returns metric outputs.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="11" target="8">
      <data key="d8">1</data>
      <data key="d9">Pulls assets or templates.</data>
      <data key="d10">2</data>
      <data key="d11">meta</data>
      <data key="d12">0</data>
    </edge>
    <edge source="11" target="1">
      <data key="d8">3</data>
      <data key="d9">Delivers segments.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <data key="d0">SundaySky: Create Personalized Videos in Real Time on GPU-based Spot Instances for Video Rendering</data>
    <data key="d1">https://www.youtube.com/watch?v=6CgqEzyWpeA</data>
    <data key="d2">Sunday Sky's Rendering as a Service (RAS) generates personalized videos at scale. User requests via API Gateway trigger a frontend Lambda, which pushes jobs to an SQS queue. EC2 Spot Instances pull jobs, render segments, and upload them to S3, from where they are served via CloudFront. Spot interruptions are managed via CloudWatch events triggering a drain Lambda. Scaling is orchestrated by Step Functions triggering a metric-checking Lambda.</data>
    <data key="d3">data_ingestion, compute_intensive, interactive</data>
    <data key="d4">True</data>
  </graph>
</graphml>
