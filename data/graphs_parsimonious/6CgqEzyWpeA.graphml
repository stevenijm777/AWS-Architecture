<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Mobile Client</data>
      <data key="d6">UserConsumerMobile</data>
      <data key="d7">Requests personalized video bill and streams segments.</data>
    </node>
    <node id="1">
      <data key="d5">API Gateway</data>
      <data key="d6">ApiGateway</data>
      <data key="d7">Handles throttling, usage plans, and API keys.</data>
    </node>
    <node id="2">
      <data key="d5">RaaS Frontend</data>
      <data key="d6">Lambda</data>
      <data key="d7">Validates rendering requests.</data>
    </node>
    <node id="3">
      <data key="d5">Job Queue</data>
      <data key="d6">SQS</data>
      <data key="d7">Holds rendering instructions.</data>
    </node>
    <node id="4">
      <data key="d5">Response Queue</data>
      <data key="d6">SQS</data>
      <data key="d7">Receives immediate response and triggers playlist generation.</data>
    </node>
    <node id="5">
      <data key="d5">Rendering ASG</data>
      <data key="d6">EC2</data>
      <data key="d7">WORKLOAD_PEEK: Spot instances rendering personalized video segments.</data>
    </node>
    <node id="6">
      <data key="d5">Video Storage</data>
      <data key="d6">S3</data>
      <data key="d7">Stores rendered video segments.</data>
    </node>
    <node id="7">
      <data key="d5">Scaling Step Function</data>
      <data key="d6">StepFunctions</data>
      <data key="d7">Triggers metric evaluation every 15 seconds.</data>
    </node>
    <node id="8">
      <data key="d5">Scaling Controller</data>
      <data key="d6">Lambda</data>
      <data key="d7">Updates ASG capacity based on active load.</data>
    </node>
    <node id="9">
      <data key="d5">CloudWatch Events</data>
      <data key="d6">CloudWatch</data>
      <data key="d7">Detects 2-minute Spot interruption warnings.</data>
    </node>
    <node id="10">
      <data key="d5">Interruption Handler</data>
      <data key="d6">Lambda</data>
      <data key="d7">Signals instance to stop pulling and drain.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">User requests video bill.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="0" target="6" id="0">
      <data key="d8">0</data>
      <data key="d9">User pulls playlist and segments from S3.</data>
      <data key="d10">6</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">Triggers request validation.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="3" id="0">
      <data key="d8">0</data>
      <data key="d9">Pushes rendering instructions to queue.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="4" id="0">
      <data key="d8">0</data>
      <data key="d9">Sends immediate response to response queue.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="3" id="0">
      <data key="d8">0</data>
      <data key="d9">Pulls render jobs when capacity is available.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="6" id="0">
      <data key="d8">0</data>
      <data key="d9">Uploads rendered segments to S3.</data>
      <data key="d10">5</data>
      <data key="d11">data</data>
    </edge>
    <edge source="7" target="8" id="0">
      <data key="d8">1</data>
      <data key="d9">Triggers scale-out assessment.</data>
      <data key="d10">0</data>
      <data key="d11">meta</data>
    </edge>
    <edge source="8" target="5" id="0">
      <data key="d8">1</data>
      <data key="d9">Instructs ASG to scale rendering capacity.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="9" target="10" id="0">
      <data key="d8">2</data>
      <data key="d9">Triggers on Spot interruption notice.</data>
      <data key="d10">0</data>
      <data key="d11">meta</data>
    </edge>
    <edge source="10" target="5" id="0">
      <data key="d8">2</data>
      <data key="d9">Calls instance API to stop pulling rendering tasks.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">SundaySky Rendering as a Service</data>
    <data key="d1">https://www.youtube.com/watch?v=6CgqEzyWpeA</data>
    <data key="d2">Generates billions of personalized videos yearly using EC2 Spot-based rendering engines with automated scaling and proactive spot-interruption handling.</data>
    <data key="d3">data_ingestion, compute_intensive</data>
    <data key="d4">True</data>
  </graph>
</graphml>
