<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Client Devices</data>
      <data key="d6">UserConsumerWeb</data>
      <data key="d7">Web and mobile clients requesting personalized video content.</data>
    </node>
    <node id="1">
      <data key="d5">API Gateway</data>
      <data key="d6">ApiGateway</data>
      <data key="d7">Handles incoming requests, managing usage plans and API keys.</data>
    </node>
    <node id="2">
      <data key="d5">Frontend Lambda</data>
      <data key="d6">Lambda</data>
      <data key="d7">Validates requests and manages queue interaction.</data>
    </node>
    <node id="3">
      <data key="d5">Jobs SQS Queue</data>
      <data key="d6">SQS</data>
      <data key="d7">Buffers incoming video rendering jobs.</data>
    </node>
    <node id="4">
      <data key="d5">Response SQS Queue</data>
      <data key="d6">SQS</data>
      <data key="d7">Holds completed rendering results and playlists.</data>
    </node>
    <node id="5">
      <data key="d5">Rendering ASG</data>
      <data key="d6">EC2</data>
      <data key="d7">Auto-scaling spot instances processing rendering jobs.</data>
    </node>
    <node id="6">
      <data key="d5">Video S3 Bucket</data>
      <data key="d6">S3</data>
      <data key="d7">Stores rendered video segments and playlists.</data>
    </node>
    <node id="7">
      <data key="d5">CloudFront CDN</data>
      <data key="d6">CloudFront</data>
      <data key="d7">Caches and streams video segments to end users.</data>
    </node>
    <node id="8">
      <data key="d5">CloudWatch Events</data>
      <data key="d6">CloudWatch</data>
      <data key="d7">Monitors spot instances and collects custom queue metrics.</data>
    </node>
    <node id="9">
      <data key="d5">Interruption Lambda</data>
      <data key="d6">Lambda</data>
      <data key="d7">Drains active jobs from spot instances marked for termination.</data>
    </node>
    <node id="10">
      <data key="d5">Scaling Orchestrator</data>
      <data key="d6">StepFunctions</data>
      <data key="d7">Triggers scaling logic checks every 15 seconds.</data>
    </node>
    <node id="11">
      <data key="d5">Scaling Calculator</data>
      <data key="d6">Lambda</data>
      <data key="d7">Calculates required rendering capacity and updates ASG.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">Sends rendering request</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="0" target="7" id="0">
      <data key="d8">1</data>
      <data key="d9">Requests video stream</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">Invokes validation handler</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="3" id="0">
      <data key="d8">0</data>
      <data key="d9">Pushes rendering parameters</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="4" id="0">
      <data key="d8">0</data>
      <data key="d9">Pulls and returns playlist URL to client</data>
      <data key="d10">6</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="5" id="0">
      <data key="d8">0</data>
      <data key="d9">Engines pull jobs when free</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="4" id="0">
      <data key="d8">0</data>
      <data key="d9">Pushes playlist information</data>
      <data key="d10">5</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="6" id="0">
      <data key="d8">0</data>
      <data key="d9">Uploads completed MP4 segments</data>
      <data key="d10">7</data>
      <data key="d11">data</data>
    </edge>
    <edge source="7" target="6" id="0">
      <data key="d8">1</data>
      <data key="d9">Fetches segments from S3 origin</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="8" target="9" id="0">
      <data key="d8">2</data>
      <data key="d9">Triggers 2-min termination warning</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="9" target="5" id="0">
      <data key="d8">2</data>
      <data key="d9">Instructs targeted instance to drain and detach</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="10" target="11" id="0">
      <data key="d8">3</data>
      <data key="d9">Runs scaling evaluation loop</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="11" target="5" id="0">
      <data key="d8">3</data>
      <data key="d9">Modifies desired capacity of ASG</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">SundaySky Personalized Video Rendering Architecture</data>
    <data key="d1">https://www.youtube.com/watch?v=6CgqEzyWpeA</data>
    <data key="d2">A scalable video rendering architecture (Rendering as a Service - RAS) utilizing cost-efficient spot instances on EC2 managed via custom Step Functions scaling and automated Spot Interruption workflows.</data>
    <data key="d3">compute_intensive, interactive</data>
    <data key="d4">True</data>
  </graph>
</graphml>
