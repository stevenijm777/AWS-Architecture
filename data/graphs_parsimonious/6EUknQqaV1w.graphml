  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Kinesis Data Streams (Collect)</data>
      <data key="d6">KinesisDataStream</data>
      <data key="d7">WORKLOAD_PEEK: Real-time ingestion of native cloud security event streams handling billions of events daily.</data>
    </node>
    <node id="1">
      <data key="d5">Amazon Neptune</data>
      <data key="d6">Neptune</data>
      <data key="d7">DATA_PEEK: Handles 50M+ highly interconnected cloud resources. Agnostic graph database supporting read scale-out and schema-less data representation.</data>
    </node>
    <node id="2">
      <data key="d5">Elasticsearch</data>
      <data key="d6">OpenSearch</data>
      <data key="d7">Used for reporting, analytical capabilities, search, and aggregations.</data>
    </node>
    <node id="3">
      <data key="d5">Amazon DynamoDB</data>
      <data key="d6">DynamoDB</data>
      <data key="d7">Used for historical resource configuration visualization and storing security violations.</data>
    </node>
    <node id="4">
      <data key="d5">Amazon CloudWatch</data>
      <data key="d6">CloudWatch</data>
      <data key="d7">Monitors CPU, memory, and performance metrics from Neptune and Elasticsearch.</data>
    </node>
    <node id="5">
      <data key="d5">Sharder Service</data>
      <data key="d6">EC2</data>
      <data key="d7">Microservice that uses CloudWatch metrics to determine shard capacity and balance data loads.</data>
    </node>
    <node id="6">
      <data key="d5">Kinesis Data Streams (Rule Engine)</data>
      <data key="d6">KinesisDataStream</data>
      <data key="d7">Fronts the rule execution pipeline, running thousands of rules over Neptune graph database.</data>
    </node>
    <node id="7">
      <data key="d5">Slack &amp; Email</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Real-time notifications sent to customers when security violations are detected.</data>
    </node>
    <edge source="0" target="1">
      <data key="d8">0</data>
      <data key="d9">Publishes evaluated cloud resources into Neptune.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
