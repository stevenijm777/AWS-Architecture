  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">IoT Connect Admin</data>
      <data key="d6">UserConsumerWebMobile</data>
      <data key="d7">Admin users who monitor data planes and onboard new OEM organizations.</data>
    </node>
    <node id="1">
      <data key="d5">AWS Organizations</data>
      <data key="d6">Organizations</data>
      <data key="d7">Automates account generation and isolation for new OEM clients.</data>
    </node>
    <node id="2">
      <data key="d5">AWS CloudFormation</data>
      <data key="d6">CloudFormation</data>
      <data key="d7">Spins up dedicated data plane infrastructure for new accounts.</data>
    </node>
    <node id="3">
      <data key="d5">Admin database (SQL Server)</data>
      <data key="d6">RDS</data>
      <data key="d7">Stores metadata about client accounts and deployed data planes.</data>
    </node>
    <node id="4">
      <data key="d5">API Gateway</data>
      <data key="d6">ApiGateway</data>
      <data key="d7">Exposes API metrics and data plane monitoring details to administrators.</data>
    </node>
    <node id="5">
      <data key="d5">IoT Devices</data>
      <data key="d6">UserConsumerMobile</data>
      <data key="d7">OEM client devices deployed on the field.</data>
    </node>
    <node id="6">
      <data key="d5">AWS IoT Core</data>
      <data key="d6">IoTCore</data>
      <data key="d7">Ingests telemetry data from field devices and executes routing rules.</data>
    </node>
    <node id="7">
      <data key="d5">Amazon Kinesis</data>
      <data key="d6">Kinesis</data>
      <data key="d7">Ingests telemetry streams from IoT Core actions.</data>
    </node>
    <node id="8">
      <data key="d5">Cold Storage S3</data>
      <data key="d6">S3</data>
      <data key="d7">Stores historical telemetry data for long-term archiving.</data>
    </node>
    <node id="9">
      <data key="d5">Device Data DynamoDB</data>
      <data key="d6">DynamoDB</data>
      <data key="d7">Generic NoSQL database used to store flexible data points for varied devices.</data>
    </node>
    <node id="10">
      <data key="d5">Rule Processing Lambdas</data>
      <data key="d6">Lambda</data>
      <data key="d7">12 distinct Lambda functions that trigger custom business alerts and push data to apps.</data>
    </node>
    <node id="11">
      <data key="d5">Amazon SageMaker</data>
      <data key="d6">SageMaker</data>
      <data key="d7">Hosts and executes machine learning models in the cloud.</data>
    </node>
    <node id="12">
      <data key="d5">Amazon Bedrock</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Integrates public models for advanced AI capabilities and inferences.</data>
    </node>
