<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d12" for="edge" attr.name="id" attr.type="string" />
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Developer</data>
      <data key="d6">UserCompanyDeveloper</data>
      <data key="d7">Developer commits infrastructure and application code modifications.</data>
    </node>
    <node id="1">
      <data key="d5">AWS CodePipeline</data>
      <data key="d6">CodePipeline</data>
      <data key="d7">Orchestrates the build and deployment pipeline stages.</data>
    </node>
    <node id="2">
      <data key="d5">AWS CodeCommit</data>
      <data key="d6">CodeCommit</data>
      <data key="d7">Version control repository for application code and CloudFormation templates.</data>
    </node>
    <node id="3">
      <data key="d5">AWS CodeBuild</data>
      <data key="d6">CodeBuild</data>
      <data key="d7">Builds docker images on demand inside short-lived containers.</data>
    </node>
    <node id="4">
      <data key="d5">Amazon ECR Registry</data>
      <data key="d6">ECR</data>
      <data key="d7">Stores completed application docker images ready for deployment.</data>
    </node>
    <node id="5">
      <data key="d5">AWS CloudFormation</data>
      <data key="d6">CloudFormation</data>
      <data key="d7">Executes deployment in three steps: ChangeSet, Approve, and Execute to deploy templates.</data>
    </node>
    <node id="6">
      <data key="d5">Customer VPC</data>
      <data key="d6">VPC</data>
      <data key="d7">Isolated network environment deployed for each customer.</data>
    </node>
    <node id="7">
      <data key="d5">Amazon ECS</data>
      <data key="d6">ECS</data>
      <data key="d7">Runs the containerized applications defined in task definitions.</data>
    </node>
    <node id="8">
      <data key="d5">Application Load Balancer</data>
      <data key="d6">ALB</data>
      <data key="d7">Routes external traffic to the ECS container tasks.</data>
    </node>
    <node id="9">
      <data key="d5">AWS IAM</data>
      <data key="d6">IAM</data>
      <data key="d7">Defines access permissions and execution roles for deployed applications.</data>
    </node>
    <edge source="0" target="2">
      <data key="d8">0</data>
      <data key="d9">Developer pushes code changes to git repository.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="2" target="3">
      <data key="d8">0</data>
      <data key="d9">CodeCommit triggers AWS CodeBuild.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="3" target="4">
      <data key="d8">0</data>
      <data key="d9">CodeBuild outputs built container image to ECR.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="5" target="6">
      <data key="d8">1</data>
      <data key="d9">CloudFormation deploys and configures the target customer VPC environment.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="5" target="7">
      <data key="d8">1</data>
      <data key="d9">CloudFormation updates or instantiates ECS task definitions.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="5" target="8">
      <data key="d8">1</data>
      <data key="d9">CloudFormation provisions or modifies the Application Load Balancer.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="5" target="9">
      <data key="d8">1</data>
      <data key="d9">CloudFormation applies IAM roles and permission policies.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <data key="d0">Aetion: Deploy Applications  Provision Cloud Resources with AWS Developer Tools</data>
    <data key="d1">https://www.youtube.com/watch?v=6YkguepAQuQ</data>
    <data key="d2">Automated deployment pipeline leveraging CodePipeline, CodeBuild, and CloudFormation to consistently deploy isolated tenant workloads to separate VPCs containing ECS, ALB, and IAM resources.</data>
    <data key="d3">control, compute_intensive</data>
    <data key="d4">True</data>
  </graph>
</graphml>
