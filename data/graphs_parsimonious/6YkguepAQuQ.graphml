  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Developer</data>
      <data key="d6">UserCompanyDeveloper</data>
      <data key="d7">Triggers code commits and approves CloudFormation Change Sets.</data>
    </node>
    <node id="1">
      <data key="d5">AWS CodeCommit</data>
      <data key="d6">CodeCommit</data>
      <data key="d7">Hosts application code and CloudFormation templates.</data>
    </node>
    <node id="2">
      <data key="d5">AWS CodeBuild</data>
      <data key="d6">CodeBuild</data>
      <data key="d7">Builds docker container images from the source code.</data>
    </node>
    <node id="3">
      <data key="d5">Amazon ECR Registry</data>
      <data key="d6">ECR</data>
      <data key="d7">Stores the built application container images.</data>
    </node>
    <node id="4">
      <data key="d5">AWS CloudFormation</data>
      <data key="d6">CloudFormation</data>
      <data key="d7">Deploys application infrastructure using a multi-step Change Set approval workflow.</data>
    </node>
    <node id="5">
      <data key="d5">Production VPC</data>
      <data key="d6">VPC</data>
      <data key="d7">Target VPC environment for customer deployments.</data>
    </node>
    <node id="6">
      <data key="d5">Amazon ECS</data>
      <data key="d6">ECS</data>
      <data key="d7">Runs the application containers.</data>
    </node>
    <node id="7">
      <data key="d5">Application Load Balancer</data>
      <data key="d6">ALB</data>
      <data key="d7">Routes traffic to the ECS tasks.</data>
    </node>
    <node id="8">
      <data key="d5">IAM Roles</data>
      <data key="d6">IAM</data>
      <data key="d7">Provides permissions for the ECS tasks and infrastructure.</data>
    </node>
    <node id="9">
      <data key="d5">AWS CodePipeline</data>
      <data key="d6">CodePipeline</data>
      <data key="d7">Orchestrates the build and deployment pipeline.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">Developer commits code changes.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="0" target="4" id="0">
      <data key="d8">1</data>
      <data key="d9">Developer approves the CloudFormation Change Set.</data>
      <data key="d10">0</data>
      <data key="d11">meta</data>
    </edge>
    <edge source="1" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">Triggers container build.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="3" id="0">
      <data key="d8">0</data>
      <data key="d9">Pushes successful build image to registry.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="6" id="0">
      <data key="d8">1</data>
      <data key="d9">Deploys or updates ECS tasks.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="7" id="0">
      <data key="d8">1</data>
      <data key="d9">Provisions/configures application load balancer.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="8" id="0">
      <data key="d8">1</data>
      <data key="d9">Creates and assigns IAM roles.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">Aetion: Deploy Applications  Provision Cloud Resources with AWS Developer Tools</data>
    <data key="d1">https://www.youtube.com/watch?v=6YkguepAQuQ</data>
    <data key="d2">Automated deployment pipeline leveraging CodePipeline, CodeCommit, CodeBuild, and CloudFormation to consistently instantiate client environments containing ECS, ALB, and IAM components across multiple target VPCs.</data>
    <data key="d3">compute_intensive,control</data>
    <data key="d4">True</data>
  </graph>
</graphml>
