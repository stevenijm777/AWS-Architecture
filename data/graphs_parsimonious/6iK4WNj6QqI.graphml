<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Fans / Ticket Buyers</data>
      <data key="d6">UserConsumerWebMobile</data>
      <data key="d7">Fans purchasing tickets online.</data>
    </node>
    <node id="1">
      <data key="d5">CDN</data>
      <data key="d6">CloudFront</data>
      <data key="d7">Handles entry point and routing.</data>
    </node>
    <node id="2">
      <data key="d5">EKS (Next.js)</data>
      <data key="d6">EKS</data>
      <data key="d7">WORKLOAD_PEEK: Runs Next.js to handle page rendering.</data>
    </node>
    <node id="3">
      <data key="d5">AppSync</data>
      <data key="d6">AppSync</data>
      <data key="d7">Exposes GraphQL queries, mutations, and WebSocket subscriptions.</data>
    </node>
    <node id="4">
      <data key="d5">Lambda</data>
      <data key="d6">Lambda</data>
      <data key="d7">Handles single-step operations and quick data lookups.</data>
    </node>
    <node id="5">
      <data key="d5">Step Functions</data>
      <data key="d6">StepFunctions</data>
      <data key="d7">Orchestrates multi-step purchase flow, including payments.</data>
    </node>
    <node id="6">
      <data key="d5">DynamoDB</data>
      <data key="d6">DynamoDB</data>
      <data key="d7">DATA_PEEK: Replicated globally using Global Tables across active-active regions.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">Fans access Ticketmaster platform.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">Routes static/page rendering requests to EKS.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="3" id="0">
      <data key="d8">0</data>
      <data key="d9">Routes API endpoints to AppSync GraphQL.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="4" id="0">
      <data key="d8">0</data>
      <data key="d9">Quick load queries routed to single Lambda.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="5" id="0">
      <data key="d8">1</data>
      <data key="d9">Purchase mutations routed to Step Functions orchestration.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="6" id="0">
      <data key="d8">0</data>
      <data key="d9">Lambda reads/writes ticketing data.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <edge source="6" target="6" id="0">
      <data key="d8">2</data>
      <data key="d9">Bi-directional DynamoDB Global Table replication across regions.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">Ticketmaster Active-Active Multi-Region Ticket Purchasing System</data>
    <data key="d1">https://www.youtube.com/watch?v=6iK4WNj6QqI</data>
    <data key="d2">An active-active multi-region setup utilizing Route 53 latency routing, Next.js on EKS for frontend rendering, AppSync for GraphQL APIs, and DynamoDB Global Tables to sync inventory state globally.</data>
    <data key="d3">interactive, control</data>
    <data key="d4">True</data>
  </graph>
</graphml>
