<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Administrator</data>
      <data key="d6">UserCompanyDeveloper</data>
      <data key="d7">Uses Docker and kubectl to manage configurations and deploy applications.</data>
    </node>
    <node id="1">
      <data key="d5">End Users</data>
      <data key="d6">UserConsumerWeb</data>
      <data key="d7">Initiate traffic to access the web applications.</data>
    </node>
    <node id="2">
      <data key="d5">Elastic Load Balancing</data>
      <data key="d6">ELB</data>
      <data key="d7">Provides entry-point high-availability infrastructure load balancing.</data>
    </node>
    <node id="3">
      <data key="d5">Amazon Elastic Container Registry</data>
      <data key="d6">ECR</data>
      <data key="d7">Stores Docker container images built by the administrator.</data>
    </node>
    <node id="4">
      <data key="d5">Nginx Ingress Controller (KIC)</data>
      <data key="d6">EKS</data>
      <data key="d7">Runs on EKS. Handles URL routing, TLS termination, WAF (App Protect), and authentication.</data>
    </node>
    <node id="5">
      <data key="d5">Backend Services (A, B, C)</data>
      <data key="d6">EKS</data>
      <data key="d7">Target application pods running inside EKS.</data>
    </node>
    <edge source="0" target="3" id="0">
      <data key="d8">0</data>
      <data key="d9">Pushes built Docker images to ECR.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="0" target="4" id="0">
      <data key="d8">0</data>
      <data key="d9">Applies configurations and deployments using kubectl.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="2" id="0">
      <data key="d8">1</data>
      <data key="d9">Accesses the application via standard web protocols.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="4" id="0">
      <data key="d8">1</data>
      <data key="d9">Forwards edge traffic to the Ingress Controller.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="4" id="0">
      <data key="d8">0</data>
      <data key="d9">Pulls container images to run on EKS.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="5" id="0">
      <data key="d8">1</data>
      <data key="d9">Performs Layer 7 routing and forwards traffic to services A, B, or C.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">Nginx Ingress Controller on Amazon EKS</data>
    <data key="d1">https://www.youtube.com/watch?v=6sY0AunanlM</data>
    <data key="d2">Architecture illustrating modern application delivery using Nginx Kubernetes Ingress Controller (KIC) on Amazon EKS to manage, secure, and route traffic to backend microservices.</data>
    <data key="d3">compute_intensive,control</data>
    <data key="d4">True</data>
  </graph>
</graphml>
