<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">E-commerce User</data>
      <data key="d6">UserConsumerWeb</data>
      <data key="d7">End users accessing the e-commerce website.</data>
    </node>
    <node id="1">
      <data key="d5">Route 53</data>
      <data key="d6">Route53</data>
      <data key="d7">Handles external domain resolution and internal FQDNs for service communication.</data>
    </node>
    <node id="2">
      <data key="d5">WAF</data>
      <data key="d6">WAF</data>
      <data key="d7">Protects against DDoS and bot attacks.</data>
    </node>
    <node id="3">
      <data key="d5">CloudFront</data>
      <data key="d6">CloudFront</data>
      <data key="d7">Used for edge caching and intelligent traffic steering based on behaviors.</data>
    </node>
    <node id="4">
      <data key="d5">S3 Static Assets</data>
      <data key="d6">S3</data>
      <data key="d7">Stores static website elements (e.g., images) and manages logs.</data>
    </node>
    <node id="5">
      <data key="d5">Proprietary Load Balancer</data>
      <data key="d6">EC2</data>
      <data key="d7">Hosts a proprietary load balancer (Pass Secure) for traffic distribution to EKS.</data>
    </node>
    <node id="6">
      <data key="d5">EKS Cluster</data>
      <data key="d6">EKS</data>
      <data key="d7">Manages over 100 e-commerce stores, providing flexibility and traffic segregation for users.</data>
    </node>
    <node id="7">
      <data key="d5">ElasticSearch</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Used for indexing product searches within the e-commerce platform.</data>
    </node>
    <node id="8">
      <data key="d5">ElastiCache</data>
      <data key="d6">ElastiCache</data>
      <data key="d7">Provides application caching and manages user sessions.</data>
    </node>
    <node id="9">
      <data key="d5">Aurora Database</data>
      <data key="d6">Aurora</data>
      <data key="d7">MySQL-compatible database for the Magento stack, offering georeplication and point-in-time restore.</data>
    </node>
    <node id="10">
      <data key="d5">Self-managed NFS</data>
      <data key="d6">EC2</data>
      <data key="d7">Self-managed NFS server for file storage, used alongside AWS EFS.</data>
    </node>
    <node id="11">
      <data key="d5">VPN</data>
      <data key="d6">VPN</data>
      <data key="d7">IPSec-based VPN for managing all services within the architecture.</data>
    </node>
    <node id="12">
      <data key="d5">Lambda Functions</data>
      <data key="d6">Lambda</data>
      <data key="d7">Used for configuration activities, monitoring, and alerting across the architecture.</data>
    </node>
    <node id="13">
      <data key="d5">RedShift BI</data>
      <data key="d6">RedShift</data>
      <data key="d7">Data warehouse used for Business Intelligence (BI).</data>
    </node>
    <node id="14">
      <data key="d5">Mail Server</data>
      <data key="d6">EC2</data>
      <data key="d7">Self-managed EC2 instance used as a mail server.</data>
    </node>
    <node id="15">
      <data key="d5">Operations Team</data>
      <data key="d6">UserCompanyAgent</data>
      <data key="d7">Internal operations team responsible for managing the AWS services.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">User accesses the website via domain name.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">DNS routes traffic to the WAF.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="3" id="0">
      <data key="d8">0</data>
      <data key="d9">WAF filters traffic before reaching CloudFront.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="4" id="0">
      <data key="d8">1</data>
      <data key="d9">CloudFront serves static elements (e.g., images) directly from S3.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="5" id="0">
      <data key="d8">2</data>
      <data key="d9">CloudFront routes dynamic content requests to the proprietary load balancer hosted on EC2.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="6" id="0">
      <data key="d8">3</data>
      <data key="d9">Proprietary load balancer distributes traffic to the EKS cluster.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="6" target="7" id="0">
      <data key="d8">4</data>
      <data key="d9">EKS interacts with ElasticSearch for product search indexing.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="6" target="8" id="0">
      <data key="d8">4</data>
      <data key="d9">EKS uses ElastiCache for application caching and session management.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="6" target="9" id="0">
      <data key="d8">4</data>
      <data key="d9">EKS interacts with Aurora for database operations.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="6" target="10" id="0">
      <data key="d8">4</data>
      <data key="d9">EKS accesses the self-managed NFS server for file storage.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="6" target="4" id="0">
      <data key="d8">4</data>
      <data key="d9">EKS stores logs and potentially other static assets in S3.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <edge source="15" target="11" id="0">
      <data key="d8">5</data>
      <data key="d9">Operations team uses VPN for management access to services.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">Tribù E-commerce Platform Architecture</data>
    <data key="d1">https://www.youtube.com/watch?v=6sew_hdI6cY</data>
    <data key="d2">Architecture for Tribù's e-commerce platform based on Magento, managing over 100 stores on AWS, featuring proprietary load balancing, EKS for containerized applications, and a robust data layer.</data>
    <data key="d3">data_ingestion, interactive, compute_intensive, control</data>
    <data key="d4">True</data>
  </graph>
