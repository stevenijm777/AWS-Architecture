      <data key="d10">2b</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">Grindr Next-Gen Chat Architecture</data>
    <data key="d1">https://www.youtube.com/watch?v=6uEX5RKd0Bk</data>
    <data key="d2">Handles 121 billion annual chats. Bifurcates write-heavy chat bodies to DynamoDB (encrypted via KMS) and read-heavy inbox metadata to Aurora/Redis cache. Utilizes MSK for decoupled async operations.</data>
    <data key="d3">data_ingestion, compute_intensive, interactive</data>
    <data key="d4">True</data>
