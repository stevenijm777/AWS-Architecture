  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Grindr Mobile App</data>
      <data key="d6">UserConsumerWebMobile</data>
      <data key="d7">WORKLOAD_PEEK: Handles WebSocket (chats) and REST (inbox queries) requests.</data>
    </node>
    <node id="1">
      <data key="d5">EKS REST &amp; WebSocket</data>
      <data key="d6">EKS</data>
      <data key="d7">WORKLOAD_PEEK: Manages active WebSocket connections (W1, W2) and basic validation.</data>
    </node>
    <node id="2">
      <data key="d5">EKS Chat &amp; Notifications</data>
      <data key="d6">EKS</data>
      <data key="d7">WORKLOAD_PEEK: Central microservice brain orchestrating logic, security, and persistence.</data>
    </node>
    <node id="3">
      <data key="d5">ElastiCache Redis</data>
      <data key="d6">ElastiCache</data>
      <data key="d7">DATA_PEEK: Caches active user inboxes to prevent direct Aurora DB reads.</data>
    </node>
    <node id="4">
      <data key="d5">Amazon Aurora Postgres</data>
      <data key="d6">Aurora</data>
      <data key="d7">DATA_PEEK: Stores read-heavy inbox metadata, timestamps, and message headers.</data>
    </node>
    <node id="5">
      <data key="d5">Amazon DynamoDB</data>
      <data key="d6">DynamoDB</data>
      <data key="d7">DATA_PEEK: Scalable key-value store for encrypted application chat bodies.</data>
    </node>
    <node id="6">
      <data key="d5">Amazon Pinpoint</data>
      <data key="d6">Pinpoint</data>
      <data key="d7">WORKLOAD_PEEK: Triggers mobile push alerts over telephony network when user is offline.</data>
    </node>
    <node id="7">
      <data key="d5">Amazon MSK</data>
      <data key="d6">MSK</data>
      <data key="d7">WORKLOAD_PEEK: Managed Kafka cluster decoupling async flows like spam protection.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">User sends chat via WebSocket.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="0" target="1" id="1">
      <data key="d8">2</data>
      <data key="d9">User requests inbox retrieval over REST.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">Forwards message to chat processing services.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="2" id="1">
      <data key="d8">2</data>
      <data key="d9">Proxies inbox request to brain.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="0" id="0">
      <data key="d8">1</data>
      <data key="d9">If online, pushes chat directly over recipient socket.</data>
      <data key="d10">1a</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="5" id="0">
      <data key="d8">0</data>
      <data key="d9">Persists encrypted message body.</data>
      <data key="d10">2a</data>
      <data key="d11">data</data>
