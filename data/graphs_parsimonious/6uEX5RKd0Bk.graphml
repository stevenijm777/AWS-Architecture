    <edge source="2" target="4" id="0">
      <data key="d8">0</data>
      <data key="d9">Saves relational envelope/metadata.</data>
      <data key="d10">2b</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="4" id="1">
      <data key="d8">2</data>
      <data key="d9">On cache miss, loads from Aurora database and backfills Redis.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="7" id="0">
      <data key="d8">0</data>
      <data key="d9">Publishes event to Kafka for offline processing.</data>
      <data key="d10">2c</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="1" id="0">
      <data key="d8">1</data>
      <data key="d9">Checks if recipient user is online.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="6" id="0">
      <data key="d8">1</data>
      <data key="d9">If offline, routes push request to Pinpoint.</data>
      <data key="d10">1b</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="3" id="0">
      <data key="d8">2</data>
      <data key="d9">Queries Redis cache for user's inbox.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
