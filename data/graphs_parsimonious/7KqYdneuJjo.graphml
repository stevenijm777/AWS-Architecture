<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Practitioner</data>
      <data key="d6">UserConsumerWeb</data>
      <data key="d7">Healthcare professional seeking job listings.</data>
    </node>
    <node id="1">
      <data key="d5">.NET Application</data>
      <data key="d6">ECS</data>
      <data key="d7">Orchestrates user queries and controls GenAI workflows.</data>
    </node>
    <node id="2">
      <data key="d5">Bedrock Claude 2 (Sanitizer)</data>
      <data key="d6">AmazonML</data>
      <data key="d7">Sanitizes prompts, handles prompt injection, and converts locations to coordinates.</data>
    </node>
    <node id="3">
      <data key="d5">Bedrock Titan (Embed)</data>
      <data key="d6">AmazonML</data>
      <data key="d7">Converts user search prompts into vector embeddings.</data>
    </node>
    <node id="4">
      <data key="d5">MS SQL on EC2</data>
      <data key="d6">EC2</data>
      <data key="d7">Retrieves historical search history for the user.</data>
    </node>
    <node id="5">
      <data key="d5">Elasticsearch on EC2</data>
      <data key="d6">EC2</data>
      <data key="d7">Full-text and vector content knowledge base of job descriptions.</data>
    </node>
    <node id="6">
      <data key="d5">Bedrock Claude 2 (Generator)</data>
      <data key="d6">AmazonML</data>
      <data key="d7">Generates a structured NLP response streaming back to the user.</data>
    </node>
    <node id="7">
      <data key="d5">S3 Document Store</data>
      <data key="d6">S3</data>
      <data key="d7">Stores RSS and API feeds from external partners.</data>
    </node>
    <node id="8">
      <data key="d5">Bedrock Titan (Vectorize)</data>
      <data key="d6">AmazonML</data>
      <data key="d7">Vectorizes job descriptions from S3 before storage.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">User submits a natural language search query.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">Passes query for sanitization and geolocation conversion.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="3" id="0">
      <data key="d8">0</data>
      <data key="d9">Requests vector embedding of the sanitized prompt.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">Returns enriched and sanitized prompt.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="4" id="0">
      <data key="d8">0</data>
      <data key="d9">Passes vectorized query to retrieve chat history.</data>
      <data key="d10">5</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="5" id="0">
      <data key="d8">0</data>
      <data key="d9">Queries vector database using search query and historical context.</data>
      <data key="d10">6</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="6" id="0">
      <data key="d8">0</data>
      <data key="d9">Extracts 6 relevant job descriptions and sends to Bedrock.</data>
      <data key="d10">7</data>
      <data key="d11">data</data>
    </edge>
    <edge source="6" target="0" id="0">
      <data key="d8">0</data>
      <data key="d9">Streams AI-generated response back to the user.</data>
      <data key="d10">8</data>
      <data key="d11">data</data>
    </edge>
    <edge source="7" target="8" id="0">
      <data key="d8">1</data>
      <data key="d9">Feeds new jobs from S3 to Titan every 6 hours for vectorization.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="8" target="5" id="0">
      <data key="d8">1</data>
      <data key="d9">Stores vectorized job descriptions in the search database.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">Healthy Careers GenAI Job Search Engine</data>
    <data key="d1">https://www.youtube.com/watch?v=7KqYdneuJjo</data>
    <data key="d2">Generative AI search engine utilizing Amazon Bedrock (Claude 2 and Titan) and Elasticsearch to provide NLP-based job searches for healthcare workers with &gt;80% interaction rates.</data>
    <data key="d3">interactive, compute_intensive, data_ingestion</data>
    <data key="d4">True</data>
  </graph>
</graphml>
