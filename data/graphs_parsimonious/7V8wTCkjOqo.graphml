  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Service Teams</data>
      <data key="d6">UserCompanyDeveloper</data>
      <data key="d7">WORKLOAD_PEEK: Developers running CI/CD pipelines in non-production environments.</data>
    </node>
    <node id="1">
      <data key="d5">Kong Gateway on ECS</data>
      <data key="d6">ECS</data>
      <data key="d7">WORKLOAD_PEEK: API gateway publishing endpoints and receiving pipeline events.</data>
    </node>
    <node id="2">
      <data key="d5">Assessment Engine</data>
      <data key="d6">Lambda</data>
      <data key="d7">WORKLOAD_PEEK: Orchestration logic that validates evidence and coordinates deployments. Scaled to multiple concurrent executions.</data>
    </node>
    <node id="3">
      <data key="d5">Build Events Store</data>
      <data key="d6">DynamoDB</data>
      <data key="d7">DATA_PEEK: Key-value store holding immutable pipeline execution and audit evidence.</data>
    </node>
    <node id="4">
      <data key="d5">Compliance Rules DB</data>
      <data key="d6">RDS</data>
      <data key="d7">DATA_PEEK: PostgreSQL DB managing relational standards, regulatory controls, and rules.</data>
    </node>
    <node id="5">
      <data key="d5">Deployment SNS</data>
      <data key="d6">SNS</data>
      <data key="d7">WORKLOAD_PEEK: Fan-out messaging system notifying target prod environment of verified builds.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">Pipelines push build event evidence to API gateway.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="0" target="1" id="1">
      <data key="d8">1</data>
      <data key="d9">Service teams initiate a deployment/promotion request.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">ECS forwards API events to Lambda.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
