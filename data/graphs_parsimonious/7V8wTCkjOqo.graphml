    <edge source="1" target="2" id="1">
      <data key="d8">1</data>
      <data key="d9">Gateway routes promotion call to Lambda.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="3" id="0">
      <data key="d8">0</data>
      <data key="d9">Lambda records build evidence in DynamoDB.</data>
      <data key="d10">2</data>
