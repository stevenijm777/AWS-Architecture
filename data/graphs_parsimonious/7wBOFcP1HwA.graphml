    <node id="8">
      <data key="d5">RDS Database</data>
      <data key="d6">RDS</data>
      <data key="d7">Managed relational database layer.</data>
    </node>
    <node id="9">
      <data key="d5">EC2 Instances</data>
      <data key="d6">EC2</data>
      <data key="d7">Hosts self-managed tooling and databases.</data>
    </node>
    <node id="10">
      <data key="d5">CloudWatch</data>
      <data key="d6">CloudWatch</data>
      <data key="d7">Provides infrastructure monitoring and observability.</data>
    </node>
