    <node id="4">
      <data key="d5">60+ Load Balancers</data>
      <data key="d6">ALB</data>
      <data key="d7">WORKLOAD_PEEK: Separated for Web and APIs.</data>
    </node>
    <node id="5">
      <data key="d5">Legacy Monolith</data>
      <data key="d6">EC2</data>
      <data key="d7">Handles ~20% of legacy traffic.</data>
