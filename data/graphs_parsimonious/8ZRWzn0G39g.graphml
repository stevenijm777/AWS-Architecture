<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Enterprise Users</data>
      <data key="d6">UserCompanyAPI</data>
      <data key="d7">Enterprise customers with strict regulatory/compliance requirements.</data>
    </node>
    <node id="1">
      <data key="d5">Standard Users</data>
      <data key="d6">UserConsumerWeb</data>
      <data key="d7">Standard multi-tenant SaaS users.</data>
    </node>
    <node id="2">
      <data key="d5">API Gateway</data>
      <data key="d6">ApiGateway</data>
      <data key="d7">Unified entry point for API routing and traffic management.</data>
    </node>
    <node id="3">
      <data key="d5">Business Logic</data>
      <data key="d6">EKS</data>
      <data key="d7">SaaS business logic running on EKS, ECS, and EC2.</data>
    </node>
    <node id="4">
      <data key="d5">Inter-Infrastructure Intelligence (I3)</data>
      <data key="d6">Fargate</data>
      <data key="d7">Fargate-based routing API used to look up database locations per tenant.</data>
    </node>
    <node id="5">
      <data key="d5">I3 Config Store</data>
      <data key="d6">DynamoDB</data>
      <data key="d7">DATA_PEEK: Stores tenant routing metadata and lookup maps.</data>
    </node>
    <node id="6">
      <data key="d5">Shared Aurora DB</data>
      <data key="d6">Aurora</data>
      <data key="d7">DATA_PEEK: Multi-tenant database encrypted with standard platform key.</data>
    </node>
    <node id="7">
      <data key="d5">Replicon KMS</data>
      <data key="d6">KMS</data>
      <data key="d7">Platform-managed KMS key for encrypting shared tenant data.</data>
    </node>
    <node id="8">
      <data key="d5">Dedicated Aurora DB</data>
      <data key="d6">Aurora</data>
      <data key="d7">DATA_PEEK: Single-tenant isolated database for enterprise compliance.</data>
    </node>
    <node id="9">
      <data key="d5">Customer KMS CMK</data>
      <data key="d6">KMS</data>
      <data key="d7">Customer-managed CMK hosted in client AWS account, accessed via cross-account key policy.</data>
    </node>
    <edge source="0" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">Enterprise traffic is routed to API Gateway.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="2" id="0">
      <data key="d8">1</data>
      <data key="d9">Standard user traffic is routed to API Gateway.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="3" id="0">
      <data key="d8">0</data>
      <data key="d9">Forwards API calls to the shared business logic tier.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="4" id="0">
      <data key="d8">0</data>
      <data key="d9">Queries routing API to identify database target.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="6" id="0">
      <data key="d8">1</data>
      <data key="d9">Accesses shared multi-tenant database for standard requests.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="8" id="0">
      <data key="d8">0</data>
      <data key="d9">Accesses isolated database instance for enterprise requests.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="5" id="0">
      <data key="d8">0</data>
      <data key="d9">Retrieves tenant database configuration mappings.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="6" target="7" id="0">
      <data key="d8">1</data>
      <data key="d9">Decrypts/encrypts shared data with platform-owned KMS key.</data>
      <data key="d10">5</data>
      <data key="d11">data</data>
    </edge>
    <edge source="8" target="9" id="0">
      <data key="d8">0</data>
      <data key="d9">Decrypts/encrypts enterprise tenant data with customer-managed KMS key.</data>
      <data key="d10">5</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">Replicon Multi-Tenant SaaS Key Management Architecture</data>
    <data key="d1">https://www.youtube.com/watch?v=8ZRWzn0G39g</data>
    <data key="d2">SaaS application separating standard multi-tenant users and regulatory compliance enterprise users. Uses bring-your-own-key (BYOK) via cross-account AWS KMS CMK for dedicated tenant database encryption.</data>
    <data key="d3">compute_intensive, interactive</data>
    <data key="d4">True</data>
  </graph>
</graphml>
