<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Client Buckets</data>
      <data key="d6">S3</data>
      <data key="d7">WORKLOAD_PEEK: Individual client buckets storing shared data.</data>
    </node>
    <node id="1">
      <data key="d5">S3 Access Logs</data>
      <data key="d6">S3</data>
      <data key="d7">Consolidated target bucket receiving all S3 access logs.</data>
    </node>
    <node id="2">
      <data key="d5">Log Parser Lambda</data>
      <data key="d6">Lambda</data>
      <data key="d7">DATA_PEEK: Processes 18-20M logs/month. Resolves IP to Country ID.</data>
    </node>
    <node id="3">
      <data key="d5">Elasticsearch Service</data>
      <data key="d6">OpenSearch</data>
      <data key="d7">Runs Anomaly Detector on custom Country ID numeric field.</data>
    </node>
    <node id="4">
      <data key="d5">SNS</data>
      <data key="d6">SNS</data>
      <data key="d7">Triggers email alerts when anomalies are detected.</data>
    </node>
    <node id="5">
      <data key="d5">Service Team</data>
      <data key="d6">UserCompanyAgent</data>
      <data key="d7">Investigates detected anomalies.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">S3 access log generation</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">Triggers Lambda function</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="3" id="0">
      <data key="d8">0</data>
      <data key="d9">Inserts parsed and mapped logs</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="4" id="0">
      <data key="d8">1</data>
      <data key="d9">Triggers alert on anomaly</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="5" id="0">
      <data key="d8">1</data>
      <data key="d9">Sends notification email</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">Mobilewala Proactive Near Real-Time Anomaly Detector</data>
    <data key="d1">https://www.youtube.com/watch?v=8s0wGRkiDrw</data>
    <data key="d2">System processes 18-20M logs/month to detect anomalous access patterns by mapping IPs to numeric IDs for Elasticsearch anomaly detection.</data>
    <data key="d3">data_ingestion, control</data>
    <data key="d4">True</data>
  </graph>
</graphml>
