<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Healthcare Providers</data>
      <data key="d6">UserConsumerHospital</data>
      <data key="d7">Hospitals and clinics sending healthcare data over TCP.</data>
    </node>
    <node id="1">
      <data key="d5">NLB</data>
      <data key="d6">NLB</data>
      <data key="d7">Handles Layer 4 TCP traffic and whitelists source/destination IPs.</data>
    </node>
    <node id="2">
      <data key="d5">HA Proxy Ingress</data>
      <data key="d6">EC2</data>
      <data key="d7">HA Proxy ingress controller running on EC2 inside the EKS cluster.</data>
    </node>
    <node id="3">
      <data key="d5">EKS Worker Nodes</data>
      <data key="d6">EC2</data>
      <data key="d7">WORKLOAD_PEEK: Arm-based Graviton instances hosting customer-segregated EKS namespaces.</data>
    </node>
    <node id="4">
      <data key="d5">EBS GP3</data>
      <data key="d6">EBS</data>
      <data key="d7">DATA_PEEK: Dedicated encrypted GP3 volumes per customer environment.</data>
    </node>
    <node id="5">
      <data key="d5">ECR</data>
      <data key="d6">ECR</data>
      <data key="d7">Stores containerized integration engine images.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">1</data>
      <data key="d9">Sends healthcare data via TCP.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="2" id="0">
      <data key="d8">1</data>
      <data key="d9">Routes traffic securely to HA Proxy.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="3" id="0">
      <data key="d8">1</data>
      <data key="d9">Forwards traffic to tenant-specific namespaces.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="4" id="0">
      <data key="d8">1</data>
      <data key="d9">Writes data to isolated, encrypted EBS GP3 volumes.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="3" id="0">
      <data key="d8">0</data>
      <data key="d9">Deploys integration engines as container images to worker nodes.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">Lineate Envoy Healthcare Data Integration Platform</data>
    <data key="d1">https://www.youtube.com/watch?v=9-6hQdFeolc</data>
    <data key="d2">Multi-tenant healthcare platform utilizing EKS with Graviton instances, NLB with HA Proxy for layer 4 TCP traffic, and dedicated EBS GP3 volumes for tenant isolation.</data>
    <data key="d3">data_ingestion, compute_intensive</data>
    <data key="d4">True</data>
  </graph>
</graphml>
