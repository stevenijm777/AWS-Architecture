  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Internal User</data>
      <data key="d6">UserCompanyDeveloper</data>
      <data key="d7">Requests new AWS account via portal.</data>
    </node>
    <node id="1">
      <data key="d5">API Gateway</data>
      <data key="d6">ApiGateway</data>
      <data key="d7">Exposes API endpoint for the web portal requests.</data>
    </node>
    <node id="2">
      <data key="d5">Step Functions (AVM)</data>
      <data key="d6">StepFunctions</data>
      <data key="d7">Account Vending Machine to coordinate account provisioning workflows.</data>
    </node>
    <node id="3">
      <data key="d5">DynamoDB</data>
      <data key="d6">DynamoDB</data>
      <data key="d7">DATA_PEEK: Stores target state config, ensuring process idempotency.</data>
    </node>
    <node id="4">
      <data key="d5">Control Tower</data>
      <data key="d6">ControlTower</data>
      <data key="d7">Creates new AWS accounts using Service Catalog items.</data>
    </node>
    <node id="5">
      <data key="d5">Step Functions (Blueprint)</data>
      <data key="d6">StepFunctions</data>
      <data key="d7">Applies standard blueprints (IAM, networking, security) into target accounts.</data>
    </node>
    <node id="6">
      <data key="d5">AWS Account</data>
      <data key="d6">Organizations</data>
      <data key="d7">The newly provisioned, configured target tenant account.</data>
    </node>
    <node id="7">
      <data key="d5">SES</data>
      <data key="d6">SES</data>
      <data key="d7">Sends email notification to the user upon successful account setup.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">Submits metadata for network setup and blueprints.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">Triggers Account Vending Machine workflow.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="3" id="0">
      <data key="d8">0</data>
      <data key="d9">Checks/stores target state config details.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="4" id="0">
      <data key="d8">0</data>
      <data key="d9">Triggers Control Tower account creation.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="5" id="0">
      <data key="d8">0</data>
      <data key="d9">Triggers deployment of standard configurations.</data>
      <data key="d10">5</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="6" id="0">
      <data key="d8">0</data>
      <data key="d9">Applies network, IAM, and security configurations to target account.</data>
      <data key="d10">6</data>
      <data key="d11">data</data>
