  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Developer</data>
      <data key="d6">UserConsumerDeveloper</data>
      <data key="d7">Pushes code to trigger Git-based workflow.</data>
    </node>
    <node id="1">
      <data key="d5">Git Repository</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Hosts application code and triggers Lagoon via webhook.</data>
    </node>
    <node id="2">
      <data key="d5">Lagoon EKS</data>
      <data key="d6">EKS</data>
      <data key="d7">Core Lagoon application platform handling orchestration.</data>
    </node>
    <node id="3">
      <data key="d5">Target EKS</data>
      <data key="d6">EKS</data>
      <data key="d7">Target Kubernetes cluster containing developer environments.</data>
    </node>
    <node id="4">
      <data key="d5">EC2</data>
      <data key="d6">EC2</data>
      <data key="d7">Base instances for production workloads.</data>
    </node>
    <node id="5">
      <data key="d5">EC2 Spot</data>
      <data key="d6">EC2</data>
      <data key="d7">Used for non-production environments to save up to 90% cost.</data>
    </node>
    <node id="6">
      <data key="d5">Aurora R6g</data>
      <data key="d6">Aurora</data>
      <data key="d7">Database storage utilizing Graviton2 (R6g) ARM instances.</data>
    </node>
    <node id="7">
      <data key="d5">EBS GP3</data>
      <data key="d6">EBS</data>
      <data key="d7">Block storage for databases and search workloads like OpenSearch.</data>
    </node>
    <node id="8">
      <data key="d5">EFS</data>
      <data key="d6">EFS</data>
      <data key="d7">Shared file system for standard application assets.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">Push code</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">Webhook trigger</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="3" id="0">
      <data key="d8">0</data>
      <data key="d9">Deploys environment</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="4" id="0">
      <data key="d8">0</data>
      <data key="d9">Launches pods on EC2</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="5" id="0">
      <data key="d8">0</data>
      <data key="d9">Launches pods on Spot</data>
      <data key="d10">5</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="6" id="0">
      <data key="d8">0</data>
      <data key="d9">Connects to database</data>
      <data key="d10">6</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="7" id="0">
      <data key="d8">0</data>
      <data key="d9">Mounts block storage</data>
      <data key="d10">7</data>
      <data key="d11">data</data>
