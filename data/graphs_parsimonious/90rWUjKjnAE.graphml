    <data key="d0">Amazie.io Lagoon Kubernetes Delivery Platform</data>
    <data key="d1">https://www.youtube.com/watch?v=90rWUjKjnAE</data>
    <data key="d2">Application delivery platform leveraging EKS, EC2 Spot, and ARM-based Aurora R6g instances to reduce costs by 70-90% and improve I/O performance.</data>
    <data key="d3">compute_intensive, interactive</data>
    <data key="d4">True</data>
