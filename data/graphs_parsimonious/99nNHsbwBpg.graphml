<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Kubernetes Cluster Autoscaler</data>
      <data key="d6">EC2</data>
      <data key="d7">WORKLOAD_PEEK: Adjusts ASG desired counts. Patched to prevent scaling lockups at zero nodes.</data>
    </node>
    <node id="1">
      <data key="d5">Auto Scaling Group 1</data>
      <data key="d6">AutoScaling</data>
      <data key="d7">WORKLOAD_PEEK: Spot pool ASG spanning multiple AZs. Diversified with instance types like C3/C4/C5.</data>
    </node>
    <node id="2">
      <data key="d5">Auto Scaling Group 2</data>
      <data key="d6">AutoScaling</data>
      <data key="d7">WORKLOAD_PEEK: Separate Spot pool ASG to maximize spot capacity availability.</data>
    </node>
    <node id="3">
      <data key="d5">EC2 Worker Nodes (ASG 1)</data>
      <data key="d6">EC2</data>
      <data key="d7">DATA_PEEK: Runs HAProxy ingress controllers. Detects spot termination metadata to drain pods gracefully.</data>
    </node>
    <node id="4">
      <data key="d5">EC2 Worker Nodes (ASG 2)</data>
      <data key="d6">EC2</data>
      <data key="d7">DATA_PEEK: Runs HAProxy ingress controllers. Coordinates with ELB to stop incoming traffic during termination.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">Triggers scale-up/down actions on ASG 1 based on cluster demand.</data>
      <data key="d10">0</data>
      <data key="d11">meta</data>
    </edge>
    <edge source="0" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">Triggers scale-up/down actions on ASG 2.</data>
      <data key="d10">1</data>
      <data key="d11">meta</data>
    </edge>
    <edge source="1" target="3" id="0">
      <data key="d8">0</data>
      <data key="d9">Provisions or terminates worker instances in ASG 1.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="4" id="0">
      <data key="d8">0</data>
      <data key="d9">Provisions or terminates worker instances in ASG 2.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">Skyscanner 100% Spot Instance Kubernetes Architecture</data>
    <data key="d1">https://www.youtube.com/watch?v=99nNHsbwBpg</data>
    <data key="d2">Handles 60k-70k QPS and peak loads of 3,500-4,000 cores using 100% Spot instances. Utilizes multiple ASGs to diversify spot instance types across AZs. A custom script handles the 2-minute spot termination notice by draining nodes.</data>
    <data key="d3">compute_intensive,control</data>
    <data key="d4">True</data>
  </graph>
</graphml>
