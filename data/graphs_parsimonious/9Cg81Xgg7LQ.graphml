<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Giving Platform (Monolith)</data>
      <data key="d6">EC2</data>
      <data key="d7">WORKLOAD_PEEK: Legacy .NET Windows monolith.</data>
    </node>
    <node id="1">
      <data key="d5">SQL Server</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">DATA_PEEK: Database for the legacy monolith.</data>
    </node>
    <node id="2">
      <data key="d5">Apps Platform</data>
      <data key="d6">EC2</data>
      <data key="d7">WORKLOAD_PEEK: Node-based apps platform.</data>
    </node>
    <node id="3">
      <data key="d5">Identity Service (ECS)</data>
      <data key="d6">ECS</data>
      <data key="d7">WORKLOAD_PEEK: .NET Core container running on Alpine Linux hosting a GraphQL API.</data>
    </node>
    <node id="4">
      <data key="d5">DynamoDB</data>
      <data key="d6">DynamoDB</data>
      <data key="d7">DATA_PEEK: Event store capturing user profile histories.</data>
    </node>
    <node id="5">
      <data key="d5">Kinesis Stream</data>
      <data key="d6">Kinesis</data>
      <data key="d7">DATA_PEEK: Distributes events back to other microservices and legacy platform.</data>
    </node>
    <node id="6">
      <data key="d5">AWS X-Ray</data>
      <data key="d6">XRay</data>
      <data key="d7">Used for tracing requests across the distributed system.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">Monolith database queries.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="0" target="3" id="0">
      <data key="d8">1</data>
      <data key="d9">Sign-in/up requests from legacy platform to new Identity API.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="3" id="0">
      <data key="d8">1</data>
      <data key="d9">Sign-in/up requests from Apps platform to GraphQL API.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="4" id="0">
      <data key="d8">1</data>
      <data key="d9">Stores events in DynamoDB.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="5" id="0">
      <data key="d8">1</data>
      <data key="d9">Publishes events to Kinesis.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="6" id="0">
      <data key="d8">1</data>
      <data key="d9">Sends execution trace logs.</data>
      <data key="d10">5</data>
      <data key="d11">meta</data>
    </edge>
    <edge source="5" target="0" id="0">
      <data key="d8">1</data>
      <data key="d9">Synchronization loop back to the monolith.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">Pushpay Monolith Decomposition to Containerized Microservices</data>
    <data key="d1">https://www.youtube.com/watch?v=9Cg81Xgg7LQ</data>
    <data key="d2">Decomposing a .NET/SQL Server monolith into containerized .NET Core microservices on ECS, utilizing DynamoDB for event sourcing and Kinesis to sync back with the legacy platform.</data>
    <data key="d3">compute_intensive, data_ingestion</data>
    <data key="d4">True</data>
  </graph>
