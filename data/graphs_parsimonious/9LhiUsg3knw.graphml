<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Mobile App User</data>
      <data key="d6">UserConsumerMobile</data>
      <data key="d7">Users accessing the Music Match mobile app to listen to synchronized lyrics and provide feedback.</data>
    </node>
    <node id="1">
      <data key="d5">Web User</data>
      <data key="d6">UserConsumerWeb</data>
      <data key="d7">Users interacting with the Music Match service via a web browser.</data>
    </node>
    <node id="2">
      <data key="d5">Internal/Expert Users</data>
      <data key="d6">UserCompanyAgent</data>
      <data key="d7">Internal Music Match personnel or external experts (e.g., artists, genre specialists) responsible for reviewing and editing content, or checking synchronization.</data>
    </node>
    <node id="3">
      <data key="d5">AppSync</data>
      <data key="d6">AppSync</data>
      <data key="d7">Distributes tasks to different user categories, allows instant data synchronization on client devices, and handles content submission interfacing with other services.</data>
    </node>
    <node id="4">
      <data key="d5">Content Submission Lambda</data>
      <data key="d6">Lambda</data>
      <data key="d7">Handles content submission, potentially processing data from CouchBase and EC2 before sending to AppSync.</data>
    </node>
    <node id="5">
      <data key="d5">Legacy Backend</data>
      <data key="d6">EC2</data>
      <data key="d7">Hosts the legacy part of Music Match's backend, processes initial user feedback, and interacts with various databases.</data>
    </node>
    <node id="6">
      <data key="d5">CouchBase</data>
      <data key="d6">CouchBase</data>
      <data key="d7">NoSQL database used for storing user-generated data.</data>
    </node>
    <node id="7">
      <data key="d5">Aurora</data>
      <data key="d6">Aurora</data>
      <data key="d7">Relational database used for storing editorial data.</data>
    </node>
    <node id="8">
      <data key="d5">DynamoDB</data>
      <data key="d6">DynamoDB</data>
      <data key="d7">Stores tasks generated from feedback and content updates, used for task distribution and results.</data>
    </node>
    <node id="9">
      <data key="d5">Orchestration Lambda</data>
      <data key="d6">Lambda</data>
      <data key="d7">Orchestrates complex operations like simultaneous writing of task results to DynamoDB and content publication, triggered by AppSync.</data>
    </node>
    <node id="10">
      <data key="d5">Fargate Batch Jobs</data>
      <data key="d6">Fargate</data>
      <data key="d7">Runs batch jobs to update and prioritize content based on streaming service charts and other relevance metrics, feeding into DynamoDB.</data>
    </node>
    <node id="11">
      <data key="d5">Redshift Analytics</data>
      <data key="d6">RedShift</data>
      <data key="d7">Our analytics platform, extracts rankings of relevant content per country and language, contributing to task prioritization in DynamoDB.</data>
    </node>
    <edge source="0" target="3" id="0">
      <data key="d8">0</data>
      <data key="d9">Users interact with the app for synchronized lyrics and submit feedback.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="0" target="5" id="0">
      <data key="d8">9</data>
      <data key="d9">Feedback from mobile app users arrives at the EC2 legacy system.</data>
      <data key="d10">9</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="3" id="0">
      <data key="d8">1</data>
      <data key="d9">Users interact with the service via web.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="3" id="0">
      <data key="d8">2</data>
      <data key="d9">Internal users and experts manage tasks and content via AppSync.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="8" id="0">
      <data key="d8">3</data>
      <data key="d9">AppSync interacts with DynamoDB for task creation, updates, and content synchronization.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="9" id="0">
      <data key="d8">5</data>
      <data key="d9">AppSync triggers Lambda for complex content-related operations.</data>
      <data key="d10">5</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="3" id="0">
      <data key="d8">14</data>
      <data key="d9">Submitted content flows to AppSync for distribution and synchronization.</data>
      <data key="d10">14</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="7" id="0">
      <data key="d8">7</data>
      <data key="d9">EC2 legacy backend uses Aurora for editorial data.</data>
      <data key="d10">7</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="6" id="0">
      <data key="d8">8</data>
      <data key="d9">EC2 legacy backend uses CouchBase for user-generated data.</data>
      <data key="d10">8</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="8" id="0">
      <data key="d8">10</data>
      <data key="d9">Feedback processed by EC2 creates tasks in DynamoDB.</data>
      <data key="d10">10</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="4" id="0">
      <data key="d8">11</data>
      <data key="d9">EC2 triggers Lambda for content submission.</data>
      <data key="d10">11</data>
      <data key="d11">data</data>
    </edge>
    <edge source="6" target="5" id="0">
      <data key="d8">12</data>
      <data key="d9">User data and feedback from CouchBase are processed by EC2.</data>
      <data key="d10">12</data>
      <data key="d11">data</data>
    </edge>
    <edge source="6" target="4" id="0">
      <data key="d8">13</data>
      <data key="d9">CouchBase data is used by Lambda for content submission.</data>
      <data key="d10">13</data>
      <data key="d11">data</data>
    </edge>
    <edge source="8" target="3" id="0">
      <data key="d8">4</data>
      <data key="d9">Tasks from DynamoDB are distributed to users via AppSync.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <edge source="9" target="8" id="0">
      <data key="d8">6</data>
      <data key="d9">Lambda writes task results and publishes content to DynamoDB.</data>
      <data key="d10">6</data>
      <data key="d11">data</data>
    </edge>
    <edge source="10" target="8" id="0">
      <data key="d8">15</data>
      <data key="d9">Fargate batch jobs update and prioritize content tasks in DynamoDB.</data>
      <data key="d10">15</data>
      <data key="d11">data</data>
    </edge>
    <edge source="11" target="8" id="0">
      <data key="d8">16</data>
      <data key="d9">Redshift analytics (content rankings) contribute to task ranking in DynamoDB.</data>
      <data key="d10">16</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">Music Match Architecture</data>
    <data key="d1">https://www.youtube.com/watch?v=9LhiUsg3knw</data>
    <data key="d2">Music Match's architecture for managing song lyrics, feedback, and content synchronization. It leverages AWS services like EC2 for legacy systems, Aurora and CouchBase for data storage, DynamoDB for task management, Fargate for batch processing, Redshift for analytics, Lambda for complex operations, and AppSync for real-time data synchronization and user interaction.</data>
    <data key="d3">data_ingestion, interactive, compute_intensive, control</data>
    <data key="d4">True</data>
  </graph>
</graphml>
