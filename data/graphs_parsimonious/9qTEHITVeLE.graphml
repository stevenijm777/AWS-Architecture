  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Meta Manager</data>
      <data key="d6">EKS</data>
      <data key="d7">WORKLOAD_PEEK: Brains of the grid, abstracts complexity of data movement. Runs as microservices on EKS.</data>
    </node>
    <node id="1">
      <data key="d5">MetaStore</data>
      <data key="d6">OpenSearch</data>
      <data key="d7">DATA_PEEK: Labeled Elasticsearch/Neo4j. Stores schema, API, and table details.</data>
    </node>
    <node id="2">
      <data key="d5">Multiple Data Sources</data>
      <data key="d6">OnPremDC</data>
      <data key="d7">DATA_PEEK: Legacy databases and APIs across different countries and business domains.</data>
    </node>
    <node id="3">
      <data key="d5">Kafka</data>
      <data key="d6">MSK</data>
      <data key="d7">DATA_PEEK: Managed Kafka streaming platform with 600 topics, 250 GB/day, and 7 days retention.</data>
    </node>
    <node id="4">
      <data key="d5">S3 Data Lake</data>
      <data key="d6">S3</data>
      <data key="d7">DATA_PEEK: Labeled 60TB. Central repository for multi-source data.</data>
    </node>
    <node id="5">
      <data key="d5">EMR</data>
      <data key="d6">EMR</data>
      <data key="d7">WORKLOAD_PEEK: Spark/Hadoop processing engine to aggregate and refine data lake tables.</data>
    </node>
    <node id="6">
      <data key="d5">RDS</data>
      <data key="d6">RDS</data>
      <data key="d7">DATA_PEEK: Target transactional OLTP database for consumed analytics.</data>
    </node>
    <node id="7">
      <data key="d5">Vertica</data>
      <data key="d6">EC2</data>
      <data key="d7">WORKLOAD_PEEK: Labeled Vertica. Columnar database running on EC2 for high-performance analytics.</data>
    </node>
    <node id="8">
      <data key="d5">Applications</data>
