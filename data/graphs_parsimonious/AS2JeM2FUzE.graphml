  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Data Sources</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Crawlers, premium connectors, and custom carrier feeds.</data>
    </node>
    <node id="1">
      <data key="d5">ELB</data>
      <data key="d6">ELB</data>
      <data key="d7">Distributes incoming crawled and connector data.</data>
    </node>
    <node id="2">
      <data key="d5">K8S Cluster</data>
      <data key="d6">EC2</data>
      <data key="d7">Self-managed Kubernetes hosting microservices, Kong Gateway, Keycloak, and Jupyter Notebooks.</data>
    </node>
    <node id="3">
      <data key="d5">Amazon MQ</data>
      <data key="d6">AmazonMQ</data>
      <data key="d7">Decouples microservices and queues message processing.</data>
    </node>
    <node id="4">
      <data key="d5">VPC Peering</data>
      <data key="d6">VPCPeering</data>
      <data key="d7">Provides private routing to MongoDB Atlas.</data>
    </node>
    <node id="5">
      <data key="d5">MongoDB Atlas</data>
      <data key="d6">MongoDBAtlas</data>
      <data key="d7">Stores curated entity profiles and risk data.</data>
    </node>
    <node id="6">
      <data key="d5">Consumers</data>
      <data key="d6">UserConsumerWeb</data>
      <data key="d7">Underwriters and policy agents querying risk scores.</data>
    </node>
    <node id="7">
      <data key="d5">RDS Postgres</data>
      <data key="d6">RDS</data>
      <data key="d7">Stores configuration for Kong and identity data for Keycloak.</data>
    </node>
    <node id="8">
      <data key="d5">Redis Cache</data>
      <data key="d6">ElastiCache</data>
      <data key="d7">Handles user session and cache management.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">Raw crawled data ingestion.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">Fans out traffic to K8S microservices.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="3" id="0">
      <data key="d8">0</data>
      <data key="d9">Pushes unprocessed messages to the queue.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="4" id="0">
      <data key="d8">0</data>
      <data key="d9">Routes traffic securely through VPC peering.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="7" id="0">
      <data key="d8">1</data>
      <data key="d9">Authenticates and authorizes via Keycloak database.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="8" id="0">
      <data key="d8">1</data>
      <data key="d9">Retrieves or updates user session state.</data>
      <data key="d10">2</data>
