      <data key="d9">Triggers batch writer</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="4" target="7">
      <data key="d8">2</data>
      <data key="d9">Streams records for archiving</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="5" target="6">
      <data key="d8">1</data>
      <data key="d9">Performs high-speed database writes</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
