  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Client Lambda</data>
      <data key="d6">Lambda</data>
      <data key="d7">WORKLOAD_PEEK: Monitored user lambdas generating logs.</data>
    </node>
    <node id="1">
      <data key="d5">Log Stream Kinesis</data>
      <data key="d6">Kinesis</data>
      <data key="d7">Ingests streamed CloudWatch log groups from customer accounts.</data>
    </node>
    <node id="2">
      <data key="d5">Transform Lambda</data>
      <data key="d6">Lambda</data>
      <data key="d7">WORKLOAD_PEEK: Transforms raw log lines into clean invocation records.</data>
    </node>
    <node id="3">
      <data key="d5">Metadata DB</data>
      <data key="d6">DynamoDB</data>
      <data key="d7">DATA_PEEK: Keeps track of customer functions, configs, and partial state.</data>
    </node>
    <node id="4">
      <data key="d5">Invocation Stream Kinesis</data>
      <data key="d6">Kinesis</data>
      <data key="d7">Streams processed invocation records.</data>
    </node>
    <node id="5">
      <data key="d5">Aurora Writer Lambda</data>
      <data key="d6">Lambda</data>
      <data key="d7">Writes invocation records to Aurora DB. Concurrency controlled by Kinesis integration to prevent Aurora overload.</data>
    </node>
    <node id="6">
      <data key="d5">Serverless Aurora</data>
      <data key="d6">Aurora</data>
      <data key="d7">DATA_PEEK: High-speed storage optimized for single point-in-time trace queries.</data>
    </node>
    <node id="7">
      <data key="d5">Firehose</data>
      <data key="d6">Firehose</data>
      <data key="d7">Batches incoming invocation records and converts JSON to Parquet.</data>
    </node>
    <node id="8">
      <data key="d5">Glue Data Catalog</data>
      <data key="d6">Glue</data>
      <data key="d7">Provides table schema for Parquet conversion within Firehose.</data>
    </node>
    <node id="9">
      <data key="d5">Data Lake S3</data>
      <data key="d6">S3</data>
      <data key="d7">DATA_PEEK: Long-term storage of optimized Parquet records.</data>
    </node>
    <node id="10">
      <data key="d5">Athena</data>
      <data key="d6">Athena</data>
      <data key="d7">Performs ad-hoc queries and builds aggregated metrics from S3.</data>
    </node>
    <edge source="0" target="1">
      <data key="d8">0</data>
      <data key="d9">Streams logs from client account</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="1" target="2">
