      <data key="d9">Feeds log streams in batches</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="2" target="3">
      <data key="d8">0</data>
      <data key="d9">Queries metadata and manages state</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="2" target="4">
      <data key="d8">0</data>
      <data key="d9">Emits parsed invocation records</data>
      <data key="d10">4</data>
