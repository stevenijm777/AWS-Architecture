<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Caller Carrie</data>
      <data key="d6">UserConsumerWeb</data>
      <data key="d7">End customer initiating voice, chat, or email support requests.</data>
    </node>
    <node id="1">
      <data key="d5">Amazon Connect</data>
      <data key="d6">Connect</data>
      <data key="d7">Manages incoming chat and voice contacts.</data>
    </node>
    <node id="2">
      <data key="d5">IVR Routing Lambda</data>
      <data key="d6">Lambda</data>
      <data key="d7">Executes logic for IVR menus and routing decisions.</data>
    </node>
    <node id="3">
      <data key="d5">ECS Microservices</data>
      <data key="d6">ECS</data>
      <data key="d7">Runs backend microservices connecting to external enterprise systems.</data>
    </node>
    <node id="4">
      <data key="d5">CRMs</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Third-party customer relationship systems like Salesforce or Siebel.</data>
    </node>
    <node id="5">
      <data key="d5">Amazon SES</data>
      <data key="d6">SES</data>
      <data key="d7">Handles inbound and outbound emails for the contact center.</data>
    </node>
    <node id="6">
      <data key="d5">Email Handler Lambda</data>
      <data key="d6">Lambda</data>
      <data key="d7">Processes inbound email content and triggers automation.</data>
    </node>
    <node id="7">
      <data key="d5">Amazon DynamoDB</data>
      <data key="d6">DynamoDB</data>
      <data key="d7">Stores metadata and state for processed email interactions.</data>
    </node>
    <node id="8">
      <data key="d5">ContactSuite App (EC2/ELB/ASG)</data>
      <data key="d6">EC2</data>
      <data key="d7">Main hosting environment for the ContactSuite portal and SenseIQ KB.</data>
    </node>
    <node id="9">
      <data key="d5">Agent Andy</data>
      <data key="d6">UserCompanyAgent</data>
      <data key="d7">Contact center agent accessing the system via browser.</data>
    </node>
    <node id="10">
      <data key="d5">Amazon RDS</data>
      <data key="d6">RDS</data>
      <data key="d7">Relational database storing ContactSuite transactional and reporting data.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">Customer places voice call or starts a chat.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="0" target="5" id="0">
      <data key="d8">1</data>
      <data key="d9">Customer sends support email.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">Connect triggers IVR customer flow logic via Lambda.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="3" id="0">
      <data key="d8">0</data>
      <data key="d9">Lambda invokes microservices in ECS to fetch context.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="4" id="0">
      <data key="d8">0</data>
      <data key="d9">ECS microservices retrieve customer profiles from external CRM systems.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="6" id="0">
      <data key="d8">1</data>
      <data key="d9">SES routes inbound email payloads to a parsing Lambda.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="6" target="7" id="0">
      <data key="d8">1</data>
      <data key="d9">Lambda saves parsed email records to DynamoDB.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="8" target="10" id="0">
      <data key="d8">2</data>
      <data key="d9">ContactSuite writes system metrics and agent performance data to RDS.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="9" target="8" id="0">
      <data key="d8">2</data>
      <data key="d9">Agent logs into the dashboard via browser with MFA.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">ContactSuite Contact Center Scale Architecture</data>
    <data key="d1">https://www.youtube.com/watch?v=BPvr0qWpJlA</data>
    <data key="d2">A scalable contact center solution built around Amazon Connect, ECS microservices, and Amazon SES to manage voice, chat, and email workloads with unified CRM integrations and automated reporting.</data>
    <data key="d3">data_ingestion, compute_intensive, other</data>
    <data key="d4">True</data>
  </graph>
