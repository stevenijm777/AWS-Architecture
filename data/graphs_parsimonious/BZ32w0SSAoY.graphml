<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Web Browser</data>
      <data key="d6">UserConsumerWeb</data>
      <data key="d7">End-user interface to create accounts, configure workflows, and trigger processing jobs.</data>
    </node>
    <node id="1">
      <data key="d5">Web Server &amp; Job Manager</data>
      <data key="d6">EC2</data>
      <data key="d7">Hosts the web frontend and coordinates jobs, triggering metadata extraction and orchestration.</data>
    </node>
    <node id="2">
      <data key="d5">Database</data>
      <data key="d6">RDS</data>
      <data key="d7">Caches video metadata retrieved by Lambda to expose to the frontend web server.</data>
    </node>
    <node id="3">
      <data key="d5">Customer S3 Bucket</data>
      <data key="d6">S3</data>
      <data key="d7">User-managed bucket containing raw source clips and destination for processed outputs.</data>
    </node>
    <node id="4">
      <data key="d5">Metadata Extractor</data>
      <data key="d6">Lambda</data>
      <data key="d7">Invokes MediaInfo on S3 objects to retrieve metadata in the background.</data>
    </node>
    <node id="5">
      <data key="d5">G3 GPU Nodes</data>
      <data key="d6">EC2</data>
      <data key="d7">GPU-accelerated instances executing Wormhole, Spacetime, and Dark Energy transcode engines.</data>
    </node>
    <node id="6">
      <data key="d5">IMF Server</data>
      <data key="d6">EC2</data>
      <data key="d7">Handles Interoperable Master Format (IMF) wrapping for platforms like Netflix.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">1</data>
      <data key="d9">User logs in, views assets, and configures transcode workflow.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="4" id="0">
      <data key="d8">2</data>
      <data key="d9">Job Manager triggers Lambda to parse video files.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="2" id="0">
      <data key="d8">3</data>
      <data key="d9">Saves extracted metadata into the database for the frontend to render.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="5" id="0">
      <data key="d8">4</data>
      <data key="d9">Submits transcoding jobs to parallel GPU processing instances.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="6" id="0">
      <data key="d8">6</data>
      <data key="d9">Instructs IMF server to package transcode outputs into IMF format.</data>
      <data key="d10">6</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="3" id="0">
      <data key="d8">2</data>
      <data key="d9">Lambda reads video header info directly from the customer S3 bucket.</data>
      <data key="d10">2.1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="3" id="0">
      <data key="d8">5</data>
      <data key="d9">Asset Manager copies raw input files locally and transfers processed outputs back to S3.</data>
      <data key="d10">5</data>
      <data key="d11">data</data>
    </edge>
    <edge source="6" target="3" id="0">
      <data key="d8">6</data>
      <data key="d9">Asset Manager uploads finalized IMF files to user's S3 bucket.</data>
      <data key="d10">6.1</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">Cinefilm PixelStrings Cloud Architecture</data>
    <data key="d1">https://www.youtube.com/watch?v=BZ32w0SSAoY</data>
    <data key="d2">PixelStrings runs video processing workflows (retiming, deinterlacing, noise removal) on GPU-enabled EC2 instances utilizing customer-owned S3 buckets.</data>
    <data key="d3">data_ingestion, compute_intensive</data>
    <data key="d4">True</data>
  </graph>
</graphml>
