<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Sensors</data>
      <data key="d6">UserConsumerIOT</data>
      <data key="d7">100k field water meters transmitting utility data.</data>
    </node>
    <node id="1">
      <data key="d5">API Gateway</data>
      <data key="d6">ApiGateway</data>
      <data key="d7">Entry point for incoming utility data stream.</data>
    </node>
    <node id="2">
      <data key="d5">Transformer</data>
      <data key="d6">Lambda</data>
      <data key="d7">Standardizes raw data from multiple generations of sensors.</data>
    </node>
    <node id="3">
      <data key="d5">Flow Queue</data>
      <data key="d6">SQS</data>
      <data key="d7">Buffers sensor flow data.</data>
    </node>
    <node id="4">
      <data key="d5">Alarm Queue</data>
      <data key="d6">SQS</data>
      <data key="d7">Buffers active sensor alarm events.</data>
    </node>
    <node id="5">
      <data key="d5">Preprocessor</data>
      <data key="d6">Lambda</data>
      <data key="d7">Processes queued records and decides which data warrants persistence.</data>
    </node>
    <node id="6">
      <data key="d5">Elastic Cache</data>
      <data key="d6">ElastiCache</data>
      <data key="d7">Redis cache used by the preprocessor to filter redundant data.</data>
    </node>
    <node id="7">
      <data key="d5">Post Processor</data>
      <data key="d6">EC2</data>
      <data key="d7">Processes the filtered 40% of data stream.</data>
    </node>
    <node id="8">
      <data key="d5">DynamoDB</data>
      <data key="d6">DynamoDB</data>
      <data key="d7">Stores event data such as tank deliveries and pump events.</data>
    </node>
    <node id="9">
      <data key="d5">Aurora</data>
      <data key="d6">Aurora</data>
      <data key="d7">Stores aggregated daily statistics.</data>
    </node>
    <node id="10">
      <data key="d5">Mobile Client</data>
      <data key="d6">UserConsumerMobile</data>
      <data key="d7">End users accessing visualization reports and portals.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">Sensors transmit usage and alarm metrics.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">Triggers transformation execution.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="3" id="0">
      <data key="d8">0</data>
      <data key="d9">Pushes normalized flow data to queue.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="4" id="0">
      <data key="d8">0</data>
      <data key="d9">Pushes normalized alarm data to queue.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="5" id="0">
      <data key="d8">0</data>
      <data key="d9">Preprocessor pulls flow records.</data>
      <data key="d10">5</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="5" id="0">
      <data key="d8">0</data>
      <data key="d9">Preprocessor pulls alarm records.</data>
      <data key="d10">6</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="6" id="0">
      <data key="d8">0</data>
      <data key="d9">Consults Redis cache to filter redundant data points.</data>
      <data key="d10">7</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="7" id="0">
      <data key="d8">0</data>
      <data key="d9">Passes filtered 40% of events for final processing.</data>
      <data key="d10">8</data>
      <data key="d11">data</data>
    </edge>
    <edge source="7" target="8" id="0">
      <data key="d8">0</data>
      <data key="d9">Saves point-in-time events.</data>
      <data key="d10">9</data>
      <data key="d11">data</data>
    </edge>
    <edge source="7" target="9" id="0">
      <data key="d8">0</data>
      <data key="d9">Stores daily metrics.</data>
      <data key="d10">10</data>
      <data key="d11">data</data>
    </edge>
    <edge source="8" target="10" id="0">
      <data key="d8">0</data>
      <data key="d9">Feeds mobile apps with event logs.</data>
      <data key="d10">11</data>
      <data key="d11">data</data>
    </edge>
    <edge source="9" target="10" id="0">
      <data key="d8">0</data>
      <data key="d9">Feeds dashboards with daily usage aggregates.</data>
      <data key="d10">12</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">Vigod Aqua Water Management Platform</data>
    <data key="d1">https://www.youtube.com/watch?v=CE03UMddoYU</data>
    <data key="d2">An IoT utility monitoring architecture that scales to handle 27 million daily events while reducing costs by 25% through SQS buffering, smart caching, and serverless ingestion.</data>
    <data key="d3">data_ingestion, compute_intensive</data>
    <data key="d4">True</data>
  </graph>
