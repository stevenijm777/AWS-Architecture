<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">iOS Client</data>
      <data key="d6">UserConsumerMobile</data>
      <data key="d7">Initializes the send-snap flow, uploading media and metadata.</data>
    </node>
    <node id="1">
      <data key="d5">Android Client</data>
      <data key="d6">UserConsumerMobile</data>
      <data key="d7">Receives real-time push messages and downloads media.</data>
    </node>
    <node id="2">
      <data key="d5">Gateway (GW)</data>
      <data key="d6">EKS</data>
      <data key="d7">Entry point gateway running on EKS to route incoming client traffic.</data>
    </node>
    <node id="3">
      <data key="d5">Media Service</data>
      <data key="d6">EKS</data>
      <data key="d7">EKS-based microservice that handles snap media uploads and coordinates metadata storage.</data>
    </node>
    <node id="4">
      <data key="d5">Messaging Service (MCS)</data>
      <data key="d6">EKS</data>
      <data key="d7">Manages persistent connections and routes chat/message delivery.</data>
    </node>
    <node id="5">
      <data key="d5">Friend Graph</data>
      <data key="d6">EKS</data>
      <data key="d7">EKS-based microservice mapping user social relationships.</data>
    </node>
    <node id="6">
      <data key="d5">Snap DB</data>
      <data key="d6">EKS</data>
      <data key="d7">Custom database storage layer running on EKS to manage ephemeral data, TTLs, and incremental sync.</data>
    </node>
    <node id="7">
      <data key="d5">CloudFront</data>
      <data key="d6">CloudFront</data>
      <data key="d7">Low-latency content delivery network for distributing snap media globally.</data>
    </node>
    <node id="8">
      <data key="d5">S3</data>
      <data key="d6">S3</data>
      <data key="d7">DATA_PEEK: Stores raw media files for snaps and stories.</data>
    </node>
    <node id="9">
      <data key="d5">ElastiCache</data>
      <data key="d6">ElastiCache</data>
      <data key="d7">Stores active connection IDs and server mappings for routing push notifications.</data>
    </node>
    <node id="10">
      <data key="d5">DynamoDB</data>
      <data key="d6">DynamoDB</data>
      <data key="d7">DATA_PEEK: Stores 400+ TB of persistent metadata. Supports nightly scans processing 2B rows/minute.</data>
    </node>
    <edge source="0" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">iOS client initiates send snap request to the Gateway.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="3" id="0">
      <data key="d8">0</data>
      <data key="d9">Gateway routes media-related traffic to the Media Service.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="4" id="0">
      <data key="d8">1</data>
      <data key="d9">Gateway handles and routes messaging flows to MCS.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="7" id="0">
      <data key="d8">0</data>
      <data key="d9">Media service uploads media content via CloudFront.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="5" id="0">
      <data key="d8">0</data>
      <data key="d9">Media service verifies recipients against Friend Graph.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="6" id="0">
      <data key="d8">0</data>
      <data key="d9">Media service sends snap metadata to the Snap DB application layer.</data>
      <data key="d10">5</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="9" id="0">
      <data key="d8">1</data>
      <data key="d9">MCS looks up active server and connection IDs in ElastiCache.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="1" id="0">
      <data key="d8">1</data>
      <data key="d9">MCS pushes message directly to the recipient client over a persistent connection.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="6" target="10" id="0">
      <data key="d8">0</data>
      <data key="d9">Snap DB persists structured snap metadata into DynamoDB.</data>
      <data key="d10">6</data>
      <data key="d11">data</data>
    </edge>
    <edge source="7" target="8" id="0">
      <data key="d8">0</data>
      <data key="d9">CloudFront persists snap media files into S3.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">Snapchat Core Messaging and Media Architecture</data>
    <data key="d1">https://www.youtube.com/watch?v=Cgv0kfp_6xQ</data>
    <data key="d2">Handles over 300 million daily active users and billions of snaps. Utilizes EKS for microservices and a custom SnapDB layer over DynamoDB to optimize cost, TTL, and transactional performance.</data>
    <data key="d3">data_ingestion, interactive, compute_intensive</data>
    <data key="d4">True</data>
  </graph>
</graphml>
