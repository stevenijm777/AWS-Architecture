<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Salesforce UI</data>
      <data key="d6">UserCompanyCRM</data>
      <data key="d7">Used by customers to set up and tear down private connections.</data>
    </node>
    <node id="1">
      <data key="d5">Control Plane API Gateway</data>
      <data key="d6">ApiGateway</data>
      <data key="d7">Receives setup/teardown requests from Salesforce UI.</data>
    </node>
    <node id="2">
      <data key="d5">Setup / Teardown Lambda</data>
      <data key="d6">Lambda</data>
      <data key="d7">Configures PrivateLink and manages connection metadata.</data>
    </node>
    <node id="3">
      <data key="d5">Metadata Store</data>
      <data key="d6">DynamoDB</data>
      <data key="d7">DATA_PEEK: Stores multi-tenant customer connection metadata.</data>
    </node>
    <node id="4">
      <data key="d5">State Change Notifications</data>
      <data key="d6">SNS</data>
      <data key="d7">Gets notified of AWS PrivateLink connection state changes.</data>
    </node>
    <node id="5">
      <data key="d5">Salesforce Datacenter</data>
      <data key="d6">OnPremDC</data>
      <data key="d7">Source of customer data to be synchronized with AWS workloads.</data>
    </node>
    <node id="6">
      <data key="d5">Transit Gateway</data>
      <data key="d6">TransitGateway</data>
      <data key="d7">Terminates site-to-site VPN from Salesforce Datacenter.</data>
    </node>
    <node id="7">
      <data key="d5">Connection Forwarders</data>
      <data key="d6">EKS</data>
      <data key="d7">WORKLOAD_PEEK: Multi-tenant routing containers that forward traffic based on customer metadata.</data>
    </node>
    <node id="8">
      <data key="d5">AWS PrivateLink</data>
      <data key="d6">PrivateLink</data>
      <data key="d7">Establishes secure private endpoints.</data>
    </node>
    <node id="9">
      <data key="d5">Customer VPC</data>
      <data key="d6">VPC</data>
      <data key="d7">The target AWS environment for secure data processing.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">Admin triggers connection setup from UI.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">API Gateway triggers orchestration Lambda.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="3" id="0">
      <data key="d8">0</data>
      <data key="d9">Lambda registers metadata in DynamoDB.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="8" id="0">
      <data key="d8">0</data>
      <data key="d9">Lambda provisions PrivateLink endpoint connection.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="6" id="0">
      <data key="d8">1</data>
      <data key="d9">Data travels over encrypted Site-to-Site VPN to Transit Gateway.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="6" target="7" id="0">
      <data key="d8">1</data>
      <data key="d9">Transit Gateway routes traffic to EKS Connection Forwarders.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="7" target="3" id="0">
      <data key="d8">1</data>
      <data key="d9">EKS queries DynamoDB to lookup routing metadata.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="7" target="8" id="0">
      <data key="d8">1</data>
      <data key="d9">EKS forwards customer traffic via correct PrivateLink.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="8" target="4" id="0">
      <data key="d8">0</data>
      <data key="d9">SNS receives updates on PrivateLink state changes.</data>
      <data key="d10">4</data>
      <data key="d11">meta</data>
    </edge>
    <edge source="8" target="9" id="0">
      <data key="d8">1</data>
      <data key="d9">Traffic is securely delivered into Customer VPC.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">Salesforce Private Connect to AWS VPC</data>
    <data key="d1">https://www.youtube.com/watch?v=Cw26CrJUqv8</data>
    <data key="d2">Salesforce Private Connect provides secure, private, and automated connectivity between Salesforce DC and AWS Customer VPCs using API-driven serverless control planes and multi-tenant connection forwarders on EKS.</data>
    <data key="d3">data_ingestion, compute_intensive, control</data>
    <data key="d4">True</data>
  </graph>
</graphml>
