<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d12" for="edge" attr.name="id" attr.type="string" />
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Internal Stakeholders</data>
      <data key="d6">UserCompanyInternalPlatform</data>
      <data key="d7">WORKLOAD_PEEK: Incident response, customer care, and on-call teams viewing status.</data>
    </node>
    <node id="1">
      <data key="d5">Amplify</data>
      <data key="d6">Amplify</data>
      <data key="d7">Hosts the status page UI dashboard for stakeholders without AWS console access.</data>
    </node>
    <node id="2">
      <data key="d5">AppSync</data>
      <data key="d6">AppSync</data>
      <data key="d7">Provides a GraphQL interface to query canary status and alerts.</data>
    </node>
    <node id="3">
      <data key="d5">Lambda Resolver</data>
      <data key="d6">Lambda</data>
      <data key="d7">Uses AWS SDK to pull canary execution metadata, history, and screenshot logs.</data>
    </node>
    <node id="4">
      <data key="d5">CloudWatch</data>
      <data key="d6">CloudWatch</data>
      <data key="d7">DATA_PEEK: Runs Synthetics Canaries every 1-5 minutes to test endpoints and manage alerting.</data>
    </node>
    <node id="5">
      <data key="d5">S3 Bucket</data>
      <data key="d6">S3</data>
      <data key="d7">DATA_PEEK: Stores canary test run artifacts, including HAR files and screenshots.</data>
    </node>
    <node id="6">
      <data key="d5">Time Trigger</data>
      <data key="d6">EventBridge</data>
      <data key="d7">Schedules the canary tests to run automatically.</data>
    </node>
    <edge source="0" target="1">
      <data key="d8">1</data>
      <data key="d9">Stakeholder accesses the experience status dashboard.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="1" target="2">
      <data key="d8">1</data>
      <data key="d9">Sends GraphQL query for canary status.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="2" target="3">
      <data key="d8">1</data>
      <data key="d9">Invokes backend Lambda resolver.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="3" target="4">
      <data key="d8">1</data>
      <data key="d9">Pulls historical runs, statuses, and logs.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="4" target="5">
      <data key="d8">0</data>
      <data key="d9">Saves HAR files and screenshots from canary runs.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="6" target="4">
      <data key="d8">0</data>
      <data key="d9">Triggers CloudWatch Synthetics Canaries on a schedule.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <data key="d0">HBO Max: Using Canaries for Outside-in Validation</data>
    <data key="d1">https://www.youtube.com/watch?v=D9qTotVJYss</data>
    <data key="d2">Serverless validation framework for monitoring HBO Max experiences globally. Uses CloudWatch Canaries deployed across multiple regions to simulate users, saving artifacts to S3 and exposing status via an Amplify/AppSync frontend.</data>
    <data key="d3">control, data_ingestion</data>
    <data key="d4">True</data>
  </graph>
</graphml>
