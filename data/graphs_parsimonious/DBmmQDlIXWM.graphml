<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">PBC (Packaged Business Component)</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">External SaaS partner application acting as message producer or consumer.</data>
    </node>
    <node id="1">
      <data key="d5">API Gateway (PBC)</data>
      <data key="d6">ApiGateway</data>
      <data key="d7">Ingests API calls and messages from the PBC side.</data>
    </node>
    <node id="2">
      <data key="d5">Routing Lambda (PBC)</data>
      <data key="d6">Lambda</data>
      <data key="d7">Applies authorization and dynamic routing rules from DynamoDB.</data>
    </node>
    <node id="3">
      <data key="d5">DynamoDB Tenant Register</data>
      <data key="d6">DynamoDB</data>
      <data key="d7">Central registry storing routing rules and tenant details.</data>
    </node>
    <node id="4">
      <data key="d5">SNS FIFO</data>
      <data key="d6">SNS</data>
      <data key="d7">Provides ordered, sequence-guaranteed message routing.</data>
    </node>
    <node id="5">
      <data key="d5">SQS FIFO (Tenant)</data>
      <data key="d6">SQS</data>
      <data key="d7">Buffers ordered messages for consumption by the tenant application.</data>
    </node>
    <node id="6">
      <data key="d5">Tenant App</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">External tenant PaaS application processing asynchronous messages.</data>
    </node>
    <node id="7">
      <data key="d5">API Gateway (Tenant)</data>
      <data key="d6">ApiGateway</data>
      <data key="d7">Ingests API requests and events from the Tenant side.</data>
    </node>
    <node id="8">
      <data key="d5">Routing Lambda (Tenant)</data>
      <data key="d6">Lambda</data>
      <data key="d7">Applies tenant-side routing rules fetched from DynamoDB.</data>
    </node>
    <node id="9">
      <data key="d5">SQS FIFO (PBC)</data>
      <data key="d6">SQS</data>
      <data key="d7">Buffers ordered messages for consumption by the PBC SaaS platform.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">1</data>
      <data key="d9">PBC sends messages or events</data>
      <data key="d10">1.1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="2" id="0">
      <data key="d8">1</data>
      <data key="d9">Triggers validation Lambda</data>
      <data key="d10">1.2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="4" id="0">
      <data key="d8">1</data>
      <data key="d9">Publishes to SNS FIFO</data>
      <data key="d10">1.4</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="2" id="0">
      <data key="d8">1</data>
      <data key="d9">Fetches tenant routing rules</data>
      <data key="d10">1.3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="8" id="0">
      <data key="d8">2</data>
      <data key="d9">Fetches target routing rules</data>
      <data key="d10">2.3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="5" id="0">
      <data key="d8">1</data>
      <data key="d9">Routes sequentially to SQS queue</data>
      <data key="d10">1.5</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="9" id="0">
      <data key="d8">2</data>
      <data key="d9">Routes sequentially to SQS queue</data>
      <data key="d10">2.5</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="6" id="0">
      <data key="d8">1</data>
      <data key="d9">Tenant App consumes message</data>
      <data key="d10">1.6</data>
      <data key="d11">data</data>
    </edge>
    <edge source="6" target="7" id="0">
      <data key="d8">2</data>
      <data key="d9">Tenant sends messages back</data>
      <data key="d10">2.1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="7" target="8" id="0">
      <data key="d8">2</data>
      <data key="d9">Triggers validation Lambda</data>
      <data key="d10">2.2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="8" target="4" id="0">
      <data key="d8">2</data>
      <data key="d9">Publishes back to SNS FIFO</data>
      <data key="d10">2.4</data>
      <data key="d11">data</data>
    </edge>
    <edge source="9" target="0" id="0">
      <data key="d8">2</data>
      <data key="d9">PBC SaaS consumes message</data>
      <data key="d10">2.6</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">Spryker: Decoupled SaaS and PaaS Application Integration Platform</data>
    <data key="d1">https://www.youtube.com/watch?v=DBmmQDlIXWM</data>
    <data key="d2">Decoupled bi-directional FIFO messaging platform connecting external SaaS components with tenant applications securely using token-based isolation.</data>
    <data key="d3">data_ingestion, interactive</data>
    <data key="d4">True</data>
  </graph>
</graphml>
