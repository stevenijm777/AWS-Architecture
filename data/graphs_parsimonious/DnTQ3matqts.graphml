<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">APP</data>
      <data key="d6">UserConsumerMobile</data>
      <data key="d7">Mobile app used by installers to deploy systems in gyms and retrieve real-time sensor information.</data>
    </node>
    <node id="1">
      <data key="d5">API Gateway (App Backend)</data>
      <data key="d6">ApiGateway</data>
      <data key="d7">RESTful interface for the mobile app's backend and for ingesting utilization data from GreenGrass.</data>
    </node>
    <node id="2">
      <data key="d5">App Backend SQS</data>
      <data key="d6">SQS</data>
      <data key="d7">Queue used to buffer data and requests from the API Gateway for asynchronous processing by the Utilization Lambda.</data>
    </node>
    <node id="3">
      <data key="d5">UTILIZATION Lambda</data>
      <data key="d6">Lambda</data>
      <data key="d7">Processes raw sensor data from the queue, crunching numbers to calculate equipment utilization metrics.</data>
    </node>
    <node id="4">
      <data key="d5">TIMESERIES DB</data>
      <data key="d6">Timestream</data>
      <data key="d7">Central time-series database storing all processed utilization and health data. Serves as the source of truth for reporting and analytics.</data>
    </node>
    <node id="5">
      <data key="d5">SENSOR</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Physical sensors attached to gym equipment, tracking usage and activity.</data>
    </node>
    <node id="6">
      <data key="d5">GREENGRASS</data>
      <data key="d6">Greengrass</data>
      <data key="d7">Runs on edge gateways located in gyms, hosting Lambdas for local data processing, deployment, and buffering before sending to AWS cloud services.</data>
    </node>
    <node id="7">
      <data key="d5">IOT CORE</data>
      <data key="d6">IoTCore</data>
      <data key="d7">Ingests real-time sensor information from GreenGrass gateways, primarily for monitoring sensor health.</data>
    </node>
    <node id="8">
      <data key="d5">Sensor Health Queue</data>
      <data key="d6">SQS</data>
      <data key="d7">Queue used by the Sensor Health Lambda to store and manage sensor/gateway status updates and potential alerts.</data>
    </node>
    <node id="9">
      <data key="d5">SENSOR HEALTH Lambda</data>
      <data key="d6">Lambda</data>
      <data key="d7">Monitors data from IoT Core to detect if sensors or GreenGrass gateways go offline, triggering alerts.</data>
    </node>
    <node id="10">
      <data key="d5">Notifications SNS</data>
      <data key="d6">SNS</data>
      <data key="d7">Sends notifications to internal teams when sensor gateways are detected as offline or other system issues arise.</data>
    </node>
    <node id="11">
      <data key="d5">COGNITO</data>
      <data key="d6">Cognito</data>
      <data key="d7">Provides user authentication and authorization services for accessing the reporting portal.</data>
    </node>
    <node id="12">
      <data key="d5">API Gateway (Reporting Portal)</data>
      <data key="d6">ApiGateway</data>
      <data key="d7">Serves as the interface for the customer reporting portal, handling requests for report generation and direct data access.</data>
    </node>
    <node id="13">
      <data key="d5">REPORTING Lambda</data>
      <data key="d6">Lambda</data>
      <data key="d7">Generates automated reports based on the processed utilization data stored in the TimeSeries DB.</data>
    </node>
    <node id="14">
      <data key="d5">REPORTS Portal</data>
      <data key="d6">UserConsumerWeb</data>
      <data key="d7">Web-based portal where end customers can view generated reports and insights into equipment utilization.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">Mobile app sends configuration commands or data to the backend API.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="0" target="6" id="0">
      <data key="d8">0</data>
      <data key="d9">Mobile app retrieves real-time information directly from GreenGrass gateways via a RESTful interface.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="2" id="0">
      <data key="d8">1</data>
      <data key="d9">API Gateway queues utilization data for asynchronous processing.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="3" id="0">
      <data key="d8">1</data>
      <data key="d9">Utilization Lambda consumes utilization data from the SQS queue.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="4" id="0">
      <data key="d8">1</data>
      <data key="d9">Processed utilization data is stored in the TimeSeries DB.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="13" id="0">
      <data key="d8">3</data>
      <data key="d9">Reporting Lambda queries the TimeSeries DB to fetch data required for reports.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="12" id="0">
      <data key="d8">3</data>
      <data key="d9">TimeSeries DB data is also exposed via the API Gateway, allowing the portal and potential BI tools to directly access data.</data>
      <data key="d10">5</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="6" id="0">
      <data key="d8">1</data>
      <data key="d9">Sensors send raw utilization data to local GreenGrass gateways.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="6" target="1" id="0">
      <data key="d8">1</data>
      <data key="d9">GreenGrass gateways send aggregated or raw utilization data to the backend API Gateway for processing.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="6" target="7" id="0">
      <data key="d8">2</data>
      <data key="d9">GreenGrass gateways send real-time sensor information to IoT Core for health monitoring.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="7" target="9" id="0">
      <data key="d8">2</data>
      <data key="d9">IoT Core events trigger the Sensor Health Lambda for monitoring.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="8" target="10" id="0">
      <data key="d8">2</data>
      <data key="d9">SQS triggers SNS to send notifications for detected issues, such as offline gateways.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="9" target="8" id="0">
      <data key="d8">2</data>
      <data key="d9">Sensor Health Lambda publishes status updates or alerts to the SQS queue.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="11" target="12" id="0">
      <data key="d8">3</data>
      <data key="d9">Users authenticate via Cognito to access the reporting portal's backend.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="12" target="13" id="0">
      <data key="d8">3</data>
      <data key="d9">API Gateway triggers the Reporting Lambda for automated report generation or data retrieval.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="13" target="14" id="0">
      <data key="d8">3</data>
      <data key="d9">Generated reports are delivered by the Lambda function to the customer portal.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <edge source="14" target="12" id="0">
      <data key="d8">3</data>
      <data key="d9">The reporting portal makes requests to the API Gateway for data or report generation.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">EcoFit Fitness Equipment Tracking Architecture</data>
    <data key="d1">https://www.youtube.com/watch?v=DnTQ3matqts</data>
    <data key="d2">EcoFit tracks fitness equipment utilization using sensors and AWS GreenGrass at the edge. Data is ingested via IoT Core for real-time monitoring and API Gateway for utilization processing. The architecture heavily relies on serverless components like Lambda, SQS, and API Gateway for scalability. Processed data is stored in a TimeSeries database and used for automated reporting and ad-hoc analysis via a customer portal.</data>
    <data key="d3">data_ingestion, interactive, compute_intensive, control</data>
    <data key="d4">True</data>
  </graph>
</graphml>
