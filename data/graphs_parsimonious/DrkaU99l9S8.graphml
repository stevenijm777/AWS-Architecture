<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">BIQSens</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">On-premise sensor and gateway device collecting plant machinery data.</data>
    </node>
    <node id="1">
      <data key="d5">AWS IoT Greengrass</data>
      <data key="d6">Greengrass</data>
      <data key="d7">Manages local compute, messaging, and data caching at the edge.</data>
    </node>
    <node id="2">
      <data key="d5">AWS Lambda (Edge)</data>
      <data key="d6">Lambda</data>
      <data key="d7">Runs anomaly detection models locally at the edge.</data>
    </node>
    <node id="3">
      <data key="d5">AWS IoT Core</data>
      <data key="d6">IoTCore</data>
      <data key="d7">Ingests data from edge devices and routes it using rules.</data>
    </node>
    <node id="4">
      <data key="d5">Amazon Kinesis Data Streams</data>
      <data key="d6">Kinesis</data>
      <data key="d7">Ingests real-time sensor streams for hot-path analytics and cold-path storage.</data>
    </node>
    <node id="5">
      <data key="d5">Amazon Kinesis Data Analytics</data>
      <data key="d6">KinesisAnalytics</data>
      <data key="d7">Runs real-time anomaly detection and condition-based monitoring.</data>
    </node>
    <node id="6">
      <data key="d5">Amazon S3</data>
      <data key="d6">S3</data>
      <data key="d7">Acts as a data lake for raw sensor telemetry and model training data.</data>
    </node>
    <node id="7">
      <data key="d5">Amazon SageMaker</data>
      <data key="d6">SageMaker</data>
      <data key="d7">Trains and refines machine learning models using S3 data.</data>
    </node>
    <node id="8">
      <data key="d5">AWS IoT Analytics</data>
      <data key="d6">IoTAnalytics</data>
      <data key="d7">Processes batch data and runs statistical process control.</data>
    </node>
    <node id="9">
      <data key="d5">Amazon QuickSight</data>
      <data key="d6">QuickSight</data>
      <data key="d7">Visualizes batch historical analytics and plant KPIs.</data>
    </node>
    <node id="10">
      <data key="d5">Plant Operator</data>
      <data key="d6">UserCompanyAnalyst</data>
      <data key="d7">Monitors real-time dashboards and receives anomaly alerts.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">Sensors report physical machine metrics to Greengrass.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="0" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">Sensors stream data directly to local Lambda for low-latency processing.</data>
      <data key="d10">0.1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="3" id="0">
      <data key="d8">1</data>
      <data key="d9">Greengrass routes telemetry to IoT Core in the cloud.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="3" id="0">
      <data key="d8">1</data>
      <data key="d9">Local Lambda outputs anomalies and status to IoT Core.</data>
      <data key="d10">1.1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="4" id="0">
      <data key="d8">2</data>
      <data key="d9">IoT Core rules route high-velocity streams to Kinesis.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="8" id="0">
      <data key="d8">2</data>
      <data key="d9">IoT Core rules send batch data to IoT Analytics.</data>
      <data key="d10">2.1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="5" id="0">
      <data key="d8">3</data>
      <data key="d9">Streams real-time metrics to Analytics.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="6" id="0">
      <data key="d8">4</data>
      <data key="d9">Persists raw data into S3 data lake.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="10" id="0">
      <data key="d8">3</data>
      <data key="d9">Pushes real-time alerts and dashboard updates to operators.</data>
      <data key="d10">3.1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="6" target="7" id="0">
      <data key="d8">4</data>
      <data key="d9">Loads accumulated historical datasets for model training.</data>
      <data key="d10">4.1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="7" target="2" id="0">
      <data key="d8">4</data>
      <data key="d9">Deploys newly optimized models back to edge Lambda.</data>
      <data key="d10">4.2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="8" target="9" id="0">
      <data key="d8">5</data>
      <data key="d9">Feeds aggregated statistics into QuickSight.</data>
      <data key="d10">5</data>
      <data key="d11">data</data>
    </edge>
    <edge source="8" target="10" id="0">
      <data key="d8">5</data>
      <data key="d9">Provides long-term analytical insights directly to users.</data>
      <data key="d10">5.1</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">L&amp;T Technology Services: Edge-to-Cloud IoT Predictive Maintenance</data>
    <data key="d1">https://www.youtube.com/watch?v=DrkaU99l9S8</data>
    <data key="d2">An end-to-end industrial IoT solution that collects sensor data at the edge, performs real-time and batch analytics in the cloud, and utilizes machine learning to redeploy models back to edge devices.</data>
    <data key="d3">data_ingestion, compute_intensive, other</data>
    <data key="d4">True</data>
  </graph>
