<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Field Agents</data>
      <data key="d6">UserCompanyAgent</data>
      <data key="d7">Field managers collecting GIS data on mobile devices.</data>
    </node>
    <node id="1">
      <data key="d5">Satellite Data</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Open domain satellite data sources like ISRO and NASA.</data>
    </node>
    <node id="2">
      <data key="d5">S3 Bucket</data>
      <data key="d6">S3</data>
      <data key="d7">Stores satellite data and processed map images.</data>
    </node>
    <node id="3">
      <data key="d5">Registry of Open Data</data>
      <data key="d6">S3</data>
      <data key="d7">Registry on AWS providing specific spectral regions to reduce data size.</data>
    </node>
    <node id="4">
      <data key="d5">PostgreSQL GIS</data>
      <data key="d6">RDS</data>
      <data key="d7">PostgreSQL database storing GIS boundaries and final zonal statistics.</data>
    </node>
    <node id="5">
      <data key="d5">SageMaker</data>
      <data key="d6">SageMaker</data>
      <data key="d7">Runs parallel processing jobs to analyze geospatial data.</data>
    </node>
    <node id="6">
      <data key="d5">Lambda</data>
      <data key="d6">Lambda</data>
      <data key="d7">Triggers and actuates parallel SageMaker jobs.</data>
    </node>
    <node id="7">
      <data key="d5">EC2</data>
      <data key="d6">EC2</data>
      <data key="d7">Graviton instances powering the EKS compute backend.</data>
    </node>
    <node id="8">
      <data key="d5">EKS</data>
      <data key="d6">EKS</data>
      <data key="d7">Hosts UI applications and serves geospatial layers.</data>
    </node>
    <node id="9">
      <data key="d5">CloudFront</data>
      <data key="d6">CloudFront</data>
      <data key="d7">Caches map data layers to improve UX and decrease costs.</data>
    </node>
    <node id="10">
      <data key="d5">Agri Users</data>
      <data key="d6">UserConsumerWeb</data>
      <data key="d7">Farmers, agribanks, and finance agencies consuming GIS layers.</data>
    </node>
    <edge source="0" target="4" id="0">
      <data key="d8">0</data>
      <data key="d9">Field agents upload local GIS boundaries to database.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">Ingests raw satellite imagery into S3.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="5" id="0">
      <data key="d8">1</data>
      <data key="d9">SageMaker fetches raw satellite imagery.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="5" id="0">
      <data key="d8">1</data>
      <data key="d9">SageMaker reads specific spectral bands from Open Data registry.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="5" id="0">
      <data key="d8">1</data>
      <data key="d9">SageMaker retrieves GIS boundaries for processing.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="2" id="0">
      <data key="d8">1</data>
      <data key="d9">Saves processed map images back to S3.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="4" id="0">
      <data key="d8">1</data>
      <data key="d9">Pushes zonal statistics back to PostgreSQL GIS.</data>
      <data key="d10">5</data>
      <data key="d11">data</data>
    </edge>
    <edge source="6" target="5" id="0">
      <data key="d8">1</data>
      <data key="d9">Lambda triggers SageMaker processing.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="7" target="8" id="0">
      <data key="d8">2</data>
      <data key="d9">EC2 runs EKS worker nodes.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="8" target="9" id="0">
      <data key="d8">2</data>
      <data key="d9">Exposes maps and data layers via CloudFront.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="9" target="10" id="0">
      <data key="d8">2</data>
      <data key="d9">Users query and view cached GIS layers.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">TCS Digital Platform for Next Gen Agriculture</data>
    <data key="d1">https://www.youtube.com/watch?v=Dxq_U1TNx1s</data>
    <data key="d2">A geospatial analytics platform leveraging parallel SageMaker processing jobs and cached delivery via CloudFront to scale agricultural insights.</data>
    <data key="d3">data_ingestion, compute_intensive, interactive</data>
    <data key="d4">True</data>
  </graph>
</graphml>
