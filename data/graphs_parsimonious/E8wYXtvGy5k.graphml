<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Handheld Scanner</data>
      <data key="d6">UserCompanyAgent</data>
      <data key="d7">Handheld scan devices used by drivers on-site to log package actions.</data>
    </node>
    <node id="1">
      <data key="d5">Fargate Ingestion API</data>
      <data key="d6">Fargate</data>
      <data key="d7">Consumes and handles incoming scan payloads from various sources.</data>
    </node>
    <node id="2">
      <data key="d5">DynamoDB</data>
      <data key="d6">DynamoDB</data>
      <data key="d7">Persists scan events and emits updates through DynamoDB Streams.</data>
    </node>
    <node id="3">
      <data key="d5">Stream Processor Lambda</data>
      <data key="d6">Lambda</data>
      <data key="d7">Processes DynamoDB Streams and publishes to SNS.</data>
    </node>
    <node id="4">
      <data key="d5">SNS Fanout Topic</data>
      <data key="d6">SNS</data>
      <data key="d7">Distributes scan events to multiple downstream queues.</data>
    </node>
    <node id="5">
      <data key="d5">Website SQS Queue</data>
      <data key="d6">SQS</data>
      <data key="d7">Decouples the primary tracking stream from the website update engine.</data>
    </node>
    <node id="6">
      <data key="d5">Fargate Website Engine</data>
      <data key="d6">Fargate</data>
      <data key="d7">Processes tracking status updates and renders them on the site.</data>
    </node>
    <node id="7">
      <data key="d5">Public Website</data>
      <data key="d6">UserConsumerWeb</data>
      <data key="d7">Allows end-users to view parcel tracking status updates.</data>
    </node>
    <node id="8">
      <data key="d5">Image/Async SQS Queue</data>
      <data key="d6">SQS</data>
      <data key="d7">Buffers secondary asynchronous tasks such as signature/image scans.</data>
    </node>
    <node id="9">
      <data key="d5">Fargate Async Processor</data>
      <data key="d6">Fargate</data>
      <data key="d7">Processes and manages asynchronous scan payloads.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">Drivers upload parcel tracking scans via handheld devices.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="2" id="0">
      <data key="d8">1</data>
      <data key="d9">Ingestion API writes scan payload into DynamoDB table.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="3" id="0">
      <data key="d8">2</data>
      <data key="d9">DynamoDB Streams triggers Lambda function.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="4" id="0">
      <data key="d8">3</data>
      <data key="d9">Lambda forwards scan messages to SNS topic.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="5" id="0">
      <data key="d8">4</data>
      <data key="d9">SNS publishes messages to Website SQS queue.</data>
      <data key="d10">5</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="8" id="0">
      <data key="d8">5</data>
      <data key="d9">SNS publishes messages to Image/Async SQS queue.</data>
      <data key="d10">5</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="6" id="0">
      <data key="d8">6</data>
      <data key="d9">Fargate pulls scan details from the queue.</data>
      <data key="d10">6</data>
      <data key="d11">data</data>
    </edge>
    <edge source="6" target="7" id="0">
      <data key="d8">7</data>
      <data key="d9">Website engine updates the tracking status display.</data>
      <data key="d10">7</data>
      <data key="d11">data</data>
    </edge>
    <edge source="8" target="9" id="0">
      <data key="d8">8</data>
      <data key="d9">Fargate pulls processing tasks from the SQS queue.</data>
      <data key="d10">6</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">Freightways High-Volume Parcel Scanning Pipeline</data>
    <data key="d1">https://www.youtube.com/watch?v=E8wYXtvGy5k</data>
    <data key="d2">Freightways processes over 50 million parcel scans annually. The solution scales seamlessly from 500 scans/minute to 1500 scans/minute during peak hours, ensuring tracking visibility is updated within 5 minutes.</data>
    <data key="d3">data_ingestion, compute_intensive</data>
    <data key="d4">True</data>
  </graph>
</graphml>
