<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="coach">
      <data key="d5">Coach Interface</data>
      <data key="d6">UserCompanyAgent</data>
      <data key="d7">Web portal for class coaching and monitoring real-time participant heart rates.</data>
    </node>
    <node id="member">
      <data key="d5">Member App</data>
      <data key="d6">UserConsumerMobile</data>
      <data key="d7">Mobile/tablet app for members joining virtual workouts and transmitting heart rate telemetry.</data>
    </node>
    <node id="chime">
      <data key="d5">Chime SDK</data>
      <data key="d6">Chime</data>
      <data key="d7">Enables interactive, low-latency video feeds and WebSocket connections.</data>
    </node>
    <node id="cognito">
      <data key="d5">Cognito</data>
      <data key="d6">Cognito</data>
      <data key="d7">Authenticates coaches and members.</data>
    </node>
    <node id="apigateway">
      <data key="d5">API Gateway</data>
      <data key="d6">ApiGateway</data>
      <data key="d7">Exposes REST endpoints for class metadata.</data>
    </node>
    <node id="lambda">
      <data key="d5">Lambda</data>
      <data key="d6">Lambda</data>
      <data key="d7">Processes API requests and handles database persistence logic.</data>
    </node>
    <node id="aurora">
      <data key="d5">Aurora DB</data>
      <data key="d6">Aurora</data>
      <data key="d7">Relational storage for class schedules and metadata.</data>
    </node>
    <node id="dynamodb">
      <data key="d5">DynamoDB</data>
      <data key="d6">DynamoDB</data>
      <data key="d7">Fast, key-value storage for individual workout summaries.</data>
    </node>
    <node id="kinesis">
      <data key="d5">Kinesis Data Stream</data>
      <data key="d6">Kinesis</data>
      <data key="d7">Ingests high-frequency, second-by-second workout metrics.</data>
    </node>
    <node id="s3">
      <data key="d5">S3 Data Lake</data>
      <data key="d6">S3</data>
      <data key="d7">Provides durable, long-term analytical storage.</data>
    </node>
    <edge source="coach" target="cognito" id="0">
      <data key="d8">1</data>
      <data key="d9">Coach authentication request.</data>
      <data key="d10">1a</data>
      <data key="d11">data</data>
    </edge>
    <edge source="coach" target="apigateway" id="0">
      <data key="d8">2</data>
      <data key="d9">Coach requests class metadata.</data>
      <data key="d10">2a</data>
      <data key="d11">data</data>
    </edge>
    <edge source="member" target="cognito" id="0">
      <data key="d8">1</data>
      <data key="d9">Member authentication request.</data>
      <data key="d10">1b</data>
      <data key="d11">data</data>
    </edge>
    <edge source="member" target="apigateway" id="0">
      <data key="d8">2</data>
      <data key="d9">Member requests class metadata.</data>
      <data key="d10">2b</data>
      <data key="d11">data</data>
    </edge>
    <edge source="member" target="chime" id="0">
      <data key="d8">3</data>
      <data key="d9">Streams real-time video &amp; heart rate telemetry.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="member" target="kinesis" id="0">
      <data key="d8">4</data>
      <data key="d9">Streams analytical telemetry.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="chime" target="coach" id="0">
      <data key="d8">3</data>
      <data key="d9">Delivers real-time student feeds to coach monitor.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="apigateway" target="lambda" id="0">
      <data key="d8">2</data>
      <data key="d9">Forwards API payload.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="lambda" target="aurora" id="0">
      <data key="d8">2</data>
      <data key="d9">Retrieves class details.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <edge source="lambda" target="dynamodb" id="0">
      <data key="d8">5</data>
      <data key="d9">Saves post-workout summary for member app access.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="kinesis" target="s3" id="0">
      <data key="d8">4</data>
      <data key="d9">Archives raw metrics to data lake.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">Orange Theory Fitness OT Live Virtual Classes</data>
    <data key="d1">https://www.youtube.com/watch?v=Eoq7E6jMtBs</data>
    <data key="d2">Serverless interactive fitness platform utilizing Chime SDK for real-time video and WebSocket metrics, and Kinesis for high-frequency telemetry ingestion.</data>
    <data key="d3">data_ingestion, compute_intensive, interactive</data>
    <data key="d4">True</data>
  </graph>
</graphml>
