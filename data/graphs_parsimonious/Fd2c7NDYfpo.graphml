  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Engineer</data>
      <data key="d6">UserCompanyDeveloper</data>
      <data key="d7">Requests sandbox accounts via portal.</data>
    </node>
    <node id="1">
      <data key="d5">API Gateway</data>
      <data key="d6">ApiGateway</data>
      <data key="d7">Handles portal requests.</data>
    </node>
    <node id="2">
      <data key="d5">Validate Lambda</data>
      <data key="d6">Lambda</data>
      <data key="d7">Validates requester domain and metadata.</data>
    </node>
    <node id="3">
      <data key="d5">SQS Queue</data>
      <data key="d6">SQS</data>
      <data key="d7">Buffers validated creation requests.</data>
    </node>
    <node id="4">
      <data key="d5">Create Lambda</data>
      <data key="d6">Lambda</data>
      <data key="d7">Handles account lifecycle and configurations.</data>
    </node>
    <node id="5">
      <data key="d5">AWS Organizations</data>
      <data key="d6">Organizations</data>
      <data key="d7">Manages accounts, OUs, and SCP policies.</data>
    </node>
    <node id="6">
      <data key="d5">CloudFormation</data>
      <data key="d6">CloudFormation</data>
      <data key="d7">Deploys baselines and budget alerts.</data>
    </node>
    <node id="7">
      <data key="d5">SES</data>
      <data key="d6">SES</data>
      <data key="d7">Sends user notifications and credentials.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">Submits request</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">Triggers validation</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="7" id="0">
      <data key="d8">1</data>
      <data key="d9">Sends acknowledgement notification</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="3" id="0">
      <data key="d8">0</data>
      <data key="d9">Enqueues request</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="4" id="0">
      <data key="d8">0</data>
      <data key="d9">Triggers creation task</data>
      <data key="d10">5</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="5" id="0">
      <data key="d8">0</data>
      <data key="d9">Creates and assigns AWS account to OU</data>
      <data key="d10">6</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="6" id="0">
      <data key="d8">0</data>
      <data key="d9">Deploys budget alerts</data>
      <data key="d10">7</data>
      <data key="d11">data</data>
