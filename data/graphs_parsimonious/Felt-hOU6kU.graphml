<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Developers</data>
      <data key="d6">UserCompanyDeveloper</data>
      <data key="d7">1600+ developers accessing the self-service infrastructure portal.</data>
    </node>
    <node id="1">
      <data key="d5">ALB</data>
      <data key="d6">ALB</data>
      <data key="d7">Enables secure, VPN-less access to the portal.</data>
    </node>
    <node id="2">
      <data key="d5">EKS (Portal)</data>
      <data key="d6">EKS</data>
      <data key="d7">Hosts the frontend and backend of the developer portal.</data>
    </node>
    <node id="3">
      <data key="d5">SQS</data>
      <data key="d6">SQS</data>
      <data key="d7">Decouples portal UI from backend provisioning tasks.</data>
    </node>
    <node id="4">
      <data key="d5">EKS (Terraform Runner)</data>
      <data key="d6">EKS</data>
      <data key="d7">Runs containerized Terraform jobs to deploy infrastructure.</data>
    </node>
    <node id="5">
      <data key="d5">Terraform</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Infrastructure-as-code tool used to define resources.</data>
    </node>
    <node id="6">
      <data key="d5">Subnets</data>
      <data key="d6">VPC</data>
      <data key="d7">Configured across accounts for application deployment.</data>
    </node>
    <node id="7">
      <data key="d5">RAM</data>
      <data key="d6">RAM</data>
      <data key="d7">Shares subnets and resources across 150+ AWS accounts.</data>
    </node>
    <node id="8">
      <data key="d5">RDS</data>
      <data key="d6">RDS</data>
      <data key="d7">Relational databases provisioned on behalf of developers.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">Developers access portal through ALB.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">ALB routes traffic to EKS hosting the portal.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="3" id="0">
      <data key="d8">0</data>
      <data key="d9">Portal places provisioning requests onto SQS.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="4" id="0">
      <data key="d8">0</data>
      <data key="d9">EKS runners consume provisioning jobs from SQS.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="6" id="0">
      <data key="d8">0</data>
      <data key="d9">Provisions and configures subnets.</data>
      <data key="d10">6</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="7" id="0">
      <data key="d8">0</data>
      <data key="d9">Utilizes RAM to share subnets across accounts.</data>
      <data key="d10">7</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="8" id="0">
      <data key="d8">0</data>
      <data key="d9">Provisions RDS databases.</data>
      <data key="d10">8</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="4" id="0">
      <data key="d8">0</data>
      <data key="d9">Terraform configuration is applied on EKS.</data>
      <data key="d10">5</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">Xero: Self-Service Developer Provisioning Platform</data>
    <data key="d1">https://www.youtube.com/watch?v=Felt-hOU6kU</data>
    <data key="d2">Xero built an automated self-service portal enabling over 1,600 developers to provision compliant AWS infrastructure in minutes instead of days, leveraging EKS, Terraform, and AWS Resource Access Manager (RAM) to manage 150+ accounts.</data>
    <data key="d3">control, interactive</data>
    <data key="d4">True</data>
  </graph>
</graphml>
