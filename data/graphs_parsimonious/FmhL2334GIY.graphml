<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Developer / CI/CD</data>
      <data key="d6">UserCompanyDeveloper</data>
      <data key="d7">Submits test scripts via UI, API, or CI/CD pipelines.</data>
    </node>
    <node id="1">
      <data key="d5">Scheduler</data>
      <data key="d6">EC2</data>
      <data key="d7">Manages automated execution frequency for synthetic tests.</data>
    </node>
    <node id="2">
      <data key="d5">Job Queue</data>
      <data key="d6">SQS</data>
      <data key="d7">Buffers scheduled test jobs for execution.</data>
    </node>
    <node id="3">
      <data key="d5">Monitor API</data>
      <data key="d6">EC2</data>
      <data key="d7">Serves jobs and receives metrics from private monitors.</data>
    </node>
    <node id="4">
      <data key="d5">Results Queue</data>
      <data key="d6">SQS</data>
      <data key="d7">Stores test results for alerting and dashboard visualization.</data>
    </node>
    <node id="5">
      <data key="d5">Public Monitors</data>
      <data key="d6">EC2</data>
      <data key="d7">New Relic-managed containerized runtimes for public testing.</data>
    </node>
    <node id="6">
      <data key="d5">Public Endpoint</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Customer's public-facing website or API.</data>
    </node>
    <node id="7">
      <data key="d5">Global Accelerator</data>
      <data key="d6">GlobalAccelerator</data>
      <data key="d7">Provides static IPs for secure routing from private minions.</data>
    </node>
    <node id="8">
      <data key="d5">Private Monitors</data>
      <data key="d6">EC2</data>
      <data key="d7">Customer-hosted containerized minions running inside private networks.</data>
    </node>
    <node id="9">
      <data key="d5">Private Endpoint</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Customer's internal site or API behind firewalls.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">Schedules test script.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="2" id="0">
      <data key="d8">1</data>
      <data key="d9">Pushes run details to queue.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="3" id="0">
      <data key="d8">2</data>
      <data key="d9">Passes job data to monitor API.</data>
      <data key="d10">2a</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="5" id="0">
      <data key="d8">3</data>
      <data key="d9">Public monitors pull jobs.</data>
      <data key="d10">2b</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="4" id="0">
      <data key="d8">7</data>
      <data key="d9">Sends execution results to queue.</data>
      <data key="d10">6</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="1" id="0">
      <data key="d8">8</data>
      <data key="d9">Schedules next iteration.</data>
      <data key="d10">7</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="6" id="0">
      <data key="d8">4</data>
      <data key="d9">Executes test on public API.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="7" target="3" id="0">
      <data key="d8">5</data>
      <data key="d9">Retrieves jobs from API.</data>
      <data key="d10">4b</data>
      <data key="d11">data</data>
    </edge>
    <edge source="8" target="7" id="0">
      <data key="d8">5</data>
      <data key="d9">Communicates via static IPs.</data>
      <data key="d10">4a</data>
      <data key="d11">data</data>
    </edge>
    <edge source="8" target="9" id="0">
      <data key="d8">6</data>
      <data key="d9">Tests internal private API.</data>
      <data key="d10">5</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">New Relic Synthetics Private and Public Monitoring</data>
    <data key="d1">https://www.youtube.com/watch?v=FmhL2334GIY</data>
    <data key="d2">Automated synthetic testing architecture using public and private minions to run scripted tests against endpoints securely.</data>
    <data key="d3">compute_intensive, control</data>
    <data key="d4">True</data>
  </graph>
</graphml>
