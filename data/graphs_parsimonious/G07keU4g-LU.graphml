<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">POS</data>
      <data key="d6">UserConsumerPOS</data>
      <data key="d7">Point of sale machines in 1,200 restaurants.</data>
    </node>
    <node id="1">
      <data key="d5">E-COMM</data>
      <data key="d6">UserConsumerMobile</data>
      <data key="d7">Customer facing mobile application and website.</data>
    </node>
    <node id="2">
      <data key="d5">POS DB</data>
      <data key="d6">EC2</data>
      <data key="d7">Consolidation database server on AWS cloud.</data>
    </node>
    <node id="3">
      <data key="d5">E-Comm DB</data>
      <data key="d6">RDS</data>
      <data key="d7">Transactional MySQL database for e-commerce orders.</data>
    </node>
    <node id="4">
      <data key="d5">DMS</data>
      <data key="d6">DMS</data>
      <data key="d7">AWS Database Migration Service replicates e-commerce database to S3.</data>
    </node>
    <node id="5">
      <data key="d5">S3 Data Lake</data>
      <data key="d6">S3</data>
      <data key="d7">Central data lake with raw and curated data buckets.</data>
    </node>
    <node id="6">
      <data key="d5">EMR</data>
      <data key="d6">EMR</data>
      <data key="d7">Transforms raw S3 data to curated layer, and loads curated hot data to Redshift.</data>
    </node>
    <node id="7">
      <data key="d5">Redshift</data>
      <data key="d6">RedShift</data>
      <data key="d7">Data warehouse storing hot transactional data (last 5-6 months).</data>
    </node>
    <node id="8">
      <data key="d5">Redshift Spectrum</data>
      <data key="d6">RedShift</data>
      <data key="d7">Queries historical cold/warm data directly from S3.</data>
    </node>
    <node id="9">
      <data key="d5">Athena</data>
      <data key="d6">Athena</data>
      <data key="d7">Provides ad-hoc SQL querying capability over S3 data for analysts.</data>
    </node>
    <edge source="0" target="2" id="0">
      <data key="d8">3</data>
      <data key="d9">POS systems upload local restaurant sales data to consolidation DB.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="0" id="0">
      <data key="d8">0</data>
      <data key="d9">Online orders flow into restaurant POS systems.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="3" id="0">
      <data key="d8">1</data>
      <data key="d9">E-commerce orders written to MySQL database.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="5" id="0">
      <data key="d8">4</data>
      <data key="d9">Custom ETL scripts transform and load POS DB data to S3.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="4" id="0">
      <data key="d8">2</data>
      <data key="d9">DMS reads transaction data.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="5" id="0">
      <data key="d8">2</data>
      <data key="d9">DMS writes raw transactional data to S3.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="6" id="0">
      <data key="d8">5</data>
      <data key="d9">EMR pulls raw data for transformation.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="6" target="5" id="0">
      <data key="d8">5</data>
      <data key="d9">EMR writes curated data back to S3.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="6" target="7" id="0">
      <data key="d8">5</data>
      <data key="d9">EMR loads curated hot data into Redshift.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="8" target="5" id="0">
      <data key="d8">6</data>
      <data key="d9">Spectrum transparently queries cold data from S3.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="9" target="5" id="0">
      <data key="d8">7</data>
      <data key="d9">Analysts execute ad-hoc SQL queries on S3 historical data.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">Jubilant Foodworks Serverless Data Lake and Analytics Architecture</data>
    <data key="d1">https://www.youtube.com/watch?v=G07keU4g-LU</data>
    <data key="d2">Data lake architecture utilizing AWS analytics services to ingest POS and e-commerce transaction data, separating hot data in Redshift from cold data in S3.</data>
    <data key="d3">data_ingestion, compute_intensive</data>
    <data key="d4">True</data>
  </graph>
