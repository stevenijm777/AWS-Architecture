  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Mobile Gamer</data>
      <data key="d6">UserConsumerMobile</data>
      <data key="d7">End-user playing a Voodoo game, triggering cross-promotion ad requests.</data>
    </node>
    <node id="1">
      <data key="d5">ALB</data>
      <data key="d6">ALB</data>
      <data key="d7">Distributes incoming traffic to the ad serving backend.</data>
    </node>
    <node id="2">
      <data key="d5">ECS</data>
      <data key="d6">ECS</data>
      <data key="d7">Runs the microservices that handle ad filtering and model requests.</data>
    </node>
    <node id="3">
      <data key="d5">EC2</data>
      <data key="d6">EC2</data>
      <data key="d7">Provides the underlying compute instances for the ECS cluster.</data>
    </node>
    <node id="4">
      <data key="d5">DynamoDB</data>
      <data key="d6">DynamoDB</data>
      <data key="d7">Stores and retrieves real-time user features for predictions.</data>
    </node>
    <node id="5">
      <data key="d5">SageMaker Endpoint</data>
      <data key="d6">SageMaker</data>
      <data key="d7">Hosts deployed ML models to return real-time ad install probability predictions.</data>
    </node>
    <node id="6">
      <data key="d5">Data Lake S3</data>
      <data key="d6">S3</data>
      <data key="d7">Stores raw analytical and transactional game data.</data>
    </node>
    <node id="7">
      <data key="d5">EMR</data>
      <data key="d6">EMR</data>
      <data key="d7">Runs scheduled batch jobs to aggregate and join data sources.</data>
    </node>
    <node id="8">
      <data key="d5">Dataset S3</data>
      <data key="d6">S3</data>
      <data key="d7">Stores processed datasets ready for ML training.</data>
    </node>
    <node id="9">
      <data key="d5">SageMaker Notebook</data>
      <data key="d6">SageMaker</data>
      <data key="d7">Used by data scientists to experiment, validate online performance, and run offline tests.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">User requests an ad.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">Routes traffic to ad serving container.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="4" id="0">
      <data key="d8">0</data>
      <data key="d9">Queries user features.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="5" id="0">
      <data key="d8">0</data>
      <data key="d9">Involves SageMaker endpoint for prediction scoring.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <edge source="6" target="7" id="0">
      <data key="d8">1</data>
      <data key="d9">EMR reads raw records from Data Lake.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="7" target="8" id="0">
      <data key="d8">1</data>
      <data key="d9">EMR writes structured datasets.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="8" target="9" id="0">
      <data key="d8">1</data>
      <data key="d9">Reads prepared datasets for model testing and training.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">Voodoo Mobile Ad Cross-Promotion Architecture</data>
    <data key="d1">https://www.youtube.com/watch?v=G5tNCpmD2uQ</data>
    <data key="d2">An AWS architecture that handles over 100 million model invocations daily to optimize cross-promotion of mobile games using Amazon ECS, DynamoDB, and SageMaker.</data>
    <data key="d3">data_ingestion, compute_intensive</data>
    <data key="d4">True</data>
  </graph>
