  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">EFS</data>
      <data key="d6">EFS</data>
      <data key="d7">Source for unstructured flat files.</data>
    </node>
    <node id="1">
      <data key="d5">DynamoDB</data>
      <data key="d6">DynamoDB</data>
      <data key="d7">Source for transactional NoSQL data.</data>
    </node>
    <node id="2">
      <data key="d5">Redshift</data>
      <data key="d6">RedShift</data>
      <data key="d7">Source for structured columnar data.</data>
    </node>
    <node id="3">
      <data key="d5">S3 Input</data>
      <data key="d6">S3</data>
      <data key="d7">Landing zone for batch CSV and raw data inputs.</data>
    </node>
    <node id="4">
      <data key="d5">Glue</data>
      <data key="d6">Glue</data>
      <data key="d7">Performs ETL on incoming source data.</data>
    </node>
    <node id="5">
      <data key="d5">S3 Central</data>
      <data key="d6">S3</data>
      <data key="d7">Stores ready data and triggers the ML pipeline on write events.</data>
    </node>
    <node id="6">
      <data key="d5">Lambda</data>
      <data key="d6">Lambda</data>
      <data key="d7">Orchestrates SageMaker ML jobs sequentially.</data>
    </node>
    <node id="7">
      <data key="d5">SageMaker</data>
      <data key="d6">SageMaker</data>
      <data key="d7">Runs k-means clustering and random forest prediction models.</data>
    </node>
    <node id="8">
      <data key="d5">API Client</data>
      <data key="d6">UserConsumerAPI</data>
      <data key="d7">Real-time API endpoints for operational application integration.</data>
    </node>
    <node id="9">
      <data key="d5">BI Dashboard</data>
      <data key="d6">UserCompanyAnalyst</data>
      <data key="d7">Consumes downstream prediction results for analytics.</data>
    </node>
    <edge source="0" target="4" id="0">
      <data key="d8">0</data>
      <data key="d9">Ingests unstructured files into Glue.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="4" id="0">
