<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="user">
      <data key="d5">Operations Agent</data>
      <data key="d6">UserCompanyAgent</data>
      <data key="d7">Administrators and operators triggering actions or sending instructions to the management pipeline.</data>
    </node>
    <node id="ec2">
      <data key="d5">Fugue Conductor</data>
      <data key="d6">EC2</data>
      <data key="d7">Orchestration engine running in an Auto Scaling Group that provisions infrastructure and scans for drift.</data>
    </node>
    <node id="s3">
      <data key="d5">Policy &amp; Declarations Storage</data>
      <data key="d6">S3</data>
      <data key="d7">Saves compiled infrastructure declarations and custom/standard compliance policies.</data>
    </node>
    <node id="dynamodb">
      <data key="d5">State Persistence</data>
      <data key="d6">DynamoDB</data>
      <data key="d7">Maintains persistent state data for the orchestration engine.</data>
    </node>
    <node id="sqs">
      <data key="d5">Inbound Message Queue</data>
      <data key="d6">SQS</data>
      <data key="d7">Handles inbound instruction messages sent to the conductor.</data>
    </node>
    <node id="sns">
      <data key="d5">Drift Notifications</data>
      <data key="d6">SNS</data>
      <data key="d7">Publishes real-time alerts if a resource drift is detected.</data>
    </node>
    <node id="kms">
      <data key="d5">KMS Encryption</data>
      <data key="d6">KMS</data>
      <data key="d7">Secures orchestration data and SQS message payloads.</data>
    </node>
    <node id="sts">
      <data key="d5">STS &amp; IAM</data>
      <data key="d6">STS</data>
      <data key="d7">Authenticates and generates cross-account credentials to manage multiple target accounts.</data>
    </node>
    <node id="vpc_1">
      <data key="d5">AWS Account 1</data>
      <data key="d6">VPC</data>
      <data key="d7">First target client account managed and monitored for drift by the central conductor.</data>
    </node>
    <node id="vpc_2">
      <data key="d5">AWS Account 2</data>
      <data key="d6">VPC</data>
      <data key="d7">Second target client account managed and monitored for drift by the central conductor.</data>
    </node>
    <edge source="user" target="sts" id="0">
      <data key="d8">1</data>
      <data key="d9">Operator initiates administrative deployment commands.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="ec2" target="dynamodb" id="0">
      <data key="d8">3</data>
      <data key="d9">Conductor reads and writes execution state data.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="ec2" target="sqs" id="0">
      <data key="d8">4</data>
      <data key="d9">Pulls configuration instructions from the queue.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <edge source="ec2" target="vpc_1" id="0">
      <data key="d8">5</data>
      <data key="d9">Scans and enforces compliant states in Target Account 1.</data>
      <data key="d10">5</data>
      <data key="d11">data</data>
    </edge>
    <edge source="ec2" target="vpc_2" id="0">
      <data key="d8">5</data>
      <data key="d9">Scans and enforces compliant states in Target Account 2.</data>
      <data key="d10">5.1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="s3" target="ec2" id="0">
      <data key="d8">2</data>
      <data key="d9">Conductor downloads the compiled policy definitions.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="sts" target="ec2" id="0">
      <data key="d8">1</data>
      <data key="d9">Delegates temporary security credentials to the conductor.</data>
      <data key="d10">1.1</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">Automated Drift Detection and Baseline Enforcement with Fugue</data>
    <data key="d1">https://www.youtube.com/watch?v=Gds8hl8dKuo</data>
    <data key="d2">Fugue Conductor runs as an EC2-based orchestration engine inside a dedicated customer account to provision, continuously scan, and remediate resource drift across multiple target AWS accounts via IAM cross-account roles.</data>
    <data key="d3">control</data>
    <data key="d4">True</data>
  </graph>
</graphml>
