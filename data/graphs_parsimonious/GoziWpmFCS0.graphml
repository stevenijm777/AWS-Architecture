<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d12" for="edge" attr.name="id" attr.type="string" />
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Data Pipeline</data>
      <data key="d6">UserCompanyDataStream</data>
      <data key="d7">Source pipeline ingesting raw JSON records.</data>
    </node>
    <node id="1">
      <data key="d5">S3 (JSON)</data>
      <data key="d6">S3</data>
      <data key="d7">DATA_PEEK: Receives around 3 TB of JSON data per day.</data>
    </node>
    <node id="2">
      <data key="d5">Glue Crawler (JSON)</data>
      <data key="d6">Glue</data>
      <data key="d7">Crawls raw JSON data to automatically discover schema.</data>
    </node>
    <node id="3">
      <data key="d5">Glue Data Catalog</data>
      <data key="d6">Glue</data>
      <data key="d7">Stores metadata tables and schemas (column types, names, and tables).</data>
    </node>
    <node id="4">
      <data key="d5">Glue Job</data>
      <data key="d6">Glue</data>
      <data key="d7">WORKLOAD_PEEK: Converts newly arrived JSON files into Apache Parquet format.</data>
    </node>
    <node id="5">
      <data key="d5">S3 (Parquet)</data>
      <data key="d6">S3</data>
      <data key="d7">Stores historical data in columnar Parquet format for faster, cost-effective queries.</data>
    </node>
    <node id="6">
      <data key="d5">Glue Crawler (Parquet)</data>
      <data key="d6">Glue</data>
      <data key="d7">Crawls the converted Parquet files to update table metadata.</data>
    </node>
    <node id="7">
      <data key="d5">Athena</data>
      <data key="d6">Athena</data>
      <data key="d7">Query engine used to query raw JSON and columnar Parquet data.</data>
    </node>
    <node id="8">
      <data key="d5">Research Scientists</data>
      <data key="d6">UserCompanyDomainExpert</data>
      <data key="d7">Explores the data lake to find patterns, identify bugs, and design new features.</data>
    </node>
    <edge source="0" target="1">
      <data key="d8">0</data>
      <data key="d9">Ingests raw JSON records into S3 bucket</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="1" target="2">
      <data key="d8">0</data>
      <data key="d9">Crawler inspects JSON data</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="1" target="4">
      <data key="d8">1</data>
      <data key="d9">Reads JSON files</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="2" target="3">
      <data key="d8">0</data>
      <data key="d9">Saves table schemas in Data Catalog</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="4" target="5">
      <data key="d8">1</data>
      <data key="d9">Writes converted Parquet files</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="5" target="6">
      <data key="d8">1</data>
      <data key="d9">Crawler inspects Parquet files</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="6" target="3">
      <data key="d8">1</data>
      <data key="d9">Saves Parquet schemas in Data Catalog</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="7" target="3">
      <data key="d8">2</data>
      <data key="d9">Fetches metadata and table structures</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="7" target="1">
      <data key="d8">2</data>
      <data key="d9">Queries raw JSON (short-term history)</data>
      <data key="d10">3a</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="7" target="5">
      <data key="d8">2</data>
      <data key="d9">Queries Parquet data (long-term history)</data>
      <data key="d10">3b</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="8" target="7">
      <data key="d8">2</data>
      <data key="d9">Scientists execute analytical queries</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <data key="d0">iRobot: Serverless Data Cataloging for Data Scientists</data>
    <data key="d1">https://www.youtube.com/watch?v=GoziWpmFCS0</data>
    <data key="d2">A completely serverless data lake processing 3 TB of raw JSON data per day. Converts data to Parquet to optimize queries and reduce costs for long-term historical analysis.</data>
    <data key="d3">data_ingestion, interactive</data>
    <data key="d4">True</data>
  </graph>
