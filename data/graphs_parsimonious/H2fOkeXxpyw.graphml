<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Developer CLI</data>
      <data key="d6">UserCompanyDeveloper</data>
      <data key="d7">Developers write and deploy custom application code using the CLI.</data>
    </node>
    <node id="1">
      <data key="d5">Deployment Web Service</data>
      <data key="d6">EC2</data>
      <data key="d7">Receives and scales deployment requests from the developer CLI.</data>
    </node>
    <node id="2">
      <data key="d5">State Database</data>
      <data key="d6">DynamoDB</data>
      <data key="d7">Stores and tracks the progress and state of active deployments.</data>
    </node>
    <node id="3">
      <data key="d5">Deployment Queue</data>
      <data key="d6">SQS</data>
      <data key="d7">Buffers deployment requests to prevent rate limiting of the Lambda control plane.</data>
    </node>
    <node id="4">
      <data key="d5">Deployment Worker</data>
      <data key="d6">EC2</data>
      <data key="d7">Consumes deployment jobs from SQS and creates customer Lambdas.</data>
    </node>
    <node id="5">
      <data key="d5">Customer Lambdas</data>
      <data key="d6">Lambda</data>
      <data key="d7">Runs tenant code in dedicated AWS account using secure V8 isolates.</data>
    </node>
    <node id="6">
      <data key="d5">End User Browser</data>
      <data key="d6">UserConsumerWeb</data>
      <data key="d7">Interacts with Forge applications and triggers function execution.</data>
    </node>
    <node id="7">
      <data key="d5">Invocation Service</data>
      <data key="d6">EC2</data>
      <data key="d7">Handles authentication, permission checks, and triggers Lambda execution.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">1</data>
      <data key="d9">Developer deploys code using CLI.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="2" id="0">
      <data key="d8">2</data>
      <data key="d9">Persists deployment state tracking.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="3" id="0">
      <data key="d8">3</data>
      <data key="d9">Enqueues deployment tasks.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="4" id="0">
      <data key="d8">4</data>
      <data key="d9">Worker polls deployment jobs.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="5" id="0">
      <data key="d8">4</data>
      <data key="d9">Deploys custom code as Lambda function.</data>
      <data key="d10">5</data>
      <data key="d11">data</data>
    </edge>
    <edge source="6" target="7" id="0">
      <data key="d8">5</data>
      <data key="d9">Requests application features/renders.</data>
      <data key="d10">6</data>
      <data key="d11">data</data>
    </edge>
    <edge source="7" target="5" id="0">
      <data key="d8">5</data>
      <data key="d9">Invokes the targeted Lambda function.</data>
      <data key="d10">7</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">Atlassian Forge Extensibility Platform</data>
    <data key="d1">https://www.youtube.com/watch?v=H2fOkeXxpyw</data>
    <data key="d2">Atlassian Forge uses a multi-tenant Lambda execution model with V8 isolates inside a dedicated AWS account to secure tenant code execution.</data>
    <data key="d3">compute_intensive,interactive,control</data>
    <data key="d4">True</data>
  </graph>
</graphml>
