<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Security DevOps Team</data>
      <data key="d6">UserCompanyDeveloper</data>
      <data key="d7">Pushes the mappings.json configuration file containing account mappings to Git to initiate onboarding.</data>
    </node>
    <node id="1">
      <data key="d5">Git Repository</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Houses configuration files and uses Git Actions to upload artifacts to S3.</data>
    </node>
    <node id="2">
      <data key="d5">S3 Artifact Bucket</data>
      <data key="d6">S3</data>
      <data key="d7">Stores mapping configuration files and triggers Step Functions upon upload.</data>
    </node>
    <node id="3">
      <data key="d5">Onboarding Step Function</data>
      <data key="d6">StepFunctions</data>
      <data key="d7">Orchestrates the onboarding process: creating IAM roles, triggering Lambda to set up Thales KMS tenants, and sending completion alerts via SNS.</data>
    </node>
    <node id="4">
      <data key="d5">SNS</data>
      <data key="d6">SNS</data>
      <data key="d7">Sends notifications back to the Security DevOps team upon successful onboarding.</data>
    </node>
    <node id="5">
      <data key="d5">Onboarding Lambda</data>
      <data key="d6">Lambda</data>
      <data key="d7">Invoked by Step Functions to set up virtual wrappers/tenants within Thales KMS.</data>
    </node>
    <node id="6">
      <data key="d5">IAM Role</data>
      <data key="d6">IAM</data>
      <data key="d7">Cross-account IAM roles allowing Thales KMS to perform key operations in AWS.</data>
    </node>
    <node id="7">
      <data key="d5">Thales KMS</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">On-premises Key Management Service used to generate symmetric keys and manage virtual tenants securely.</data>
    </node>
    <node id="8">
      <data key="d5">DevOps / Product Team</data>
      <data key="d6">UserCompanyDeveloper</data>
      <data key="d7">Responsible for generating master cryptographic keys on Thales and managing key lifecycles (rotation/revocation).</data>
    </node>
    <node id="9">
      <data key="d5">AWS KMS</data>
      <data key="d6">KMS</data>
      <data key="d7">Imports symmetric keys from Thales as Customer Managed Keys (CMKs) to perform resource-level encryption.</data>
    </node>
    <node id="10">
      <data key="d5">S3 Data Bucket</data>
      <data key="d6">S3</data>
      <data key="d7">Data stored in S3 is encrypted using the customer-managed keys imported into KMS.</data>
    </node>
    <node id="11">
      <data key="d5">EBS Volume</data>
      <data key="d6">EBS</data>
      <data key="d7">EBS volumes are encrypted using the customer-managed keys imported into KMS.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">1</data>
      <data key="d9">Pushes mappings.json configuration file.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="2" id="0">
      <data key="d8">1</data>
      <data key="d9">Uploads mapping file artifact via Git Action.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="3" id="0">
      <data key="d8">1</data>
      <data key="d9">Triggers the onboarding Step Function execution.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="6" id="0">
      <data key="d8">1</data>
      <data key="d9">Creates specific IAM roles in the target AWS accounts.</data>
      <data key="d10">4a</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="5" id="0">
      <data key="d8">1</data>
      <data key="d9">Triggers Lambda to set up virtual tenant.</data>
      <data key="d10">4b</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="4" id="0">
      <data key="d8">1</data>
      <data key="d9">Signals SNS of workflow completion.</data>
      <data key="d10">4d</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="0" id="0">
      <data key="d8">1</data>
      <data key="d9">Sends confirmation of tenant onboarding.</data>
      <data key="d10">5</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="7" id="0">
      <data key="d8">1</data>
      <data key="d9">Creates virtual wrappers/tenants in Thales KMS.</data>
      <data key="d10">4c</data>
      <data key="d11">data</data>
    </edge>
    <edge source="7" target="6" id="0">
      <data key="d8">2</data>
      <data key="d9">Assumes the IAM role to gain permission to import keys.</data>
      <data key="d10">2a</data>
      <data key="d11">data</data>
    </edge>
    <edge source="7" target="9" id="0">
      <data key="d8">2</data>
      <data key="d9">Imports the generated symmetric key into KMS as a CMK.</data>
      <data key="d10">2b</data>
      <data key="d11">data</data>
    </edge>
    <edge source="8" target="7" id="0">
      <data key="d8">2</data>
      <data key="d9">Generates symmetric 256-bit encryption keys on-prem.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="9" target="10" id="0">
      <data key="d8">2</data>
      <data key="d9">Encrypts S3 storage with the imported customer-managed key.</data>
      <data key="d10">3a</data>
      <data key="d11">data</data>
    </edge>
    <edge source="9" target="11" id="0">
      <data key="d8">2</data>
      <data key="d9">Encrypts EBS block storage with the imported customer-managed key.</data>
      <data key="d10">3b</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">On-Premises Key Management with AWS KMS Integration</data>
    <data key="d1">https://www.youtube.com/watch?v=H_S7CxtHgSM</data>
    <data key="d2">Raiffeisen Bank International's solution for maintaining on-premises key management control while seamlessly utilizing KMS to secure AWS services like S3 and EBS in a highly compliant banking environment.</data>
    <data key="d3">control</data>
    <data key="d4">True</data>
  </graph>
</graphml>
