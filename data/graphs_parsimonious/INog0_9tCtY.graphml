<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Customer VPC</data>
      <data key="d6">VPC</data>
      <data key="d7">Boundary for customer environment.</data>
    </node>
    <node id="1">
      <data key="d5">Customer EC2 Instances</data>
      <data key="d6">EC2</data>
      <data key="d7">Runs ThreatStack security agent.</data>
    </node>
    <node id="2">
      <data key="d5">AWS CloudTrail</data>
      <data key="d6">CloudTrail</data>
      <data key="d7">Tracks user activity and API usage.</data>
    </node>
    <node id="3">
      <data key="d5">Apache Kafka</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Ingests events and serializes them into Avro.</data>
    </node>
    <node id="4">
      <data key="d5">Apache Flink</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Processes and routes real-time streams.</data>
    </node>
    <node id="5">
      <data key="d5">NRT S3 Bucket</data>
      <data key="d6">S3</data>
      <data key="d7">Stores near-real-time JSON data GZIPed.</data>
    </node>
    <node id="6">
      <data key="d5">EMR Batch Cluster</data>
      <data key="d6">EMR</data>
      <data key="d7">Processes and batches 30-day data.</data>
    </node>
    <node id="7">
      <data key="d5">Parquet S3 Bucket</data>
      <data key="d6">S3</data>
      <data key="d7">Long-term data warehouse storing Parquet files.</data>
    </node>
    <node id="8">
      <data key="d5">Orchestration Instance</data>
      <data key="d6">EC2</data>
      <data key="d7">Launches secure EMR clusters and submits Spark JARs.</data>
    </node>
    <node id="9">
      <data key="d5">Amazon Athena</data>
      <data key="d6">Athena</data>
      <data key="d7">Runs ad-hoc SQL queries on Parquet logs.</data>
    </node>
    <node id="10">
      <data key="d5">Amazon SageMaker</data>
      <data key="d6">SageMaker</data>
      <data key="d7">Trains models for anomaly detection.</data>
    </node>
    <node id="11">
      <data key="d5">EMR Analytics Cluster</data>
      <data key="d6">EMR</data>
      <data key="d7">Executes analytics and nightly reports.</data>
    </node>
    <edge source="1" target="3" id="0">
      <data key="d8">0</data>
      <data key="d9">Sends agent telemetry.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="3" id="0">
      <data key="d8">0</data>
      <data key="d9">Sends CloudTrail logs.</data>
      <data key="d10">0a</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="4" id="0">
      <data key="d8">1</data>
      <data key="d9">Streams real-time events.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="6" id="0">
      <data key="d8">2</data>
      <data key="d9">Feeds 30-day batch stream.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="5" id="0">
      <data key="d8">1</data>
      <data key="d9">Writes GZIP JSON.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="6" target="7" id="0">
      <data key="d8">2</data>
      <data key="d9">Writes Parquet format.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="7" target="9" id="0">
      <data key="d8">4</data>
      <data key="d9">Queries security data.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="7" target="10" id="0">
      <data key="d8">4</data>
      <data key="d9">Feeds ML models.</data>
      <data key="d10">1a</data>
      <data key="d11">data</data>
    </edge>
    <edge source="7" target="11" id="0">
      <data key="d8">4</data>
      <data key="d9">Processes reporting data.</data>
      <data key="d10">1b</data>
      <data key="d11">data</data>
    </edge>
    <edge source="8" target="6" id="0">
      <data key="d8">3</data>
      <data key="d9">Orchestrates cluster lifecycle.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="8" target="11" id="0">
      <data key="d8">3</data>
      <data key="d9">Submits analytical JAR jobs.</data>
      <data key="d10">0a</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">ThreatStack Telemetry Ingestion and Analytics Pipeline</data>
    <data key="d1">https://www.youtube.com/watch?v=INog0_9tCtY</data>
    <data key="d2">Ingestion pipeline processing 60 billion daily events. Employs a split stream: near-real-time via Flink to S3, and long-term batch via EMR to S3 Parquet for SQL, ML, and reporting queries.</data>
    <data key="d3">data_ingestion, compute_intensive</data>
    <data key="d4">True</data>
  </graph>
</graphml>
