  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Data Engineers &amp; Analysts</data>
      <data key="d6">UserCompanyAgent</data>
      <data key="d7">Internal users requesting infrastructure or data access.</data>
    </node>
    <node id="1">
      <data key="d5">Self-Service Portal</data>
      <data key="d6">EC2</data>
      <data key="d7">Web portal for selecting infrastructure types and cost center tracking.</data>
    </node>
    <node id="2">
      <data key="d5">EKS Core Platform</data>
      <data key="d6">EKS</data>
      <data key="d7">Hosts 100+ microservices for computing lifecycle, provisioning, and workflow orchestration.</data>
    </node>
    <node id="3">
      <data key="d5">PostgreSQL</data>
      <data key="d6">RDS</data>
      <data key="d7">Stores request records and configuration metadata.</data>
    </node>
    <node id="4">
      <data key="d5">SQS Queue</data>
      <data key="d6">SQS</data>
      <data key="d7">Queues events for automated infrastructure and data access workflows.</data>
    </node>
    <node id="5">
      <data key="d5">SES</data>
      <data key="d6">SES</data>
      <data key="d7">Sends approval requests and status notifications back to users.</data>
    </node>
    <node id="6">
      <data key="d5">EMR Cluster</data>
      <data key="d6">EMR</data>
      <data key="d7">Provisioned for batch ETL pipelines.</data>
    </node>
    <node id="7">
      <data key="d5">Glue Catalog</data>
      <data key="d6">Glue</data>
      <data key="d7">Manages databases and controls access permissions.</data>
    </node>
    <node id="8">
      <data key="d5">S3 Data Lake</data>
      <data key="d6">S3</data>
      <data key="d7">Secure storage buckets created for data residency.</data>
    </node>
    <node id="9">
      <data key="d5">Airflow / NiFi EC2</data>
      <data key="d6">EC2</data>
      <data key="d7">Hosts containerized ETL orchestration engines.</data>
    </node>
    <node id="10">
      <data key="d5">IAM &amp; Ranger</data>
      <data key="d6">IAM</data>
      <data key="d7">Applies role policies and fine-grained access controls.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">1</data>
      <data key="d9">User requests infrastructure via portal.</data>
