  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">CSV &amp; Excel Source</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Raw trade data uploaded by data providers.</data>
    </node>
    <node id="1">
      <data key="d5">Raw S3 Bucket</data>
      <data key="d6">S3</data>
      <data key="d7">WORKLOAD_PEEK: Stores incoming raw trade reports.</data>
    </node>
    <node id="2">
      <data key="d5">Validation Lambda</data>
      <data key="d6">Lambda</data>
      <data key="d7">Validates data structure and flags discrepancies.</data>
    </node>
    <node id="3">
      <data key="d5">Validated S3 Bucket</data>
      <data key="d6">S3</data>
      <data key="d7">Stores validated copy of the data files.</data>
    </node>
    <node id="4">
      <data key="d5">Ingestion Lambda</data>
      <data key="d6">Lambda</data>
      <data key="d7">Triggers on new validated uploads, creates templates, indexes, and ingests into OpenSearch.</data>
    </node>
    <node id="5">
      <data key="d5">OpenSearch Cluster (Ingest)</data>
      <data key="d6">OpenSearch</data>
      <data key="d7">DATA_PEEK: Indexes data for fast search. Powered by Graviton2.</data>
    </node>
    <node id="6">
      <data key="d5">End User</data>
      <data key="d6">UserConsumerWebMobile</data>
      <data key="d7">Retrieves trade reports and analysis.</data>
    </node>
    <node id="7">
      <data key="d5">Angular Frontend</data>
      <data key="d6">EC2</data>
      <data key="d7">Web interface serving UI to browsers.</data>
    </node>
    <node id="8">
      <data key="d5">Python Backend</data>
      <data key="d6">EC2</data>
      <data key="d7">Handles business logic and API requests for web and mobile.</data>
    </node>
    <node id="9">
      <data key="d5">OpenSearch Cluster (Query)</data>
      <data key="d6">OpenSearch</data>
      <data key="d7">Serves aggregate search requests in 2-4 seconds.</data>
    </node>
    <node id="10">
      <data key="d5">Amazon RDS</data>
      <data key="d6">RDS</data>
      <data key="d7">Stores relational data and user metadata.</data>
    </node>
    <node id="11">
      <data key="d5">Reports S3 Bucket</data>
      <data key="d6">S3</data>
      <data key="d7">Generates and stores large reports (&gt;10k records).</data>
    </node>
    <node id="12">
      <data key="d5">Amazon SES</data>
      <data key="d6">SES</data>
      <data key="d7">Sends pre-signed S3 URL download links to users via email.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">Uploads raw files</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">Triggers validation</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="3" id="0">
      <data key="d8">0</data>
      <data key="d9">Saves validated dataset copy</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="4" id="0">
      <data key="d8">0</data>
      <data key="d9">Triggers indexing</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="5" id="0">
      <data key="d8">0</data>
      <data key="d9">Ingests data records</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <edge source="6" target="7" id="0">
      <data key="d8">1</data>
      <data key="d9">Web access request</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="6" target="8" id="0">
      <data key="d8">1</data>
      <data key="d9">Mobile access API request</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="7" target="8" id="0">
      <data key="d8">1</data>
      <data key="d9">Forwards API requests</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="8" target="9" id="0">
      <data key="d8">1</data>
      <data key="d9">Queries search indexes</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="8" target="10" id="0">
      <data key="d8">1</data>
      <data key="d9">Fetches metadata/relational data</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <edge source="8" target="11" id="0">
      <data key="d8">1</data>
      <data key="d9">Uploads heavy reports</data>
      <data key="d10">5</data>
      <data key="d11">data</data>
    </edge>
    <edge source="8" target="12" id="0">
      <data key="d8">1</data>
      <data key="d9">Triggers email notification</data>
      <data key="d10">6</data>
      <data key="d11">data</data>
    </edge>
    <edge source="12" target="6" id="0">
      <data key="d8">1</data>
      <data key="d9">Sends pre-signed URL to download report</data>
      <data key="d10">7</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">Noventiq: Harnessing Search and Analytics with Event-Driven Architecture on Amazon OpenSearch</data>
    <data key="d1">https://www.youtube.com/watch?v=JYeXbUdFOdw</data>
    <data key="d2">Handles over 5 billion import-export trade records. Switched to Graviton2 for Amazon OpenSearch to reduce costs by 25-30% ($100k savings). Complex queries are served within 2 to 4 seconds.</data>
    <data key="d3">data_ingestion, interactive</data>
    <data key="d4">True</data>
  </graph>
