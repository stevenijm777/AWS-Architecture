    <node id="3">
      <data key="d5">Source S3 Bucket</data>
      <data key="d6">S3</data>
      <data key="d7">Stores zipped code artifacts.</data>
    </node>
    <node id="4">
      <data key="d5">CodeBuild</data>
      <data key="d6">CodeBuild</data>
      <data key="d7">Calculates checksums to detect modified files.</data>
    </node>
    <node id="5">
      <data key="d5">Artifact S3 Bucket</data>
      <data key="d6">S3</data>
      <data key="d7">Stores filtered changed files.</data>
