    <node id="6">
      <data key="d5">CodePipeline</data>
      <data key="d6">CodePipeline</data>
      <data key="d7">Orchestrates deployment pipeline steps.</data>
    </node>
    <node id="7">
      <data key="d5">CloudFormation</data>
      <data key="d6">CloudFormation</data>
      <data key="d7">Applies change sets to manage stacks.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">Webhook trigger</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="0" target="2" id="0">
