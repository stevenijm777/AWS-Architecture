  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Data Files</data>
      <data key="d6">UserCompanyDataStream</data>
      <data key="d7">External client data source emitting raw files.</data>
    </node>
    <node id="1">
      <data key="d5">Input Bucket</data>
      <data key="d6">S3</data>
      <data key="d7">Stores incoming raw data files.</data>
    </node>
    <node id="2">
      <data key="d5">Metadata SQS</data>
      <data key="d6">SQS</data>
      <data key="d7">Buffers ingestion metadata details.</data>
    </node>
    <node id="3">
      <data key="d5">Metadata Ingestion Lambda</data>
      <data key="d6">Lambda</data>
      <data key="d7">Processes SQS metadata events.</data>
    </node>
    <node id="4">
      <data key="d5">Postgres RDS</data>
      <data key="d6">RDS</data>
      <data key="d7">Central state database managing processing workflows.</data>
    </node>
    <node id="5">
      <data key="d5">EMR Scheduler Lambda</data>
      <data key="d6">Lambda</data>
      <data key="d7">Coordinates EMR jobs based on database state.</data>
    </node>
    <node id="6">
      <data key="d5">Spark Cluster</data>
      <data key="d6">EMR</data>
      <data key="d7">Performs file transformation and formatting.</data>
    </node>
    <node id="7">
      <data key="d5">Output Bucket</data>
      <data key="d6">S3</data>
      <data key="d7">Stores transformed and formatted target files.</data>
    </node>
    <node id="8">
      <data key="d5">Upload Coordinator Lambda</data>
      <data key="d6">Lambda</data>
      <data key="d7">Performs fan-out triggers of uploaders based on RDS status.</data>
    </node>
    <node id="9">
      <data key="d5">Target Uploader Lambdas</data>
      <data key="d6">Lambda</data>
      <data key="d7">Runs concurrently up to thousands of instances to push files.</data>
    </node>
    <node id="10">
      <data key="d5">Ad Networks</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">External advertising partner destinations.</data>
    </node>
    <node id="11">
      <data key="d5">Buffer SQS Queue</data>
      <data key="d6">SQS</data>
      <data key="d7">Prevents RDS DB connection exhaustion by queuing status reports.</data>
    </node>
    <node id="12">
      <data key="d5">Status Database Writer</data>
      <data key="d6">Lambda</data>
      <data key="d7">Pulls batches from SQS to update RDS states.</data>
    </node>
