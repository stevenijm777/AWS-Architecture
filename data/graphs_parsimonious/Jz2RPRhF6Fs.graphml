<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">User</data>
      <data key="d6">UserConsumerMobile</data>
      <data key="d7">Web and mobile clients sending API requests.</data>
    </node>
    <node id="1">
      <data key="d5">CloudFront</data>
      <data key="d6">CloudFront</data>
      <data key="d7">CDN caching and entry point for routing.</data>
    </node>
    <node id="2">
      <data key="d5">Lambda@Edge</data>
      <data key="d6">LambdaAtEdge</data>
      <data key="d7">Handles traffic shifting between legacy gateway and AWS API Gateway.</data>
    </node>
    <node id="3">
      <data key="d5">Legacy API Gateway</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">XML-configured legacy backend API.</data>
    </node>
    <node id="4">
      <data key="d5">API Gateway</data>
      <data key="d6">ApiGateway</data>
      <data key="d7">Centralized, secure gateway natively integrating with Lambda.</data>
    </node>
    <node id="5">
      <data key="d5">Custom Authorizer Lambda</data>
      <data key="d6">Lambda</data>
      <data key="d7">Decodes JWT tokens and verifies scopes.</data>
    </node>
    <node id="6">
      <data key="d5">DynamoDB</data>
      <data key="d6">DynamoDB</data>
      <data key="d7">Externalized store for API scope configurations.</data>
    </node>
    <node id="7">
      <data key="d5">ELB</data>
      <data key="d6">ELB</data>
      <data key="d7">Load balances traffic from API Gateway to Nginx.</data>
    </node>
    <node id="8">
      <data key="d5">Nginx Proxy</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Terminates mutual TLS connection from API Gateway.</data>
    </node>
    <node id="9">
      <data key="d5">Private ALB</data>
      <data key="d6">ALB</data>
      <data key="d7">Fronts private containerized backend services.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">1</data>
      <data key="d9">Initiates API request with JWT token.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="2" id="0">
      <data key="d8">1</data>
      <data key="d9">Triggers edge routing logic.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="3" id="0">
      <data key="d8">1</data>
      <data key="d9">Routes legacy traffic to legacy API.</data>
      <data key="d10">3a</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="4" id="0">
      <data key="d8">1</data>
      <data key="d9">Routes migrated traffic to Amazon API Gateway.</data>
      <data key="d10">3b</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="5" id="0">
      <data key="d8">2</data>
      <data key="d9">Invokes custom authorizer to validate token.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="7" id="0">
      <data key="d8">3</data>
      <data key="d9">Routes validated request to backend cluster.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="6" id="0">
      <data key="d8">2</data>
      <data key="d9">Queries DynamoDB to verify scopes.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="7" target="8" id="0">
      <data key="d8">3</data>
      <data key="d9">Forwards to Nginx proxy for mutual TLS.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="8" target="9" id="0">
      <data key="d8">3</data>
      <data key="d9">Sends requests to the private ALB.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">Accolade API Gateway Migration and Security Architecture</data>
    <data key="d1">https://www.youtube.com/watch?v=Jz2RPRhF6Fs</data>
    <data key="d2">Migration architecture from legacy XML API gateway to Amazon API Gateway. Uses CloudFront and Lambda@Edge for traffic shifting, custom Lambda authorizers with DynamoDB for scope validation, and Nginx for mutual TLS termination before a private ALB.</data>
    <data key="d3">interactive, control</data>
    <data key="d4">True</data>
  </graph>
</graphml>
