<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">CodePipeline</data>
      <data key="d6">CodePipeline</data>
      <data key="d7">Orchestrates build, QA deploy, manual approval, and production deployment.</data>
    </node>
    <node id="1">
      <data key="d5">SNS Topic</data>
      <data key="d6">SNS</data>
      <data key="d7">Receives approval state trigger from CodePipeline.</data>
    </node>
    <node id="2">
      <data key="d5">Notification Lambda</data>
      <data key="d6">Lambda</data>
      <data key="d7">Triggered by SNS to deliver an interactive Yes/No message to Slack.</data>
    </node>
    <node id="3">
      <data key="d5">Slack</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Collaboration tool where the team receives notifications and approves builds.</data>
    </node>
    <node id="4">
      <data key="d5">API Gateway</data>
      <data key="d6">ApiGateway</data>
      <data key="d7">Receives webhook callbacks from interactive Slack buttons.</data>
    </node>
    <node id="5">
      <data key="d5">Approval Response Lambda</data>
      <data key="d6">Lambda</data>
      <data key="d7">Validates credentials and signals CodePipeline to resume deployment.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">Triggers approval notification</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">Invokes notification Lambda</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="3" id="0">
      <data key="d8">0</data>
      <data key="d9">Posts interactive message to Slack</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="4" id="0">
      <data key="d8">1</data>
      <data key="d9">Sends Yes/No button click response</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="5" id="0">
      <data key="d8">1</data>
      <data key="d9">Passes callback payload</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="0" id="0">
      <data key="d8">1</data>
      <data key="d9">Approves and resumes pipeline</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">OpenFit ChatOps CI CD Pipeline with Slack</data>
    <data key="d1">https://www.youtube.com/watch?v=Kebb0LOVC28</data>
    <data key="d2">Serverless ChatOps deployment pipeline using Slack interactive buttons to approve production releases.</data>
    <data key="d3">compute_intensive,control</data>
    <data key="d4">True</data>
  </graph>
</graphml>
