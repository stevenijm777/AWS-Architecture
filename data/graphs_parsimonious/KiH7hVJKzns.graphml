<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Web Users</data>
      <data key="d6">UserConsumerWeb</data>
      <data key="d7">Employees and employers accessing via web browsers.</data>
    </node>
    <node id="1">
      <data key="d5">Mobile Users</data>
      <data key="d6">UserConsumerMobile</data>
      <data key="d7">Employees clocking in/out via mobile devices.</data>
    </node>
    <node id="2">
      <data key="d5">API Layer</data>
      <data key="d6">ApiGateway</data>
      <data key="d7">Handles incoming API requests from devices.</data>
    </node>
    <node id="3">
      <data key="d5">ELB</data>
      <data key="d6">ELB</data>
      <data key="d7">Load balancing cluster distributing traffic to EKS.</data>
    </node>
    <node id="4">
      <data key="d5">EKS Cluster</data>
      <data key="d6">EKS</data>
      <data key="d7">Runs hundreds of microservices including continuous calc payroll engine.</data>
    </node>
    <node id="5">
      <data key="d5">Streaming for Kafka</data>
      <data key="d6">MSK</data>
      <data key="d7">Processes high-speed clock-out events.</data>
    </node>
    <node id="6">
      <data key="d5">Aurora PostgreSQL</data>
      <data key="d6">Aurora</data>
      <data key="d7">Encrypted system of record with row-level security.</data>
    </node>
    <node id="7">
      <data key="d5">ElastiCache</data>
      <data key="d6">ElastiCache</data>
      <data key="d7">Caches user entitlements for fast retrieval.</data>
    </node>
    <node id="8">
      <data key="d5">Elasticsearch</data>
      <data key="d6">OpenSearch</data>
      <data key="d7">Powering employee and payroll history searches.</data>
    </node>
    <edge source="0" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">Web requests to API layer.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">Mobile requests to API layer.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="3" id="0">
      <data key="d8">0</data>
      <data key="d9">Forwards API traffic to ELB.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="4" id="0">
      <data key="d8">0</data>
      <data key="d9">Distributes traffic to microservices in EKS.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="5" id="0">
      <data key="d8">1</data>
      <data key="d9">EKS publishes clock-out event to Kafka.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="6" id="0">
      <data key="d8">2</data>
      <data key="d9">Stores transactional payroll data.</data>
      <data key="d10">6</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="7" id="0">
      <data key="d8">3</data>
      <data key="d9">Queries entitlements on login.</data>
      <data key="d10">9</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="4" id="0">
      <data key="d8">1</data>
      <data key="d9">Continuous payroll engine reads event to recalculate.</data>
      <data key="d10">5</data>
      <data key="d11">data</data>
    </edge>
    <edge source="6" target="7" id="0">
      <data key="d8">2</data>
      <data key="d9">Syncs database data to cache.</data>
      <data key="d10">7</data>
      <data key="d11">data</data>
    </edge>
    <edge source="6" target="8" id="0">
      <data key="d8">2</data>
      <data key="d9">Syncs database data to search cluster.</data>
      <data key="d10">8</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">ADP Workforce Now Real-Time Payroll Architecture</data>
    <data key="d1">https://www.youtube.com/watch?v=KiH7hVJKzns</data>
    <data key="d2">Scalable human capital management architecture using EKS microservices and real-time Kafka event streaming to calculate up-to-the-minute payroll.</data>
    <data key="d3">data_ingestion, compute_intensive</data>
    <data key="d4">True</data>
  </graph>
</graphml>
