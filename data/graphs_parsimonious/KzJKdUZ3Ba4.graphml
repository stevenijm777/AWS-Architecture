<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Project Manager</data>
      <data key="d6">UserCompanyAgent</data>
      <data key="d7">Initiates purchase orders within SAP.</data>
    </node>
    <node id="1">
      <data key="d5">Supplier</data>
      <data key="d6">UserCompanyAgent</data>
      <data key="d7">Supply chain participant.</data>
    </node>
    <node id="2">
      <data key="d5">Distributor</data>
      <data key="d6">UserCompanyAgent</data>
      <data key="d7">Supply chain logistics participant.</data>
    </node>
    <node id="3">
      <data key="d5">Utility Company</data>
      <data key="d6">UserCompanyAgent</data>
      <data key="d7">End recipient of physical assets.</data>
    </node>
    <node id="4">
      <data key="d5">SAP ERP</data>
      <data key="d6">SAP</data>
      <data key="d7">Triggers the workflow via API call when a purchase order is created.</data>
    </node>
    <node id="5">
      <data key="d5">Amazon Managed Blockchain</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Runs Hyperledger Fabric 1.2 to store immutable ledger state and run chaincode.</data>
    </node>
    <node id="6">
      <data key="d5">AWS IoT Core</data>
      <data key="d6">IoTCore</data>
      <data key="d7">Ingests physical asset telemetry and triggers blockchain updates based on thresholds.</data>
    </node>
    <edge source="0" target="4" id="0">
      <data key="d8">0</data>
      <data key="d9">PM creates Purchase Order in SAP.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="5" id="0">
      <data key="d8">0</data>
      <data key="d9">API call publishes PO to blockchain.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="6" target="5" id="0">
      <data key="d8">1</data>
      <data key="d9">Publishes sensor telemetry and asset handoffs to the ledger.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="6" target="3" id="0">
      <data key="d8">2</data>
      <data key="d9">Sends real-time alerts or mobile notifications for threshold breaches.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">PwC Blockchain-Powered Material Traceability</data>
    <data key="d1">https://www.youtube.com/watch?v=KzJKdUZ3Ba4</data>
    <data key="d2">Integrates SAP enterprise workflows with Amazon Managed Blockchain and AWS IoT Core to provide end-to-end supply chain transparency.</data>
    <data key="d3">data_ingestion, compute_intensive</data>
    <data key="d4">True</data>
  </graph>
</graphml>
