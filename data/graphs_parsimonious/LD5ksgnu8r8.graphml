<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">PDF Images</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Source of medical claim images and PDFs.</data>
    </node>
    <node id="1">
      <data key="d5">AWS Lambda Data Automation</data>
      <data key="d6">Lambda</data>
      <data key="d7">Automates the ingestion and upload of PDF documents.</data>
    </node>
    <node id="2">
      <data key="d5">Amazon S3</data>
      <data key="d6">S3</data>
      <data key="d7">Stores uploaded claim images.</data>
    </node>
    <node id="3">
      <data key="d5">AWS Lambda Scan and Process</data>
      <data key="d6">Lambda</data>
      <data key="d7">Processes images using AI services and writes results to DynamoDB.</data>
    </node>
    <node id="4">
      <data key="d5">Amazon Textract</data>
      <data key="d6">Textract</data>
      <data key="d7">Extracts text from scanned claims images.</data>
    </node>
    <node id="5">
      <data key="d5">Amazon Comprehend</data>
      <data key="d6">Comprehend</data>
      <data key="d7">Classifies descriptions into medical codes.</data>
    </node>
    <node id="6">
      <data key="d5">Amazon DynamoDB</data>
      <data key="d6">DynamoDB</data>
      <data key="d7">Stores metadata and extracted medical codes.</data>
    </node>
    <node id="7">
      <data key="d5">Amazon API Gateway</data>
      <data key="d6">ApiGateway</data>
      <data key="d7">Exposes APIs for the React review application.</data>
    </node>
    <node id="8">
      <data key="d5">Amazon ECS React App</data>
      <data key="d6">ECS</data>
      <data key="d7">Hosts the stateless React web frontend.</data>
    </node>
    <node id="9">
      <data key="d5">Exception Cases Team</data>
      <data key="d6">UserCompanyAgent</data>
      <data key="d7">Operators who review and correct low-confidence claims.</data>
    </node>
    <node id="10">
      <data key="d5">Legacy Application</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">The target system where processed claims are entered.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">PDF images are sent for ingestion.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">Lambda uploads PDFs to S3 bucket.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="3" id="0">
      <data key="d8">1</data>
      <data key="d9">S3 triggers the processing Lambda function.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="6" id="0">
      <data key="d8">1</data>
      <data key="d9">Lambda writes extracted data to DynamoDB.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="3" id="0">
      <data key="d8">1</data>
      <data key="d9">Lambda sends image to Textract and receives extracted text.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="3" id="0">
      <data key="d8">1</data>
      <data key="d9">Lambda queries Comprehend to classify medical codes.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="6" target="7" id="0">
      <data key="d8">2</data>
      <data key="d9">API Gateway retrieves claim data from DynamoDB.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="8" target="9" id="0">
      <data key="d8">2</data>
      <data key="d9">React frontend is served to the review team.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="9" target="7" id="0">
      <data key="d8">2</data>
      <data key="d9">Reviewers make API requests to load and review claim data.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">DXC Claim Automation Solution</data>
    <data key="d1">https://www.youtube.com/watch?v=LD5ksgnu8r8</data>
    <data key="d2">Serverless claims processing system that uses AI/ML to automate text extraction and medical classification, reducing manual processing time from 4.5 minutes to under 1.5 minutes per claim.</data>
    <data key="d3">data_ingestion, interactive</data>
    <data key="d4">True</data>
  </graph>
</graphml>
