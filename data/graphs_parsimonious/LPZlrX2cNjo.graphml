<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Channels</data>
      <data key="d6">UserConsumerWeb</data>
      <data key="d7">Redbus channels where users submit reviews.</data>
    </node>
    <node id="1">
      <data key="d5">API</data>
      <data key="d6">EC2</data>
      <data key="d7">Handles user feedback ingestion.</data>
    </node>
    <node id="2">
      <data key="d5">Arango DB</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Graph database storing unstructured user reviews and tags.</data>
    </node>
    <node id="3">
      <data key="d5">SageMaker Pipeline</data>
      <data key="d6">SageMaker</data>
      <data key="d7">Runs Managed Training, BYOA (Scikit-Learn/Random Forest), Automatic Model Tuning (HPO), and Batch Transform.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">Users submit reviews.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="2" id="0">
      <data key="d8">1</data>
      <data key="d9">API stores unstructured reviews.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="3" id="0">
      <data key="d8">2</data>
      <data key="d9">SageMaker reads training data and batch inference inputs.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="2" id="0">
      <data key="d8">3</data>
      <data key="d9">Saves generated dynamic tags and model metadata back.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">Redbus ML-powered User Review Tagging with Amazon SageMaker</data>
    <data key="d1">https://www.youtube.com/watch?v=LPZlrX2cNjo</data>
    <data key="d2">Redbus uses Amazon SageMaker to build a machine learning pipeline that automatically classifies and generates tags from unstructured user reviews stored in ArangoDB.</data>
    <data key="d3">data_ingestion, compute_intensive</data>
    <data key="d4">True</data>
  </graph>
