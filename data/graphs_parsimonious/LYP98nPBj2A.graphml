<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Merchants &amp; Mobile Users</data>
      <data key="d6">UserConsumerMobile</data>
      <data key="d7">External consumers initiating mobile top-up transactions.</data>
    </node>
    <node id="1">
      <data key="d5">Singtel Support &amp; Management</data>
      <data key="d6">UserCompanyAgent</data>
      <data key="d7">Internal staff managing application and analyzing performance.</data>
    </node>
    <node id="2">
      <data key="d5">Internet Gateway</data>
      <data key="d6">VPC</data>
      <data key="d7">Handles incoming external public traffic.</data>
    </node>
    <node id="3">
      <data key="d5">Virtual Private Gateway</data>
      <data key="d6">VPC</data>
      <data key="d7">Secures incoming internal company traffic.</data>
    </node>
    <node id="4">
      <data key="d5">Application Load Balancer</data>
      <data key="d6">ALB</data>
      <data key="d7">Distributes traffic and handles web front-end failover.</data>
    </node>
    <node id="5">
      <data key="d5">Web Servers</data>
      <data key="d6">EC2</data>
      <data key="d7">Web front-end servers for user interface.</data>
    </node>
    <node id="6">
      <data key="d5">App Servers</data>
      <data key="d6">EC2</data>
      <data key="d7">Core application logic servers.</data>
    </node>
    <node id="7">
      <data key="d5">Amazon Aurora</data>
      <data key="d6">Aurora</data>
      <data key="d7">Relational database used as the secure system of record.</data>
    </node>
    <edge source="0" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">External transaction requests.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="3" id="0">
      <data key="d8">1</data>
      <data key="d9">Internal management access.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="4" id="0">
      <data key="d8">0</data>
      <data key="d9">Routes external traffic to load balancer.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="4" id="0">
      <data key="d8">1</data>
      <data key="d9">Routes internal traffic to load balancer.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="5" id="0">
      <data key="d8">0</data>
      <data key="d9">ALB directs traffic to the active web instance.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="6" id="0">
      <data key="d8">0</data>
      <data key="d9">Web tier communicates with App tier.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <edge source="6" target="7" id="0">
      <data key="d8">0</data>
      <data key="d9">App tier queries and updates database.</data>
      <data key="d10">5</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">Singtel Electronic Mobile Top-up System</data>
    <data key="d1">https://www.youtube.com/watch?v=LYP98nPBj2A</data>
    <data key="d2">Electronic Mobile Top-up system segregating internal/external traffic via IGW/VGW, using ALB to direct traffic to highly-available multi-tier EC2 stacks, and Aurora as the system of record.</data>
    <data key="d3">compute_intensive, interactive</data>
    <data key="d4">True</data>
  </graph>
