<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Web Browser</data>
      <data key="d6">UserConsumerWeb</data>
      <data key="d7">Students and faculty asking questions via the university website.</data>
    </node>
    <node id="1">
      <data key="d5">Mobile Device</data>
      <data key="d6">UserConsumerMobile</data>
      <data key="d7">Students querying the bot via SMS text messages.</data>
    </node>
    <node id="2">
      <data key="d5">Alexa Speaker</data>
      <data key="d6">UserConsumerAlexaGoogleHome</data>
      <data key="d7">Alexa devices in student residence halls.</data>
    </node>
    <node id="3">
      <data key="d5">Amazon Lex</data>
      <data key="d6">Lex</data>
      <data key="d7">Core bot engine that parses user intent and routes requests.</data>
    </node>
    <node id="4">
      <data key="d5">Amazon DynamoDB</data>
      <data key="d6">DynamoDB</data>
      <data key="d7">Stores default, holiday, and break hours for university buildings.</data>
    </node>
    <node id="5">
      <data key="d5">Food Vendor Database</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">External database containing daily dining schedules and menus.</data>
    </node>
    <node id="6">
      <data key="d5">Partner Database</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Second external partner database integrated with the chatbot.</data>
    </node>
    <node id="7">
      <data key="d5">Amazon SNS</data>
      <data key="d6">SNS</data>
      <data key="d7">Sends real-time email alerts to content owners upon negative user feedback.</data>
    </node>
    <node id="8">
      <data key="d5">Amazon Comprehend</data>
      <data key="d6">Comprehend</data>
      <data key="d7">Hones in on keywords and subjects while filtering out common linking words.</data>
    </node>
    <node id="9">
      <data key="d5">Elasticsearch</data>
      <data key="d6">OpenSearch</data>
      <data key="d7">Provides real-time scoring to evaluate how questions map to configured answers.</data>
    </node>
    <edge source="0" target="3" id="0">
      <data key="d8">0</data>
      <data key="d9">Web query sent to Lex bot.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="3" id="0">
      <data key="d8">0</data>
      <data key="d9">SMS query sent to Lex bot.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="3" id="0">
      <data key="d8">0</data>
      <data key="d9">Alexa voice query sent to Lex bot.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="4" id="0">
      <data key="d8">1</data>
      <data key="d9">Lex retrieves building hours from DynamoDB.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="5" id="0">
      <data key="d8">2</data>
      <data key="d9">Lex fetches menu data from external partner database.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="6" id="0">
      <data key="d8">2</data>
      <data key="d9">Lex queries second external database.</data>
      <data key="d10">5</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="9" id="0">
      <data key="d8">3</data>
      <data key="d9">Lex evaluates question mapping and scoring in Elasticsearch.</data>
      <data key="d10">6</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="8" id="0">
      <data key="d8">4</data>
      <data key="d9">Lex uses Comprehend to analyze user sentiment and extract keywords.</data>
      <data key="d10">7</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="7" id="0">
      <data key="d8">5</data>
      <data key="d9">Lex triggers SNS notification for negative feedback.</data>
      <data key="d10">8</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">St. Louis University Q&amp;A Chatbot</data>
    <data key="d1">https://www.youtube.com/watch?v=LxeSC3-xMlk</data>
    <data key="d2">Multi-channel Q&amp;A chatbot using Amazon Lex to answer student questions, integrated with DynamoDB, OpenSearch, Comprehend, and partner databases.</data>
    <data key="d3">interactive, compute_intensive</data>
    <data key="d4">True</data>
  </graph>
</graphml>
