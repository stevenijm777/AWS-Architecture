  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">IoT Devices</data>
      <data key="d6">UserConsumerIOT</data>
      <data key="d7">On-vehicle sensors capturing GPS, speed, and g-forces.</data>
    </node>
    <node id="1">
      <data key="d5">Ingestion Lambda</data>
      <data key="d6">Lambda</data>
      <data key="d7">DATA_PEEK: Raw telematics streams.</data>
    </node>
    <node id="2">
      <data key="d5">Raw S3 Data Lake</data>
      <data key="d6">S3</data>
      <data key="d7">Stores raw telemetry logs.</data>
    </node>
    <node id="3">
      <data key="d5">SQS Queue</data>
      <data key="d6">SQS</data>
      <data key="d7">WORKLOAD_PEEK: Batches raw records to ensure processing durability and scale.</data>
    </node>
    <node id="4">
      <data key="d5">Enrichment Lambda</data>
      <data key="d6">Lambda</data>
      <data key="d7">Performs rapid lookup against pre-chunked map data.</data>
    </node>
    <node id="5">
      <data key="d5">OpenStreetMap S3 Bucket</data>
      <data key="d6">S3</data>
      <data key="d7">Contains OSM data pre-divided into 1-degree coordinate chunks via Athena.</data>
    </node>
    <node id="6">
      <data key="d5">Kinesis Stream</data>
      <data key="d6">Kinesis</data>
      <data key="d7">Performs sliding window analytics to identify safety violations (speeding, harsh braking).</data>
    </node>
    <node id="7">
      <data key="d5">Enriched Events S3</data>
      <data key="d6">S3</data>
      <data key="d7">Stores detected safety event records.</data>
    </node>
    <node id="8">
      <data key="d5">Athena</data>
      <data key="d6">Athena</data>
      <data key="d7">Runs ad-hoc queries over raw data for summary reports.</data>
    </node>
    <node id="9">
      <data key="d5">AWS Glue</data>
      <data key="d6">Glue</data>
      <data key="d7">Orchestrates extraction of events and raw summary data.</data>
    </node>
    <node id="10">
      <data key="d5">On-Premises Data Center</data>
      <data key="d6">OnPremDC</data>
      <data key="d7">Receives processed telemetry to drive customer dashboards.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">Ingests raw vehicle data.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">Saves raw payload.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="3" id="0">
      <data key="d8">0</data>
      <data key="d9">Batches events.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="8" id="0">
      <data key="d8">2</data>
      <data key="d9">Queries raw telemetry logs.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="4" id="0">
      <data key="d8">1</data>
      <data key="d9">Triggers enrichment function.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="6" id="0">
      <data key="d8">1</data>
      <data key="d9">Streams events for window calculations.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="4" id="0">
      <data key="d8">1</data>
      <data key="d9">Loads map chunk.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="6" target="7" id="0">
      <data key="d8">1</data>
      <data key="d9">Persists detected safety incidents.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="7" target="9" id="0">
      <data key="d8">2</data>
      <data key="d9">Extracts enriched data.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="8" target="9" id="0">
      <data key="d8">2</data>
      <data key="d9">Supplies query results.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="9" target="10" id="0">
      <data key="d8">2</data>
      <data key="d9">Syncs reporting data to on-prem databases.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">LeasePlan: Leverages Serverless to Increase Driver Safety Reduce Fleet Costs and Lower Risk</data>
    <data key="d1">https://www.youtube.com/watch?v=QOtCpD23118</data>
    <data key="d2">OneConnect ingests vehicle telematics data, batches it using SQS, enriches it with OpenStreetMap data via Lambda and Kinesis, and uses Glue to sync telemetry analytics to on-premises reporting systems.</data>
    <data key="d3">data_ingestion,interactive</data>
    <data key="d4">True</data>
  </graph>
</graphml>
