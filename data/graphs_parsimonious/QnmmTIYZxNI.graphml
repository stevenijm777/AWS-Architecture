<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">EKS Cluster</data>
      <data key="d6">EKS</data>
      <data key="d7">WORKLOAD_PEEK: Hosts product workloads inside the reused CIDR block.</data>
    </node>
    <node id="1">
      <data key="d5">EC2 Instances</data>
      <data key="d6">EC2</data>
      <data key="d7">WORKLOAD_PEEK: Runs customer applications alongside EKS in the reused CIDR block.</data>
    </node>
    <node id="2">
      <data key="d5">NGW</data>
      <data key="d6">NAT</data>
      <data key="d7">DATA_PEEK: Translates local EKS/EC2 IPs to enable external and cross-VPC communication.</data>
    </node>
    <node id="3">
      <data key="d5">NLB</data>
      <data key="d6">NLB</data>
      <data key="d7">DATA_PEEK: Handles inbound traffic to the customer VPC application endpoints.</data>
    </node>
    <node id="4">
      <data key="d5">TRANSIT GW</data>
      <data key="d6">TransitGateway</data>
      <data key="d7">WORKLOAD_PEEK: Acts as regional hub routing traffic between VPCs and on-premise networks.</data>
    </node>
    <node id="5">
      <data key="d5">DIRECT CONNECT</data>
      <data key="d6">DirectConnect</data>
      <data key="d7">DATA_PEEK: Hybrid cloud link to on-premise infrastructure.</data>
    </node>
    <node id="6">
      <data key="d5">VPN</data>
      <data key="d6">VPN</data>
      <data key="d7">DATA_PEEK: Secured backup hybrid connectivity.</data>
    </node>
    <node id="7">
      <data key="d5">VPC PRIVATE LINK</data>
      <data key="d6">PrivateLink</data>
      <data key="d7">WORKLOAD_PEEK: Centralizes access to shared services securely across the network.</data>
    </node>
    <edge source="0" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">Outbound traffic from reused subnet routes to NAT Gateway.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="4" id="0">
      <data key="d8">0</data>
      <data key="d9">NAT Gateway forwards traffic out to Transit Gateway.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="5" id="0">
      <data key="d8">1</data>
      <data key="d9">Transit Gateway routes data to on-premise via Direct Connect.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="6" id="0">
      <data key="d8">1</data>
      <data key="d9">Transit Gateway routes backup traffic via VPN.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="7" id="0">
      <data key="d8">1</data>
      <data key="d9">Transit Gateway connects regional VPCs to shared services through Private Link.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">Adobe: Simplifying Networking Across Thousands of AWS Accounts with AWS Transit Gateway LIVE</data>
    <data key="d1">https://www.youtube.com/watch?v=QnmmTIYZxNI</data>
    <data key="d2">Adobe leverages Transit Gateway to handle networking at scale across thousands of AWS accounts, using a dual CIDR block strategy (reused and routed space) to optimize IPv4 addresses.</data>
    <data key="d3">control, other</data>
    <data key="d4">True</data>
  </graph>
</graphml>
