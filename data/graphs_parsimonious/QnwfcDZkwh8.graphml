<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Audience / Voting Channels</data>
      <data key="d6">UserConsumerWebMobile</data>
      <data key="d7">WORKLOAD_PEEK: Voting via SMS, mobile apps, websites, and connected TVs.</data>
    </node>
    <node id="1">
      <data key="d5">AWS WAF</data>
      <data key="d6">WAF</data>
      <data key="d7">Restricts voting to users inside Italy using geographic checks.</data>
    </node>
    <node id="2">
      <data key="d5">Application Load Balancer</data>
      <data key="d6">ALB</data>
      <data key="d7">Handles incoming spiky traffic and routes to frontend containers.</data>
    </node>
    <node id="3">
      <data key="d5">AWS Fargate</data>
      <data key="d6">Fargate</data>
      <data key="d7">WORKLOAD_PEEK: Auto-scaled frontend and backend microservices that handle user auth, session verification, and request processing.</data>
    </node>
    <node id="4">
      <data key="d5">Amazon MemoryDB for Redis</data>
      <data key="d6">MemoryDB</data>
      <data key="d7">DATA_PEEK: Houses active contestants, active sessions, and limits. Executes Lua scripts for atomic vote counting under 10ms.</data>
    </node>
    <node id="5">
      <data key="d5">AWS Site-to-Site VPN</data>
      <data key="d6">VPN</data>
      <data key="d7">Securely tunnels admin/editorial commands from on-premises network.</data>
    </node>
    <node id="6">
      <data key="d5">On-Premises Editorial System</data>
      <data key="d6">OnPremDC</data>
      <data key="d7">Used by editorial teams to manage sessions and read final voting results for the broadcast.</data>
    </node>
    <node id="7">
      <data key="d5">Amazon CloudWatch</data>
      <data key="d6">CloudWatch</data>
      <data key="d7">Aggregates logs and metrics from ALB and Fargate container environments.</data>
    </node>
    <node id="8">
      <data key="d5">Amazon Kinesis Data Firehose</data>
      <data key="d6">Firehose</data>
      <data key="d7">Buffers and streams logs from CloudWatch for persistent archival.</data>
    </node>
    <node id="9">
      <data key="d5">Amazon S3</data>
      <data key="d6">S3</data>
      <data key="d7">Acts as the final long-term storage data lake for vote audit certification.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">1</data>
      <data key="d9">User submits vote.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="2" id="0">
      <data key="d8">1</data>
      <data key="d9">Valid geo-checked traffic passed to ALB.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="3" id="0">
      <data key="d8">1</data>
      <data key="d9">ALB distributes requests to active Fargate containers.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="7" id="0">
      <data key="d8">2</data>
      <data key="d9">ALB logs sent to CloudWatch.</data>
      <data key="d10">0</data>
      <data key="d11">meta</data>
    </edge>
    <edge source="3" target="4" id="0">
      <data key="d8">0</data>
      <data key="d9">Saves session configuration or closes the voting session.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="4" id="1">
      <data key="d8">1</data>
      <data key="d9">Executes Lua scripts in Redis to validate limits and increment counter.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="5" id="0">
      <data key="d8">0</data>
      <data key="d9">Forwards final results back to VPN.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="7" id="0">
      <data key="d8">2</data>
      <data key="d9">Container logs sent to CloudWatch.</data>
      <data key="d10">1</data>
      <data key="d11">meta</data>
    </edge>
    <edge source="4" target="3" id="0">
      <data key="d8">0</data>
      <data key="d9">Returns voting results data.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="3" id="1">
      <data key="d8">1</data>
      <data key="d9">Acks the vote status and updates limits remaining.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="3" id="0">
      <data key="d8">0</data>
      <data key="d9">Fargate admin/backend microservice receives command.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="6" id="0">
      <data key="d8">0</data>
      <data key="d9">Delivers results to on-premise system for host announcements.</data>
      <data key="d10">5</data>
      <data key="d11">data</data>
    </edge>
    <edge source="6" target="5" id="0">
      <data key="d8">0</data>
      <data key="d9">Session configuration or results command transmitted.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="7" target="8" id="0">
      <data key="d8">2</data>
      <data key="d9">Logs streamed continuously.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="8" target="9" id="0">
      <data key="d8">2</data>
      <data key="d9">Persists log batches for compliance auditing.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">Mediaset: Achieving an Omni-Channel Broadcasting Voting System Near Realtime at Scale</data>
    <data key="d1">https://www.youtube.com/watch?v=QnwfcDZkwh8</data>
    <data key="d2">Serverless, low-latency architecture designed to process &gt;5 million votes within 10ms per vote under highly spiky traffic conditions.</data>
    <data key="d3">interactive, data_ingestion</data>
    <data key="d4">True</data>
  </graph>
