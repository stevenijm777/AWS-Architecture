<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Content Creator</data>
      <data key="d6">UserConsumerWebMobile</data>
      <data key="d7">MagellanTV editors who upload documentaries and perform quality checks.</data>
    </node>
    <node id="1">
      <data key="d5">Source Bucket</data>
      <data key="d6">S3</data>
      <data key="d7">Stores raw documentary video and audio files.</data>
    </node>
    <node id="2">
      <data key="d5">Workflow Orchestrator</data>
      <data key="d6">StepFunctions</data>
      <data key="d7">Orchestrates the serverless steps of the translation pipeline.</data>
    </node>
    <node id="3">
      <data key="d5">Amazon Translate</data>
      <data key="d6">Translate</data>
      <data key="d7">Performs initial translation of transcript segments.</data>
    </node>
    <node id="4">
      <data key="d5">Amazon Bedrock</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Executes GenAI-based slang detection, sentence shortening, and cultural validation.</data>
    </node>
    <node id="5">
      <data key="d5">Amazon Polly</data>
      <data key="d6">Polly</data>
      <data key="d7">Converts final translated text into synthesized speech.</data>
    </node>
    <node id="6">
      <data key="d5">Amazon A2I</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Enables human-in-the-loop translation review and validation.</data>
    </node>
    <node id="7">
      <data key="d5">Output Bucket</data>
      <data key="d6">S3</data>
      <data key="d7">Stores finalized video, sound, and closed-caption subtitle files.</data>
    </node>
    <node id="8">
      <data key="d5">AWS CloudFormation</data>
      <data key="d6">CloudFormation</data>
      <data key="d7">Provisions and scales parallel nodes for processing large volume batches.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">Uploads documentaries to the raw ingest bucket.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">Triggers Step Functions pipeline execution.</data>
      <data key="d10">1</data>
      <data key="d11">meta</data>
    </edge>
    <edge source="2" target="3" id="0">
      <data key="d8">0</data>
      <data key="d9">Pushes audio transcript text to Translate.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="4" id="0">
      <data key="d8">0</data>
      <data key="d9">Forwards translated text to Bedrock.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="5" id="0">
      <data key="d8">0</data>
      <data key="d9">Pushes refined, shortened, and culturally-checked script to Polly.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="6" id="0">
      <data key="d8">0</data>
      <data key="d9">Sends synthesized speech audio to A2I validation workflow.</data>
      <data key="d10">5</data>
      <data key="d11">data</data>
    </edge>
    <edge source="6" target="7" id="0">
      <data key="d8">0</data>
      <data key="d9">Saves verified multilingual media files to S3 output.</data>
      <data key="d10">6</data>
      <data key="d11">data</data>
    </edge>
    <edge source="8" target="2" id="0">
      <data key="d8">1</data>
      <data key="d9">Spins up parallel processing nodes.</data>
      <data key="d10">0</data>
      <data key="d11">meta</data>
    </edge>
    <data key="d0">Mission Cloud: Generative AI Video Translation Pipeline with Bedrock</data>
    <data key="d1">https://www.youtube.com/watch?v=UPV6ggX4eSE</data>
    <data key="d2">Mission Cloud built a cost-effective content translation pipeline for MagellanTV. MagellanTV uploads videos to S3, triggering Step Functions to orchestrate a serverless translation and refinement flow. Text is translated via Amazon Translate and processed by Bedrock (slang detection, sentence shortening, and cultural checks). Amazon Polly generates speech audio, which is verified by human editors using Amazon A2I before final assets are stored in S3. CDK and CloudFormation scale the workflow across parallel nodes.</data>
    <data key="d3">data_ingestion, compute_intensive, control</data>
    <data key="d4">True</data>
  </graph>
</graphml>
