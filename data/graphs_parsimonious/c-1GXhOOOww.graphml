  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Web/Mobile Customers &amp; Tenants</data>
      <data key="d6">UserConsumerWeb</data>
      <data key="d7">Accesses onboarding wizards and ticket booking interfaces.</data>
    </node>
    <node id="1">
      <data key="d5">Third-Party OTAs</data>
      <data key="d6">UserConsumerAPI</data>
      <data key="d7">Resellers like Expedia and Viator accessing APIs.</data>
    </node>
    <node id="2">
      <data key="d5">CDN</data>
      <data key="d6">CloudFront</data>
      <data key="d7">Handles static content routing and API request distribution.</data>
    </node>
    <node id="3">
      <data key="d5">S3</data>
      <data key="d6">S3</data>
      <data key="d7">Hosts static website assets, images, and descriptions.</data>
    </node>
    <node id="4">
      <data key="d5">AppSync</data>
      <data key="d6">AppSync</data>
      <data key="d7">GraphQL gateway handling dynamic requests and pipeline/direct resolvers.</data>
    </node>
    <node id="5">
      <data key="d5">API Gateway</data>
      <data key="d6">ApiGateway</data>
      <data key="d7">Exposes REST endpoints for external resellers.</data>
    </node>
    <node id="6">
      <data key="d5">Lambda</data>
      <data key="d6">Lambda</data>
      <data key="d7">WORKLOAD_PEEK: Handles core business logic, fan-out actions, and SQS event processing.</data>
    </node>
    <node id="7">
      <data key="d5">DynamoDB</data>
      <data key="d6">DynamoDB</data>
      <data key="d7">DATA_PEEK: Shared multi-tenant database partitioned by tenant ID.</data>
    </node>
    <node id="8">
      <data key="d5">SQS</data>
      <data key="d6">SQS</data>
      <data key="d7">Queues tasks such as email follow-ups and background onboarding processes.</data>
    </node>
