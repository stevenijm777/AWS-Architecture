<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Developer</data>
      <data key="d6">UserCompanyDeveloper</data>
      <data key="d7">Pushes code and manifest to S3 via Git CI/CD.</data>
    </node>
    <node id="1">
      <data key="d5">S3 Manifest Store</data>
      <data key="d6">S3</data>
      <data key="d7">WORKLOAD_PEEK: Stores the dynamic application manifest describing resources.</data>
    </node>
    <node id="2">
      <data key="d5">Global SNS</data>
      <data key="d6">SNS</data>
      <data key="d7">Fans out deployment events to multiple AWS regions globally.</data>
    </node>
    <node id="3">
      <data key="d5">Deployment Lambda</data>
      <data key="d6">Lambda</data>
      <data key="d7">Transforms manifest to CloudFormation and queues remaining tasks.</data>
    </node>
    <node id="4">
      <data key="d5">CloudFormation</data>
      <data key="d6">CloudFormation</data>
      <data key="d7">Dynamically provisions regional roles and resources.</data>
    </node>
    <node id="5">
      <data key="d5">Deployment Queue</data>
      <data key="d6">SQS</data>
      <data key="d7">Provides fault tolerance and retry capability for deployment steps.</data>
    </node>
    <node id="6">
      <data key="d5">Amazon EKS</data>
      <data key="d6">EKS</data>
      <data key="d7">Final compute destination for deployed applications.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">Developer pushes commit and persists application manifest to S3.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">S3 triggers global fan-out event via SNS.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="3" id="0">
      <data key="d8">0</data>
      <data key="d9">Regional Lambda functions subscribe to SNS deploy events.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="4" id="0">
      <data key="d8">0</data>
      <data key="d9">Lambda dynamically provisions infrastructure via CloudFormation.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="5" id="0">
      <data key="d8">0</data>
      <data key="d9">Queues additional runtime deployment tasks.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="6" id="0">
      <data key="d8">0</data>
      <data key="d9">Applies configurations to complete deployment inside EKS cluster.</data>
      <data key="d10">5</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">Instructure: Elevating Digital Education to the Next-Level Event Driven CI/CD Deployments Globally</data>
    <data key="d1">https://www.youtube.com/watch?v=fppIOuRMI2g</data>
    <data key="d2">Automated pipeline enabling developers to deploy applications globally across multiple AWS regions using dynamic manifests transformed into CloudFormation templates.</data>
    <data key="d3">compute_intensive,control</data>
    <data key="d4">True</data>
  </graph>
</graphml>
