<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Data Scientist (DS)</data>
      <data key="d6">UserCompanyDeveloper</data>
      <data key="d7">Prepares Jupyter notebooks, logs into SageMaker Studio, and initiates processing jobs.</data>
    </node>
    <node id="1">
      <data key="d5">Amazon RDS</data>
      <data key="d6">RDS</data>
      <data key="d7">WORKLOAD_PEEK: Core database hosting relational transactional data.</data>
    </node>
    <node id="2">
      <data key="d5">AWS Glue</data>
      <data key="d6">Glue</data>
      <data key="d7">WORKLOAD_PEEK: PySpark jobs that ingest, anonymize, and synthesize data from RDS, BigQuery, and Kinesis.</data>
    </node>
    <node id="3">
      <data key="d5">Amazon S3</data>
      <data key="d6">S3</data>
      <data key="d7">DATA_PEEK: Core data lake keeping domain-specific data marts ACID-compliant using Apache Hudi.</data>
    </node>
    <node id="4">
      <data key="d5">Amazon SageMaker</data>
      <data key="d6">SageMaker</data>
      <data key="d7">Runs SageMaker Studio and transient processing jobs inside a private VPC.</data>
    </node>
    <node id="5">
      <data key="d5">AWS IAM</data>
      <data key="d6">IAM</data>
      <data key="d7">Enforces workspace isolation using distinct execution roles for different data science groups (e.g. customer vs. application data).</data>
    </node>
    <node id="6">
      <data key="d5">AWS Lambda</data>
      <data key="d6">Lambda</data>
      <data key="d7">Triggers ECR to pull custom container libraries and injects parameters into notebooks dynamically using PaperMill.</data>
    </node>
    <edge source="0" target="4" id="0">
      <data key="d8">1</data>
      <data key="d9">DS submits notebook job configuration to SageMaker Studio.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">Transactional data ingested into Glue processing pipeline.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="3" id="0">
      <data key="d8">0</data>
      <data key="d9">Glue transforms and saves synthesized data into S3.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="5" id="0">
      <data key="d8">1</data>
      <data key="d9">Checks IAM permissions and applies user-group execution policies.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="6" id="0">
      <data key="d8">1</data>
      <data key="d9">SageMaker invokes Lambda to prepare and trigger the containerized processing job.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="3" id="0">
      <data key="d8">1</data>
      <data key="d9">Processing job executes and saves output directly to the S3 data lake.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">FPL Technologies Serverless ML Workbench</data>
    <data key="d1">https://www.youtube.com/watch?v=gu54VVeDD10</data>
    <data key="d2">An on-demand, serverless, and secure ML workbench for data scientists. Uses SageMaker processing jobs to replace static notebooks, isolating workspaces with IAM and automating pipeline execution with Lambda.</data>
    <data key="d3">data_ingestion, compute_intensive</data>
    <data key="d4">True</data>
  </graph>
</graphml>
