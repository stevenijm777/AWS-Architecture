  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">SQL Server</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Transactional on-premises database farm.</data>
    </node>
    <node id="1">
      <data key="d5">AWS DMS</data>
      <data key="d6">DMS</data>
      <data key="d7">Migrates transactional inserts, updates, and deletes to S3.</data>
    </node>
    <node id="2">
      <data key="d5">Landing Bucket</data>
      <data key="d6">S3</data>
      <data key="d7">Stores raw transaction files in Parquet format.</data>
    </node>
    <node id="3">
      <data key="d5">SQS Queues</data>
      <data key="d6">SQS</data>
      <data key="d7">Three queues categorized by latency requirements to capture S3 events.</data>
    </node>
    <node id="4">
      <data key="d5">Amazon EventBridge</data>
      <data key="d6">EventBridge</data>
      <data key="d7">Triggers workflows on 10-minute, 60-minute, and 3-hour schedules.</data>
    </node>
    <node id="5">
      <data key="d5">AWS Step Functions</data>
      <data key="d6">StepFunctions</data>
      <data key="d7">Orchestrates AWS Glue jobs native integration.</data>
    </node>
    <node id="6">
      <data key="d5">AWS Glue</data>
      <data key="d6">Glue</data>
      <data key="d7">Serverless ETL process replacing EMR to perform upserts.</data>
    </node>
    <node id="7">
      <data key="d5">Delta Lake</data>
      <data key="d6">S3</data>
      <data key="d7">Consists of Bronze, Silver, and Gold tiers for reliable querying.</data>
    </node>
    <node id="8">
      <data key="d5">Data Scientists</data>
      <data key="d6">UserCompanyAnalyst</data>
      <data key="d7">Queries the S3 Delta Lake stages using PySpark SQL.</data>
    </node>
    <edge source="0" target="1">
      <data key="d8">0</data>
      <data key="d9">Replicates transactional source tables.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="1" target="2">
      <data key="d8">0</data>
      <data key="d9">Writes raw updates to S3 Landing.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="2" target="3">
      <data key="d8">0</data>
      <data key="d9">Triggers S3 Event Notifications.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="3" target="6">
      <data key="d8">1</data>
      <data key="d9">Glue reads S3 file locations from SQS.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="4" target="5">
      <data key="d8">1</data>
      <data key="d9">Invokes Step Functions on defined schedules.</data>
      <data key="d10">0</data>
      <data key="d11">meta</data>
      <data key="d12">0</data>
    </edge>
    <edge source="5" target="6">
      <data key="d8">1</data>
      <data key="d9">Orchestrates Glue extraction jobs.</data>
      <data key="d10">1</data>
      <data key="d11">meta</data>
      <data key="d12">0</data>
    </edge>
    <edge source="6" target="7">
      <data key="d8">1</data>
      <data key="d9">Writes upserts and updates to the Delta Lake.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="8" target="7">
      <data key="d8">2</data>
      <data key="d9">Queries stages using PySpark SQL for ML features.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <data key="d0">TrueBlue: Scaling Job Matching with a Serverless Delta Lake</data>
    <data key="d1">https://www.youtube.com/watch?v=iKYvG5aiIn8</data>
    <data key="d2">Transitioned from long-running EMR clusters to a serverless AWS Glue and Step Functions architecture. Achieved near real-time updates for blue-collar job matching across North America.</data>
    <data key="d3">data_ingestion, compute_intensive</data>
    <data key="d4">True</data>
  </graph>
