  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">SQL Server</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">On-premises transactional databases.</data>
    </node>
    <node id="1">
      <data key="d5">AWS DMS</data>
      <data key="d6">DMS</data>
      <data key="d7">Replicates transactional databases to S3.</data>
    </node>
    <node id="2">
      <data key="d5">Landing S3</data>
      <data key="d6">S3</data>
      <data key="d7">S3 landing bucket for raw transactional Parquet files.</data>
    </node>
    <node id="3">
      <data key="d5">Amazon SQS</data>
      <data key="d6">SQS</data>
      <data key="d7">Buffers S3 event notifications categorized by latency.</data>
    </node>
    <node id="4">
      <data key="d5">Amazon EventBridge</data>
      <data key="d6">EventBridge</data>
      <data key="d7">Triggers step functions based on scheduled latency rules.</data>
    </node>
    <node id="5">
      <data key="d5">AWS Step Functions</data>
      <data key="d6">StepFunctions</data>
      <data key="d7">Orchestrates AWS Glue workflows.</data>
    </node>
    <node id="6">
      <data key="d5">AWS Glue</data>
      <data key="d6">Glue</data>
      <data key="d7">Serverless ETL jobs processing and writing updates to Delta Lake.</data>
    </node>
    <node id="7">
      <data key="d5">Delta Lake S3</data>
      <data key="d6">S3</data>
      <data key="d7">Three-tiered (bronze, silver, gold) Delta Lake storage.</data>
    </node>
    <node id="8">
      <data key="d5">Data Scientist</data>
      <data key="d6">UserCompanyAnalyst</data>
      <data key="d7">Data scientists querying Delta Lake tables via PySpark SQL.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">Replicates source data.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="2" id="0">
