<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Players</data>
      <data key="d6">UserConsumerWeb</data>
      <data key="d7">Players of League of Legends and other titles, interacting with the game client and API from around the world.</data>
    </node>
    <node id="1">
      <data key="d5">Game Client API</data>
      <data key="d6">EKS</data>
      <data key="d7">Elastic Kubernetes Service running the game client API. Receives player experience data from game clients and game servers. Supports millions of players across 20+ global shards.</data>
    </node>
    <node id="2">
      <data key="d5">Game Servers / On-prem Kafka</data>
      <data key="d6">OnPremDC</data>
      <data key="d7">On-premise game servers located in global data centers. These servers host local Kafka clusters to buffer game data and send game client/server data to the EKS API. Uses MirrorMaker to replicate buffered data to regional AWS MSK clusters.</data>
    </node>
    <node id="3">
      <data key="d5">Regional MSK Buffer</data>
      <data key="d6">MSK</data>
      <data key="d7">Managed Streaming for Kafka, acting as a regional buffer (across 5 regions) for incoming game data. Ingests data from the EKS API and replicated data from on-prem Kafka clusters. Prepares data for processing, handling peaks of over 500,000 events per second and 8 TB of data per day.</data>
    </node>
    <node id="4">
      <data key="d5">Delta Lake Data Lake</data>
      <data key="d6">S3</data>
      <data key="d7">Amazon S3 storing the processed game data in a Delta Lake format. Serves as the primary data lake for all subsequent analysis and insights.</data>
    </node>
    <node id="5">
      <data key="d5">Glue Metastore</data>
      <data key="d6">Glue</data>
      <data key="d7">AWS Glue Data Catalog acting as the metastore for the Delta Lake in S3. Provides information about logical tables, their locations in S3, and functions as the permission and access layer for data consumers.</data>
    </node>
    <node id="6">
      <data key="d5">Data Consumers (Analysts/Executives)</data>
      <data key="d6">UserCompanyAnalyst</data>
      <data key="d7">Analysts and executives running queries against the game data via Glue to gain insights into gameplay, champion changes, patch effects, and player engagement, with reduced insight time from 6-24 hours to 5 minutes.</data>
    </node>
    <node id="7">
      <data key="d5">Data Consumers (Designers/Engineers)</data>
      <data key="d6">UserCompanyDeveloper</data>
      <data key="d7">Designers and engineers running queries against the game data via Glue for development and game balancing purposes.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">Players interact with the game client which talks to the API running in EKS.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="3" id="0">
      <data key="d8">3</data>
      <data key="d9">Game data and player experience information flows from the EKS API into the regional MSK buffer.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="1" id="0">
      <data key="d8">1</data>
      <data key="d9">Game servers and game clients send player experience information to the EKS API.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="3" id="0">
      <data key="d8">2</data>
      <data key="d9">Data buffered in local Kafka clusters on-prem is replicated to regional MSK clusters using MirrorMaker to handle network congestion.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="4" id="0">
      <data key="d8">4</data>
      <data key="d9">A Spark streaming job processes data from MSK and writes it out to the Delta Lake in S3.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="4" id="0">
      <data key="d8">5</data>
      <data key="d9">Glue provides metadata and access control for the Delta Lake files stored in S3.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="6" target="5" id="0">
      <data key="d8">6</data>
      <data key="d9">Analysts and executives use Glue to discover, access, and query the game data.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="7" target="5" id="0">
      <data key="d8">7</data>
      <data key="d9">Designers and engineers use Glue to discover, access, and query the game data for their needs.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">Riot Games - Honno over IP: League of Legends Data Ingest System</data>
    <data key="d1">https://www.youtube.com/watch?v=iwZLadQ3XpY</data>
    <data key="d2">Riot Games' hybrid architecture for ingesting League of Legends game data. It processes millions of players' data globally across 20+ shards, handling 8 terabytes of data daily and peaking at over 500,000 events per second. The system provides near real-time insights (down to 5 minutes) on gameplay and player engagement.</data>
    <data key="d3">data_ingestion, compute_intensive, interactive</data>
    <data key="d4">True</data>
  </graph>
</graphml>
