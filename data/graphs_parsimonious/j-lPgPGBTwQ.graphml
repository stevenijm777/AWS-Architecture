<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Cattle Collar Devices</data>
      <data key="d6">UserConsumerIOT</data>
      <data key="d7">Solar-powered, GPS-enabled collars sending telemetry over WiFi or LoRa.</data>
    </node>
    <node id="1">
      <data key="d5">IoT Core</data>
      <data key="d6">IoTCore</data>
      <data key="d7">Ingests high-throughput collar data over WiFi using MQTT.</data>
    </node>
    <node id="2">
      <data key="d5">LoRa Base Station Server</data>
      <data key="d6">EC2</data>
      <data key="d7">EC2 instance running third-party software to handle LoRa base station traffic.</data>
    </node>
    <node id="3">
      <data key="d5">Raw Kinesis Stream</data>
      <data key="d6">KinesisDataStream</data>
      <data key="d7">Aggregates duplicate, binary formatted telemetry from both ingestion paths.</data>
    </node>
    <node id="4">
      <data key="d5">Deduplication &amp; Decoding Lambda</data>
      <data key="d6">Lambda</data>
      <data key="d7">Decodes binary payloads to JSON and removes duplicate telemetry entries.</data>
    </node>
    <node id="5">
      <data key="d5">Processed Kinesis Stream</data>
      <data key="d6">KinesisDataStream</data>
      <data key="d7">Main processed JSON stream consumed by multiple downstream services.</data>
    </node>
    <node id="6">
      <data key="d5">Kinesis Analytics</data>
      <data key="d6">KinesisAnalytics</data>
      <data key="d7">Runs Apache Flink to aggregate location data and add geo-indices.</data>
    </node>
    <node id="7">
      <data key="d5">S3 Data Lake</data>
      <data key="d6">S3</data>
      <data key="d7">Stores partitioned location data using farm ID and date as keys.</data>
    </node>
    <node id="8">
      <data key="d5">Athena</data>
      <data key="d6">Athena</data>
      <data key="d7">Queries historical location data in S3 to perform MapReduce aggregations.</data>
    </node>
    <node id="9">
      <data key="d5">ECS Fargate</data>
      <data key="d6">ECS</data>
      <data key="d7">Backend API service that orchestrates query initiation and fetches results.</data>
    </node>
    <node id="10">
      <data key="d5">Farmer Mobile App</data>
      <data key="d6">UserConsumerFarmer</data>
      <data key="d7">End-user interface used by farmers to view cow location heatmaps.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">Collar transmits data via WiFi MQTT</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="0" target="2" id="0">
      <data key="d8">1</data>
      <data key="d9">Collar transmits data over long-range LoRa</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="3" id="0">
      <data key="d8">0</data>
      <data key="d9">Streams raw WiFi payloads</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="3" id="0">
      <data key="d8">1</data>
      <data key="d9">Streams raw LoRa payloads</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="4" id="0">
      <data key="d8">2</data>
      <data key="d9">Lambda pulls binary data</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="5" id="0">
      <data key="d8">2</data>
      <data key="d9">Lambda writes decoded JSON</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="6" id="0">
      <data key="d8">2</data>
      <data key="d9">Kinesis Analytics reads processed streams</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="6" target="7" id="0">
      <data key="d8">2</data>
      <data key="d9">Saves aggregated records to S3 partition</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="9" target="8" id="0">
      <data key="d8">3</data>
      <data key="d9">ECS Fargate triggers Athena MapReduce query</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="9" target="7" id="0">
      <data key="d8">3</data>
      <data key="d9">ECS Fargate retrieves final results from S3</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="10" target="9" id="0">
      <data key="d8">3</data>
      <data key="d9">Farmer requests location heatmap report</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">Halter IoT Cattle Tracking and Pasture Management Architecture</data>
    <data key="d1">https://www.youtube.com/watch?v=j-lPgPGBTwQ</data>
    <data key="d2">IoT telemetry pipeline ingesting WiFi and LoRa cattle collar data, processing it through Kinesis and Lambda, and serving spatial analytics to farmers via ECS and Athena.</data>
    <data key="d3">data_ingestion, compute_intensive, interactive</data>
    <data key="d4">True</data>
  </graph>
</graphml>
