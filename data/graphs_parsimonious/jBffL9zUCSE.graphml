<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Developer</data>
      <data key="d6">UserCompanyDeveloper</data>
      <data key="d7">WORKLOAD_PEEK: Pushes container images to ECR accounts.</data>
    </node>
    <node id="1">
      <data key="d5">Elastic Container Registry</data>
      <data key="d6">ECR</data>
      <data key="d7">Hosts application docker images inside individual team accounts.</data>
    </node>
    <node id="2">
      <data key="d5">Amazon RDS</data>
      <data key="d6">RDS</data>
      <data key="d7">Relational database used by engineering teams inside their vended accounts.</data>
    </node>
    <node id="3">
      <data key="d5">Amazon S3</data>
      <data key="d6">S3</data>
      <data key="d7">Object storage inside team accounts, governed by SCPs to prevent public access.</data>
    </node>
    <node id="4">
      <data key="d5">AWS Control Tower</data>
      <data key="d6">ControlTower</data>
      <data key="d7">Responsible for vending accounts and applying Guardrails/SCPs.</data>
    </node>
    <node id="5">
      <data key="d5">Amazon EKS</data>
      <data key="d6">EKS</data>
      <data key="d7">WORKLOAD_PEEK: Central runtime environment hosting Kubernetes clusters.</data>
    </node>
    <node id="6">
      <data key="d5">AWS Transit Gateway</data>
      <data key="d6">TransitGateway</data>
      <data key="d7">Routes traffic securely from EKS back to resources in vended accounts.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">Developer pushes container images.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="5" id="0">
      <data key="d8">0</data>
      <data key="d9">Images are deployed to Kubernetes clusters.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="3" id="0">
      <data key="d8">1</data>
      <data key="d9">Control Tower provisions accounts with security guardrails applied.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="6" id="0">
      <data key="d8">0</data>
      <data key="d9">EKS sends outbound traffic via Transit Gateway.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="6" target="3" id="0">
      <data key="d8">0</data>
      <data key="d9">Transit Gateway routes traffic to internal resources like S3.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">The New York Times: Standardizing Multi-Account Governance with Control Tower</data>
    <data key="d1">https://www.youtube.com/watch?v=jBffL9zUCSE</data>
    <data key="d2">The New York Times standardizes and secures multi-account deployment using AWS Control Tower and Transit Gateway to isolate environments while ensuring secure, governed communication.</data>
    <data key="d3">control, compute_intensive</data>
    <data key="d4">True</data>
  </graph>
</graphml>
