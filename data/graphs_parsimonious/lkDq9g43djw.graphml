<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Route 53</data>
      <data key="d6">Route53</data>
      <data key="d7">WORKLOAD_PEEK: Handles 10 million requests a day. Routes traffic dynamically away from any inactive Availability Zones.</data>
    </node>
    <node id="1">
      <data key="d5">NLB</data>
      <data key="d6">NLB</data>
      <data key="d7">Network Load Balancer routing traffic to the active compute instances across AZs.</data>
    </node>
    <node id="2">
      <data key="d5">EKS (AZ 1)</data>
      <data key="d6">EKS</data>
      <data key="d7">WORKLOAD_PEEK: EKS cluster orchestrating containerized workloads in Availability Zone 1. Uses Karpenter for autoscaling.</data>
    </node>
    <node id="3">
      <data key="d5">EC2 (AZ 1)</data>
      <data key="d6">EC2</data>
      <data key="d7">WORKLOAD_PEEK: Spot and On-Demand instances running workloads managed by EKS in AZ 1.</data>
    </node>
    <node id="4">
      <data key="d5">EC2 (AZ 2)</data>
      <data key="d6">EC2</data>
      <data key="d7">WORKLOAD_PEEK: Spot and On-Demand instances running workloads managed by EKS in AZ 2.</data>
    </node>
    <node id="5">
      <data key="d5">EKS (AZ 2)</data>
      <data key="d6">EKS</data>
      <data key="d7">WORKLOAD_PEEK: EKS cluster orchestrating containerized workloads in Availability Zone 2. Uses Karpenter for autoscaling.</data>
    </node>
    <node id="6">
      <data key="d5">Aurora</data>
      <data key="d6">Aurora</data>
      <data key="d7">DATA_PEEK: Handles 3,000 requests per second. Replicates across multiple AZs and regions to support chaos engineering resilience goals.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">Routes daily traffic of 10M requests to the load balancer.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">Distributes requests to compute tier in AZ 1.</data>
      <data key="d10">2a</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="5" id="0">
      <data key="d8">0</data>
      <data key="d9">Distributes requests to compute tier in AZ 2.</data>
      <data key="d10">2b</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="6" id="0">
      <data key="d8">0</data>
      <data key="d9">Sends database queries to Aurora at 3,000 requests per second.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">FINBOURNE Resilient and Elastic SaaS Financial Data Management</data>
    <data key="d1">https://www.youtube.com/watch?v=lkDq9g43djw</data>
    <data key="d2">FINBOURNE built an active-active resilient architecture on AWS using EKS and Aurora. It processes 10 million requests daily and manages database loads of 3,000 requests per second. Using Karpenter for EKS, they leverage both Spot and On-Demand instances, saving 30% of costs while maintaining high availability.</data>
    <data key="d3">compute_intensive, interactive</data>
    <data key="d4">True</data>
  </graph>
</graphml>
