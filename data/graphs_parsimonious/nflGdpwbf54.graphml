  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Chemists / Scientists</data>
      <data key="d6">UserCompanyDomainExpert</data>
      <data key="d7">Submits molecule search request and downloads results.</data>
    </node>
    <node id="1">
      <data key="d5">API Gateway</data>
      <data key="d6">ApiGateway</data>
      <data key="d7">Ingests HTTPS POST request with search parameters.</data>
    </node>
    <node id="2">
      <data key="d5">AWS Lambda</data>
      <data key="d6">Lambda</data>
      <data key="d7">Enriches queries and launches the on-demand ECS environment.</data>
    </node>
    <node id="3">
      <data key="d5">Relational Database</data>
      <data key="d6">RDS</data>
      <data key="d7">Stores metadata used to enrich search parameters.</data>
    </node>
    <node id="4">
      <data key="d5">Amazon MQ</data>
      <data key="d6">AmazonMQ</data>
      <data key="d7">RabbitMQ broker coordinating orchestrator and worker tasks.</data>
    </node>
    <node id="5">
      <data key="d5">Amazon ECS</data>
      <data key="d6">ECS</data>
      <data key="d7">Runs the orchestrator task to manage the search lifecycle.</data>
    </node>
    <node id="6">
      <data key="d5">AWS Fargate</data>
      <data key="d6">Fargate</data>
      <data key="d7">Runs search worker tasks utilizing Spot instances for cost efficiency.</data>
    </node>
    <node id="7">
      <data key="d5">Amazon S3</data>
      <data key="d6">S3</data>
      <data key="d7">Stores final search results.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">1</data>
      <data key="d9">Submits search parameters payload</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="2" id="0">
      <data key="d8">1</data>
      <data key="d9">Triggers Lambda function</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="3" id="0">
      <data key="d8">1</data>
      <data key="d9">Queries parameters metadata</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="5" id="0">
      <data key="d8">1</data>
      <data key="d9">Spins up orchestrator task on ECS</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="6" id="0">
      <data key="d8">2</data>
      <data key="d9">Workers consume tasks</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="5" id="0">
      <data key="d8">2</data>
      <data key="d9">Orchestrator reads updates to optimize search</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="4" id="0">
      <data key="d8">2</data>
      <data key="d9">Publishes search sub-tasks</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="6" target="4" id="0">
      <data key="d8">2</data>
      <data key="d9">Workers send execution updates</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="6" target="7" id="0">
      <data key="d8">3</data>
      <data key="d9">Writes final search results</data>
