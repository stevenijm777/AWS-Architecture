  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Engineers</data>
      <data key="d6">UserCompanyDeveloper</data>
      <data key="d7">Pushes code changes and opens pull requests.</data>
    </node>
    <node id="1">
      <data key="d5">GitHub</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Hosts application code and triggers CI/CD workflows.</data>
    </node>
    <node id="2">
      <data key="d5">Amazon EKS (CI/CD)</data>
      <data key="d6">EKS</data>
      <data key="d7">Runs Tekton pipelines, SonarQube, HashiCorp Vault, and Buildah for image assembly.</data>
    </node>
    <node id="3">
      <data key="d5">Amazon ECR</data>
      <data key="d6">ECR</data>
      <data key="d7">Stores signed application container images.</data>
    </node>
    <node id="4">
      <data key="d5">IAM Role</data>
      <data key="d6">IAM</data>
      <data key="d7">Enables cross-account access and promotion of ECR images.</data>
    </node>
    <node id="5">
      <data key="d5">AWS Control Tower</data>
      <data key="d6">ControlTower</data>
      <data key="d7">Provisions and governs multiple segregated AWS accounts.</data>
    </node>
    <node id="6">
      <data key="d5">Amazon EKS (Target Environments)</data>
      <data key="d6">EKS</data>
      <data key="d7">Hosts ephemeral, dev, and production application workloads.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">Pushes code.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">Triggers Tekton CI/CD pipeline.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="3" id="0">
      <data key="d8">0</data>
      <data key="d9">Pushes built container images.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="4" id="0">
      <data key="d8">0</data>
      <data key="d9">Authorizes cross-account image promotion.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="6" id="0">
      <data key="d8">0</data>
      <data key="d9">Deploys images to target EKS clusters.</data>
      <data key="d10">5</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="6" id="0">
      <data key="d8">1</data>
      <data key="d9">Provisions consistent target environments.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">SwiftX Secure Multi-Account CI/CD Pipeline</data>
    <data key="d1">https://www.youtube.com/watch?v=npQWtmnuM6s</data>
    <data key="d2">An automated and secure CI/CD and deployment pipeline across multiple AWS accounts managed by AWS Control Tower, targeting EKS clusters.</data>
    <data key="d3">control</data>
    <data key="d4">True</data>
  </graph>
