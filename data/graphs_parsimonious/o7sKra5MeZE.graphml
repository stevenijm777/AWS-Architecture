<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Verana</data>
      <data key="d6">UserCompanyAgent</data>
      <data key="d7">Internal team ingesting and uploading healthcare datasets.</data>
    </node>
    <node id="1">
      <data key="d5">Amazon S3 Bucket</data>
      <data key="d6">S3</data>
      <data key="d7">Stores raw and curated QData modules.</data>
    </node>
    <node id="2">
      <data key="d5">Amazon MWAA</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Airflow orchestrator managing the ingestion and validation pipeline steps.</data>
    </node>
    <node id="3">
      <data key="d5">Staging Table</data>
      <data key="d6">RedShift</data>
      <data key="d7">Temporary staging area in Redshift Serverless for incoming data.</data>
    </node>
    <node id="4">
      <data key="d5">Validation Table</data>
      <data key="d6">RedShift</data>
      <data key="d7">Performs schema, column data type, and primary/foreign key validation checks.</data>
    </node>
    <node id="5">
      <data key="d5">Production Table</data>
      <data key="d6">RedShift</data>
      <data key="d7">Stores curated, validated production data ready for sharing.</data>
    </node>
    <node id="6">
      <data key="d5">Amazon Redshift</data>
      <data key="d6">RedShift</data>
      <data key="d7">Serverless data warehouse running validations and hosting shared data.</data>
    </node>
    <node id="7">
      <data key="d5">AWS Data Exchange</data>
      <data key="d6">DataExchange</data>
      <data key="d7">Single pane of glass for customer subscriptions and documentation updates.</data>
    </node>
    <node id="8">
      <data key="d5">Amazon Redshift Data Share</data>
      <data key="d6">RedShift</data>
      <data key="d7">Enables instant, copy-free sharing of Redshift tables to customers.</data>
    </node>
    <node id="9">
      <data key="d5">Customer</data>
      <data key="d6">UserConsumerWeb</data>
      <data key="d7">Subscribes to and consumes data directly via their Redshift instance.</data>
    </node>
    <node id="10">
      <data key="d5">Slack</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Receives alert notifications if validation checks fail.</data>
    </node>
    <node id="11">
      <data key="d5">Data Engineering Team</data>
      <data key="d6">UserCompanyDeveloper</data>
      <data key="d7">Triages pipeline alerts, fixes data issues, and restarts MWAA pipeline.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">1</data>
      <data key="d9">Verana uploads ingested patient data.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="1" id="0">
      <data key="d8">2</data>
      <data key="d9">MWAA triggers data copy from S3.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="3" id="0">
      <data key="d8">2</data>
      <data key="d9">MWAA copies data into Redshift Staging.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="4" id="0">
      <data key="d8">2</data>
      <data key="d9">MWAA initiates validation step.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="4" id="0">
      <data key="d8">3</data>
      <data key="d9">Validation table reads and validates staging data.</data>
      <data key="d10">5</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="5" id="0">
      <data key="d8">3</data>
      <data key="d9">Promotes validated data to production table.</data>
      <data key="d10">6</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="10" id="0">
      <data key="d8">4</data>
      <data key="d9">Slack alert triggered on validation failure.</data>
      <data key="d10">7a</data>
      <data key="d11">data</data>
    </edge>
    <edge source="6" target="7" id="0">
      <data key="d8">5</data>
      <data key="d9">Redshift data registered and cataloged on Data Exchange.</data>
      <data key="d10">8</data>
      <data key="d11">data</data>
    </edge>
    <edge source="7" target="8" id="0">
      <data key="d8">5</data>
      <data key="d9">Data Exchange establishes Redshift Data Share.</data>
      <data key="d10">9</data>
      <data key="d11">data</data>
    </edge>
    <edge source="8" target="9" id="0">
      <data key="d8">5</data>
      <data key="d9">Customers query shared data directly.</data>
      <data key="d10">10</data>
      <data key="d11">data</data>
    </edge>
    <edge source="10" target="11" id="0">
      <data key="d8">4</data>
      <data key="d9">Engineers notified of validation failure.</data>
      <data key="d10">7b</data>
      <data key="d11">data</data>
    </edge>
    <edge source="11" target="2" id="0">
      <data key="d8">4</data>
      <data key="d9">Data engineer restarts the pipeline after fixing data.</data>
      <data key="d10">7c</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">Verana Health Automated Clinical Data Curation Pipeline</data>
    <data key="d1">https://www.youtube.com/watch?v=o7sKra5MeZE</data>
    <data key="d2">Automated data validation and curation pipeline using MWAA, Redshift Serverless, and AWS Data Exchange for seamless customer data sharing.</data>
    <data key="d3">data_ingestion, compute_intensive</data>
    <data key="d4">True</data>
  </graph>
</graphml>
