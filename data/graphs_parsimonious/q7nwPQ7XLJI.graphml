  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Batch User</data>
      <data key="d6">UserConsumerWeb</data>
      <data key="d7">End user uploading claim files via web portal.</data>
    </node>
    <node id="1">
      <data key="d5">Amazon CloudFront</data>
      <data key="d6">CloudFront</data>
      <data key="d7">Serves the Web UI content.</data>
    </node>
    <node id="2">
      <data key="d5">AWS WAF</data>
      <data key="d6">WAF</data>
      <data key="d7">Secures the Web UI against web exploits.</data>
    </node>
    <node id="3">
      <data key="d5">Amazon S3</data>
      <data key="d6">S3</data>
      <data key="d7">Stores uploaded batch claims files.</data>
    </node>
    <node id="4">
      <data key="d5">AWS Step Functions</data>
      <data key="d6">StepFunctions</data>
      <data key="d7">Orchestrates batch claims processing.</data>
    </node>
    <node id="5">
      <data key="d5">AWS Fargate</data>
      <data key="d6">Fargate</data>
      <data key="d7">Runs the ML model in container tasks for batch analysis.</data>
    </node>
    <node id="6">
      <data key="d5">Amazon SES</data>
      <data key="d6">SES</data>
      <data key="d7">Sends completion notifications to users.</data>
