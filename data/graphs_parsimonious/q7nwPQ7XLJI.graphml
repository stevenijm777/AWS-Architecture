    <node id="8">
      <data key="d5">Amazon API Gateway</data>
      <data key="d6">ApiGateway</data>
      <data key="d7">Exposes REST endpoints for real-time claims analysis.</data>
    </node>
    <node id="9">
      <data key="d5">AWS Lambda</data>
      <data key="d6">Lambda</data>
      <data key="d7">Runs containerized ML model for real-time execution.</data>
    </node>
    <node id="10">
      <data key="d5">Amazon RDS</data>
      <data key="d6">RDS</data>
      <data key="d7">Relational database using dedicated schemas for multi-tenant isolation.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">User accesses static web UI.</data>
