<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Agents &amp; Clients</data>
      <data key="d6">UserConsumerMobile</data>
      <data key="d7">Insurance agents and claiming clients connecting via mobile/web.</data>
    </node>
    <node id="1">
      <data key="d5">OpenVideo on EC2</data>
      <data key="d6">EC2</data>
      <data key="d7">Hosts WebRTC video platform and records raw sessions to local disk.</data>
    </node>
    <node id="2">
      <data key="d5">Raw Recordings S3</data>
      <data key="d6">S3</data>
      <data key="d7">Stores uploaded raw recordings from the EC2 instance.</data>
    </node>
    <node id="3">
      <data key="d5">Event Queue</data>
      <data key="d6">SQS</data>
      <data key="d7">Buffers transcoding tasks triggered by S3 upload events.</data>
    </node>
    <node id="4">
      <data key="d5">ECS Fargate Transcoder</data>
      <data key="d6">Fargate</data>
      <data key="d7">Scalable container tasks running FFmpeg to transcode raw videos to HLS.</data>
    </node>
    <node id="5">
      <data key="d5">Processed Videos S3</data>
      <data key="d6">S3</data>
      <data key="d7">Stores transcoded HLS files for playback and review.</data>
    </node>
    <node id="6">
      <data key="d5">S3 Glacier</data>
      <data key="d6">S3</data>
      <data key="d7">Archival storage for long-term retention of video recordings.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">Initiate and participate in WebRTC video calls.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="2" id="0">
      <data key="d8">1</data>
      <data key="d9">Upload raw recording files to S3.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="3" id="0">
      <data key="d8">2</data>
      <data key="d9">S3 event notification triggers SQS message.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="4" id="0">
      <data key="d8">3</data>
      <data key="d9">Fargate tasks poll queue for processing jobs.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="5" id="0">
      <data key="d8">4</data>
      <data key="d9">Upload processed HLS files to storage.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="6" id="0">
      <data key="d8">5</data>
      <data key="d9">Transition old recordings to Glacier for cost-effective archiving.</data>
      <data key="d10">5</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">Lancome Technology Video Conferencing and Recording Processing</data>
    <data key="d1">https://www.youtube.com/watch?v=qIO_54vJ_JI</data>
    <data key="d2">WebRTC video conferencing architecture hosted on EC2 with serverless media transcoding on ECS Fargate triggered via SQS queue and long-term storage on S3 Glacier.</data>
    <data key="d3">compute_intensive, data_ingestion</data>
    <data key="d4">True</data>
  </graph>
</graphml>
