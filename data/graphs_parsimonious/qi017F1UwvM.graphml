  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Web Application</data>
      <data key="d6">UserCompanyWebsite</data>
      <data key="d7">Configures workflows, journey plans, and views analytics dashboards.</data>
    </node>
    <node id="1">
      <data key="d5">Amazon Route 53</data>
      <data key="d6">Route53</data>
      <data key="d7">Routes DNS traffic for the web application.</data>
    </node>
    <node id="2">
      <data key="d5">Amazon API Gateway</data>
      <data key="d6">ApiGateway</data>
      <data key="d7">Manages back-end APIs.</data>
    </node>
    <node id="3">
      <data key="d5">AWS Fargate</data>
      <data key="d6">Fargate</data>
      <data key="d7">WORKLOAD_PEEK: Runs complex, long-running backend tasks and image processing.</data>
    </node>
    <node id="4">
      <data key="d5">AWS Lambda (Backend)</data>
      <data key="d6">Lambda</data>
      <data key="d7">Handles short-lived transactional tasks (create, read, update, delete).</data>
    </node>
    <node id="5">
      <data key="d5">Amazon RDS</data>
      <data key="d6">RDS</data>
      <data key="d7">Transactional data store for configuring workflows and tracking metrics.</data>
    </node>
    <node id="6">
      <data key="d5">Amazon ElastiCache</data>
      <data key="d6">ElastiCache</data>
      <data key="d7">Throttles database traffic and caches user permissions.</data>
    </node>
    <node id="7">
      <data key="d5">Mobile Application</data>
      <data key="d6">UserConsumerMobile</data>
      <data key="d7">Used by field forces to stream workflow analytics and tracking data.</data>
    </node>
    <node id="8">
      <data key="d5">Amazon Kinesis</data>
      <data key="d6">Kinesis</data>
      <data key="d7">DATA_PEEK: Ingests telemetry, tracking streams, and workflow events.</data>
    </node>
    <node id="9">
      <data key="d5">Amazon S3 (Raw)</data>
      <data key="d6">S3</data>
      <data key="d7">Saves raw, unprocessed incoming data streams.</data>
    </node>
    <node id="10">
      <data key="d5">AWS Lambda (Parser)</data>
      <data key="d6">Lambda</data>
      <data key="d7">Aggregates and parses Kinesis stream data for the state machine.</data>
    </node>
    <node id="11">
      <data key="d5">AWS Step Functions</data>
      <data key="d6">StepFunctions</data>
      <data key="d7">Orchestrates step-by-step workflow tracking and business logic rules.</data>
    </node>
    <node id="12">
      <data key="d5">Amazon SNS</data>
      <data key="d6">SNS</data>
      <data key="d7">Triggers alerts and notifications to users if metrics are breached.</data>
    </node>
    <node id="13">
      <data key="d5">AWS Lambda (Writer)</data>
      <data key="d6">Lambda</data>
      <data key="d7">Pushes status and metric updates back to RDS database.</data>
    </node>
    <node id="14">
      <data key="d5">Amazon S3 (Data Lake)</data>
      <data key="d6">S3</data>
      <data key="d7">DATA_PEEK: Consolidated data storage using Apache Parquet format.</data>
