  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">AWS Organizations</data>
      <data key="d6">Organizations</data>
      <data key="d7">Centrally manages and automates baselines for 1400+ AWS accounts.</data>
    </node>
    <node id="1">
      <data key="d5">SSO Bifrost (Fargate)</data>
      <data key="d6">Fargate</data>
      <data key="d7">Hosts Red Hat SSO (Bifrost) to provide federated SAML access to workloads.</data>
    </node>
    <node id="2">
      <data key="d5">AWS IAM</data>
      <data key="d6">IAM</data>
      <data key="d7">Manages user permissions and identity governance centrally.</data>
    </node>
    <node id="3">
      <data key="d5">Workload EC2</data>
      <data key="d6">EC2</data>
      <data key="d7">Represents the active business workloads isolated in staging accounts.</data>
    </node>
    <node id="4">
      <data key="d5">AWS Config</data>
      <data key="d6">AWSConfig</data>
      <data key="d7">Tracks resource configurations across accounts to generate compliance reports.</data>
    </node>
    <node id="5">
      <data key="d5">Amazon Inspector</data>
      <data key="d6">Inspector</data>
      <data key="d7">Performs vulnerability scanning on EC2 instances and containers.</data>
    </node>
    <node id="6">
      <data key="d5">AWS CloudTrail</data>
      <data key="d6">CloudTrail</data>
      <data key="d7">Aggregates API logs centrally in the dedicated auditing account.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">1</data>
      <data key="d9">Orchestrates SSO governance baseline.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="0" target="4" id="0">
      <data key="d8">1</data>
      <data key="d9">Orchestrates compliance baseline configurations.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="0" target="6" id="0">
      <data key="d8">1</data>
      <data key="d9">Configures central log routing.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="3" id="0">
      <data key="d8">2</data>
      <data key="d9">Authenticates users to workloads via SAML.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">Volkswagen Financial Services: Scalable and Compliant Landing Zone</data>
    <data key="d1">https://www.youtube.com/watch?v=r3g1Nym-ebY</data>
    <data key="d2">A multi-account landing zone structure managing 1400 accounts with centralized auditing, compliance, and SSO governance using AWS Organizations.</data>
    <data key="d3">control</data>
    <data key="d4">True</data>
