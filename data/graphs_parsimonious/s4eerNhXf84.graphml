<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Aqua SaaS</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Aqua's central management plane running as a SaaS platform.</data>
    </node>
    <node id="1">
      <data key="d5">Network Load Balancer</data>
      <data key="d6">NLB</data>
      <data key="d7">Routes traffic between the external Aqua SaaS and the internal EKS cluster nodes.</data>
    </node>
    <node id="2">
      <data key="d5">EKS Node (AZ 1)</data>
      <data key="d6">EKS</data>
      <data key="d7">Runs customer application containers in AZ 1.</data>
    </node>
    <node id="3">
      <data key="d5">Aqua Agent (AZ 1)</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Daemonset agent monitoring processes and kernel behaviors on the AZ 1 EKS node.</data>
    </node>
    <node id="4">
      <data key="d5">EKS Node (AZ 2)</data>
      <data key="d6">EKS</data>
      <data key="d7">Runs customer application containers in AZ 2.</data>
    </node>
    <node id="5">
      <data key="d5">Aqua Agent (AZ 2)</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Daemonset agent monitoring processes and kernel behaviors on the AZ 2 EKS node.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">Establishes secure management connection.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">Routes management traffic to EKS node in AZ 1.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="4" id="0">
      <data key="d8">0</data>
      <data key="d9">Routes management traffic to EKS node in AZ 2.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="3" id="0">
      <data key="d8">1</data>
      <data key="d9">Monitors container runtime processes.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="5" id="0">
      <data key="d8">1</data>
      <data key="d9">Monitors container runtime processes.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">Aqua Security CNAP Protection on AWS EKS</data>
    <data key="d1">https://www.youtube.com/watch?v=s4eerNhXf84</data>
    <data key="d2">Aqua Security's CNAP platform protects containerized workloads on EKS using a daemonset agent to monitor and block malicious kernel-level processes.</data>
    <data key="d3">compute_intensive, interactive</data>
    <data key="d4">True</data>
  </graph>
</graphml>
