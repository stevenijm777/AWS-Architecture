<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">AssemblyAI Users</data>
      <data key="d6">UserCompanyAPI</data>
      <data key="d7">External client applications submitting raw audio files or referencing existing buckets.</data>
    </node>
    <node id="1">
      <data key="d5">API Manager ECS</data>
      <data key="d6">ECS</data>
      <data key="d7">Validates requests and handles initial audio ingestion and transcoding.</data>
    </node>
    <node id="2">
      <data key="d5">Orchestrator ECS</data>
      <data key="d6">ECS</data>
      <data key="d7">Decides which ML models to run and coordinates execution order.</data>
    </node>
    <node id="3">
      <data key="d5">Amazon S3</data>
      <data key="d6">S3</data>
      <data key="d7">Stores transcoded audio with strict security lifecycle policies.</data>
    </node>
    <node id="4">
      <data key="d5">CloudWatch Metrics</data>
      <data key="d6">CloudWatch</data>
      <data key="d7">Gathers queue depth and orchestrator signals to run a custom pre-scaling loop.</data>
    </node>
    <node id="5">
      <data key="d5">Amazon SQS</data>
      <data key="d6">SQS</data>
      <data key="d7">Buffers job messages driving the model inference pipeline.</data>
    </node>
    <node id="6">
      <data key="d5">Inference Models ECS</data>
      <data key="d6">ECS</data>
      <data key="d7">Dozens of speech-to-text, speaker labeling, and LLM models on GPU instances.</data>
    </node>
    <node id="7">
      <data key="d5">Amazon SNS</data>
      <data key="d6">SNS</data>
      <data key="d7">Receives completed workflow status signals from the Orchestrator.</data>
    </node>
    <node id="8">
      <data key="d5">Webhook Lambda</data>
      <data key="d6">Lambda</data>
      <data key="d7">Asynchronously delivers transcription notifications back to client endpoints.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">Client sends audio to API Manager</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">Sends validated request parameters</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="3" id="0">
      <data key="d8">0</data>
      <data key="d9">Uploads transcoded audio payload</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="5" id="0">
      <data key="d8">1</data>
      <data key="d9">Enqueues model tasks</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="4" id="0">
      <data key="d8">2</data>
      <data key="d9">Pushes status and metric data</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="7" id="0">
      <data key="d8">3</data>
      <data key="d9">Triggers complete status notification</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="6" id="0">
      <data key="d8">1</data>
      <data key="d9">Inference container downloads audio by reference</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="6" id="0">
      <data key="d8">2</data>
      <data key="d9">Custom scaler pre-scales ECS tasks using metric predictions</data>
      <data key="d10">1</data>
      <data key="d11">meta</data>
    </edge>
    <edge source="5" target="6" id="0">
      <data key="d8">1</data>
      <data key="d9">Inference models poll queue for work</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="7" target="8" id="0">
      <data key="d8">3</data>
      <data key="d9">Triggers delivery webhook function</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="8" target="0" id="0">
      <data key="d8">3</data>
      <data key="d9">Asynchronous HTTP post of transcription results to user</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">AssemblyAI High-Scalability Audio Transcribing and ML Inference Pipeline</data>
    <data key="d1">https://www.youtube.com/watch?v=vQgUkn3rAMY</data>
    <data key="d2">AssemblyAI uses ECS for both orchestrating workflows and hosting dozens of custom ML speech-to-text models on GPUs. A custom scaling loop leveraging CloudWatch and SQS queue depth handles scaling challenges while controlling costs.</data>
    <data key="d3">compute_intensive, data_ingestion</data>
    <data key="d4">True</data>
  </graph>
</graphml>
