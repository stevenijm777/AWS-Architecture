<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Independent Agents</data>
      <data key="d6">UserCompanyAgent</data>
      <data key="d7">Agents accessing the application to sell policies.</data>
    </node>
    <node id="1">
      <data key="d5">CloudFront CDN</data>
      <data key="d6">CloudFront</data>
      <data key="d7">Caches and serves the single-page application frontend.</data>
    </node>
    <node id="2">
      <data key="d5">SPA Hosting Bucket</data>
      <data key="d6">S3</data>
      <data key="d7">Hosts static frontend assets.</data>
    </node>
    <node id="3">
      <data key="d5">API Gateway</data>
      <data key="d6">ApiGateway</data>
      <data key="d7">Entrypoint for backend API calls.</data>
    </node>
    <node id="4">
      <data key="d5">Lambda Authorizer</data>
      <data key="d6">Lambda</data>
      <data key="d7">Validates user access tokens.</data>
    </node>
    <node id="5">
      <data key="d5">Serverless Python Backend</data>
      <data key="d6">Lambda</data>
      <data key="d7">Executes modern microservice logic.</data>
    </node>
    <node id="6">
      <data key="d5">User Session Cache</data>
      <data key="d6">DynamoDB</data>
      <data key="d7">Stores cached user information regionally.</data>
    </node>
    <node id="7">
      <data key="d5">Legacy Tomcat Application</data>
      <data key="d6">EC2</data>
      <data key="d7">Runs legacy Java code for non-migrated functions.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">Request application access.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">Retrieve static assets.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="3" id="0">
      <data key="d8">1</data>
      <data key="d9">Forward dynamic API requests.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="4" id="0">
      <data key="d8">1</data>
      <data key="d9">Invoke custom access authorizer.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="5" id="0">
      <data key="d8">1</data>
      <data key="d9">Route backend logic requests.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="6" id="0">
      <data key="d8">1</data>
      <data key="d9">Read/write session details.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="7" id="0">
      <data key="d8">1</data>
      <data key="d9">Call legacy APIs on Tomcat server.</data>
      <data key="d10">5</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">American Family Insurance - Modernizing Legacy Applications with Serverless</data>
    <data key="d1">https://www.youtube.com/watch?v=wjtSHyENv0I</data>
    <data key="d2">Main Street America modernized a legacy Tomcat application using a strangler pattern, replacing frontend hosting with S3/CloudFront and API services with API Gateway and Lambda, while keeping some legacy code on EC2.</data>
    <data key="d3">interactive, compute_intensive</data>
    <data key="d4">True</data>
  </graph>
