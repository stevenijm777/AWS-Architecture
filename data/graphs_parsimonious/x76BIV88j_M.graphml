<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Mobile Client App</data>
      <data key="d6">UserConsumerMobile</data>
      <data key="d7">Mobile apps used by riders and drivers.</data>
    </node>
    <node id="1">
      <data key="d5">Amazon Route 53</data>
      <data key="d6">Route53</data>
      <data key="d7">Handles IP geolocation routing during platform migration.</data>
    </node>
    <node id="2">
      <data key="d5">Elastic Load Balancing</data>
      <data key="d6">ELB</data>
      <data key="d7">Distributes incoming mobile application traffic.</data>
    </node>
    <node id="3">
      <data key="d5">Nomad Cluster</data>
      <data key="d6">EC2</data>
      <data key="d7">Legacy container orchestration platform running on EC2.</data>
    </node>
    <node id="4">
      <data key="d5">Amazon EKS Cluster</data>
      <data key="d6">EKS</data>
      <data key="d7">Target Kubernetes cluster running containerized microservices.</data>
    </node>
    <node id="5">
      <data key="d5">Amazon RDS MySQL</data>
      <data key="d6">RDS</data>
      <data key="d7">Independent databases owned by individual microservices.</data>
    </node>
    <node id="6">
      <data key="d5">Amazon S3</data>
      <data key="d6">S3</data>
      <data key="d7">Long-term cold storage for completed trip data.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">1</data>
      <data key="d9">Resolves domain via Route 53 with geolocation.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="0" target="2" id="0">
      <data key="d8">2</data>
      <data key="d9">Sends application traffic to load balancers.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="3" id="0">
      <data key="d8">3</data>
      <data key="d9">Routes traffic to Nomad container services.</data>
      <data key="d10">3a</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="4" id="0">
      <data key="d8">3</data>
      <data key="d9">Routes traffic to migrated EKS services.</data>
      <data key="d10">3b</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="4" id="0">
      <data key="d8">4</data>
      <data key="d9">Facilitates migration/routing between clusters.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="5" id="0">
      <data key="d8">5</data>
      <data key="d9">Writes and reads active service data.</data>
      <data key="d10">5a</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="5" id="0">
      <data key="d8">5</data>
      <data key="d9">Writes and reads active service data.</data>
      <data key="d10">5b</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="6" id="0">
      <data key="d8">6</data>
      <data key="d9">Archives cold data for long-term storage.</data>
      <data key="d10">6</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">Cabify Mobile Platform Architecture</data>
    <data key="d1">https://www.youtube.com/watch?v=x76BIV88j_M</data>
    <data key="d2">Cabify uses this architecture to run real-time ride-sharing and delivery applications, migrating from a Nomad cluster on EC2 to Amazon EKS while utilizing Spot Instances for cost efficiency.</data>
    <data key="d3">interactive, compute_intensive</data>
    <data key="d4">True</data>
  </graph>
</graphml>
