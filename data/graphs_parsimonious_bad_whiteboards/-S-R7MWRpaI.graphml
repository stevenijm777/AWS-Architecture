<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d12" for="edge" attr.name="id" attr.type="string" />
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Supernode 1 (SN)</data>
      <data key="d6">UserCompanyEdge</data>
      <data key="d7">First node that registers on the network, becoming a supernode.</data>
    </node>
    <node id="1">
      <data key="d5">Supernode 2 (SN)</data>
      <data key="d6">UserCompanyEdge</data>
      <data key="d7">Manages proximal node discovery and reports telemetry.</data>
    </node>
    <node id="2">
      <data key="d5">Standard Node (N)</data>
      <data key="d6">UserCompanyEdge</data>
      <data key="d7">New node entering the network and listening to the supernode.</data>
    </node>
    <node id="3">
      <data key="d5">EKS (MDS)</data>
      <data key="d6">EKS</data>
      <data key="d7">WORKLOAD_PEEK: Runs the discovery service and handles supernode registration.</data>
    </node>
    <node id="4">
      <data key="d5">MongoDB</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">DATA_PEEK: Document database used to define clusters by proximity.</data>
    </node>
    <node id="5">
      <data key="d5">DynamoDB</data>
      <data key="d6">DynamoDB</data>
      <data key="d7">Stores user profiles and hierarchical peer associations.</data>
    </node>
    <node id="6">
      <data key="d5">Kinesis Data Streams</data>
      <data key="d6">KinesisDataStream</data>
      <data key="d7">DATA_PEEK: Handles real-time telemetry stream up to 1,000 msgs/sec.</data>
    </node>
    <node id="7">
      <data key="d5">Kinesis Firehose</data>
      <data key="d6">Firehose</data>
      <data key="d7">Buffers and flushes incoming telemetry streams to S3.</data>
    </node>
    <node id="8">
      <data key="d5">S3 Bucket</data>
      <data key="d6">S3</data>
      <data key="d7">DATA_PEEK: Long-term archival storage for all edge telemetry logs.</data>
    </node>
    <node id="9">
      <data key="d5">Snowflake</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Performs SQL queries on data stored in S3 for real-time and long-term analytics.</data>
    </node>
    <edge source="0" target="3">
      <data key="d8">0</data>
      <data key="d9">Supernode registers metadata with MDS.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="1" target="3">
      <data key="d8">0</data>
      <data key="d9">Supernode registers the new standard node.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="1" target="6">
      <data key="d8">1</data>
      <data key="d9">Supernode streams telemetry and log data.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="2" target="1">
      <data key="d8">0</data>
      <data key="d9">Standard node joins and listens to the supernode.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="3" target="4">
      <data key="d8">0</data>
      <data key="d9">EKS registers proximity and clustering data in MongoDB.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="3" target="5">
      <data key="d8">0</data>
      <data key="d9">EKS manages peer profiles and associations.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="6" target="7">
      <data key="d8">1</data>
      <data key="d9">Streams data to Firehose.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="7" target="8">
      <data key="d8">1</data>
      <data key="d9">Archives telemetry data into S3.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="8" target="9">
      <data key="d8">1</data>
      <data key="d9">Returns query result payload.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <edge source="9" target="8">
      <data key="d8">1</data>
      <data key="d9">Queries telemetry archive data.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
      <data key="d12">0</data>
    </edge>
    <data key="d0">mimik: Hybrid Edge Cloud Leveraging AWS to Support Edge Microservice Mesh</data>
    <data key="d1">https://www.youtube.com/watch?v=-S-R7MWRpaI</data>
    <data key="d2">Edge Engine allows developers to deploy edge microservices. Uses EKS for coordination and discovery, MongoDB for cluster proximity, and Snowflake over S3 for analytics.</data>
    <data key="d3">data_ingestion, compute_intensive</data>
    <data key="d4">True</data>
  </graph>
</graphml>
