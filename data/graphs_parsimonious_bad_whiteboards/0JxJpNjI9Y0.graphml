<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Public Users</data>
      <data key="d6">UserConsumerWebMobile</data>
      <data key="d7">Access the website to view HTML pages like WashingtonPost.com.</data>
    </node>
    <node id="1">
      <data key="d5">Developer &amp; Newsroom Users</data>
      <data key="d6">UserCompanyDeveloper</data>
      <data key="d7">Create page templates and deploy rendering code.</data>
    </node>
    <node id="2">
      <data key="d5">Origin ECS</data>
      <data key="d6">ECS</data>
      <data key="d7">Handles traffic routing and origin proxying.</data>
    </node>
    <node id="3">
      <data key="d5">Static Resources</data>
      <data key="d6">S3</data>
      <data key="d7">Stores static assets like CSS and JavaScript.</data>
    </node>
    <node id="4">
      <data key="d5">Pre-Rendered Content</data>
      <data key="d6">S3</data>
      <data key="d7">Stores pre-rendered HTML content for faster delivery.</data>
    </node>
    <node id="5">
      <data key="d5">Rendering Lambda</data>
      <data key="d6">Lambda</data>
      <data key="d7">Performs dynamic HTML page rendering when cache is missed.</data>
    </node>
    <node id="6">
      <data key="d5">Content Proxy ECS</data>
      <data key="d6">ECS</data>
      <data key="d7">Proxies requests to external and internal CMS systems.</data>
    </node>
    <node id="7">
      <data key="d5">Template Store</data>
      <data key="d6">DynamoDB</data>
      <data key="d7">Stores page builder templates and configurations.</data>
    </node>
    <node id="8">
      <data key="d5">Raw JSON Cache</data>
      <data key="d6">ElastiCache</data>
      <data key="d7">Caches raw CMS JSON payloads with a TTL.</data>
    </node>
    <node id="9">
      <data key="d5">CMS &amp; APIs</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">External content management systems and APIs.</data>
    </node>
    <edge source="0" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">Public user requests page.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="7" id="0">
      <data key="d8">2</data>
      <data key="d9">Newsroom configures templates stored in DynamoDB.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="5" id="0">
      <data key="d8">2</data>
      <data key="d9">Developers deploy rendering code changes.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="3" id="0">
      <data key="d8">0</data>
      <data key="d9">Fetches static assets.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="4" id="0">
      <data key="d8">0</data>
      <data key="d9">Fetches pre-rendered HTML pages.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="5" id="0">
      <data key="d8">0</data>
      <data key="d9">Falls back to dynamic Lambda rendering on cache miss.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="6" id="0">
      <data key="d8">1</data>
      <data key="d9">Lambda requests content details from content proxy.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="7" id="0">
      <data key="d8">1</data>
      <data key="d9">Retrieves page layouts and templates during execution.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="4" id="0">
      <data key="d8">1</data>
      <data key="d9">Saves rendered output back to S3 pre-render store.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <edge source="6" target="8" id="0">
      <data key="d8">1</data>
      <data key="d9">Checks ElastiCache for raw JSON content.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="6" target="9" id="0">
      <data key="d8">1</data>
      <data key="d9">Fetches raw data from backend CMS systems.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">Arc Publishing Web Rendering Platform</data>
    <data key="d1">https://www.youtube.com/watch?v=0JxJpNjI9Y0</data>
    <data key="d2">Web rendering platform for Washington Post and other media companies. Uses multi-tier caching (CDN, S3 pre-rendered pages, and ElastiCache for CMS JSON data) to guarantee high performance and availability.</data>
    <data key="d3">data_ingestion, compute_intensive</data>
    <data key="d4">True</data>
  </graph>
</graphml>
