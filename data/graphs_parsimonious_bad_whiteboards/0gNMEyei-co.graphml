  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Applications</data>
      <data key="d6">UserCompanyAPI</data>
      <data key="d7">Customer transactional and security source applications.</data>
    </node>
    <node id="1">
      <data key="d5">Kinesis</data>
      <data key="d6">Kinesis</data>
      <data key="d7">Stream for ingesting high-volume data.</data>
    </node>
    <node id="2">
      <data key="d5">Fargate</data>
      <data key="d6">Fargate</data>
      <data key="d7">Parses ingestion data, manages scoping of analysis, and processes violations.</data>
    </node>
    <node id="3">
      <data key="d5">Aurora</data>
      <data key="d6">Aurora</data>
      <data key="d7">Stores parsed security and transaction logs.</data>
    </node>
    <node id="4">
      <data key="d5">S3</data>
      <data key="d6">S3</data>
      <data key="d7">Long-term data lake storage; transformed via Glue.</data>
    </node>
    <node id="5">
      <data key="d5">Scheduler</data>
      <data key="d6">EventBridge</data>
      <data key="d7">Triggers schedule-based analytical runs.</data>
    </node>
    <node id="6">
      <data key="d5">EMR</data>
      <data key="d6">EMR</data>
      <data key="d7">Spark cluster executing audit rule analysis.</data>
    </node>
    <node id="7">
      <data key="d5">EventBridge</data>
      <data key="d6">EventBridge</data>
      <data key="d7">Receives violation events from EMR.</data>
    </node>
    <node id="8">
      <data key="d5">SQS</data>
      <data key="d6">SQS</data>
      <data key="d7">Queues violations for final decoration.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">Streams data from apps.</data>
