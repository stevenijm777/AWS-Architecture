  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">IMAGE</data>
      <data key="d6">UserConsumerWebMobile</data>
      <data key="d7">Images uploaded via SDK, API, or web/mobile.</data>
    </node>
    <node id="1">
      <data key="d5">API Gateway</data>
      <data key="d6">ApiGateway</data>
      <data key="d7">Entry point for image uploads.</data>
    </node>
    <node id="2">
      <data key="d5">ALB</data>
      <data key="d6">ALB</data>
      <data key="d7">Routes traffic to the correct ECS cluster.</data>
    </node>
    <node id="3">
      <data key="d5">ECS</data>
      <data key="d6">ECS</data>
      <data key="d7">Saves metadata to RDS and routes to processing queues.</data>
    </node>
    <node id="4">
      <data key="d5">SQS</data>
      <data key="d6">SQS</data>
      <data key="d7">Queues partitioned by processing category.</data>
    </node>
    <node id="5">
      <data key="d5">Processing Layer</data>
      <data key="d6">EC2</data>
      <data key="d7">WORKLOAD_PEEK: CPU instances for pre/post processing, G5 GPU instances for inference.</data>
    </node>
    <node id="6">
      <data key="d5">TP</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Training data source pipeline.</data>
    </node>
    <node id="7">
      <data key="d5">S3</data>
      <data key="d6">S3</data>
      <data key="d7">DATA_PEEK: Stores training data and model weights.</data>
    </node>
    <node id="8">
      <data key="d5">SageMaker</data>
      <data key="d6">SageMaker</data>
      <data key="d7">WORKLOAD_PEEK: Trains models using SageMaker Spot instances.</data>
    </node>
    <node id="9">
      <data key="d5">Lambda</data>
      <data key="d6">Lambda</data>
      <data key="d7">Triggers weight sync to processing layer.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">User uploads images</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">Forwards to ALB</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="3" id="0">
      <data key="d8">0</data>
      <data key="d9">Routes based on image category</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="4" id="0">
      <data key="d8">0</data>
      <data key="d9">Pushes tasks to appropriate SQS queue</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="5" id="0">
      <data key="d8">0</data>
      <data key="d9">Consumed by AI service instances</data>
      <data key="d10">5</data>
      <data key="d11">data</data>
    </edge>
    <edge source="6" target="7" id="0">
      <data key="d8">1</data>
      <data key="d9">Uploads training data</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="7" target="8" id="0">
      <data key="d8">1</data>
      <data key="d9">SageMaker downloads training dataset</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="8" target="7" id="0">
      <data key="d8">1</data>
      <data key="d9">Saves trained model weights</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="8" target="9" id="0">
      <data key="d8">1</data>
      <data key="d9">Triggers Lambda after evaluation passes</data>
      <data key="d10">4</data>
      <data key="d11">meta</data>
    </edge>
    <edge source="9" target="5" id="0">
      <data key="d8">1</data>
      <data key="d9">Syncs model weights to processing layer</data>
      <data key="d10">5</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">Spine.ai - High-Scale AI Cataloging Architecture</data>
    <data key="d1">https://www.youtube.com/watch?v=0wnNlOg42dc</data>
    <data key="d2">Handles processing of 100k images/day for digital cataloging using hybrid CPU/GPU instances and cost-effective SageMaker training.</data>
    <data key="d3">data_ingestion, compute_intensive, other</data>
    <data key="d4">True</data>
  </graph>
