<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Monolith Data Types</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">The original monolithic application data split into Binary, Relational, Key-Value, and Encrypted segments.</data>
    </node>
    <node id="1">
      <data key="d5">S3</data>
      <data key="d6">S3</data>
      <data key="d7">Stores unstructured binary blobs and key-value document data.</data>
    </node>
    <node id="2">
      <data key="d5">Aurora Serverless</data>
      <data key="d6">Aurora</data>
      <data key="d7">Provides independent database instances per tenant for core relational data.</data>
    </node>
    <node id="3">
      <data key="d5">DynamoDB</data>
      <data key="d6">DynamoDB</data>
      <data key="d7">Offloads configuration and key-value data to improve agility and reduce costs.</data>
    </node>
    <node id="4">
      <data key="d5">Secrets Manager</data>
      <data key="d6">SecretsManager</data>
      <data key="d7">Directly stores sensitive encrypted data, offloading security from relational DBs.</data>
    </node>
    <node id="5">
      <data key="d5">KMS</data>
      <data key="d6">KMS</data>
      <data key="d7">Manages tenant-specific keys (BYOK) used to encrypt S3 and Aurora resources.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">Binary data routed to S3</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="0" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">Relational data routed to Aurora Serverless</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="0" target="3" id="0">
      <data key="d8">0</data>
      <data key="d9">Key-value data routed to DynamoDB</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="0" target="4" id="0">
      <data key="d8">0</data>
      <data key="d9">Encrypted data routed to Secrets Manager</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="1" id="0">
      <data key="d8">1</data>
      <data key="d9">Tenant-specific KMS key encrypts S3 bucket</data>
      <data key="d10">1</data>
      <data key="d11">meta</data>
    </edge>
    <edge source="5" target="2" id="0">
      <data key="d8">1</data>
      <data key="d9">Tenant-specific KMS key encrypts Aurora instance</data>
      <data key="d10">2</data>
      <data key="d11">meta</data>
    </edge>
    <data key="d0">OutSystems Monolith Data Decomposition</data>
    <data key="d1">https://www.youtube.com/watch?v=1kWxymroGeE</data>
    <data key="d2">Decomposes a monolith platform's data into specialized AWS storage services to achieve multi-tenancy, scale, and cost-efficiency while supporting tenant-specific encryption.</data>
    <data key="d3">data_ingestion, compute_intensive</data>
    <data key="d4">True</data>
  </graph>
</graphml>
