<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Ad hoc EC2 VMs</data>
      <data key="d6">EC2</data>
      <data key="d7">WORKLOAD_PEEK: Used for ad hoc data ingestion of raw genomics data.</data>
    </node>
    <node id="1">
      <data key="d5">Amazon FSx</data>
      <data key="d6">FSX</data>
      <data key="d7">DATA_PEEK: Stores raw genomic sequences; mounted to EKS.</data>
    </node>
    <node id="2">
      <data key="d5">Amazon ECR</data>
      <data key="d6">ECR</data>
      <data key="d7">WORKLOAD_PEEK: Stores versioned Docker containers for pipelines.</data>
    </node>
    <node id="3">
      <data key="d5">Amazon EKS</data>
      <data key="d6">EKS</data>
      <data key="d7">WORKLOAD_PEEK: Scales to 100+ nodes to process genomic data.</data>
    </node>
    <node id="4">
      <data key="d5">Data Lake</data>
      <data key="d6">S3</data>
      <data key="d7">DATA_PEEK: Stores output matrices for analytical consumption.</data>
    </node>
    <node id="5">
      <data key="d5">Data Scientists &amp; Biologists</data>
      <data key="d6">UserCompanyAnalyst</data>
      <data key="d7">Analyze final matrices to discover gene targets.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">Ingested data is saved to FSx.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="3" id="0">
      <data key="d8">1</data>
      <data key="d9">EKS mounts FSx to access genomic sequences.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="3" id="0">
      <data key="d8">1</data>
      <data key="d9">EKS pulls pipeline images from ECR.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="4" id="0">
      <data key="d8">1</data>
      <data key="d9">Processed matrices are saved to S3.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="5" id="0">
      <data key="d8">2</data>
      <data key="d9">Analysts query findings from S3.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">Biopharma Genomic Data Curation Pipeline</data>
    <data key="d1">https://www.youtube.com/watch?v=53sUjFv9ByI</data>
    <data key="d2">Ingests raw genomics data using EC2, curates it at scale on EKS using versioned containers from ECR, and writes outputs to an S3 data lake.</data>
    <data key="d3">data_ingestion, compute_intensive</data>
    <data key="d4">True</data>
  </graph>
</graphml>
