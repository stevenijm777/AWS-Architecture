  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Milling Machines &amp; Apps</data>
      <data key="d6">UserCompanyEdge</data>
      <data key="d7">DATA_PEEK: 40 milling machines and 20 client applications generating telemetry.</data>
    </node>
    <node id="1">
      <data key="d5">AWS IoT Core</data>
      <data key="d6">IoTCore</data>
