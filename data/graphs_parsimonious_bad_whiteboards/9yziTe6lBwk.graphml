  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Students</data>
      <data key="d6">UserConsumerWebMobile</data>
      <data key="d7">Students logging into the educational portal.</data>
    </node>
    <node id="1">
      <data key="d5">Route 53</data>
      <data key="d6">Route53</data>
      <data key="d7">DNS routing for student traffic.</data>
    </node>
    <node id="2">
      <data key="d5">CloudFront</data>
      <data key="d6">CloudFront</data>
      <data key="d7">Caches static content to reduce latency for users in Brazil.</data>
    </node>
    <node id="3">
      <data key="d5">ELB</data>
      <data key="d6">ELB</data>
      <data key="d7">Balances incoming traffic to the EKS cluster.</data>
    </node>
    <node id="4">
      <data key="d5">EKS Cluster</data>
      <data key="d6">EKS</data>
      <data key="d7">WORKLOAD_PEEK: Runs about 60 microservices to split up the old monolith.</data>
    </node>
    <node id="5">
      <data key="d5">RDS Databases</data>
      <data key="d6">RDS</data>
      <data key="d7">DATA_PEEK: Consists of ~20 databases, with 3 dedicated specifically for enrollment renewal.</data>
    </node>
    <node id="6">
      <data key="d5">ElastiCache</data>
      <data key="d6">ElastiCache</data>
      <data key="d7">Caches enrollment data to optimize performance.</data>
    </node>
    <node id="7">
      <data key="d5">AWS Glue</data>
      <data key="d6">Glue</data>
      <data key="d7">Performs ETL tasks to load structured data from RDS.</data>
    </node>
    <node id="8">
      <data key="d5">S3 Data Lake</data>
      <data key="d6">S3</data>
      <data key="d7">Stores structured and unstructured data.</data>
    </node>
    <node id="9">
      <data key="d5">Redshift</data>
      <data key="d6">RedShift</data>
      <data key="d7">Data warehouse used for business analytics and AI algorithms.</data>
    </node>
    <edge source="0" target="1">
      <data key="d8">0</data>
      <data key="d9">Student access request</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
