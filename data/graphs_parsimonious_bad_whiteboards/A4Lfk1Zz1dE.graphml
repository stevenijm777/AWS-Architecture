  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Customer Developer</data>
      <data key="d6">UserConsumerDeveloper</data>
      <data key="d7">Deploys Spot.io integration templates and manages workloads.</data>
    </node>
    <node id="1">
      <data key="d5">CloudFormation</data>
      <data key="d6">CloudFormation</data>
      <data key="d7">WORKLOAD_PEEK: Deploys cross-account IAM role and policy in the customer account.</data>
    </node>
    <node id="2">
      <data key="d5">Cross-Account IAM Role</data>
      <data key="d6">IAM</data>
      <data key="d7">Secures access using an external ID, permitting Spot.io to describe and modify customer infrastructure.</data>
    </node>
    <node id="3">
      <data key="d5">Customer Spot Instances</data>
      <data key="d6">EC2</data>
      <data key="d7">WORKLOAD_PEEK: Customer workloads, including Auto Scaling Groups and containerized EKS worker nodes.</data>
    </node>
    <node id="4">
      <data key="d5">Spot.io SaaS EKS</data>
      <data key="d6">EKS</data>
      <data key="d7">WORKLOAD_PEEK: Runs Spot.io data collectors and automation engine to orchestrate instance replacements.</data>
    </node>
    <node id="5">
      <data key="d5">Amazon Aurora</data>
      <data key="d6">Aurora</data>
      <data key="d7">DATA_PEEK: Stores 2 billion data points a day of real-time regional Spot capacity metrics.</data>
    </node>
    <node id="6">
      <data key="d5">Amazon SageMaker</data>
      <data key="d6">SageMaker</data>
      <data key="d7">WORKLOAD_PEEK: Predicts Spot interruptions with 85% accuracy up to 1 hour in advance using machine learning.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">1</data>
      <data key="d9">Triggers CloudFormation deployment.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="2" id="0">
      <data key="d8">1</data>
      <data key="d9">Provisions cross-account IAM role.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="3" id="0">
      <data key="d8">2</data>
      <data key="d9">Describes customer EC2 instances and auto scaling groups.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="3" id="1">
      <data key="d8">3</data>
      <data key="d9">Terminates and replaces Spot instances before interruption occurs.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="2" id="0">
      <data key="d8">2</data>
      <data key="d9">Assumes cross-account role to collect metrics.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="2" id="1">
      <data key="d8">3</data>
      <data key="d9">Assumes IAM role to modify customer instances.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="5" id="0">
      <data key="d8">2</data>
      <data key="d9">Writes infrastructure metrics into Aurora database.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="6" id="0">
      <data key="d8">2</data>
      <data key="d9">Feeds historical and real-time data into ML predictive models.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <edge source="6" target="4" id="0">
      <data key="d8">3</data>
      <data key="d9">Triggers proactive replacement on interruption prediction.</data>
      <data key="d10">1</data>
      <data key="d11">meta</data>
    </edge>
    <data key="d0">Spot.io Proactive Spot Instance Management</data>
    <data key="d1">https://www.youtube.com/watch?v=A4Lfk1Zz1dE</data>
    <data key="d2">Spot.io leverages fully managed AWS services (Aurora, SageMaker, and EKS) to ingest 2 billion daily data points, predicting Spot instance interruptions with 85% accuracy up to 1 hour in advance, then executing automated proactive replacements in customer environments via secure IAM cross-account roles.</data>
    <data key="d3">compute_intensive,control,data_ingestion</data>
    <data key="d4">True</data>
  </graph>
