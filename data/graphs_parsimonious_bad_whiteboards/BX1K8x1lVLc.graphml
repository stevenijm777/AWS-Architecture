<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Web Users</data>
      <data key="d6">UserConsumerWeb</data>
      <data key="d7">Customers browsing and purchasing fashion items on the e-commerce site.</data>
    </node>
    <node id="1">
      <data key="d5">CloudFront CDN</data>
      <data key="d6">CloudFront</data>
      <data key="d7">Caches static assets and acts as the entry point for global traffic.</data>
    </node>
    <node id="2">
      <data key="d5">Varnish Cache (EC2)</data>
      <data key="d6">EC2</data>
      <data key="d7">WORKLOAD_PEEK: Hosts Varnish Cache to offload Magento application rendering.</data>
    </node>
    <node id="3">
      <data key="d5">Magento on EKS</data>
      <data key="d6">EKS</data>
      <data key="d7">WORKLOAD_PEEK: Runs web pods, admin panel, and cron jobs in dedicated auto-scaling node groups.</data>
    </node>
    <node id="4">
      <data key="d5">Elastic Container Registry</data>
      <data key="d6">ECR</data>
      <data key="d7">Stores containerized Magento application images.</data>
    </node>
    <node id="5">
      <data key="d5">Aurora MySQL</data>
      <data key="d6">Aurora</data>
      <data key="d7">DATA_PEEK: Primary transactional relational database with Multi-AZ replicas.</data>
    </node>
    <node id="6">
      <data key="d5">ElastiCache Redis</data>
      <data key="d6">ElastiCache</data>
      <data key="d7">Caches database query results and sessions to speed up page loads.</data>
    </node>
    <node id="7">
      <data key="d5">Media S3 Bucket</data>
      <data key="d6">S3</data>
      <data key="d7">DATA_PEEK: Stores media assets, mounted onto EKS containers using S3FS.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">User visits the e-commerce website.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">Dynamic requests routed to Varnish cache on EC2.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="7" id="0">
      <data key="d8">0</data>
      <data key="d9">CloudFront directly fetches and serves static media assets stored in S3.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="3" id="0">
      <data key="d8">0</data>
      <data key="d9">Cache misses forwarded to the Magento backend application in EKS.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="5" id="0">
      <data key="d8">1</data>
      <data key="d9">EKS pods read/write business data to Aurora MySQL.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="6" id="0">
      <data key="d8">1</data>
      <data key="d9">EKS pods use Redis to cache relational database queries.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="7" id="0">
      <data key="d8">1</data>
      <data key="d9">Magento writes assets/media to S3 via mounted S3FS file system.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="3" id="0">
      <data key="d8">2</data>
      <data key="d9">EKS pulls updated Magento container images for deployments.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">Love Bonito: Scalable Magento E-Commerce on EKS</data>
    <data key="d1">https://www.youtube.com/watch?v=BX1K8x1lVLc</data>
    <data key="d2">Migrated a legacy monolithic Magento deployment to EKS. Solved zero-downtime deployments and auto-scaling during peak sales. Implemented S3Fuse to mount S3 as a file system for Magento.</data>
    <data key="d3">interactive, compute_intensive</data>
    <data key="d4">True</data>
  </graph>
</graphml>
