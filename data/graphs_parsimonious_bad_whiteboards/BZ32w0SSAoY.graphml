<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Web Browser</data>
      <data key="d6">UserConsumerWeb</data>
      <data key="d7">Web interface recommended on Chrome where users log in and configure video workflows.</data>
    </node>
    <node id="1">
      <data key="d5">Web Server / Job Manager</data>
      <data key="d6">EC2</data>
      <data key="d7">WORKLOAD_PEEK: Single EC2 instance managing user requests, orchestrating processing jobs, and coordinating metadata workflow.</data>
    </node>
    <node id="2">
      <data key="d5">Database</data>
      <data key="d6">RDS</data>
      <data key="d7">Stores and caches metadata retrieved from S3 clips to serve the web UI.</data>
    </node>
    <node id="3">
      <data key="d5">Lambda</data>
      <data key="d6">Lambda</data>
      <data key="d7">WORKLOAD_PEEK: Extracts video metadata on-the-fly from the customer's S3 bucket.</data>
    </node>
    <node id="4">
      <data key="d5">S3 Bucket</data>
      <data key="d6">S3</data>
      <data key="d7">DATA_PEEK: Customer-managed bucket holding source clips and receiving output processed files.</data>
    </node>
    <node id="5">
      <data key="d5">G3 GPU Cluster</data>
      <data key="d6">EC2</data>
      <data key="d7">WORKLOAD_PEEK: GPU-accelerated EC2 instances (up to 200 parallel jobs) running proprietary processing engines (Wormhole, Spacetime, Dark Energy).</data>
    </node>
    <node id="6">
      <data key="d5">IMF wrapping</data>
      <data key="d6">EC2</data>
      <data key="d7">WORKLOAD_PEEK: Specialized packaging instance for Interoperable Master Format compilation.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">User accesses web server and enters S3 keys.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="0" target="1" id="1">
      <data key="d8">1</data>
      <data key="d9">User submits video processing workflow.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="3" id="0">
      <data key="d8">0</data>
      <data key="d9">Job manager triggers Lambda to extract clip metadata.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">Saves retrieved metadata into the database.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="5" id="0">
      <data key="d8">1</data>
      <data key="d9">Job manager dispatches processing tasks to G3 GPU instances.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">Web server retrieves metadata from database to show in browser.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="4" id="0">
      <data key="d8">0</data>
      <data key="d9">Lambda reads metadata from the customer's S3 bucket.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="5" id="0">
      <data key="d8">1</data>
      <data key="d9">Asset manager copies input clip from S3 to G3 local disk.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="6" id="0">
      <data key="d8">1</data>
      <data key="d9">If workflow specifies IMF, G3 sends processed content to IMF wrapper.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="4" id="0">
      <data key="d8">1</data>
      <data key="d9">Standard workflow: Asset manager copies output from G3 back to customer S3.</data>
      <data key="d10">4a</data>
      <data key="d11">data</data>
    </edge>
    <edge source="6" target="4" id="0">
      <data key="d8">1</data>
      <data key="d9">IMF workflow: Asset manager copies IMF package back to customer S3.</data>
      <data key="d10">4b</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">Cinefilm PixelStrings Cloud Architecture</data>
    <data key="d1">https://www.youtube.com/watch?v=BZ32w0SSAoY</data>
    <data key="d2">PixelStrings is a video processing platform running on GPU-enabled AWS EC2 instances. It supports parallel video retiming, deinterlacing, and IMF wrapping, caching metadata via Lambda in an RDS database.</data>
    <data key="d3">data_ingestion, compute_intensive</data>
    <data key="d4">True</data>
  </graph>
</graphml>
