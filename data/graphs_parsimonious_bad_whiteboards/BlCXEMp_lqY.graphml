<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Smart TVs</data>
      <data key="d6">UserConsumerTV</data>
      <data key="d7">WORKLOAD_PEEK: Generates logs, performance, and user telemetry data.</data>
    </node>
    <node id="1">
      <data key="d5">Kinesis Streams</data>
      <data key="d6">Kinesis</data>
      <data key="d7">Serves as the front door to ingest the streaming TV data, allowing scaling by managing shards.</data>
    </node>
    <node id="2">
      <data key="d5">Kinesis Firehose</data>
      <data key="d6">Firehose</data>
      <data key="d7">Pipes raw, schemaless telemetry data towards both S3 and Redshift.</data>
    </node>
    <node id="3">
      <data key="d5">S3 Bucket</data>
      <data key="d6">S3</data>
      <data key="d7">DATA_PEEK: Acts as the long-term, low-cost home where all raw telemetry columns are kept forever.</data>
    </node>
    <node id="4">
      <data key="d5">Redshift</data>
      <data key="d6">RedShift</data>
      <data key="d7">The data warehouse optimized for analytical queries at scale, replacing an Aurora prototype.</data>
    </node>
    <node id="5">
      <data key="d5">QuickSight</data>
      <data key="d6">QuickSight</data>
      <data key="d7">Provides fast and interactive dashboards utilizing SPICE (Super-fast, Parallel, In-memory Calculation Engine).</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">TVs stream logs, performance, and user data to Kinesis.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">Kinesis forwards the streaming data to Firehose.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="3" id="0">
      <data key="d8">0</data>
      <data key="d9">Firehose archives raw payload data in S3 for permanent storage.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="4" id="0">
      <data key="d8">0</data>
      <data key="d9">Firehose streams and transforms structured telemetry into Redshift.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="5" id="0">
      <data key="d8">0</data>
      <data key="d9">QuickSight queries data from Redshift to load into its SPICE in-memory database for reporting.</data>
      <data key="d10">5</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">Vizio: Smart TV Analytics at Scale</data>
    <data key="d1">https://www.youtube.com/watch?v=BlCXEMp_lqY</data>
    <data key="d2">Ingests billions of telemetry events (logs, performance, user data) per month. Replaced an initial experimental setup with Aurora with a scalable combination of Kinesis, Firehose, S3, and Redshift. QuickSight utilizes SPICE for fast dashboarding and analytics.</data>
    <data key="d3">data_ingestion, interactive</data>
    <data key="d4">True</data>
  </graph>
</graphml>
