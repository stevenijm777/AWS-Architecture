<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Scientist / User</data>
      <data key="d6">UserCompanyDomainExpert</data>
      <data key="d7">3M corporate scientists who build, publish, and run physics and ML models.</data>
    </node>
    <node id="1">
      <data key="d5">CloudFront CDN</data>
      <data key="d6">CloudFront</data>
      <data key="d7">Distributes SPA and acts as the entry point for the web application.</data>
    </node>
    <node id="2">
      <data key="d5">Auth Edge Lambda</data>
      <data key="d6">LambdaAtEdge</data>
      <data key="d7">Executes authentication checks and integrates with the external identity provider.</data>
    </node>
    <node id="3">
      <data key="d5">S3 Bucket</data>
      <data key="d6">S3</data>
      <data key="d7">Hosts the SPA assets and stores completed HPC job results.</data>
    </node>
    <node id="4">
      <data key="d5">API Gateway</data>
      <data key="d6">ApiGateway</data>
      <data key="d7">Secures and routes frontend API requests to the compute layer.</data>
    </node>
    <node id="5">
      <data key="d5">ECS Fargate</data>
      <data key="d6">ECS</data>
      <data key="d7">WORKLOAD_PEEK: Serverless API layer managing model configurations and initiating compute jobs.</data>
    </node>
    <node id="6">
      <data key="d5">DynamoDB Table</data>
      <data key="d6">DynamoDB</data>
      <data key="d7">DATA_PEEK: Stores user access permissions and frontend configuration settings.</data>
    </node>
    <node id="7">
      <data key="d5">Git Repository</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Source control system holding model definitions and code, triggering Step Functions on update.</data>
    </node>
    <node id="8">
      <data key="d5">Model Orchestrator</data>
      <data key="d6">StepFunctions</data>
      <data key="d7">Coordinates serverless publishing workflows for models.</data>
    </node>
    <node id="9">
      <data key="d5">Publishing Lambdas</data>
      <data key="d6">Lambda</data>
      <data key="d7">Executes deployment steps choreographed by Step Functions.</data>
    </node>
    <node id="10">
      <data key="d5">EC2 HPC Cluster</data>
      <data key="d6">EC2</data>
      <data key="d7">WORKLOAD_PEEK: High-performance computing cluster processing submitted physics and ML model jobs.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">User accesses the platform.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="0" target="7" id="0">
      <data key="d8">2</data>
      <data key="d9">Scientist pushes model updates to Git.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">Verifies credentials at the edge.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="3" id="0">
      <data key="d8">0</data>
      <data key="d9">Fetches SPA static assets.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="4" id="0">
      <data key="d8">1</data>
      <data key="d9">User initiates API call to run a model.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="5" id="0">
      <data key="d8">1</data>
      <data key="d9">Routes API call to the serverless container backend.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="6" id="0">
      <data key="d8">1</data>
      <data key="d9">Validates configs and permissions.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="10" id="0">
      <data key="d8">1</data>
      <data key="d9">Launches computing job on HPC cluster.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="7" target="8" id="0">
      <data key="d8">2</data>
      <data key="d9">Triggers CI/CD orchestration pipeline.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="8" target="9" id="0">
      <data key="d8">2</data>
      <data key="d9">Triggers publishing steps.</data>
      <data key="d10">2</data>
      <data key="d11">meta</data>
    </edge>
    <edge source="9" target="10" id="0">
      <data key="d8">2</data>
      <data key="d9">Deploys model files into the HPC cluster directory.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="10" target="3" id="0">
      <data key="d8">1</data>
      <data key="d9">Saves job outputs and simulation results.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">3M serverless model publishing and HPC platform</data>
    <data key="d1">https://www.youtube.com/watch?v=CTG23wd9H74</data>
    <data key="d2">Serverless architecture that automates ML/physics model publishing to an HPC cluster via step functions and Lambdas, with a secure frontend powered by ECS Fargate, Lambda@Edge, and DynamoDB.</data>
    <data key="d3">compute_intensive, interactive</data>
    <data key="d4">True</data>
  </graph>
</graphml>
