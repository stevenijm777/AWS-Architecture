<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Mobile App User</data>
      <data key="d6">UserConsumerMobile</data>
      <data key="d7">Generates clickstream data and queries the Search API.</data>
    </node>
    <node id="1">
      <data key="d5">Clickstream Kinesis Stream</data>
      <data key="d6">KinesisDataStream</data>
      <data key="d7">Ingests raw clickstream events in real time.</data>
    </node>
    <node id="2">
      <data key="d5">Kinesis Data Analytics</data>
      <data key="d6">KinesisAnalytics</data>
      <data key="d7">Filters out search keywords using simple SQL queries.</data>
    </node>
    <node id="3">
      <data key="d5">Filtered Keywords Stream</data>
      <data key="d6">KinesisDataStream</data>
      <data key="d7">Holds filtered search keyword events.</data>
    </node>
    <node id="4">
      <data key="d5">Transformer Lambda</data>
      <data key="d6">Lambda</data>
      <data key="d7">Enriches keywords with brand/category data and writes to DocumentDB.</data>
    </node>
    <node id="5">
      <data key="d5">DocumentDB</data>
      <data key="d6">DocumentDB</data>
      <data key="d7">DATA_PEEK: 650M documents, 3 AZs (1 primary, 2 replicas), 7-day TTL.</data>
    </node>
    <node id="6">
      <data key="d5">Producer Lambda</data>
      <data key="d6">Lambda</data>
      <data key="d7">Runs on a schedule to validate search data against stock inventory.</data>
    </node>
    <node id="7">
      <data key="d5">Inventory API</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Checks current product stock levels (products rotate every 72 hours).</data>
    </node>
    <node id="8">
      <data key="d5">Redis</data>
      <data key="d6">ElastiCache</data>
      <data key="d7">Caches validated search suggestions for low-latency retrieval.</data>
    </node>
    <node id="9">
      <data key="d5">Search API</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Serves the suggestions to the customer's mobile app.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">Streams real-time clickstream actions.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">Passes clickstream to Analytics.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="3" id="0">
      <data key="d8">0</data>
      <data key="d9">Sends filtered search keywords.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="4" id="0">
      <data key="d8">0</data>
      <data key="d9">Triggers transformer Lambda.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="5" id="0">
      <data key="d8">0</data>
      <data key="d9">Writes enriched search documents.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="6" id="0">
      <data key="d8">1</data>
      <data key="d9">Lambda pulls search keywords on schedule.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="6" target="8" id="0">
      <data key="d8">1</data>
      <data key="d9">Writes active suggestions to cache.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="7" target="6" id="0">
      <data key="d8">1</data>
      <data key="d9">Validates inventory availability.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="8" target="9" id="0">
      <data key="d8">1</data>
      <data key="d9">API retrieves suggestion results.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="9" target="0" id="0">
      <data key="d8">1</data>
      <data key="d9">Delivers suggestive search results back to user.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">Zulily Suggestive Search Architecture</data>
    <data key="d1">https://www.youtube.com/watch?v=Ccutfm_Srzw</data>
    <data key="d2">Suggestive search experience driven by real-time clickstream data, processing ~1000 TPS on DocumentDB with a 7-day TTL and primary/replica configuration.</data>
    <data key="d3">data_ingestion, interactive, compute_intensive</data>
    <data key="d4">True</data>
  </graph>
</graphml>
