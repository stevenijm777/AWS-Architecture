<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">GE Avio Employee</data>
      <data key="d6">UserCompanyAgent</data>
      <data key="d7">Employees managing special quarterly expenses.</data>
    </node>
    <node id="1">
      <data key="d5">OpenID Identity Provider</data>
      <data key="d6">ThirdParty</data>
      <data key="d7">Corporate identity system used for authentication.</data>
    </node>
    <node id="2">
      <data key="d5">ELB</data>
      <data key="d6">ELB</data>
      <data key="d7">Load balancer handling initial web/authorization traffic.</data>
    </node>
    <node id="3">
      <data key="d5">ECS Clusters</data>
      <data key="d6">ECS</data>
      <data key="d7">Hosts two Docker containers: one for the Single Page Application, and another for the API Gateway.</data>
    </node>
    <node id="4">
      <data key="d5">Auth Lambda</data>
      <data key="d6">Lambda</data>
      <data key="d7">Handles authentication/authorization validation.</data>
    </node>
    <node id="5">
      <data key="d5">Business Logic Lambdas</data>
      <data key="d6">Lambda</data>
      <data key="d7">WORKLOAD_PEEK: Around 20 Lambdas handling operations like creating/editing tickets and state shifts.</data>
    </node>
    <node id="6">
      <data key="d5">DynamoDB</data>
      <data key="d6">DynamoDB</data>
      <data key="d7">DATA_PEEK: Stores metadata from tickets.</data>
    </node>
    <node id="7">
      <data key="d5">S3 Bucket</data>
      <data key="d6">S3</data>
      <data key="d7">DATA_PEEK: Stores financial document attachments. Encrypted at rest via KMS.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">User authenticates against OpenID.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="0" target="3" id="0">
      <data key="d8">1</data>
      <data key="d9">App communicates back to API Gateway container on ECS.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">Auth payload goes to load balancer.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="2" target="3" id="0">
      <data key="d8">0</data>
      <data key="d9">Traffic forwarded to ECS.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="4" id="0">
      <data key="d8">0</data>
      <data key="d9">ECS invokes Lambda to authorize the user.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="0" id="0">
      <data key="d8">0</data>
      <data key="d9">Authorized user downloads the single page application from ECS.</data>
      <data key="d10">5</data>
      <data key="d11">data</data>
    </edge>
    <edge source="3" target="5" id="0">
      <data key="d8">1</data>
      <data key="d9">API Gateway routes requests to business logic Lambdas.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">Lambda verifies credentials with OpenID provider.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="6" id="0">
      <data key="d8">1</data>
      <data key="d9">Lambdas store and retrieve ticket metadata.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="5" target="7" id="0">
      <data key="d8">1</data>
      <data key="d9">Lambdas store financial document attachments in S3.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">GE Avio Special Expense Management System</data>
    <data key="d1">https://www.youtube.com/watch?v=D77FSUkPJ3o</data>
    <data key="d2">Rebuilt as a cloud-native architecture to handle quarterly spikes reliably. Saves costs and improved reliability significantly.</data>
    <data key="d3">compute_intensive, interactive</data>
    <data key="d4">True</data>
  </graph>
</graphml>
