    <node id="3">
      <data key="d5">Sync Lambda</data>
      <data key="d6">Lambda</data>
      <data key="d7">WORKLOAD_PEEK: Runs in customer account to pull users/groups from directory services.</data>
    </node>
    <node id="4">
      <data key="d5">API Gateway</data>
      <data key="d6">ApiGateway</data>
      <data key="d7">WORKLOAD_PEEK: Secure endpoint ingestion for customer sync messages.</data>
