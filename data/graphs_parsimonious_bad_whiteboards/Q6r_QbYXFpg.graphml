    <node id="7">
      <data key="d5">Job SQS Queue</data>
      <data key="d6">SQS</data>
      <data key="d7">WORKLOAD_PEEK: Decouples platform computation from long-running workspaces jobs.</data>
    </node>
    <node id="8">
      <data key="d5">Trigger Lambda</data>
      <data key="d6">Lambda</data>
      <data key="d7">WORKLOAD_PEEK: Consumes queue messages and triggers corresponding orchestration workflows.</data>
    </node>
    <node id="9">
      <data key="d5">Step Functions Orchestration</data>
      <data key="d6">StepFunctions</data>
      <data key="d7">WORKLOAD_PEEK: Coordinates long-running (20+ min) WorkSpaces provisioning steps without wasting active runtime.</data>
