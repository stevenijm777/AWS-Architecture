<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d11" for="edge" attr.name="type" attr.type="string" />
  <key id="d10" for="edge" attr.name="seq" attr.type="string" />
  <key id="d9" for="edge" attr.name="notes" attr.type="string" />
  <key id="d8" for="edge" attr.name="flow_id" attr.type="long" />
  <key id="d7" for="node" attr.name="notes" attr.type="string" />
  <key id="d6" for="node" attr.name="service" attr.type="string" />
  <key id="d5" for="node" attr.name="name" attr.type="string" />
  <key id="d4" for="graph" attr.name="graph_usable" attr.type="boolean" />
  <key id="d3" for="graph" attr.name="categories" attr.type="string" />
  <key id="d2" for="graph" attr.name="notes" attr.type="string" />
  <key id="d1" for="graph" attr.name="link" attr.type="string" />
  <key id="d0" for="graph" attr.name="name" attr.type="string" />
  <graph edgedefault="directed">
    <node id="0">
      <data key="d5">Client Display</data>
      <data key="d6">UserConsumerWeb</data>
      <data key="d7">Browser-based UI rendering seismic data via HTML5 Canvas and decompressing payloads using WebAssembly.</data>
    </node>
    <node id="1">
      <data key="d5">IVAP Server (EC2)</data>
      <data key="d6">EC2</data>
      <data key="d7">Runs reverse proxy and Node.js backend. Compresses data using AVX extension instructions for up to 6x speedup.</data>
    </node>
    <node id="2">
      <data key="d5">Cognito</data>
      <data key="d6">Cognito</data>
      <data key="d7">Used for user authentication and managing user identities.</data>
    </node>
    <node id="3">
      <data key="d5">RDS (Postgres)</data>
      <data key="d6">RDS</data>
      <data key="d7">Stores role-based access control rules and project configurations.</data>
    </node>
    <node id="4">
      <data key="d5">Adapters (Microservices)</data>
      <data key="d6">EC2</data>
      <data key="d7">Custom microservices designed to connect with various backends, including OSDU.</data>
    </node>
    <node id="5">
      <data key="d5">OSDU API Gateway</data>
      <data key="d6">ApiGateway</data>
      <data key="d7">Handles metadata queries, backed by Elasticsearch inside OSDU.</data>
    </node>
    <node id="6">
      <data key="d5">OSDU S3 Bucket</data>
      <data key="d6">S3</data>
      <data key="d7">DATA_PEEK: Stores massive seismic trace datasets (up to petabyte scale). Queried in parallel via byte-offset indexes.</data>
    </node>
    <edge source="0" target="1" id="0">
      <data key="d8">0</data>
      <data key="d9">User login and visualization requests.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="2" id="0">
      <data key="d8">0</data>
      <data key="d9">Authenticates users via Cognito.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="3" id="0">
      <data key="d8">0</data>
      <data key="d9">Checks project settings and RBAC permissions.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="4" id="0">
      <data key="d8">1</data>
      <data key="d9">Forwards seismic search/data requests to OSDU adapter.</data>
      <data key="d10">0</data>
      <data key="d11">data</data>
    </edge>
    <edge source="1" target="0" id="0">
      <data key="d8">1</data>
      <data key="d9">Streams compressed seismic trace data back to client UI.</data>
      <data key="d10">4</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="5" id="0">
      <data key="d8">1</data>
      <data key="d9">Searches for files and datasets.</data>
      <data key="d10">1</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="6" id="0">
      <data key="d8">1</data>
      <data key="d9">Performs parallel byte-range reads on seismic files.</data>
      <data key="d10">2</data>
      <data key="d11">data</data>
    </edge>
    <edge source="4" target="1" id="0">
      <data key="d8">1</data>
      <data key="d9">Sends requested traces back for server-side compression.</data>
      <data key="d10">3</data>
      <data key="d11">data</data>
    </edge>
    <data key="d0">INT: Seismic Data Visualization Platform Designed for Cloud</data>
    <data key="d1">https://www.youtube.com/watch?v=QM96Fv_NAnw</data>
    <data key="d2">Visualizes massive seismic datasets (terabytes to petabytes) in the browser. Uses Cognito for auth, RDS Postgres for project metadata, custom adapters to integrate with OSDU API/S3, and parallel byte-range requests to optimize S3 throughput.</data>
    <data key="d3">data_ingestion, compute_intensive</data>
    <data key="d4">True</data>
  </graph>
</graphml>
