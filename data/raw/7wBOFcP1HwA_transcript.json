    "start": 358.56,
    "end": 361.56,
    "text": "فأنا نريد أن نتقل في تحديد الإرخيتيكتش"
  },
  {
    "start": 361.56,
    "end": 363.56,
    "text": "وإنجابنا أن نتعرف على الإرخيتيكتش."
  },
  {
    "start": 363.56,
    "end": 364.56,
    "text": "جميل جداً."
  },
  {
    "start": 364.56,
    "end": 367.56,
    "text": "بشكرك جداً يا قايص على مشاركتك للمعلومات دي."
  },
  {
    "start": 367.56,
    "end": 369.56,
    "text": "بشكرك مو، وأنا بشكر سيرة تكنولوجيتيم"
  },
  {
    "start": 369.56,
    "end": 372.56,
    "text": "اللي لعب دور كتير كبير في بناء هاي الأركيتكتش."
  },
  {
    "start": 372.56,
    "end": 375.56,
    "text": "وأنا بحب أشكر مشاهدينا على متابعتنا اليوم."
  }
]