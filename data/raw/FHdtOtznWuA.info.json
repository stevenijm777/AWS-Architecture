 My Architecture」中，我們將介紹軟領科技( SoftChef )。它是一家是專注於物聯網的B2B整體解決方案提供商，採用AWS IoT服務與AWS Serverless架構，讓企業以低風險成本之優勢快速商轉。同時也提供IoT應用系統，包括智慧路燈、智慧電力、智慧能源、智慧工業、資產追蹤等，協助企業實現數位轉型，在市場中建立創新商業價值。\n\nSubscribe: \nMore AWS videos http://bit.ly/2O3zS75 \nMore AWS events videos http://bit.ly/316g9t4\n\n#AWS", "channel_id": "UCd6MoB9NC6uYN2grvUNT-Zg", "channel_url": "https://www.youtube.com/channel/UCd6MoB9NC6uYN2grvUNT-Zg", "duration": 444, "view_count": 5914, "age_limit": 0, "webpage_url": "https://www.youtube.com/watch?v=FHdtOtznWuA", "categories": ["Science & Technology"], "tags": ["AWS", "Amazon Web Services", "Cloud", "AWS Cloud", "Cloud Computing", "IoT", "Cognito", "Amazon DynamoDB", "AWS Greengrass", "serverless", "SoftChef", "AWS Lambda", "Amazon API Gateway", "IoT Core", "AWS Cloudformation", "This is My Architecture", "TMA"], "playable_in_embed": true, "live_status": "not_live", "media_type": "video", "_format_sort_fields": ["quality", "res", "fps", "hdr:12", "source", "vcodec", "channels", "acodec", "lang", "proto"], "automatic_captions": {"en": [{"url": "https://manifest.googlevideo.com/api/manifest/hls_timedtext_playlist/expire/1782452801/ei/4b09aok916LL-w-wzeuQCA/ip/2800:bf0:80c1:13d7:a4b0:b8fa:a348:20d0/id/14776d3adce75ae0/source/youtube/requiressl/yes/dur/443.643/tts_params/caps%3Dasr%26v%3DFHdtOtznWuA%26lang%3Den%26ip%3D2800:bf0:80c1:13d7:a4b0:b8fa:a348:20d0%26ipbits%3D0%26expire%3D1782452801%26sparams%3Dip,ipbits,expire,caps,v%26signature%3D8019AFE3E7ED24B4BC87E3E71B22A8C4D66B9D0B.7A38D6DE6DB540EF48386E22FA225B9E4FDE34BC%26key%3Ddg_yt0/rqh/4/hls_chunk_host/rr4---sn-uxajvoxu-btxd.googlevideo.com/xpc/EgVo2aDSNQ%3D%3D/cps/369/met/1782431201,/mh/Xe/mm/31,29/mn/sn-uxajvoxu-btxd,sn-cvb7sn7r/ms/au,rdu/mv/m/mvi/4/pl/48/rms/au,au/initcwndbps/2286250/bui/ARmQxEWWOF0zTzejYoFp9p3aHesVKhOuYZpQNVtY57aFAUQYo0-NI7etTAW0eXP5XK-kKQnZg3GKxpyk/spc/SQ-ummzNefsGnzzqjU-HUb7rtu0H88pqNEfYSiJMRTkrazz-BIiiZtvSZPa3wEfQ5OmXKWEU/vprv/1/ns/B-SW8EeUHBaZ_2Oj7HgUqx0W/playlist_type/CLEAN/mt/1782430871/f