[
  {
    "start": 0.0,
    "end": 8.38,
    "text": "This is my architectureへようこそ"
  },
  {
    "start": 8.38,
    "end": 11.22,
    "text": "私はAmazon Web Serviceの桐山です"
  },
  {
    "start": 11.22,
    "end": 15.36,
    "text": "本日はCookpadから水谷さんに来ていただきました"
  },
  {
    "start": 15.36,
    "end": 17.02,
    "text": "今日はよろしくお願いします"
  },
  {
    "start": 17.02,
    "end": 17.96,
    "text": "よろしくお願いします"
  },
  {
    "start": 17.96,
    "end": 21.1,
    "text": "まずはじめにCookpadについて教えてください"
  },
  {
    "start": 21.1,
    "end": 21.66,
    "text": "はい"
  },
  {
    "start": 21.66,
    "end": 24.400000000000002,
    "text": "Cookpadは料理のレシピであったり"
  },
  {
    "start": 24.400000000000002,
    "end": 26.560000000000002,
    "text": "アイデアを共有するためのプラットフォームとして"
  },
  {
    "start": 26.560000000000002,
    "end": 27.560000000000002,
    "text": "ご利用いただいています"
  },
  {
    "start": 27.56,
    "end": 32.08,
    "text": "全世界で約1億人のユーザーの方に利用していただいているので"
  },
  {
    "start": 32.08,
    "end": 36.2,
    "text": "我々にとってそれらのユーザーさんの情報というものを守っていくというのは"
  },
  {
    "start": 36.2,
    "end": 38.1,
    "text": "非常に重要なものになっております"
  },
  {
    "start": 38.1,
    "end": 42.16,
    "text": "私自身はユーザーさんの情報というのを守ったり"
  },
  {
    "start": 42.16,
    "end": 45.44,
    "text": "このアーキテクチャ自身を守っていくというようなために働いています"
  },
  {
    "start": 45.44,
    "end": 50.94,
    "text": "水谷さんの役割はCookpadのサービスやユーザーのセキュリティを守るということなんですね"
  },
  {
    "start": 50.94,
    "end": 52.16,
    "text": "はいその通りです"
  },
  {
    "start": 52.72,
    "end": 57.16,
    "text": "このアーキテクチャはその目的を達成するためのものというふうに言っていますけれども"
  },
  {
    "start": 57.16,
    "end": 59.8,
    "text": "これがどういうものかを説明していただけませんか"
  },
  {
    "start": 59.8,
    "end": 61.68,
    "text": "はいこのアーキテクチャは"
  },
  {
    "start": 61.68,
    "end": 65.56,
    "text": "セキュリティのログを監視するためのものとして構成しました"
  },
  {
    "start": 65.56,
    "end": 70.53999999999999,
    "text": "このアーキテクチャはセキュリティの監視をする人であったり"
  },
  {
    "start": 70.53999999999999,
    "end": 75.58,
    "text": "あるいはインシデントレスポンスをする人たちの助けになるために構成されたものになります"
  },
  {
    "start": 75.58,
    "end": 82.32,
    "text": "例えば内部的に持っているセキュリティのオペーションセンターのメンバーが利用するものになっています"
  },
  {
    "start": 82.32,
    "end": 87.16,
    "text": "このソリューションはセキュリティメンバーの人たちのために作られたということですね"
  },
  {
    "start": 87.16,
    "end": 89.38,
    "text": "どのように動くのでしょうか"
  },
  {
    "start": 89.38,
    "end": 93.28,
    "text": "はいこのアーキテクチャは3つのパートからなっています"
  },
  {
    "start": 93.28,
    "end": 96.66,
    "text": "まず1つ目がログを収集するところ"
  },
  {
    "start": 96.66,
    "end": 98.3,
    "text": "そしてログを保全する"
  },
  {
    "start": 98.3,
    "end": 100.85999999999999,
    "text": "そしてログの分析という3つのパートになっています"
  },
  {
    "start": 100.85999999999999,
    "end": 104.06,
    "text": "まず1つ目のログの収集に関しては"
  },
  {
    "start": 104.06,
    "end": 106.69999999999999,
    "text": "ログを集めるためのいろいろな機能が備わっています"
  },
  {
    "start": 106.7,
    "end": 109.58,
    "text": "例えばEC2インサンスからは"
  },
  {
    "start": 109.58,
    "end": 111.68,
    "text": "FluentdがSyslogのメッセージを集めて"
  },
  {
    "start": 111.68,
    "end": 115.18,
    "text": "これをFireforce経由でS3の方に保存します"
  },
  {
    "start": 115.18,
    "end": 118.62,
    "text": "またいくつかのマネージドサービス"
  },
  {
    "start": 118.62,
    "end": 120.86,
    "text": "例えばクラウドトレイルのものに関しては"
  },
  {
    "start": 120.86,
    "end": 124.04,
    "text": "直接S3にログを置くことができるので"
  },
  {
    "start": 124.04,
    "end": 126.30000000000001,
    "text": "これらの機能を使ってログを保存しています"
  },
  {
    "start": 126.30000000000001,
    "end": 129.62,
    "text": "さらにサードパーティーのサービスからは"
  },
  {
    "start": 129.62,
    "end": 132.12,
    "text": "ラムダを使ってログを収集しており"
  },
  {
    "start": 132.12,
    "end": 135.76,
    "text": "これを経由してS3の方にログを保存しています"
  },
  {
    "start": 135.76,
    "end": 138.7,
    "text": "いろいろな種類のログが扱っているんですね"
  },
  {
    "start": 138.7,
    "end": 142.22,
    "text": "では2番目のパートはどうでしょうか"
  },
  {
    "start": 142.22,
    "end": 145.12,
    "text": "はい2番目のパートはログの保全のパートになります"
  },
  {
    "start": 145.12,
    "end": 148.44,
    "text": "S3の中にすべてのログを保存して"
  },
  {
    "start": 148.44,
    "end": 151.2,
    "text": "S3のライフサイクルポリシーを使うことによって"
  },
  {
    "start": 151.2,
    "end": 154.04,
    "text": "ログの保存期間というものを全部コントロールしています"
  },
  {
    "start": 154.04,
    "end": 157.01999999999998,
    "text": "すべてのログがS3に格納されて"
  },
  {
    "start": 157.01999999999998,
    "end": 159.72,
    "text": "S3のライフサイクルポリシーで管理されていると"
  },
  {
    "start": 159.72,
    "end": 161.56,
    "text": "最後のパートはどうでしょう"
  },
  {
    "start": 161.56,
    "end": 165.54,
    "text": "はい最後のパートはログの分析のパートになります"
  },
  {
    "start": 165.54,
    "end": 168.06,
    "text": "まず短期的な目的としては"
  },
  {
    "start": 168.06,
    "end": 171.45999999999998,
    "text": "ログの中からアラートを見つけることによって"
  },
  {
    "start": 171.45999999999998,
    "end": 173.26,
    "text": "そのアラートを通知するということを"
  },
  {
    "start": 173.26,
    "end": 174.94,
    "text": "ラムダファンクションを使ってやっています"
  },
  {
    "start": 174.94,
    "end": 176.7,
    "text": "見つけたアラートに関しては"
  },
  {
    "start": 176.7,
    "end": 178.73999999999998,
    "text": "スラックの方に通知をするということをしています"
  },
  {
    "start": 178.73999999999998,
    "end": 182.06,
    "text": "一方で中長期的な目的としては"
  },
  {
    "start": 182.06,
    "end": 184.38,
    "text": "ログの検索ができるようにするために"
  },
  {
    "start": 184.38,
    "end": 185.94,
    "text": "ラムダファンクションが"
  },
  {
    "start": 185.94,
    "end": 187.62,
    "text": "グレイログにログを転送します"
  },
  {
    "start": 187.62,
    "end": 191.62,
    "text": "グレイログはオープンソースのログの検索エンジンで"
  },
  {
    "start": 191.62,
    "end": 195.54,
    "text": "これはバックエンドにAmazonのエラスティックサーチサービスを使っています"
  },
  {
    "start": 195.54,
    "end": 198.76,
    "text": "最終的な目的としては"
  },
  {
    "start": 198.76,
    "end": 202.14000000000001,
    "text": "これらのログを長期的な検索ができるようにするということで"
  },
  {
    "start": 202.14000000000001,
    "end": 205.62,
    "text": "これは監査のためにできるような機能を備わせています"
  },
  {
    "start": 205.62,
    "end": 208.36,
    "text": "これはAmazonのアテナによって実現されています"
  },
  {
    "start": 208.36,
    "end": 209.62,
    "text": "ありがとうございます"
  },
  {
    "start": 209.62,
    "end": 211.5,
    "text": "全体像を理解できました"
  },
  {
    "start": 211.5,
    "end": 215.9,
    "text": "それではこの中で最も革新的な部分はどこでしょうか"
  },
  {
    "start": 215.9,
    "end": 216.58,
    "text": "はい"
  },
  {
    "start": 216.58,
    "end": 218.48000000000002,
    "text": "セキュリティのエンジニアというのは"
  },
  {
    "start": 218.48000000000002,
    "end": 221.78,
    "text": "アラートに対してなるべく早く対応する必要があります"
  },
  {
    "start": 221.78,
    "end": 225.4,
    "text": "一般的なマネージドセキュリティサービスの"
  },
  {
    "start": 225.4,
    "end": 227.42000000000002,
    "text": "SLAに基づきますと"
  },
  {
    "start": 227.42000000000002,
    "end": 229.06,
    "text": "ログを処理する時間というのは"
  },
  {
    "start": 229.06,
    "end": 231.82,
    "text": "大体約1分か2分ぐらいに抑えたいというのが"
  },
  {
    "start": 231.82,
    "end": 233.0,
    "text": "要求としてあります"
  },
  {
    "start": 233.0,
    "end": 237.0,
    "text": "一方でリアルタイムにログを処理するシステムが"
  },
  {
    "start": 237.0,
    "end": 240.54,
    "text": "大量のログに関して対応できるようにするというシステムを"
  },
  {
    "start": 240.54,
    "end": 243.66,
    "text": "蜘蛛すると非常に高価になってしまうというような傾向があります"
  },
  {
    "start": 243.66,
    "end": 245.6,
    "text": "しかしこのアーキテクチャでは"
  },
  {
    "start": 245.6,
    "end": 250.44,
    "text": "低いコストとログの処理の時間というのを"
  },
  {
    "start": 250.44,
    "end": 252.66,
    "text": "レイテンシーというものをなるべく下げるというようなことの"
  },
  {
    "start": 252.66,
    "end": 254.46,
    "text": "両方を実現しているという特徴があります"
  },
  {
    "start": 254.46,
    "end": 257.44,
    "text": "今低いコストとおっしゃいましたけれども"
  },
  {
    "start": 257.44,
    "end": 260.9,
    "text": "このアーキテクチャの中でコストメリットはどこになりますか"
  },
  {
    "start": 260.9,
    "end": 261.38,
    "text": "はい"
  },
  {
    "start": 261.38,
    "end": 266.42,
    "text": "このアーキテクチャ自体は1日あたり約3億件程度の"
  },
  {
    "start": 266.42,
    "end": 267.90000000000003,
    "text": "ログを処理しています"
  },
  {
    "start": 267.90000000000003,
    "end": 272.96000000000004,
    "text": "これはおよそ270GBに相当します"
  },
  {
    "start": 272.96000000000004,
    "end": 276.6,
    "text": "これらのログを処理するラムダファンクションが"
  },
  {
    "start": 276.6,
    "end": 278.70000000000005,
    "text": "実際にかかっている値段というのが"
  },
  {
    "start": 278.70000000000005,
    "end": 281.52000000000004,
    "text": "1日あたり約2ドルに抑えることができています"
  },
  {
    "start": 281.52000000000004,
    "end": 285.28000000000003,
    "text": "1日約2ドルというのはすごいですね"
  },
  {
    "start": 285.28000000000003,
    "end": 289.22,
    "text": "一般的なログ監視ソリューションと比較して"
  },
  {
    "start": 289.22,
    "end": 292.76000000000005,
    "text": "このソリューションが素晴らしい部分というのはどこにあるんでしょうか"
  },
  {
    "start": 292.76000000000005,
    "end": 295.76000000000005,
    "text": "一般的なログの管理ツールに関しては"
  },
  {
    "start": 295.76,
    "end": 299.3,
    "text": "基本的にログを収集する前にログのスキーマというものを"
  },
  {
    "start": 299.3,
    "end": 300.9,
    "text": "ちゃんと定義しておく必要があります"
  },
  {
    "start": 300.9,
    "end": 303.2,
    "text": "しかしこのアーキテクチャに関しては"
  },
  {
    "start": 303.2,
    "end": 305.08,
    "text": "ログの収集のパートにおいて"
  },
  {
    "start": 305.08,
    "end": 307.36,
    "text": "ログのスキーマというものを定義しないで"
  },
  {
    "start": 307.36,
    "end": 308.53999999999996,
    "text": "収集することができます"
  },
  {
    "start": 308.53999999999996,
    "end": 310.3,
    "text": "これはなぜかというと"
  },
  {
    "start": 310.3,
    "end": 312.64,
    "text": "S3がログを保存するときに"
  },
  {
    "start": 312.64,
    "end": 314.04,
    "text": "スキーマというものを気にしないで"
  },
  {
    "start": 314.04,
    "end": 316.62,
    "text": "保存することができることによって実現されています"
  },
  {
    "start": 316.62,
    "end": 319.04,
    "text": "スキーマがないことによって"
  },
  {
    "start": 319.04,
    "end": 321.06,
    "text": "いろいろなログが扱いやすくなっているんですね"
  },
  {
    "start": 321.06,
    "end": 323.40000000000003,
    "text": "それでは最後に"
  },
  {
    "start": 323.40000000000003,
    "end": 326.0,
    "text": "将来の機能拡張の予定などありますか"
  },
  {
    "start": 326.0,
    "end": 326.22,
    "text": "はい"
  },
  {
    "start": 326.22,
    "end": 329.74,
    "text": "我々としてはセキュリティのログを集めたことによって"
  },
  {
    "start": 329.74,
    "end": 331.90000000000003,
    "text": "これらを使った異常検知のシステムを"
  },
  {
    "start": 331.90000000000003,
    "end": 334.76,
    "text": "Amazon政治メーカーを使って実現したいというふうに考えています"
  },
  {
    "start": 334.76,
    "end": 336.16,
    "text": "素晴らしいですね"
  },
  {
    "start": 336.16,
    "end": 337.58000000000004,
    "text": "今日いただいてありがとうございます"
  },
  {
    "start": 337.58000000000004,
    "end": 338.52,
    "text": "こちらこそありがとうございます"
  },
  {
    "start": 338.52,
    "end": 341.94,
    "text": "今日はCuckpadの水谷さんと"
  },
  {
    "start": 341.94,
    "end": 344.29999999999995,
    "text": "セキュリティ監視ソリューションについて話してきました"
  },
  {
    "start": 344.29999999999995,
    "end": 347.5,
    "text": "This is my architectureをご視聴いただきありがとうございました"
  }
]